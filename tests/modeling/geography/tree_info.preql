import tree_common;
import sf_tree_info;
import nyc_tree_info;
import boston_tree_info;


# --- Merged union datasource ---

datasource tree_info (
    tree_id,
    city,
    # commented out for a specific test
    # common_name,
    species,
    ?plant_date,
    ?diameter_at_breast_height,
    ?latitude,
    ?longitude,
    latest_update_through
)
grain (tree_id)
file `https://storage.googleapis.com/trilogy_public_models/duckdb/trees/full_tree_info.parquet`:`gcs://trilogy_public_models/duckdb/trees/full_tree_info.parquet`
freshness by latest_update_through;
