import landmark_common;

root partial datasource nyc_landmarks_update_time (
    city: ~city,
    data_updated_through: nyc_landmark_data_updated_through
)
grain (city)
complete where city = 'USNYC'
file `./nyc_landmarks_probe.py`
freshness by nyc_landmark_data_updated_through;


root partial datasource raw_nyc_landmark_info (
    landmark_id: landmark_id,
    city: city,
    name: name,
    borough: ?borough,
    the_geom: ?geometry_raw,
)
grain (landmark_id)
complete where city = 'USNYC'
file `./nyc_landmarks.py`;


partial datasource nyc_landmark_info (
    landmark_id,
    city,
    name,
    ?borough,
    ?geometry_raw,
    nyc_landmark_data_updated_through,
)
grain (landmark_id)
complete where city = 'USNYC'
file `https://storage.googleapis.com/trilogy_public_models/duckdb/landmarks/nyc_landmark_info.parquet`:`gcs://trilogy_public_models/duckdb/landmarks/nyc_landmark_info.parquet`
freshness by nyc_landmark_data_updated_through;
