    3),
late as (
SELECT
    \"sweltering\".\"cs_item_desc\" as \"cs_item_desc\",
    \"sweltering\".\"cs_item_desc\" as \"item_desc\",
    \"sweltering\".\"cs_sold_date_week_seq\" as \"cs_sold_date_week_seq\",
