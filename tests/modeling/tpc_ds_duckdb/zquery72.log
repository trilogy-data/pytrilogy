    count(CASE WHEN \"juicy\".\"cs_promotion_sk\" is not null THEN \"juicy\".\"_virt_func_hash_3658193313443410\" ELSE NULL END) as \"promo\",
    count(CASE WHEN \"juicy\".\"cs_promotion_sk\" is null THEN \"juicy\".\"_virt_func_hash_3658193313443410\" ELSE NULL END) as \"no_promo\",
    count(md5(CONCAT_WS('\u001f', coalesce(cast(\"juicy\".\"cs_order_number\" as string),'\u001e'), coalesce(cast(\"juicy\".\"inv_item_sk\" as string),'\u001e'), coalesce(cast(\"juicy\".\"inv_date_sk\" as string),'\u001e'), coalesce(cast(\"juicy\".\"inv_warehouse_sk\" as string),'\u001e')))) as \"total_cnt\"
