ORDER BY 
    \"concerned\".\"total_cnt\" desc nulls first,
    \"vacuous\".\"item_desc\" asc nulls first,
    \"vacuous\".\"warehouse_name\" asc nulls first,
    coalesce(\"concerned\".\"cs_sale_date_week_seq\",\"vacuous\".\"week_seq\",\"young\".\"cs_sale_date_week_seq\") asc nulls first
