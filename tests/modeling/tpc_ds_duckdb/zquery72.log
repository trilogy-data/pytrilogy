    \"sweltering\".\"no_promo\" as \"no_promo\",
    \"sweltering\".\"promo\" as \"promo\"
FROM
    \"sweltering\")
SELECT
    \"late\".\"item_desc\" as \"item_desc\",
    \"late\".\"warehouse_name\" as \"warehouse_name\",
    \"late\".\"week_seq\" as \"week_seq\",
    \"late\".\"no_promo\" as \"no_promo\",
    \"late\".\"promo\" as \"promo\",
    coalesce(\"divergent\".\"total_cnt\",0) as \"total_cnt\"
FROM
    \"divergent\"
    FULL JOIN \"late\" on \"divergent\".\"cs_item_desc\" is not distinct from \"late\".\"cs_item_desc\" AND \"divergent\".\"cs_sold_date_week_seq\" = \"late\".\"cs_sold_date_week_seq\" AND \"divergent\".\"inv_warehouse_name\" is not distinct from \"late\".\"inv_warehouse_name\"
ORDER BY 
    coalesce(\"divergent\".\"total_cnt\",0) desc nulls first,
    \"late\".\"item_desc\" asc nulls first,
    \"late\".\"warehouse_name\" asc nulls first,
    \"late\".\"week_seq\" asc nulls first
LIMIT (100)"""
