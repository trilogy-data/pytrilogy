    \"juicy\".\"item_desc\" as \"item_desc\",
    \"juicy\".\"warehouse_name\" as \"warehouse_name\",
    \"juicy\".\"week_seq\" as \"week_seq\"
FROM
    \"juicy\")
SELECT
    \"vacuous\".\"item_desc\" as \"item_desc\",
    \"vacuous\".\"warehouse_name\" as \"warehouse_name\",
    coalesce(\"concerned\".\"cs_sale_date_week_seq\",\"vacuous\".\"week_seq\",\"young\".\"cs_sale_date_week_seq\") as \"week_seq\",
    \"concerned\".\"no_promo\" as \"no_promo\",
    \"concerned\".\"promo\" as \"promo\",
    \"concerned\".\"total_cnt\" as \"total_cnt\"
FROM
    \"vacuous\"
    FULL JOIN \"concerned\" on \"vacuous\".\"inv_item_sk\" = \"concerned\".\"inv_item_sk\" AND \"vacuous\".\"inv_warehouse_name\" is not distinct from \"concerned\".\"inv_warehouse_name\" AND \"vacuous\".\"week_seq\" = \"concerned\".\"cs_sale_date_week_seq\"
    RIGHT OUTER JOIN \"young\" on \"vacuous\".\"cs_sale_date_sk\" is not distinct from \"young\".\"cs_sale_date_sk\"
