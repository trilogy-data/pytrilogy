generated_sql = """

WITH 
cheerful as (
SELECT
     'CATALOG'  as \"sales_channel\",
    \"sales_catalog_sales_unified\".\"CS_SHIP_CUSTOMER_SK\" as \"sales_purchasing_customer_sk\",
    \"sales_sale_date_date\".\"D_MOY\" as \"sales_sale_date_month_of_year\",
    \"sales_sale_date_date\".\"D_YEAR\" as \"sales_sale_date_year\"
FROM
    \"memory\".\"catalog_sales\" as \"sales_catalog_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_sale_date_date\" on \"sales_catalog_sales_unified\".\"CS_SOLD_DATE_SK\" = \"sales_sale_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_sale_date_date\".\"D_YEAR\" = 2002 and (\"sales_sale_date_date\".\"D_MOY\" is not null and \"sales_sale_date_date\".\"D_MOY\" in (1,2,3,4))

UNION ALL
SELECT
     'STORE'  as \"sales_channel\",
    \"sales_store_sales_unified\".\"SS_CUSTOMER_SK\" as \"sales_purchasing_customer_sk\",
    \"sales_sale_date_date\".\"D_MOY\" as \"sales_sale_date_month_of_year\",
    \"sales_sale_date_date\".\"D_YEAR\" as \"sales_sale_date_year\"
FROM
    \"memory\".\"store_sales\" as \"sales_store_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_sale_date_date\" on \"sales_store_sales_unified\".\"SS_SOLD_DATE_SK\" = \"sales_sale_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_sale_date_date\".\"D_YEAR\" = 2002 and (\"sales_sale_date_date\".\"D_MOY\" is not null and \"sales_sale_date_date\".\"D_MOY\" in (1,2,3,4))

UNION ALL
SELECT
     'WEB'  as \"sales_channel\",
    \"sales_web_sales_unified\".\"WS_BILL_CUSTOMER_SK\" as \"sales_purchasing_customer_sk\",
    \"sales_sale_date_date\".\"D_MOY\" as \"sales_sale_date_month_of_year\",
    \"sales_sale_date_date\".\"D_YEAR\" as \"sales_sale_date_year\"
FROM
    \"memory\".\"web_sales\" as \"sales_web_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_sale_date_date\" on \"sales_web_sales_unified\".\"WS_SOLD_DATE_SK\" = \"sales_sale_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_sale_date_date\".\"D_YEAR\" = 2002 and (\"sales_sale_date_date\".\"D_MOY\" is not null and \"sales_sale_date_date\".\"D_MOY\" in (1,2,3,4))
),
thoughtful as (
SELECT
    \"cheerful\".\"sales_channel\" as \"sales_channel\",
    \"cheerful\".\"sales_purchasing_customer_sk\" as \"sales_purchasing_customer_sk\",
    \"cheerful\".\"sales_sale_date_month_of_year\" as \"sales_sale_date_month_of_year\",
    \"cheerful\".\"sales_sale_date_year\" as \"sales_sale_date_year\"
FROM
    \"cheerful\"
GROUP BY
    1,
    2,
    3,
    4),
abundant as (
SELECT
    CASE WHEN (\"thoughtful\".\"sales_channel\" is not null and \"thoughtful\".\"sales_channel\" in ('WEB','CATALOG')) and \"thoughtful\".\"sales_sale_date_year\" = 2002 and (\"thoughtful\".\"sales_sale_date_month_of_year\" is not null and \"thoughtful\".\"sales_sale_date_month_of_year\" in (1,2,3,4)) THEN \"thoughtful\".\"sales_purchasing_customer_sk\" ELSE NULL END as \"webcat_buyers\"
FROM
    \"thoughtful\"
WHERE
    (\"thoughtful\".\"sales_channel\" is not null and \"thoughtful\".\"sales_channel\" in ('WEB','CATALOG'))

GROUP BY
    1),
questionable as (
SELECT
    CASE WHEN \"thoughtful\".\"sales_channel\" = 'STORE' and \"thoughtful\".\"sales_sale_date_year\" = 2002 and (\"thoughtful\".\"sales_sale_date_month_of_year\" is not null and \"thoughtful\".\"sales_sale_date_month_of_year\" in (1,2,3,4)) THEN \"thoughtful\".\"sales_purchasing_customer_sk\" ELSE NULL END as \"store_buyers\"
FROM
    \"thoughtful\"
WHERE
    \"thoughtful\".\"sales_channel\" = 'STORE'

GROUP BY
    1)
SELECT
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_GENDER\" as \"sales_purchasing_customer_current_demographics_gender\",
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_MARITAL_STATUS\" as \"sales_purchasing_customer_current_demographics_marital_status\",
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_EDUCATION_STATUS\" as \"sales_purchasing_customer_current_demographics_education_status\",
    count(\"sales_purchasing_customer_customers\".\"C_CUSTOMER_SK\") as \"cnt1\",
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_PURCHASE_ESTIMATE\" as \"sales_purchasing_customer_current_demographics_purchase_estimate\",
    count(\"sales_purchasing_customer_customers\".\"C_CUSTOMER_SK\") as \"cnt2\",
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_CREDIT_RATING\" as \"sales_purchasing_customer_current_demographics_credit_rating\",
    count(\"sales_purchasing_customer_customers\".\"C_CUSTOMER_SK\") as \"cnt3\",
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_DEP_COUNT\" as \"sales_purchasing_customer_current_demographics_dependent_count\",
    count(\"sales_purchasing_customer_customers\".\"C_CUSTOMER_SK\") as \"cnt4\",
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_DEP_EMPLOYED_COUNT\" as \"sales_purchasing_customer_current_demographics_employed_dependent_count\",
    count(\"sales_purchasing_customer_customers\".\"C_CUSTOMER_SK\") as \"cnt5\",
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_DEP_COLLEGE_COUNT\" as \"sales_purchasing_customer_current_demographics_college_dependent_count\",
    count(\"sales_purchasing_customer_customers\".\"C_CUSTOMER_SK\") as \"cnt6\"
FROM
    \"memory\".\"customer\" as \"sales_purchasing_customer_customers\"
    INNER JOIN \"memory\".\"customer_address\" as \"sales_purchasing_customer_current_address_customer_address\" on \"sales_purchasing_customer_customers\".\"C_CURRENT_ADDR_SK\" = \"sales_purchasing_customer_current_address_customer_address\".\"CA_ADDRESS_SK\"
    INNER JOIN \"memory\".\"customer_demographics\" as \"sales_purchasing_customer_current_demographics_customer_demographics\" on \"sales_purchasing_customer_customers\".\"C_CURRENT_CDEMO_SK\" = \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_DEMO_SK\"
WHERE
    exists (select 1 from questionable where questionable.\"store_buyers\" is not distinct from \"sales_purchasing_customer_customers\".\"C_CUSTOMER_SK\") and exists (select 1 from abundant where abundant.\"webcat_buyers\" is not distinct from \"sales_purchasing_customer_customers\".\"C_CUSTOMER_SK\") and (\"sales_purchasing_customer_current_address_customer_address\".\"CA_COUNTY\" is not null and \"sales_purchasing_customer_current_address_customer_address\".\"CA_COUNTY\" in ('Rush County','Toole County','Jefferson County','Dona Ana County','La Porte County')) and \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_GENDER\" is not null

GROUP BY
    1,
    2,
    3,
    5,
    7,
    9,
    11,
    13
ORDER BY 
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_GENDER\" asc,
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_MARITAL_STATUS\" asc,
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_EDUCATION_STATUS\" asc,
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_PURCHASE_ESTIMATE\" asc,
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_CREDIT_RATING\" asc,
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_DEP_COUNT\" asc,
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_DEP_EMPLOYED_COUNT\" asc,
    \"sales_purchasing_customer_current_demographics_customer_demographics\".\"CD_DEP_COLLEGE_COUNT\" asc"""
