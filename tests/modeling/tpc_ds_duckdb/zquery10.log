    \"sales_purchasing_customer_address_customer_address\".\"CA_COUNTY\" in ('Rush County','Toole County','Jefferson County','Dona Ana County','La Porte County') and \"sales_purchasing_customer_demographics_customer_demographics\".\"CD_GENDER\" is not null and \"sales_purchasing_customer_customers\".\"C_CUSTOMER_SK\" in (select abundant.\"store_buyers\" from abundant where abundant.\"store_buyers\" is not null) and \"sales_purchasing_customer_customers\".\"C_CUSTOMER_SK\" in (select abundant.\"webcat_buyers\" from abundant where abundant.\"webcat_buyers\" is not null)
),
