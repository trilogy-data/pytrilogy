import customer as customer;
import all_sales as sales;

# TPC-DS q35 uses cs_ship_customer_sk for the catalog EXISTS branch and
# ws_bill_customer_sk for web, so:
#   - store/web filters use sales.billing_customer.sk (= SS_CUSTOMER_SK / WS_BILL_CUSTOMER_SK)
#   - catalog filter uses sales.ship_customer.sk (= CS_SHIP_CUSTOMER_SK)
rowset store_buyers <- where
    sales.channel = 'STORE'
    and sales.date.year = 2002
    and sales.date.quarter < 4
    and sales.billing_customer.sk is not null
select
    sales.billing_customer.sk as store_cust_id,
;

rowset web_buyers <- where
    sales.channel = 'WEB'
    and sales.date.year = 2002
    and sales.date.quarter < 4
    and sales.billing_customer.sk is not null
select
    sales.billing_customer.sk as web_cust_id,
;

rowset catalog_buyers <- where
    sales.channel = 'CATALOG'
    and sales.date.year = 2002
    and sales.date.quarter < 4
    and sales.ship_customer.sk is not null
select
    sales.ship_customer.sk as cat_cust_id,
;

where
    customer.sk in store_buyers.store_cust_id
    and (customer.sk in web_buyers.web_cust_id or customer.sk in catalog_buyers.cat_cust_id)
    and customer.current_demographics.sk is not null
select
    customer.current_address.state,
    customer.current_demographics.gender,
    customer.current_demographics.marital_status,
    customer.current_demographics.dependent_count,
    count(customer.sk) as cnt1,
    min(customer.current_demographics.dependent_count) as min1,
    max(customer.current_demographics.dependent_count) as max1,
    avg(customer.current_demographics.dependent_count) as avg1,
    customer.current_demographics.employed_dependent_count,
    count(customer.sk) as cnt2,
    min(customer.current_demographics.employed_dependent_count) as min2,
    max(customer.current_demographics.employed_dependent_count) as max2,
    avg(customer.current_demographics.employed_dependent_count) as avg2,
    customer.current_demographics.college_dependent_count,
    count(customer.sk) as cnt3,
    min(customer.current_demographics.college_dependent_count) as min3,
    max(customer.current_demographics.college_dependent_count) as max3,
    avg(customer.current_demographics.college_dependent_count) as avg3,
order by
    customer.current_address.state asc nulls first,
    customer.current_demographics.gender asc nulls first,
    customer.current_demographics.marital_status asc nulls first,
    customer.current_demographics.dependent_count asc nulls first,
    customer.current_demographics.employed_dependent_count asc nulls first,
    customer.current_demographics.college_dependent_count asc nulls first
limit 100
;
