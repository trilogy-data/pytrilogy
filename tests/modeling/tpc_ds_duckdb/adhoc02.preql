WHERE
    physical_sales.date.id is not null
SELECT
    physical_sales.date.year,
    count(physical_sales.ticket_number) as store_order_count
HAVING
    store_order_count>0
MERGE
WHERE
    web_sales.date.id is not null
SELECT
    web_sales.date.year,
    count(web_sales.order_number) as web_order_count
HAVING
    web_order_count>0
ALIGN 
    report_date: physical_sales.date.year, web_sales.date.year
ORDER BY
    report_date asc;