generated_sql = """

WITH 
thoughtful as (
SELECT
    \"ss_item_items\".\"I_BRAND\" as \"ss_item_brand_name\",
    \"ss_item_items\".\"I_CATEGORY\" as \"ss_item_category\",
    \"ss_item_items\".\"I_CLASS\" as \"ss_item_class\",
    \"ss_item_items\".\"I_PRODUCT_NAME\" as \"ss_item_product_name\",
    \"ss_sale_date_date\".\"D_MOY\" as \"ss_sale_date_month_of_year\",
    \"ss_sale_date_date\".\"D_QOY\" as \"ss_sale_date_quarter\",
    \"ss_sale_date_date\".\"D_YEAR\" as \"ss_sale_date_year\",
    \"ss_store_sales\".\"SS_QUANTITY\" as \"ss_quantity\",
    \"ss_store_sales\".\"SS_SALES_PRICE\" as \"ss_sales_price\",
    \"ss_store_store\".\"S_STORE_ID\" as \"ss_store_id\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
    INNER JOIN \"memory\".\"item\" as \"ss_item_items\" on \"ss_store_sales\".\"SS_ITEM_SK\" = \"ss_item_items\".\"I_ITEM_SK\"
    INNER JOIN \"memory\".\"store\" as \"ss_store_store\" on \"ss_store_sales\".\"SS_STORE_SK\" = \"ss_store_store\".\"S_STORE_SK\"
    INNER JOIN \"memory\".\"date_dim\" as \"ss_sale_date_date\" on \"ss_store_sales\".\"SS_SOLD_DATE_SK\" = \"ss_sale_date_date\".\"D_DATE_SK\"
WHERE
    \"ss_sale_date_date\".\"D_MONTH_SEQ\" BETWEEN 1200 AND 1211 and \"ss_store_sales\".\"SS_STORE_SK\" is not null
),
questionable as (
SELECT
    \"thoughtful\".\"ss_item_brand_name\" as \"ss_item_brand_name\",
    \"thoughtful\".\"ss_item_category\" as \"ss_item_category\",
    \"thoughtful\".\"ss_item_class\" as \"ss_item_class\",
    \"thoughtful\".\"ss_item_product_name\" as \"ss_item_product_name\",
    \"thoughtful\".\"ss_sale_date_month_of_year\" as \"ss_sale_date_month_of_year\",
    \"thoughtful\".\"ss_sale_date_quarter\" as \"ss_sale_date_quarter\",
    \"thoughtful\".\"ss_sale_date_year\" as \"ss_sale_date_year\",
    \"thoughtful\".\"ss_store_id\" as \"ss_store_id\",
    sum(coalesce(\"thoughtful\".\"ss_sales_price\" * \"thoughtful\".\"ss_quantity\",0)) as \"sumsales\"
FROM
    \"thoughtful\"
GROUP BY
    ROLLUP (2, 3, 1, 4, 7, 6, 5, 8)),
abundant as (
SELECT
    \"questionable\".\"ss_item_brand_name\" as \"ss_item_brand_name\",
    \"questionable\".\"ss_item_category\" as \"ss_item_category\",
    \"questionable\".\"ss_item_class\" as \"ss_item_class\",
    \"questionable\".\"ss_item_product_name\" as \"ss_item_product_name\",
    \"questionable\".\"ss_sale_date_month_of_year\" as \"ss_sale_date_month_of_year\",
    \"questionable\".\"ss_sale_date_quarter\" as \"ss_sale_date_quarter\",
    \"questionable\".\"ss_sale_date_year\" as \"ss_sale_date_year\",
    \"questionable\".\"ss_store_id\" as \"ss_store_id\",
    \"questionable\".\"sumsales\" as \"sumsales\",
    rank() over (partition by \"questionable\".\"ss_item_category\" order by \"questionable\".\"sumsales\" desc ) as \"rk\"
FROM
    \"questionable\")
SELECT
    \"abundant\".\"ss_item_category\" as \"ss_item_category\",
    \"abundant\".\"ss_item_class\" as \"ss_item_class\",
    \"abundant\".\"ss_item_brand_name\" as \"ss_item_brand_name\",
    \"abundant\".\"ss_item_product_name\" as \"ss_item_product_name\",
    \"abundant\".\"ss_sale_date_year\" as \"ss_sale_date_year\",
    \"abundant\".\"ss_sale_date_quarter\" as \"ss_sale_date_quarter\",
    \"abundant\".\"ss_sale_date_month_of_year\" as \"ss_sale_date_month_of_year\",
    \"abundant\".\"ss_store_id\" as \"ss_store_id\",
    \"abundant\".\"sumsales\" as \"sumsales\",
    \"abundant\".\"rk\" as \"rk\"
FROM
    \"abundant\"
WHERE
    \"abundant\".\"rk\" <= 100

ORDER BY 
    \"abundant\".\"ss_item_category\" asc nulls first,
    \"abundant\".\"ss_item_class\" asc nulls first,
    \"abundant\".\"ss_item_brand_name\" asc nulls first,
    \"abundant\".\"ss_item_product_name\" asc nulls first,
    \"abundant\".\"ss_sale_date_year\" asc nulls first,
    \"abundant\".\"ss_sale_date_quarter\" asc nulls first,
    \"abundant\".\"ss_sale_date_month_of_year\" asc nulls first,
    \"abundant\".\"ss_store_id\" asc nulls first,
    \"abundant\".\"sumsales\" asc nulls first,
    \"abundant\".\"rk\" asc nulls first
LIMIT (100)"""
