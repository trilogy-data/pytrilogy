import store_sales as ss;

def day_sales(d) -> sum(filter ss.sales_price where ss.date.day_name = d) by ss.store.id, ss.date.week_seq;

rowset wss <- WHERE
    ss.date.month_seq between 1212 and 1235
    and ss.store.id is not null
    and ss.date.week_seq is not null
SELECT
    ss.store.id -> store_id,
    ss.store.name -> store_name,
    ss.store.text_id -> store_text_id,
    ss.date.week_seq -> week_seq,
    @day_sales('Sunday') -> sun_sales,
    @day_sales('Monday') -> mon_sales,
    @day_sales('Tuesday') -> tue_sales,
    @day_sales('Wednesday') -> wed_sales,
    @day_sales('Thursday') -> thu_sales,
    @day_sales('Friday') -> fri_sales,
    @day_sales('Saturday') -> sat_sales,
    max(CASE
            WHEN ss.date.month_seq >= 1212 and ss.date.month_seq <= 1223 THEN 1
            ELSE 0
        END) -> in_year1,
    max(CASE
            WHEN ss.date.month_seq >= 1224 and ss.date.month_seq <= 1235 THEN 1
            ELSE 0
        END) -> in_year2,
;

property normalized_week <- wss.week_seq - (CASE
    WHEN wss.in_year2 = 1 THEN 52
    ELSE 0
END);

SELECT
    wss.store_name -> s_store_name1,
    wss.store_text_id -> s_store_id1,
    wss.week_seq -> d_week_seq1,
    --wss.in_year1 -> year1_flag,
    wss.sun_sales / lead(wss.sun_sales,1) over (partition by wss.store_id,normalized_week order by wss.in_year2 asc) -> sun_sales_ratio,
    wss.mon_sales / lead(wss.mon_sales,1) over (partition by wss.store_id,normalized_week order by wss.in_year2 asc) -> mon_sales_ratio,
    wss.tue_sales / lead(wss.tue_sales,1) over (partition by wss.store_id,normalized_week order by wss.in_year2 asc) -> tue_sales_ratio,
    wss.wed_sales / lead(wss.wed_sales,1) over (partition by wss.store_id,normalized_week order by wss.in_year2 asc) -> wed_sales_ratio,
    wss.thu_sales / lead(wss.thu_sales,1) over (partition by wss.store_id,normalized_week order by wss.in_year2 asc) -> thu_sales_ratio,
    wss.fri_sales / lead(wss.fri_sales,1) over (partition by wss.store_id,normalized_week order by wss.in_year2 asc) -> fri_sales_ratio,
    wss.sat_sales / lead(wss.sat_sales,1) over (partition by wss.store_id,normalized_week order by wss.in_year2 asc) -> sat_sales_ratio,
HAVING
    year1_flag = 1 and sun_sales_ratio is not null

ORDER BY
    s_store_name1 asc nulls first,
    s_store_id1 asc nulls first,
    d_week_seq1 asc nulls first
LIMIT 100
;
