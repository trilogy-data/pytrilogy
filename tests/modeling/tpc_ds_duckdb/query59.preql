import store_sales as ss;

def day_sales(d) -> sum(ss.sales_price ? ss.date.day_name = d) by ss.store.id, ss.date.week_seq;

# Shared wss-rowset: 7-day-name sums and year-bucket flags computed once per (store, week_seq).
# Both year1 and year2 derive from this single aggregate, avoiding the duplicated
# CASE-WHEN sum CTEs the previous shape emitted.
with wss as
where ss.date.month_seq between 1200 and 1235 and ss.store.id is not null and ss.date.week_seq is not null
SELECT
    ss.store.id as store_id,
    ss.store.name as store_name,
    ss.store.text_id as store_text_id,
    ss.date.week_seq as week_seq,
    @day_sales('Sunday')    as sun_sales,
    @day_sales('Monday')    as mon_sales,
    @day_sales('Tuesday')   as tue_sales,
    @day_sales('Wednesday') as wed_sales,
    @day_sales('Thursday')  as thu_sales,
    @day_sales('Friday')    as fri_sales,
    @day_sales('Saturday')  as sat_sales,
    max(case when ss.date.month_seq >= 1212 and ss.date.month_seq <= 1223 then 1 else 0 end) as in_year1,
    max(case when ss.date.month_seq >= 1224 and ss.date.month_seq <= 1235 then 1 else 0 end) as in_year2,
;

with year1 as
WHERE wss.in_year1 = 1
SELECT
    wss.store_id as y1_store_id,
    wss.store_name as y1_store_name,
    wss.store_text_id as y1_store_text_id,
    wss.week_seq as y1_week_seq,
    wss.week_seq + 52 as y1_join_week,
    wss.sun_sales as y1_sun,
    wss.mon_sales as y1_mon,
    wss.tue_sales as y1_tue,
    wss.wed_sales as y1_wed,
    wss.thu_sales as y1_thu,
    wss.fri_sales as y1_fri,
    wss.sat_sales as y1_sat,
    1 as y1_present,
;

with year2 as
WHERE wss.in_year2 = 1
SELECT
    wss.store_id as y2_store_id,
    wss.store_text_id as y2_store_text_id,
    wss.week_seq as y2_week_seq,
    wss.sun_sales as y2_sun,
    wss.mon_sales as y2_mon,
    wss.tue_sales as y2_tue,
    wss.wed_sales as y2_wed,
    wss.thu_sales as y2_thu,
    wss.fri_sales as y2_fri,
    wss.sat_sales as y2_sat,
    1 as y2_present,
;

merge year1.y1_store_text_id into year2.y2_store_text_id;
merge year1.y1_join_week into year2.y2_week_seq;

WHERE year1.y1_present = 1 and year2.y2_present = 1
SELECT
    year1.y1_store_name as s_store_name1,
    year1.y1_store_text_id as s_store_id1,
    year1.y1_week_seq as d_week_seq1,
    year1.y1_sun / year2.y2_sun as sun_sales_ratio,
    year1.y1_mon / year2.y2_mon as mon_sales_ratio,
    year1.y1_tue / year2.y2_tue as tue_sales_ratio,
    year1.y1_wed / year2.y2_wed as wed_sales_ratio,
    year1.y1_thu / year2.y2_thu as thu_sales_ratio,
    year1.y1_fri / year2.y2_fri as fri_sales_ratio,
    year1.y1_sat / year2.y2_sat as sat_sales_ratio,
ORDER BY
    s_store_name1 asc nulls first,
    s_store_id1 asc nulls first,
    d_week_seq1 asc nulls first
LIMIT 100;
