import store_sales as ss;

def day_sales(d) -> sum(ss.sales_price ? ss.date.day_name = d) by ss.store.sk, ss.date.week_seq;

auto sun_sales <- @day_sales('Sunday');
auto mon_sales <- @day_sales('Monday');
auto tue_sales <- @day_sales('Tuesday');
auto wed_sales <- @day_sales('Wednesday');
auto thu_sales <- @day_sales('Thursday');
auto fri_sales <- @day_sales('Friday');
auto sat_sales <- @day_sales('Saturday');

auto year_flag <- max(case when ss.date.month_seq between 1212 and  1223 then 1 
when ss.date.month_seq between 1224 and 1235 then 2 else 0 end)
    by ss.store.sk, ss.date.week_seq;


# Normalized week-within-year so year1's W lines up with year2's W+52
auto normalized_week <- ss.date.week_seq - (case when year_flag = 2 then 52 else 0 end);

auto sun_ratio <- sun_sales / lead(sun_sales, 1) over (partition by ss.store.sk, normalized_week order by year_flag asc);
auto mon_ratio <- mon_sales / lead(mon_sales, 1) over (partition by ss.store.sk, normalized_week order by year_flag asc);
auto tue_ratio <- tue_sales / lead(tue_sales, 1) over (partition by ss.store.sk, normalized_week order by year_flag asc);
auto wed_ratio <- wed_sales / lead(wed_sales, 1) over (partition by ss.store.sk, normalized_week order by year_flag asc);
auto thu_ratio <- thu_sales / lead(thu_sales, 1) over (partition by ss.store.sk, normalized_week order by year_flag asc);
auto fri_ratio <- fri_sales / lead(fri_sales, 1) over (partition by ss.store.sk, normalized_week order by year_flag asc);
auto sat_ratio <- sat_sales / lead(sat_sales, 1) over (partition by ss.store.sk, normalized_week order by year_flag asc);

where
    ss.date.month_seq between 1212 and 1235
    and ss.store.sk is not null
    and ss.date.week_seq is not null
select
    --ss.store.sk,
    --normalized_week,
    ss.store.name as s_store_name1,
    ss.store.id as s_store_id1,
    ss.date.week_seq as d_week_seq1,
    sun_ratio as sun_sales_ratio,
    mon_ratio as mon_sales_ratio,
    tue_ratio as tue_sales_ratio,
    wed_ratio as wed_sales_ratio,
    thu_ratio as thu_sales_ratio,
    fri_ratio as fri_sales_ratio,
    sat_ratio as sat_sales_ratio,
having
    year_flag = 1 and sun_ratio is not null

order by
    s_store_name1 asc nulls first,
    s_store_id1 asc nulls first,
    d_week_seq1 asc nulls first
limit 100
;
