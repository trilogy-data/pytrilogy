import store_sales as ss;

# wss CTE: per (store, week_seq) sums of sales_price for each day of the week
def day_sales(d) -> sum(ss.sales_price ? ss.date.day_name = d) by ss.store.id, ss.date.week_seq;
auto sun_sales <- @day_sales('Sunday');
auto mon_sales <- @day_sales('Monday');
auto tue_sales <- @day_sales('Tuesday');
auto wed_sales <- @day_sales('Wednesday');
auto thu_sales <- @day_sales('Thursday');
auto fri_sales <- @day_sales('Friday');
auto sat_sales <- @day_sales('Saturday');

# Presence flags per (store, week_seq): does this week have any date in the y / x month_seq range?
def in_range(lo, hi) -> max(case when ss.date.month_seq >= lo and ss.date.month_seq <= hi then 1 else 0 end) by ss.store.id, ss.date.week_seq;
auto in_year1 <- @in_range(1212, 1223);
auto in_year2 <- @in_range(1224, 1235);

with year1 as
WHERE in_year1 = 1 and ss.store.id is not null and ss.date.week_seq is not null
SELECT
    ss.store.text_id as store_text_id_1,
    ss.store.name as store_name_1,
    ss.date.week_seq as week_seq_1,
    ss.date.week_seq + 52 as join_week,
    sun_sales as sun1,
    mon_sales as mon1,
    tue_sales as tue1,
    wed_sales as wed1,
    thu_sales as thu1,
    fri_sales as fri1,
    sat_sales as sat1,
    1 as year1_present,
;

with year2 as
WHERE in_year2 = 1 and ss.store.id is not null and ss.date.week_seq is not null
SELECT
    ss.store.text_id as store_text_id_2,
    ss.date.week_seq as week_seq_2,
    sun_sales as sun2,
    mon_sales as mon2,
    tue_sales as tue2,
    wed_sales as wed2,
    thu_sales as thu2,
    fri_sales as fri2,
    sat_sales as sat2,
    1 as year2_present,
;

merge year1.store_text_id_1 into year2.store_text_id_2;
merge year1.join_week into year2.week_seq_2;

WHERE year1.year1_present = 1 and year2.year2_present = 1
SELECT
    year1.store_name_1 as s_store_name1,
    year1.store_text_id_1 as s_store_id1,
    year1.week_seq_1 as d_week_seq1,
    year1.sun1 / year2.sun2 as sun_sales_ratio,
    year1.mon1 / year2.mon2 as mon_sales_ratio,
    year1.tue1 / year2.tue2 as tue_sales_ratio,
    year1.wed1 / year2.wed2 as wed_sales_ratio,
    year1.thu1 / year2.thu2 as thu_sales_ratio,
    year1.fri1 / year2.fri2 as fri_sales_ratio,
    year1.sat1 / year2.sat2 as sat_sales_ratio,
ORDER BY
    s_store_name1 asc nulls first,
    s_store_id1 asc nulls first,
    d_week_seq1 asc nulls first
LIMIT 100;
