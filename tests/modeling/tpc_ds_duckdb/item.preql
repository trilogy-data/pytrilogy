
key id int;

properties id (
    name string,
    product_name string,
    brand_id int,
    brand_name string,
    manufacturer_id int,
    category string?,
    category_id int?,
    current_price float?,
    class string?,
    desc string?,
    color string,
    manager_id int?,
    size string,
    units string?,
);

datasource items (
    I_ITEM_SK: id,
    I_ITEM_ID: name,
    I_ITEM_DESC: desc,
    I_BRAND: brand_name,
    I_BRAND_ID: brand_id,
    I_MANUFACT_ID: manufacturer_id,
    I_CATEGORY: category,
    I_CATEGORY_ID: category_id,
    I_CLASS: class,
    I_CURRENT_PRICE: current_price,
    I_COLOR: color,
    I_MANAGER_ID: manager_id,
    I_SIZE: size,
    I_UNITS: units,
    I_PRODUCT_NAME: product_name,
)
grain (id)
address memory.item;
