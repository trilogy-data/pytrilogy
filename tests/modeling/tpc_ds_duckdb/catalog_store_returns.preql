# Bespoke model for analyze catalog sales, store sales, and store returns as a unit.
# As catalog sales are returned to stores, used for specific analysis
# of patterns across these 3 datasets; unsuitable for other purposes.
# activity across all three tables can be queried as one model. Exposes
# store quantity / net_profit, store return quantity / amount / net_loss,
# and catalog quantity / net_profit.

import std.money;

import item as item;
import customer as customer;
import store as store;
import date as store_sale_date;
import date as store_return_date;
import date as catalog_date;
import time as time;

key ticket_number int; # Store-sale ticket number identifying a single in-store transaction.
key catalog_order_number int; # Catalog order number identifying a single catalog sales transaction.

properties <ticket_number, item.sk> (
    store_quantity int, # Units sold at the store on this ticket line.
    store_net_profit numeric::usd, # Net profit reported on the store sale line (USD).
    is_returned bool, # True if the store-sold line was later returned.
    store_return_quantity int?, # Units returned for the store-sold line.
    --store_return_amount numeric::usd?, # Refund amount for the store-sold line (USD).
    store_return_net_loss numeric::usd?, # Net financial loss on the store return (USD).
);
properties <catalog_order_number, item.sk> (
    catalog_quantity int?, # Units purchased via catalog for the same (customer, item).
    catalog_net_profit numeric::usd?, # Net profit reported on the catalog sale line (USD).
);


datasource store_sales (
    SS_SOLD_DATE_SK: ?store_sale_date.sk, # FK to date the store sale occurred.
    SS_CUSTOMER_SK: customer.sk, # FK to the purchasing customer.
    SS_TICKET_NUMBER: ticket_number,
    SS_ITEM_SK: item.sk, # FK to the item sold.
    SS_STORE_SK: ?store.sk, # FK to the store the sale occurred at.
    SS_QUANTITY: store_quantity,
    SS_NET_PROFIT: store_net_profit,
)
grain (item.sk, ticket_number, customer.sk)
address memory.store_sales;

datasource store_returns (
    SR_RETURNED_DATE_SK: store_return_date.sk, # FK to date the store return occurred.
    SR_RETURN_TIME_SK: time.sk, # FK to time-of-day of the return.
    SR_ITEM_SK: ~item.sk,
    SR_CUSTOMER_SK: customer.sk, # FK to the customer initiating the return.
    SR_TICKET_NUMBER: ~ticket_number,
    SR_RETURN_QUANTITY: store_return_quantity,
    SR_RETURN_AMT: store_return_amount,
    SR_NET_LOSS: store_return_net_loss,
    raw('''SR_RETURN_TIME_SK IS NOT NULL'''): is_returned, # Derived: true when a return row exists for this line.
)
grain (item.sk, ticket_number, customer.sk)
address memory.store_returns;


datasource catalog_sales (
    CS_BILL_CUSTOMER_SK: customer.sk, # FK to the billed customer (joined to store_sales customer).
    CS_ITEM_SK: item.sk, # FK to the item ordered.
    CS_SOLD_DATE_SK: ?catalog_date.sk, # FK to date the catalog order was sold.
    CS_ORDER_NUMBER: catalog_order_number,
    CS_QUANTITY: catalog_quantity,
    CS_NET_PROFIT: catalog_net_profit,
)
grain (catalog_order_number, item.sk)
address memory.catalog_sales;
