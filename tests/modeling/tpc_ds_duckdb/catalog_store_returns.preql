import item as item;
import customer as customer;
import store as store;
import date as store_sale_date;
import date as store_return_date;
import date as catalog_date;
import time as time;

# Cross-channel correlation source for q17/q25:
# "items the same customer bought at a store, returned at a store, and also
#  bought via catalog". A single `customer` concept is shared across all three
# physical tables — trilogy's cross-source join on (customer, item) then
# constrains the customer match without any per-query `merge` declarations.
#
# NB: this conflates SS_CUSTOMER_SK / SR_CUSTOMER_SK / CS_BILL_CUSTOMER_SK,
# which is fine for q17/q25 but not for q29 (q29's original SQL explicitly
# requires SS_CUSTOMER_SK = SR_CUSTOMER_SK, which a single-concept model
# can't express). q29 stays on the merge form for now.

key ticket_number int;

properties <ticket_number, item.id> (
    store_quantity int,
    store_net_profit float,
    is_returned bool,
    store_return_quantity int?,
    store_return_amount float?,
    store_return_net_loss float?,
);

datasource store_sales (
    SS_SOLD_DATE_SK: ?store_sale_date.id,
    SS_CUSTOMER_SK: customer.id,
    SS_TICKET_NUMBER: ticket_number,
    SS_ITEM_SK: item.id,
    SS_STORE_SK: ?store.id,
    SS_QUANTITY: store_quantity,
    SS_NET_PROFIT: store_net_profit,
)
grain (ticket_number, item.id)
address memory.store_sales;

datasource store_returns (
    SR_RETURNED_DATE_SK: store_return_date.id,
    SR_RETURN_TIME_SK: time.id,
    SR_ITEM_SK: ~item.id,
    SR_CUSTOMER_SK: customer.id,
    SR_TICKET_NUMBER: ~ticket_number,
    SR_RETURN_QUANTITY: store_return_quantity,
    SR_RETURN_AMT: store_return_amount,
    SR_NET_LOSS: store_return_net_loss,
    raw('''SR_RETURN_TIME_SK IS NOT NULL'''): is_returned,
)
grain (ticket_number, item.id)
address memory.store_returns;

key catalog_order_number int;

properties <catalog_order_number, item.id> (
    catalog_quantity int?,
    catalog_net_profit float?,
);

datasource catalog_sales (
    CS_BILL_CUSTOMER_SK: customer.id,
    CS_ITEM_SK: item.id,
    CS_SOLD_DATE_SK: ?catalog_date.id,
    CS_ORDER_NUMBER: catalog_order_number,
    CS_QUANTITY: catalog_quantity,
    CS_NET_PROFIT: catalog_net_profit,
)
grain (catalog_order_number, item.id)
address memory.catalog_sales;
