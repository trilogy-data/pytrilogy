import unified_sales as sales;
import date as date;

auto target_week_seqs <- date.week_seq ? date.date in (cast('2000-06-30' as date), cast('2000-09-27' as date), cast('2000-11-17' as date));

def channel_qty(channel) -> sum(sales.return_quantity ?
    sales.sales_channel = channel
) by sales.item.name;

def channel_present(channel) -> count(sales.order_id ?
    sales.sales_channel = channel
) by sales.item.name;

auto sr_item_qty <- @channel_qty('STORE');
auto cr_item_qty <- @channel_qty('CATALOG');
auto wr_item_qty <- @channel_qty('WEB');

auto sr_item_present <- @channel_present('STORE');
auto cr_item_present <- @channel_present('CATALOG');
auto wr_item_present <- @channel_present('WEB');

auto total_qty <- sr_item_qty + cr_item_qty + wr_item_qty;
auto avg_qty <- total_qty / 3.0;
auto sr_dev <- (sr_item_qty * 1.0000) / total_qty / 3.0000 * 100;
auto cr_dev <- (cr_item_qty * 1.0000) / total_qty / 3.0000 * 100;
auto wr_dev <- (wr_item_qty * 1.0000) / total_qty / 3.0000 * 100;

WHERE
    sales.return_date.week_seq in target_week_seqs
THEN WHERE
    sr_item_present > 0
    and cr_item_present > 0
    and wr_item_present > 0
SELECT
    sales.item.name as item_id,
    sr_item_qty,
    sr_dev,
    cr_item_qty,
    cr_dev,
    wr_item_qty,
    wr_dev,
    avg_qty as average,
    --sr_item_present,
    --cr_item_present,
    --wr_item_present
ORDER BY
    item_id asc nulls first,
    sr_item_qty asc nulls first
LIMIT 100;
