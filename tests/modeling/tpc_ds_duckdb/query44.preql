import store_sales as ss;

# Threshold: avg net_profit for store 4 where address is null, per store
auto threshold <- avg(ss.net_profit ? ss.store.id = 4 and ss.sale_address.id is null) by ss.store.id;

# Per-item avg profit at store 4
auto item_avg_profit <- avg(ss.net_profit ? ss.store.id = 4) by ss.item.id;

with ascending as
WHERE
    ss.store.id = 4
    and item_avg_profit > 0.9 * threshold
SELECT
    rank ss.item.id by item_avg_profit asc as rnk_a,
    ss.item.product_name as best_performing,
;

with descending as
WHERE
    ss.store.id = 4
    and item_avg_profit > 0.9 * threshold
SELECT
    rank ss.item.id by item_avg_profit desc as rnk_d,
    ss.item.product_name as worst_performing,
;

merge ascending.rnk_a into descending.rnk_d;

WHERE
    ascending.rnk_a < 11
SELECT
    ascending.rnk_a as rnk,
    ascending.best_performing,
    descending.worst_performing,
ORDER BY
    rnk asc nulls first,
    ascending.best_performing desc nulls first,
    descending.worst_performing desc nulls first
LIMIT 100;
