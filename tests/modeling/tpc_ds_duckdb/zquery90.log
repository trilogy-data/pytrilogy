generated_sql = """
SELECT
    CASE
	WHEN count(CASE WHEN \"ws_time_time\".\"T_HOUR\" >= 19 and \"ws_time_time\".\"T_HOUR\" <= 20 and \"ws_ship_household_demographic_household_demographics\".\"HD_DEP_COUNT\" = 6 and \"ws_web_page_web_page\".\"WP_CHAR_COUNT\" >= 5000 and \"ws_web_page_web_page\".\"WP_CHAR_COUNT\" <= 5200 THEN (cast(\"ws_web_sales\".\"WS_ORDER_NUMBER\" as string) || '-' || cast(\"ws_web_sales\".\"WS_ITEM_SK\" as string)) ELSE NULL END) = 0 THEN null
	ELSE cast(count(CASE WHEN \"ws_time_time\".\"T_HOUR\" >= 8 and \"ws_time_time\".\"T_HOUR\" <= 9 and \"ws_ship_household_demographic_household_demographics\".\"HD_DEP_COUNT\" = 6 and \"ws_web_page_web_page\".\"WP_CHAR_COUNT\" >= 5000 and \"ws_web_page_web_page\".\"WP_CHAR_COUNT\" <= 5200 THEN (cast(\"ws_web_sales\".\"WS_ORDER_NUMBER\" as string) || '-' || cast(\"ws_web_sales\".\"WS_ITEM_SK\" as string)) ELSE NULL END) as numeric(15,4)) / cast(count(CASE WHEN \"ws_time_time\".\"T_HOUR\" >= 19 and \"ws_time_time\".\"T_HOUR\" <= 20 and \"ws_ship_household_demographic_household_demographics\".\"HD_DEP_COUNT\" = 6 and \"ws_web_page_web_page\".\"WP_CHAR_COUNT\" >= 5000 and \"ws_web_page_web_page\".\"WP_CHAR_COUNT\" <= 5200 THEN (cast(\"ws_web_sales\".\"WS_ORDER_NUMBER\" as string) || '-' || cast(\"ws_web_sales\".\"WS_ITEM_SK\" as string)) ELSE NULL END) as numeric(15,4))
	END as \"am_pm_ratio\"
FROM
    \"memory\".\"web_sales\" as \"ws_web_sales\"
    INNER JOIN \"memory\".\"time_dim\" as \"ws_time_time\" on \"ws_web_sales\".\"WS_SOLD_TIME_SK\" = \"ws_time_time\".\"T_TIME_SK\"
    INNER JOIN \"memory\".\"web_page\" as \"ws_web_page_web_page\" on \"ws_web_sales\".\"WS_WEB_PAGE_SK\" = \"ws_web_page_web_page\".\"WP_WEB_PAGE_SK\"
    INNER JOIN \"memory\".\"household_demographics\" as \"ws_ship_household_demographic_household_demographics\" on \"ws_web_sales\".\"WS_SHIP_HDEMO_SK\" = \"ws_ship_household_demographic_household_demographics\".\"HD_DEMO_SK\"
ORDER BY 
    \"am_pm_ratio\" asc nulls first
LIMIT (100)"""
