# Address info: mailing addresses for customers, stores, warehouses, and
# web sites — street, city, state, ZIP, county, country, and GMT offset.

import std.geography;

key id int; # Surrogate key uniquely identifying a customer address row.

properties id (
    text_id string, # Stable business identifier for the address (16-char alphanumeric).
    street_number string?, # Numeric portion of the street address (e.g. '123').
    street_name string?, # Street name portion of the address (excludes house number).
    street_type string?, # Street type suffix (e.g. 'Ave', 'St', 'Rd').
    suite_number string?, # Suite/apartment number, if any.
    city string?, # City name.
    state string::us_state_short?, # Two-letter US state code (e.g. 'CA', 'NY').
    zip string?, # Postal/ZIP code as a string to preserve leading zeros.
    county string?, # County name within the state.
    country string::country?, # Country name (free-form string, typically 'United States').
    gmt_offset float?, # GMT offset for the address timezone (hours, e.g. -5.0 for EST).
    location_type string?, # Categorical location type: 'apartment', 'condo', or 'single family'.
);

datasource customer_address (
    CA_ADDRESS_SK: id,
    CA_ADDRESS_ID: text_id,
    CA_STREET_NUMBER: street_number,
    CA_STREET_NAME: street_name,
    CA_STREET_TYPE: street_type,
    CA_SUITE_NUMBER: suite_number,
    CA_CITY: city,
    CA_STATE: state,
    CA_ZIP: zip,
    CA_COUNTY: county,
    CA_COUNTRY: country,
    CA_GMT_OFFSET: gmt_offset,
    CA_LOCATION_TYPE: location_type,
)
grain (id)
address memory.customer_address;
