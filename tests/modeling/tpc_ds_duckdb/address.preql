
key id int;
properties id (
    street string,
    city string,
    state string?,
    zip string,
    county string,
    country string,
    gmt_offset float,
);


datasource customer_address(
    CA_ADDRESS_SK: id,
    CA_STREET: street,
    CA_CITY: city,
    CA_STATE: state,
    CA_ZIP: zip,
    CA_COUNTY: county,
    CA_COUNTRY:country,
    CA_GMT_OFFSET: gmt_offset
)
grain (id)
address memory.customer_address;
