import web_sales as ws;

# Non-rowset equivalent of query30 (rowset form): the key-join shape achieved by
# grouping the aggregate to (return_address.state, customer.sk). The year/state
# filter is bound *inside* the conditional sum because a plain sum + a row-grain
# WHERE year=2002 loses the filter from the customer-grain aggregate.
auto customer_state_returns_2002 <- sum(
    ws.return_amount
        ? ws.return_date.year = 2002 and ws.return_address.state is not null
)
    by ws.return_address.state, ws.return_customer.sk;
auto scaled_state_returns_2002 <- 1.2 * avg(customer_state_returns_2002) by ws.return_address.state;

where
    customer_state_returns_2002 > scaled_state_returns_2002
    and ws.return_customer.address.state = 'GA'
    and ws.return_address.state is not null
select
    --ws.return_customer.sk,
    ws.return_customer.id,
    ws.return_customer.salutation,
    ws.return_customer.first_name,
    ws.return_customer.last_name,
    ws.return_customer.preferred_cust_flag,
    ws.return_customer.birth_day,
    ws.return_customer.birth_month,
    ws.return_customer.birth_year,
    ws.return_customer.birth_country,
    ws.return_customer.login,
    ws.return_customer.email_address,
    ws.return_customer.last_review_date,
    customer_state_returns_2002,
order by
    ws.return_customer.id asc nulls first,
    ws.return_customer.salutation asc nulls first,
    ws.return_customer.first_name asc nulls first,
    ws.return_customer.last_name asc nulls first,
    ws.return_customer.preferred_cust_flag asc nulls first,
    ws.return_customer.birth_day asc nulls first,
    ws.return_customer.birth_month asc nulls first,
    ws.return_customer.birth_year asc nulls first,
    ws.return_customer.birth_country asc nulls first,
    ws.return_customer.login asc nulls first,
    ws.return_customer.email_address asc nulls first,
    ws.return_customer.last_review_date asc nulls first,
    customer_state_returns_2002 asc nulls first
limit 100
;
