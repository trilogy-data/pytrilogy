# Catalog channel sales (TPC-DS catalog_sales): fact at (item, order_number)
# grain with price / cost / profit measures, ship vs sold date, and a
# secondary `catalog_returns_inline` datasource that exposes return_amount /
# return_quantity joined directly on order+item without crossing the
# catalog_returns model.

import item as item;
import date as date;
import date as ship_date;
import date as sold_date;
import time as time;
import customer as customer;
import customer as bill_customer;
import call_center as call_center;
import catalog_page as catalog_page;
import warehouse as warehouse;
import customer_demographic as bill_customer_demographic;
import household_demographic as bill_household_demographic;
import promotion as promotion;
import ship_mode as ship_mode;
import address as customer_address;
import address as bill_address;

key warehouse_id int;
key order_number int;
auto days_to_ship <- date_diff(sold_date.date, ship_date.date, day);

# metrics
properties <order_number, item.id> (
    quantity int,
    sales_price float,
    list_price float,
    wholesale_cost float,
    discount_amount float,
    ext_sales_price numeric(15,2),
    ext_list_price float,
    ext_ship_cost float,
    ext_wholesale_cost float,
    net_profit float,
    net_paid float,
    net_paid_inc_tax float,
    coupon_amt float,
    return_amount float?,
    return_quantity int?,
    row_counter int,
);

auto profit <- list_price - wholesale_cost - discount_amount + ext_sales_price;

datasource catalog_sales (
    raw('''1'''): row_counter,
    CS_SOLD_DATE_SK: ?date.id,
    CS_SOLD_DATE_SK: ?sold_date.id,
    CS_SOLD_TIME_SK: ?time.id,
    CS_SHIP_DATE_SK: ?ship_date.id,
    CS_SHIP_CUSTOMER_SK: ?customer.id,
    CS_SHIP_ADDR_SK: ?customer_address.id,
    CS_BILL_CUSTOMER_SK: ?bill_customer.id,
    CS_BILL_CDEMO_SK: ?bill_customer_demographic.id,
    CS_BILL_HDEMO_SK: ?bill_household_demographic.id,
    CS_BILL_ADDR_SK: ?bill_address.id,
    CS_ITEM_SK: item.id,
    CS_QUANTITY: quantity,
    CS_LIST_PRICE: list_price,
    CS_SALES_PRICE: sales_price,
    CS_ORDER_NUMBER: order_number,
    CS_WHOLESALE_COST: wholesale_cost,
    CS_EXT_WHOLESALE_COST: ext_wholesale_cost,
    CS_EXT_DISCOUNT_AMT: discount_amount,
    CS_CALL_CENTER_SK: ?call_center.id,
    CS_CATALOG_PAGE_SK: ?catalog_page.id,
    CS_EXT_SHIP_COST: ext_ship_cost,
    CS_EXT_SALES_PRICE: ext_sales_price,
    CS_EXT_LIST_PRICE: ext_list_price,
    CS_NET_PROFIT: net_profit,
    CS_COUPON_AMT: coupon_amt,
    CS_WAREHOUSE_SK: ?warehouse.id,
    CS_PROMO_SK: ?promotion.id,
    CS_SHIP_MODE_SK: ?ship_mode.id,
    CS_NET_PAID: net_paid,
    CS_NET_PAID_INC_TAX: net_paid_inc_tax,
)
grain (item.id, order_number)
address memory.catalog_sales;

datasource catalog_returns_inline (
    CR_ORDER_NUMBER: ~order_number,
    CR_ITEM_SK: ~item.id,
    CR_RETURN_AMOUNT: return_amount,
    CR_RETURN_QUANTITY: return_quantity,
)
grain (item.id, order_number)
address memory.catalog_returns;
