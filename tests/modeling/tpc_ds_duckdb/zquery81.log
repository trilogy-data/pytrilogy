    FULL JOIN \"cheerful\" on \"cooperative\".\"cr_return_address_state\" is not distinct from \"cheerful\".\"cr_return_address_state\")
SELECT
    \"yummy\".\"cr_customer_text_id\" as \"cr_customer_text_id\",
