    avg(\"cheerful\".\"_returns_2000_customer_state\") as \"_virt_agg_avg_7337605889132590\"
FROM
    \"cheerful\"
GROUP BY
    1),
questionable as (
SELECT
    \"cheerful\".\"_returns_2000_customer_state\" as \"returns_2000_customer_state\",
    \"cheerful\".\"cr_customer_id\" as \"cr_customer_id\",
    \"cheerful\".\"cr_customer_id\" as \"returns_2000_cr_customer_id\",
    1.2 * \"cooperative\".\"_virt_agg_avg_7337605889132590\" as \"returns_2000_scaled_state\"
