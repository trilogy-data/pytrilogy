import store_sales as store_sales;

WHERE
    (store_sales.household_demographic.dependent_count = 4 or store_sales.household_demographic.vehicle_count = 3)
    and store_sales.date.day_of_week in (6, 0)
    and store_sales.date.year in (1999, 2000, 2001)
    and store_sales.store.city in ('Fairview', 'Midway')
    and store_sales.customer.address.city != store_sales.customer_address.city
SELECT
    store_sales.customer.last_name,
    store_sales.customer.first_name,
    store_sales.customer.address.city,
    store_sales.customer_address.city -> bought_city,
    store_sales.ticket_number,
    sum(store_sales.coupon_amt) -> amt,
    sum(store_sales.net_profit) -> profit
ORDER BY
    store_sales.customer.last_name asc nulls first,
    store_sales.customer.first_name asc nulls first,
    store_sales.customer.address.city asc nulls first,
    bought_city asc nulls first,
    store_sales.ticket_number asc nulls first
LIMIT 100;
