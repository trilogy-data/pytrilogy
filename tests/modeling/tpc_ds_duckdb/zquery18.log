    avg(cast(\"abhorrent\".\"row_birth_year\" as numeric(12,2))) as \"agg6_c\"
FROM
    \"abhorrent\"
GROUP BY
    1,
    2),
dapper as (
SELECT
    \"abhorrent\".\"cs_bill_customer_address_country\" as \"cs_bill_customer_address_country\",
    \"abhorrent\".\"cs_bill_customer_address_state\" as \"cs_bill_customer_address_state\",
    \"abhorrent\".\"cs_item_name\" as \"cs_item_name\",
    avg(cast(\"abhorrent\".\"row_birth_year\" as numeric(12,2))) as \"agg6_b\"
FROM
    \"abhorrent\"
GROUP BY
    1,
    2,
    3),
sweltering as (
SELECT
    \"abhorrent\".\"cs_item_name\" as \"cs_item_name\",
    avg(cast(\"abhorrent\".\"row_birth_year\" as numeric(12,2))) as \"agg6_d\"
FROM
    \"abhorrent\"
GROUP BY
    1),
puffy as (
SELECT
    \"rambunctious\".\"agg7_e\" as \"agg7_e\",
    \"waggish\".\"agg6_e\" as \"agg6_e\"
FROM
    \"waggish\"
    FULL JOIN \"rambunctious\" on 1=1),
nondescript as (
SELECT
    \"quick\".\"agg7_a\" as \"agg7_a\",
    \"trite\".\"agg6_a\" as \"agg6_a\",
    coalesce(\"quick\".\"cs_bill_customer_address_country\",\"trite\".\"cs_bill_customer_address_country\") as \"cs_bill_customer_address_country\",
    coalesce(\"quick\".\"cs_bill_customer_address_county\",\"trite\".\"cs_bill_customer_address_county\") as \"cs_bill_customer_address_county\",
    coalesce(\"quick\".\"cs_bill_customer_address_state\",\"trite\".\"cs_bill_customer_address_state\") as \"cs_bill_customer_address_state\",
    coalesce(\"quick\".\"cs_item_name\",\"trite\".\"cs_item_name\") as \"cs_item_name\"
FROM
    \"quick\"
    FULL JOIN \"trite\" on \"quick\".\"cs_bill_customer_address_country\" is not distinct from \"trite\".\"cs_bill_customer_address_country\" AND \"quick\".\"cs_bill_customer_address_county\" is not distinct from \"trite\".\"cs_bill_customer_address_county\" AND \"quick\".\"cs_bill_customer_address_state\" is not distinct from \"trite\".\"cs_bill_customer_address_state\" AND \"quick\".\"cs_item_name\" is not distinct from \"trite\".\"cs_item_name\"),
tearful as (
SELECT
    \"ceaseless\".\"agg7_c\" as \"agg7_c\",
    \"wooden\".\"agg6_c\" as \"agg6_c\",
    coalesce(\"ceaseless\".\"cs_bill_customer_address_country\",\"wooden\".\"cs_bill_customer_address_country\") as \"cs_bill_customer_address_country\",
    coalesce(\"ceaseless\".\"cs_item_name\",\"wooden\".\"cs_item_name\") as \"cs_item_name\"
FROM
    \"ceaseless\"
    FULL JOIN \"wooden\" on \"ceaseless\".\"cs_bill_customer_address_country\" is not distinct from \"wooden\".\"cs_bill_customer_address_country\" AND \"ceaseless\".\"cs_item_name\" is not distinct from \"wooden\".\"cs_item_name\"),
vast as (
SELECT
    \"courageous\".\"agg7_b\" as \"agg7_b\",
    \"dapper\".\"agg6_b\" as \"agg6_b\",
    coalesce(\"courageous\".\"cs_bill_customer_address_country\",\"dapper\".\"cs_bill_customer_address_country\") as \"cs_bill_customer_address_country\",
    coalesce(\"courageous\".\"cs_bill_customer_address_state\",\"dapper\".\"cs_bill_customer_address_state\") as \"cs_bill_customer_address_state\",
    coalesce(\"courageous\".\"cs_item_name\",\"dapper\".\"cs_item_name\") as \"cs_item_name\"
FROM
    \"courageous\"
    FULL JOIN \"dapper\" on \"courageous\".\"cs_bill_customer_address_country\" is not distinct from \"dapper\".\"cs_bill_customer_address_country\" AND \"courageous\".\"cs_bill_customer_address_state\" is not distinct from \"dapper\".\"cs_bill_customer_address_state\" AND \"courageous\".\"cs_item_name\" is not distinct from \"dapper\".\"cs_item_name\"),
friendly as (
SELECT
    \"scrawny\".\"agg7_d\" as \"agg7_d\",
    \"sweltering\".\"agg6_d\" as \"agg6_d\",
    coalesce(\"scrawny\".\"cs_item_name\",\"sweltering\".\"cs_item_name\") as \"cs_item_name\"
FROM
    \"scrawny\"
    FULL JOIN \"sweltering\" on \"scrawny\".\"cs_item_name\" is not distinct from \"sweltering\".\"cs_item_name\"),
sedate as (
SELECT
    \"hard\".\"agg1_e\" as \"agg1_e\",
    \"hard\".\"agg2_e\" as \"agg2_e\",
    \"hard\".\"agg3_e\" as \"agg3_e\",
    \"hard\".\"agg4_e\" as \"agg4_e\",
    \"hard\".\"agg5_e\" as \"agg5_e\",
    \"puffy\".\"agg6_e\" as \"agg6_e\",
    \"puffy\".\"agg7_e\" as \"agg7_e\"
FROM
    \"puffy\"
    FULL JOIN \"hard\" on 1=1),
slow as (
SELECT
    \"nondescript\".\"agg6_a\" as \"agg6_a\",
    \"nondescript\".\"agg7_a\" as \"agg7_a\",
    \"round\".\"agg1_a\" as \"agg1_a\",
    \"round\".\"agg2_a\" as \"agg2_a\",
    \"round\".\"agg3_a\" as \"agg3_a\",
    \"round\".\"agg4_a\" as \"agg4_a\",
    \"round\".\"agg5_a\" as \"agg5_a\",
    coalesce(\"nondescript\".\"cs_bill_customer_address_country\",\"round\".\"cs_bill_customer_address_country\") as \"ca_country\",
    coalesce(\"nondescript\".\"cs_bill_customer_address_county\",\"round\".\"cs_bill_customer_address_county\") as \"ca_county\",
    coalesce(\"nondescript\".\"cs_bill_customer_address_state\",\"round\".\"cs_bill_customer_address_state\") as \"ca_state\",
    coalesce(\"nondescript\".\"cs_item_name\",\"round\".\"cs_item_name\") as \"i_item_id\"
FROM
    \"nondescript\"
    FULL JOIN \"round\" on \"nondescript\".\"cs_bill_customer_address_country\" is not distinct from \"round\".\"cs_bill_customer_address_country\" AND \"nondescript\".\"cs_bill_customer_address_county\" is not distinct from \"round\".\"cs_bill_customer_address_county\" AND \"nondescript\".\"cs_bill_customer_address_state\" is not distinct from \"round\".\"cs_bill_customer_address_state\" AND \"nondescript\".\"cs_item_name\" is not distinct from \"round\".\"cs_item_name\"),
gullible as (
SELECT
    \"cloudy\".\"agg1_c\" as \"agg1_c\",
    \"cloudy\".\"agg2_c\" as \"agg2_c\",
    \"cloudy\".\"agg3_c\" as \"agg3_c\",
    \"cloudy\".\"agg4_c\" as \"agg4_c\",
    \"cloudy\".\"agg5_c\" as \"agg5_c\",
    \"tearful\".\"agg6_c\" as \"agg6_c\",
    \"tearful\".\"agg7_c\" as \"agg7_c\",
    coalesce(\"cloudy\".\"cs_bill_customer_address_country\",\"tearful\".\"cs_bill_customer_address_country\") as \"country_c\",
    coalesce(\"cloudy\".\"cs_item_name\",\"tearful\".\"cs_item_name\") as \"item_id_c\"
FROM
    \"tearful\"
    FULL JOIN \"cloudy\" on \"tearful\".\"cs_bill_customer_address_country\" is not distinct from \"cloudy\".\"cs_bill_customer_address_country\" AND \"tearful\".\"cs_item_name\" is not distinct from \"cloudy\".\"cs_item_name\"),
elated as (
SELECT
    \"cool\".\"agg1_b\" as \"agg1_b\",
    \"cool\".\"agg2_b\" as \"agg2_b\",
    \"cool\".\"agg3_b\" as \"agg3_b\",
    \"cool\".\"agg4_b\" as \"agg4_b\",
    \"cool\".\"agg5_b\" as \"agg5_b\",
    \"vast\".\"agg6_b\" as \"agg6_b\",
    \"vast\".\"agg7_b\" as \"agg7_b\",
    coalesce(\"cool\".\"cs_bill_customer_address_country\",\"vast\".\"cs_bill_customer_address_country\") as \"country_b\",
    coalesce(\"cool\".\"cs_bill_customer_address_state\",\"vast\".\"cs_bill_customer_address_state\") as \"state_b\",
    coalesce(\"cool\".\"cs_item_name\",\"vast\".\"cs_item_name\") as \"item_id_b\"
FROM
    \"vast\"
    FULL JOIN \"cool\" on \"vast\".\"cs_bill_customer_address_country\" is not distinct from \"cool\".\"cs_bill_customer_address_country\" AND \"vast\".\"cs_bill_customer_address_state\" is not distinct from \"cool\".\"cs_bill_customer_address_state\" AND \"vast\".\"cs_item_name\" is not distinct from \"cool\".\"cs_item_name\"),
divergent as (
SELECT
    \"friendly\".\"agg6_d\" as \"agg6_d\",
    \"friendly\".\"agg7_d\" as \"agg7_d\",
    \"kaput\".\"agg1_d\" as \"agg1_d\",
    \"kaput\".\"agg2_d\" as \"agg2_d\",
    \"kaput\".\"agg3_d\" as \"agg3_d\",
    \"kaput\".\"agg4_d\" as \"agg4_d\",
    \"kaput\".\"agg5_d\" as \"agg5_d\",
    coalesce(\"friendly\".\"cs_item_name\",\"kaput\".\"cs_item_name\") as \"item_id_d\"
FROM
    \"friendly\"
    FULL JOIN \"kaput\" on \"friendly\".\"cs_item_name\" is not distinct from \"kaput\".\"cs_item_name\"),
yellow as (
SELECT
    \"charming\".\"null_country_e\" as \"ca_country\",
    \"premium\".\"null_item_id_e\" as \"i_item_id\",
    \"protective\".\"null_county_e\" as \"ca_county\",
    \"puzzled\".\"null_state_e\" as \"ca_state\",
    \"sedate\".\"agg1_e\" as \"agg1_e\",
    \"sedate\".\"agg2_e\" as \"agg2_e\",
    \"sedate\".\"agg3_e\" as \"agg3_e\",
    \"sedate\".\"agg4_e\" as \"agg4_e\",
    \"sedate\".\"agg5_e\" as \"agg5_e\",
    \"sedate\".\"agg6_e\" as \"agg6_e\",
    \"sedate\".\"agg7_e\" as \"agg7_e\"
FROM
    \"charming\"
    FULL JOIN \"protective\" on 1=1
    FULL JOIN \"premium\" on 1=1
    FULL JOIN \"puzzled\" on 1=1
    FULL JOIN \"sedate\" on 1=1),
flashy as (
SELECT
    \"bewildered\".\"null_county_c\" as \"ca_county\",
    \"gullible\".\"agg1_c\" as \"agg1_c\",
    \"gullible\".\"agg2_c\" as \"agg2_c\",
    \"gullible\".\"agg3_c\" as \"agg3_c\",
    \"gullible\".\"agg4_c\" as \"agg4_c\",
    \"gullible\".\"agg5_c\" as \"agg5_c\",
    \"gullible\".\"agg6_c\" as \"agg6_c\",
    \"gullible\".\"agg7_c\" as \"agg7_c\",
    \"gullible\".\"country_c\" as \"ca_country\",
    \"gullible\".\"item_id_c\" as \"i_item_id\",
    \"level\".\"null_state_c\" as \"ca_state\"
FROM
    \"gullible\"
    FULL JOIN \"bewildered\" on 1=1
    FULL JOIN \"level\" on 1=1),
wary as (
SELECT
    \"elated\".\"agg1_b\" as \"agg1_b\",
    \"elated\".\"agg2_b\" as \"agg2_b\",
    \"elated\".\"agg3_b\" as \"agg3_b\",
    \"elated\".\"agg4_b\" as \"agg4_b\",
    \"elated\".\"agg5_b\" as \"agg5_b\",
    \"elated\".\"agg6_b\" as \"agg6_b\",
    \"elated\".\"agg7_b\" as \"agg7_b\",
    \"elated\".\"country_b\" as \"ca_country\",
    \"elated\".\"item_id_b\" as \"i_item_id\",
    \"elated\".\"state_b\" as \"ca_state\",
    \"resonant\".\"null_county_b\" as \"ca_county\"
FROM
    \"elated\"
    FULL JOIN \"resonant\" on 1=1),
busy as (
SELECT
    \"divergent\".\"agg1_d\" as \"agg1_d\",
    \"divergent\".\"agg2_d\" as \"agg2_d\",
    \"divergent\".\"agg3_d\" as \"agg3_d\",
    \"divergent\".\"agg4_d\" as \"agg4_d\",
    \"divergent\".\"agg5_d\" as \"agg5_d\",
    \"divergent\".\"agg6_d\" as \"agg6_d\",
    \"divergent\".\"agg7_d\" as \"agg7_d\",
    \"divergent\".\"item_id_d\" as \"i_item_id\",
    \"juicy\".\"null_state_d\" as \"ca_state\",
    \"uneven\".\"null_country_d\" as \"ca_country\",
    \"yummy\".\"null_county_d\" as \"ca_county\"
FROM
    \"divergent\"
    FULL JOIN \"uneven\" on 1=1
    FULL JOIN \"yummy\" on 1=1
    FULL JOIN \"juicy\" on 1=1),
spiritual as (
SELECT
    coalesce(\"busy\".\"ca_country\",\"flashy\".\"ca_country\",\"slow\".\"ca_country\",\"wary\".\"ca_country\",\"yellow\".\"ca_country\") as \"ca_country\",
    coalesce(\"busy\".\"ca_county\",\"flashy\".\"ca_county\",\"slow\".\"ca_county\",\"wary\".\"ca_county\",\"yellow\".\"ca_county\") as \"ca_county\",
    coalesce(\"busy\".\"ca_state\",\"flashy\".\"ca_state\",\"slow\".\"ca_state\",\"wary\".\"ca_state\",\"yellow\".\"ca_state\") as \"ca_state\",
    coalesce(\"busy\".\"i_item_id\",\"flashy\".\"i_item_id\",\"slow\".\"i_item_id\",\"wary\".\"i_item_id\",\"yellow\".\"i_item_id\") as \"i_item_id\",
    coalesce(\"slow\".\"agg1_a\",\"wary\".\"agg1_b\",\"flashy\".\"agg1_c\",\"busy\".\"agg1_d\",\"yellow\".\"agg1_e\") as \"agg1\",
    coalesce(\"slow\".\"agg2_a\",\"wary\".\"agg2_b\",\"flashy\".\"agg2_c\",\"busy\".\"agg2_d\",\"yellow\".\"agg2_e\") as \"agg2\",
    coalesce(\"slow\".\"agg3_a\",\"wary\".\"agg3_b\",\"flashy\".\"agg3_c\",\"busy\".\"agg3_d\",\"yellow\".\"agg3_e\") as \"agg3\",
    coalesce(\"slow\".\"agg4_a\",\"wary\".\"agg4_b\",\"flashy\".\"agg4_c\",\"busy\".\"agg4_d\",\"yellow\".\"agg4_e\") as \"agg4\",
    coalesce(\"slow\".\"agg5_a\",\"wary\".\"agg5_b\",\"flashy\".\"agg5_c\",\"busy\".\"agg5_d\",\"yellow\".\"agg5_e\") as \"agg5\",
    coalesce(\"slow\".\"agg6_a\",\"wary\".\"agg6_b\",\"flashy\".\"agg6_c\",\"busy\".\"agg6_d\",\"yellow\".\"agg6_e\") as \"agg6\",
    coalesce(\"slow\".\"agg7_a\",\"wary\".\"agg7_b\",\"flashy\".\"agg7_c\",\"busy\".\"agg7_d\",\"yellow\".\"agg7_e\") as \"agg7\"
FROM
    \"slow\"
    FULL JOIN \"wary\" on \"slow\".\"ca_country\" is not distinct from \"wary\".\"ca_country\" AND \"slow\".\"ca_county\" is not distinct from \"wary\".\"ca_county\" AND \"slow\".\"ca_state\" is not distinct from \"wary\".\"ca_state\" AND \"slow\".\"i_item_id\" is not distinct from \"wary\".\"i_item_id\"
    FULL JOIN \"flashy\" on coalesce(\"slow\".\"ca_country\", \"wary\".\"ca_country\") = \"flashy\".\"ca_country\" AND coalesce(\"slow\".\"ca_county\", \"wary\".\"ca_county\") = \"flashy\".\"ca_county\" AND coalesce(\"slow\".\"ca_state\", \"wary\".\"ca_state\") = \"flashy\".\"ca_state\" AND coalesce(\"slow\".\"i_item_id\", \"wary\".\"i_item_id\") = \"flashy\".\"i_item_id\"
    FULL JOIN \"busy\" on coalesce(\"slow\".\"ca_country\", \"wary\".\"ca_country\", \"flashy\".\"ca_country\") = \"busy\".\"ca_country\" AND coalesce(\"slow\".\"ca_county\", \"wary\".\"ca_county\", \"flashy\".\"ca_county\") = \"busy\".\"ca_county\" AND coalesce(\"slow\".\"ca_state\", \"wary\".\"ca_state\", \"flashy\".\"ca_state\") = \"busy\".\"ca_state\" AND coalesce(\"slow\".\"i_item_id\", \"wary\".\"i_item_id\", \"flashy\".\"i_item_id\") = \"busy\".\"i_item_id\"
    FULL JOIN \"yellow\" on coalesce(\"slow\".\"ca_country\", \"wary\".\"ca_country\", \"flashy\".\"ca_country\", \"busy\".\"ca_country\") = \"yellow\".\"ca_country\" AND coalesce(\"slow\".\"ca_county\", \"wary\".\"ca_county\", \"flashy\".\"ca_county\", \"busy\".\"ca_county\") = \"yellow\".\"ca_county\" AND coalesce(\"slow\".\"ca_state\", \"wary\".\"ca_state\", \"flashy\".\"ca_state\", \"busy\".\"ca_state\") = \"yellow\".\"ca_state\" AND coalesce(\"slow\".\"i_item_id\", \"wary\".\"i_item_id\", \"flashy\".\"i_item_id\", \"busy\".\"i_item_id\") = \"yellow\".\"i_item_id\")
SELECT
    \"spiritual\".\"i_item_id\" as \"q18_results_i_item_id\",
    \"spiritual\".\"ca_country\" as \"q18_results_ca_country\",
    \"spiritual\".\"ca_state\" as \"q18_results_ca_state\",
    \"spiritual\".\"ca_county\" as \"q18_results_ca_county\",
    \"spiritual\".\"agg1\" as \"q18_results_agg1\",
    \"spiritual\".\"agg2\" as \"q18_results_agg2\",
    \"spiritual\".\"agg3\" as \"q18_results_agg3\",
    \"spiritual\".\"agg4\" as \"q18_results_agg4\",
    \"spiritual\".\"agg5\" as \"q18_results_agg5\",
    \"spiritual\".\"agg6\" as \"q18_results_agg6\",
    \"spiritual\".\"agg7\" as \"q18_results_agg7\"
FROM
    \"spiritual\"
    FULL JOIN \"vivacious\" on 1=1
    FULL JOIN \"abundant\" on 1=1
ORDER BY 
    \"q18_results_ca_country\" asc nulls first,
    \"q18_results_ca_state\" asc nulls first,
    \"q18_results_ca_county\" asc nulls first,
    \"q18_results_i_item_id\" asc nulls first
LIMIT (100)"""
