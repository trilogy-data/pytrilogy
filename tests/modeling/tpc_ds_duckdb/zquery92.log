generated_sql = """

WITH 
cheerful as (
SELECT
    \"ws_item_items\".\"I_ITEM_SK\" as \"ws_item_id\",
    \"ws_item_items\".\"I_MANUFACT_ID\" as \"ws_item_manufacturer_id\",
    \"ws_web_sales\".\"WS_EXT_DISCOUNT_AMT\" as \"ws_ext_discount_amount\",
    cast(\"ws_date_date\".\"D_DATE\" as date) as \"ws_date_date\"
FROM
    \"memory\".\"date_dim\" as \"ws_date_date\"
    FULL JOIN \"memory\".\"web_sales\" as \"ws_web_sales\" on \"ws_date_date\".\"D_DATE_SK\" is not distinct from \"ws_web_sales\".\"WS_SOLD_DATE_SK\"
    INNER JOIN \"memory\".\"item\" as \"ws_item_items\" on \"ws_web_sales\".\"WS_ITEM_SK\" = \"ws_item_items\".\"I_ITEM_SK\"
WHERE
    \"ws_item_items\".\"I_MANUFACT_ID\" = 350 and cast(\"ws_date_date\".\"D_DATE\" as date) >= :start_date and cast(\"ws_date_date\".\"D_DATE\" as date) <= :end_date
),
thoughtful as (
SELECT
    \"ws_web_sales\".\"WS_ITEM_SK\" as \"ws_item_id\",
    avg(\"ws_web_sales\".\"WS_EXT_DISCOUNT_AMT\") as \"_virt_agg_avg_85246949879440\"
FROM
    \"memory\".\"date_dim\" as \"ws_date_date\"
    FULL JOIN \"memory\".\"web_sales\" as \"ws_web_sales\" on \"ws_date_date\".\"D_DATE_SK\" is not distinct from \"ws_web_sales\".\"WS_SOLD_DATE_SK\"
WHERE
    cast(\"ws_date_date\".\"D_DATE\" as date) >= :start_date and cast(\"ws_date_date\".\"D_DATE\" as date) <= :end_date

GROUP BY
    1)
SELECT
    sum(\"cheerful\".\"ws_ext_discount_amount\") as \"excess_discount_amount\"
FROM
    \"thoughtful\"
    RIGHT OUTER JOIN \"cheerful\" on \"thoughtful\".\"ws_item_id\" is not distinct from \"cheerful\".\"ws_item_id\"
WHERE
    \"cheerful\".\"ws_item_manufacturer_id\" = 350 and \"cheerful\".\"ws_date_date\" >= :start_date and \"cheerful\".\"ws_date_date\" <= :end_date and \"cheerful\".\"ws_ext_discount_amount\" > 1.3 * \"thoughtful\".\"_virt_agg_avg_85246949879440\"

ORDER BY 
    \"excess_discount_amount\" asc nulls first
LIMIT (100)"""
