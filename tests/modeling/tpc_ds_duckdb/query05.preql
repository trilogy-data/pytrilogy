import unified_sales as sales;

auto channel_label <- CASE
    WHEN sales.sales_channel = 'STORE' THEN 'store channel'
    WHEN sales.sales_channel = 'CATALOG' THEN 'catalog channel'
    WHEN sales.sales_channel = 'WEB' THEN 'web channel'
    ELSE null
END;

auto id_label <- CASE
    WHEN sales.sales_channel = 'STORE' THEN concat('store', sales.channel_dim_text_id)
    WHEN sales.sales_channel = 'CATALOG' THEN concat('catalog_page', sales.channel_dim_text_id)
    WHEN sales.sales_channel = 'WEB' THEN concat('web_site', sales.channel_dim_text_id)
    ELSE null
END;

# Aliases so we can apply '?' filters: sum(coalesce(x, 0) ? cond) is rejected
# by the parser (concept-only filters), so wrap the coalesce in a property auto.
property <sales.sales_channel, sales.order_id, sales.item.id>.return_amount_safe <- coalesce(sales.return_amount, 0);
property <sales.sales_channel, sales.order_id, sales.item.id>.return_net_loss_safe <- coalesce(sales.return_net_loss, 0);

# Per-row filtered metrics. Sales side keys off date.date in window;
# returns side keys off return_date.date in window. They're independent.

with q5_results as
WHERE
    sales.channel_dim_text_id is not null
SELECT
    channel_label as channel_a,
    id_label as id_a,
    sum(sales.ext_sales_price ? sales.date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) as sales_a,
    sum(return_amount_safe ? sales.return_date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) as returns_a,
    sum(sales.net_profit ? sales.date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) - sum(return_net_loss_safe ? sales.return_date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) as profit_a,
MERGE
WHERE
    sales.channel_dim_text_id is not null
SELECT
    channel_label as channel_b,
    cast(null as string) as null_id_b,
    sum(sales.ext_sales_price ? sales.date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) as sales_b,
    sum(return_amount_safe ? sales.return_date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) as returns_b,
    sum(sales.net_profit ? sales.date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) - sum(return_net_loss_safe ? sales.return_date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) as profit_b,
MERGE
WHERE
    sales.channel_dim_text_id is not null
SELECT
    cast(null as string) as null_channel_c,
    cast(null as string) as null_id_c,
    sum(sales.ext_sales_price ? sales.date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) as sales_c,
    sum(return_amount_safe ? sales.return_date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) as returns_c,
    sum(sales.net_profit ? sales.date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) - sum(return_net_loss_safe ? sales.return_date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)) as profit_c,
align
    channel: channel_a, channel_b, null_channel_c
    AND id: id_a, null_id_b, null_id_c
derive
    coalesce(q5_results.sales_a, q5_results.sales_b, q5_results.sales_c) -> sales_total,
    coalesce(q5_results.returns_a, q5_results.returns_b, q5_results.returns_c) -> returns_total,
    coalesce(q5_results.profit_a, q5_results.profit_b, q5_results.profit_c) -> profit_total
;

SELECT
    q5_results.channel,
    q5_results.id,
    q5_results.sales_total,
    q5_results.returns_total,
    q5_results.profit_total,
ORDER BY
    q5_results.channel asc nulls first,
    q5_results.id asc nulls first
LIMIT 100;
