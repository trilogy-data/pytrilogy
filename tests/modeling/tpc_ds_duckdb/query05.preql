import unified_sales as sales;

auto channel_label <- CASE
    WHEN sales.sales_channel = 'STORE' THEN 'store channel'
    WHEN sales.sales_channel = 'CATALOG' THEN 'catalog channel'
    WHEN sales.sales_channel = 'WEB' THEN 'web channel'
    ELSE null
END;

auto id_label <- CASE
    WHEN sales.sales_channel = 'STORE' THEN concat('store', sales.channel_dim_text_id)
    WHEN sales.sales_channel = 'CATALOG' THEN concat('catalog_page', sales.channel_dim_text_id)
    WHEN sales.sales_channel = 'WEB' THEN concat('web_site', sales.channel_dim_text_id)
    ELSE null
END;

# Per-row sale/return amounts gated to the q5 window. Rows outside window
# contribute 0 (matching the reference's UNION ALL with cast(0 AS decimal)).
property <sales.sales_channel, sales.order_id, sales.item.id>.sale_in_window <-
    case when sales.date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)
         then sales.ext_sales_price else 0.0 end;
property <sales.sales_channel, sales.order_id, sales.item.id>.profit_in_window <-
    case when sales.date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)
         then sales.net_profit else 0.0 end;
property <sales.sales_channel, sales.order_id, sales.item.id>.return_in_window <-
    case when sales.return_date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)
         then coalesce(sales.return_amount, 0.0) else 0.0 end;
property <sales.sales_channel, sales.order_id, sales.item.id>.loss_in_window <-
    case when sales.return_date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)
         then coalesce(sales.return_net_loss, 0.0) else 0.0 end;

WHERE
    sales.channel_dim_text_id is not null
    and ((sales.date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date))
         or (sales.return_date.date between cast('2000-08-23' as date) and cast('2000-09-06' as date)))
SELECT
    channel_label as channel,
    id_label as id,
    sum(sale_in_window) by rollup channel_label, id_label as sales_total,
    sum(return_in_window) by rollup channel_label, id_label as returns_total,
    --sum(profit_in_window) by rollup channel_label, id_label as profit_only,
    --sum(loss_in_window) by rollup channel_label, id_label as loss_only,
    profit_only - loss_only as profit_total,
ORDER BY
    channel asc nulls first,
    id asc nulls first
LIMIT 100;
