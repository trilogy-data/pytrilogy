import all_sales as sales;

auto channel_label <- case
    when sales.sales_channel = 'STORE' then 'store channel'
    when sales.sales_channel = 'CATALOG' then 'catalog channel'
    when sales.sales_channel = 'WEB' then 'web channel'
    else null
end;

# Sale rows expose the entity via channel_dim_text_id; return rows via
# return_channel_dim_text_id. Coalesce so sales roll up to the sale entity and
# returns to the return entity (matching the reference's UNION-then-rollup).
auto entity_text <- coalesce(sales.channel_dim_text_id, sales.return_channel_dim_text_id);
auto entity_id <- case
    when sales.sales_channel = 'STORE' then concat('store', entity_text)
    when sales.sales_channel = 'CATALOG' then concat('catalog_page', entity_text)
    when sales.sales_channel = 'WEB' then concat('web_site', entity_text)
    else null
end;

# Each measure is gated by its OWN dimension's presence (the reference inner-joins
# sales to the sale entity and returns to the return entity separately): a sale
# counts only with a sale entity in the sale window; a return only with a return
# entity in the return window. Without the per-measure gate, a combined row whose
# return entity is null but sale entity is valid would mis-count its return.
auto net_contribution <-
    coalesce(sales.net_profit ? sales.date.date between '2000-08-23'::date and '2000-09-06'::date and sales.channel_dim_text_id is not null, 0.0)
    - coalesce(sales.return_net_loss ? sales.return_date.date between '2000-08-23'::date and '2000-09-06'::date and sales.return_channel_dim_text_id is not null, 0.0);

where
    entity_text is not null
    and (sales.date.date between '2000-08-23'::date and '2000-09-06'::date
         or sales.return_date.date between '2000-08-23'::date and '2000-09-06'::date)
# `by rollup ()` rolls up over the inferred select grain (channel, id) — no need
# to restate the grouping keys.
select
    channel_label as channel,
    entity_id as id,
    coalesce(sum(sales.ext_sales_price ? sales.date.date between '2000-08-23'::date and '2000-09-06'::date and sales.channel_dim_text_id is not null) by rollup (), 0.0) as sales,
    coalesce(sum(sales.return_amount ? sales.return_date.date between '2000-08-23'::date and '2000-09-06'::date and sales.return_channel_dim_text_id is not null) by rollup (), 0.0) as returns,
    coalesce(sum(net_contribution) by rollup (), 0.0) as profit
order by
    channel asc nulls first,
    id asc nulls first
limit 100
;
