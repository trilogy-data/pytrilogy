# Web page info: per-page metadata for the retailer's web storefront —
# page type, autogen flag, and character / link / image counts.

key id int; # Surrogate key uniquely identifying a web page.

properties id (
    text_id string, # Stable business identifier for the web page (16-char alphanumeric).
    char_count int?, # Total number of characters on the page.
    link_count int?, # Number of hyperlinks on the page.
    image_count int?, # Number of images on the page.
    type enum<string>['ad', 'dynamic', 'feedback', 'general', 'order', 'protected', 'welcome']?, # Page-type category.
    autogen_flag enum<string>['Y', 'N']?, # 'Y' if the page was autogenerated, 'N' if manually authored.
);

datasource web_page (
    WP_WEB_PAGE_SK: id,
    WP_WEB_PAGE_ID: text_id,
    WP_CHAR_COUNT: char_count,
    WP_LINK_COUNT: link_count,
    WP_IMAGE_COUNT: image_count,
    WP_TYPE: type,
    WP_AUTOGEN_FLAG: autogen_flag,
)
grain (id)
address memory.web_page;
