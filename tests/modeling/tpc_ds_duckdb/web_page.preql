key id int;
properties id (
    string_id string,
    char_count int?,
    link_count int?,
    image_count int?,
    type string?,
    autogen_flag string?,
);

datasource web_page (
    WP_WEB_PAGE_SK: id,
    WP_WEB_PAGE_ID: string_id,
    WP_CHAR_COUNT: char_count,
    WP_LINK_COUNT: link_count,
    WP_IMAGE_COUNT: image_count,
    WP_TYPE: type,
    WP_AUTOGEN_FLAG: autogen_flag,
)
grain (id)
address memory.web_page;
