import store_sales as store_sales;

where
    store_sales.sale_time.hour = 20
    and store_sales.sale_time.minute >= 30
    and store_sales.pos_household_demographic.dependent_count = 7
    and store_sales.store.name = 'ese'
select
    count(concat(store_sales.ticket_number::string, '-', store_sales.item.sk::string)) as ct,
order by
    ct asc
limit 100
;
