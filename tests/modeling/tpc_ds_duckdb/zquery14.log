    \"sweltering\".\"avg_sales_average_sales\" as \"avg_sales_average_sales\"
FROM
    \"sweltering\"
    FULL JOIN \"sparkling\" on 1=1),
scrawny as (
SELECT
    \"macho\".\"brand_l0\" as \"l0_filtered_brand_l0\",
    \"macho\".\"bucket_count_l0\" as \"l0_filtered_bucket_count_l0\",
    \"macho\".\"bucket_sum_l0\" as \"l0_filtered_bucket_sum_l0\",
