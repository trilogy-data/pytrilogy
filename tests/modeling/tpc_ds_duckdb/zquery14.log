    \"macho\".\"bucket_sum_l0\" > \"macho\".\"avg_sales_average_sales\"
)
SELECT
    \"scrawny\".\"l0_filtered_channel_l0\" as \"channel\",
    \"scrawny\".\"l0_filtered_brand_l0\" as \"i_brand_id\",
    \"scrawny\".\"l0_filtered_class_l0\" as \"i_class_id\",
    \"scrawny\".\"l0_filtered_category_l0\" as \"i_category_id\",
    sum(\"scrawny\".\"l0_filtered_bucket_sum_l0\") as \"sum_sales\",
    sum(\"scrawny\".\"l0_filtered_bucket_count_l0\") as \"sum_number_sales\"
FROM
    \"scrawny\"
GROUP BY
    ROLLUP (1, 2, 3, 4)
ORDER BY 
    \"channel\" asc nulls first,
    \"i_brand_id\" asc nulls first,
    \"i_class_id\" asc nulls first,
    \"i_category_id\" asc nulls first
LIMIT (100)"""
