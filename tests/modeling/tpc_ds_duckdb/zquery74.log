    \"thoughtful\".\"sales_item_id\" as \"sales_item_id\",
    \"thoughtful\".\"sales_net_paid\" as \"sales_net_paid\",
    \"thoughtful\".\"sales_order_id\" as \"sales_order_id\",
    \"thoughtful\".\"sales_sales_channel\" as \"sales_sales_channel\"
