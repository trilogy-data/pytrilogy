    CASE WHEN \"questionable\".\"sales_channel\" = 'STORE' and \"questionable\".\"sales_sale_date_year\" = 2001 THEN \"questionable\".\"sales_net_paid\" ELSE NULL END as \"_virt_filter_net_paid_8641596681689318\",
