    \"questionable\".\"sales_order_id\" as \"sales_order_id\",
    CASE WHEN \"questionable\".\"sales_channel\" = 'STORE' and \"questionable\".\"sales_date_year\" = 2001 THEN \"questionable\".\"sales_net_paid\" ELSE NULL END as \"_virt_filter_net_paid_8492125850105602\",
    CASE WHEN \"questionable\".\"sales_channel\" = 'STORE' and \"questionable\".\"sales_date_year\" = 2002 THEN \"questionable\".\"sales_net_paid\" ELSE NULL END as \"_virt_filter_net_paid_8853252773530901\",
    CASE WHEN \"questionable\".\"sales_channel\" = 'WEB' and \"questionable\".\"sales_date_year\" = 2001 THEN \"questionable\".\"sales_net_paid\" ELSE NULL END as \"_virt_filter_net_paid_6631702181260704\",
    CASE WHEN \"questionable\".\"sales_channel\" = 'WEB' and \"questionable\".\"sales_date_year\" = 2002 THEN \"questionable\".\"sales_net_paid\" ELSE NULL END as \"_virt_filter_net_paid_8206914439048916\"
