    INNER JOIN \"cooperative\" on \"uneven\".\"sales_item_id\" = \"cooperative\".\"sales_item_id\" AND \"uneven\".\"sales_order_id\" = \"cooperative\".\"sales_order_id\" AND \"uneven\".\"sales_sales_channel\" = \"cooperative\".\"sales_sales_channel\"
GROUP BY
    1
HAVING
