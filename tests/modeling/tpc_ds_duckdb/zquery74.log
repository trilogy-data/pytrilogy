    \"yummy\".\"store_first_year\" as \"store_first_year\",
    \"yummy\".\"store_second_year\" as \"store_second_year\",
    \"yummy\".\"web_first_year\" as \"web_first_year\",
    \"yummy\".\"web_second_year\" as \"web_second_year\"
