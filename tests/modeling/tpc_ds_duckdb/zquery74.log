    INNER JOIN \"questionable\" on \"abundant\".\"sales_channel\" = \"questionable\".\"sales_channel\" AND \"abundant\".\"sales_item_sk\" = \"questionable\".\"sales_item_sk\" AND \"abundant\".\"sales_order_id\" = \"questionable\".\"sales_order_id\"
