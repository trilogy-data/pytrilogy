# Generate counts of promotional sales and total sales, and their ratio from the web channel for a particular item
#category and month to customers in a given time zone
#
# Full-outer "store vs catalog" overlap, expressed with the conformed-dimension
# + left-join idiom instead of a multi-select align: customer + item are the
# shared universe both facts attach to, and per-(customer,item) presence in each
# channel is a filtered customer_item value. This converges on the query97-one
# formulation — joins onto a conformed dimension are how a full-outer overlap is
# expressed without the multi-select.
import store_sales as store_sales;
import catalog_sales as catalog_sales;
import customer as customer;
import item as item;

auto customer_item <- concat(concat(customer.id::string, '-'), item.id::string);
auto store_present <- customer_item ? store_sales.date.month_seq between 1200 and 1200 + 11;
auto catalog_present <- customer_item ? catalog_sales.date.month_seq between 1200 and 1200 + 11;

left join customer.id = store_sales.customer.id
left join item.id = store_sales.item.id
left join customer.id = catalog_sales.bill_customer.id
left join item.id = catalog_sales.item.id
select
    sum(
            case
                when store_present is not null and catalog_present is null then 1
                else 0
            end
        ) as store_sale_count,
    sum(
            case
                when store_present is null and catalog_present is not null then 1
                else 0
            end
        ) as catalog_sale_count,
    sum(
            case
                when store_present is not null and catalog_present is not null then 1
                else 0
            end
        ) as both_sale_count,
;
