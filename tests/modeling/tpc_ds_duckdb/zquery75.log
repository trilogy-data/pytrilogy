    \"scrawny\".\"prev_prev_cnt\" as \"prev_yr_cnt\"
FROM
    \"charming\"
    INNER JOIN \"scrawny\" on \"charming\".\"curr_i_brand_id\" = \"scrawny\".\"prev_i_brand_id\" AND \"charming\".\"curr_i_category_id\" = \"scrawny\".\"prev_i_category_id\" AND \"charming\".\"curr_i_class_id\" = \"scrawny\".\"prev_i_class_id\" AND \"charming\".\"curr_i_manufact_id\" = \"scrawny\".\"prev_i_manufact_id\")
SELECT
    \"quizzical\".\"prev_year\" as \"prev_year\",
    \"quizzical\".\"year_\" as \"year_\",
    \"protective\".\"prev_i_brand_id\" as \"curr_i_brand_id\",
