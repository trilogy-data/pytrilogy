    coalesce(\"abhorrent\".\"prev_i_brand_id\",\"friendly\".\"curr_i_brand_id\") as \"curr_i_brand_id\",
    coalesce(\"abhorrent\".\"prev_i_class_id\",\"friendly\".\"curr_i_class_id\") as \"curr_i_class_id\",
    coalesce(\"abhorrent\".\"prev_i_category_id\",\"friendly\".\"curr_i_category_id\") as \"curr_i_category_id\",
