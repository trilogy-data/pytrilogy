    \"friendly\".\"curr_curr_cnt\" - \"abhorrent\".\"prev_prev_cnt\" as \"sales_cnt_diff\",
    \"friendly\".\"curr_curr_amt\" - \"abhorrent\".\"prev_prev_amt\" as \"sales_amt_diff\"
FROM
    \"friendly\"
    LEFT OUTER JOIN \"abhorrent\" on \"friendly\".\"curr_i_brand_id\" = \"abhorrent\".\"prev_i_brand_id\" AND \"friendly\".\"curr_i_category_id\" is not distinct from \"abhorrent\".\"prev_i_category_id\" AND \"friendly\".\"curr_i_class_id\" is not distinct from \"abhorrent\".\"prev_i_class_id\" AND \"friendly\".\"curr_i_manufact_id\" = \"abhorrent\".\"prev_i_manufact_id\"
WHERE
