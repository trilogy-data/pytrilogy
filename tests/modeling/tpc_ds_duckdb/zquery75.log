    \"abundant\".\"sales_quantity\" - coalesce(\"cheerful\".\"sales_return_quantity\",0) as \"deduped_cnt_per_row\",
    \"sales_item_items\".\"I_BRAND_ID\" as \"deduped_sales_item_brand_id\",
