    INNER JOIN \"macho\" on \"late\".\"deduped_sales_item_brand_id\" = \"macho\".\"deduped_sales_item_brand_id\" AND \"late\".\"deduped_sales_item_category_id\" is not distinct from \"macho\".\"deduped_sales_item_category_id\" AND \"late\".\"deduped_sales_item_class_id\" is not distinct from \"macho\".\"deduped_sales_item_class_id\" AND \"late\".\"deduped_sales_item_manufacturer_id\" = \"macho\".\"deduped_sales_item_manufacturer_id\"
