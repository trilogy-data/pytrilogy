protective as (
SELECT
    \"charming\".\"curr_curr_amt\" - \"scrawny\".\"prev_prev_amt\" as \"sales_amt_diff\",
    \"charming\".\"curr_curr_cnt\" - \"scrawny\".\"prev_prev_cnt\" as \"sales_cnt_diff\",
