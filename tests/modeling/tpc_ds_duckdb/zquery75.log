    INNER JOIN \"memory\".\"item\" as \"sales_item_items\" on \"abundant\".\"sales_item_id\" = \"sales_item_items\".\"I_ITEM_SK\"
WHERE
    \"abundant\".\"sales_date_year\" = 2002

GROUP BY
    1,
    2,
    3,
    4)
SELECT
