    cast(\"rambunctious\".\"curr_yr_cnt\" as numeric(17,2)) / cast(\"rambunctious\".\"prev_yr_cnt\" as numeric(17,2)) < 0.9

ORDER BY 
    \"rambunctious\".\"sales_cnt_diff\" asc nulls first,
    \"rambunctious\".\"sales_amt_diff\" asc nulls first
LIMIT (100)"""
