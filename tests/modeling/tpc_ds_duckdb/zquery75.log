generated_sql = """

WITH 
cheerful as (
SELECT
     'CATALOG'  as \"sales_channel\",
    \"sales_catalog_returns_unified\".\"CR_ITEM_SK\" as \"sales_item_sk\",
    \"sales_catalog_returns_unified\".\"CR_ORDER_NUMBER\" as \"sales_order_id\",
    \"sales_catalog_returns_unified\".\"CR_RETURN_AMOUNT\" as \"sales_return_amount\",
    \"sales_catalog_returns_unified\".\"CR_RETURN_QUANTITY\" as \"sales_return_quantity\"
FROM
    \"memory\".\"catalog_returns\" as \"sales_catalog_returns_unified\"
UNION ALL
SELECT
     'STORE'  as \"sales_channel\",
    \"sales_store_returns_unified\".\"SR_ITEM_SK\" as \"sales_item_sk\",
    \"sales_store_returns_unified\".\"SR_TICKET_NUMBER\" as \"sales_order_id\",
    \"sales_store_returns_unified\".\"SR_RETURN_AMT\" as \"sales_return_amount\",
    \"sales_store_returns_unified\".\"SR_RETURN_QUANTITY\" as \"sales_return_quantity\"
FROM
    \"memory\".\"store_returns\" as \"sales_store_returns_unified\"
UNION ALL
SELECT
     'WEB'  as \"sales_channel\",
    \"sales_web_returns_unified\".\"WR_ITEM_SK\" as \"sales_item_sk\",
    \"sales_web_returns_unified\".\"WR_ORDER_NUMBER\" as \"sales_order_id\",
    \"sales_web_returns_unified\".\"WR_RETURN_AMT\" as \"sales_return_amount\",
    \"sales_web_returns_unified\".\"WR_RETURN_QUANTITY\" as \"sales_return_quantity\"
FROM
    \"memory\".\"web_returns\" as \"sales_web_returns_unified\"),
abundant as (
SELECT
     'CATALOG'  as \"sales_channel\",
    \"sales_catalog_sales_unified\".\"CS_SOLD_DATE_SK\" as \"sales_date_sk\",
    \"sales_catalog_sales_unified\".\"CS_EXT_SALES_PRICE\" as \"sales_ext_sales_price\",
    \"sales_catalog_sales_unified\".\"CS_ITEM_SK\" as \"sales_item_sk\",
    \"sales_catalog_sales_unified\".\"CS_ORDER_NUMBER\" as \"sales_order_id\",
    \"sales_catalog_sales_unified\".\"CS_QUANTITY\" as \"sales_quantity\"
FROM
    \"memory\".\"catalog_sales\" as \"sales_catalog_sales_unified\"
UNION ALL
SELECT
     'STORE'  as \"sales_channel\",
    \"sales_store_sales_unified\".\"SS_SOLD_DATE_SK\" as \"sales_date_sk\",
    \"sales_store_sales_unified\".\"SS_EXT_SALES_PRICE\" as \"sales_ext_sales_price\",
    \"sales_store_sales_unified\".\"SS_ITEM_SK\" as \"sales_item_sk\",
    \"sales_store_sales_unified\".\"SS_TICKET_NUMBER\" as \"sales_order_id\",
    \"sales_store_sales_unified\".\"SS_QUANTITY\" as \"sales_quantity\"
FROM
    \"memory\".\"store_sales\" as \"sales_store_sales_unified\"
UNION ALL
SELECT
     'WEB'  as \"sales_channel\",
    \"sales_web_sales_unified\".\"WS_SOLD_DATE_SK\" as \"sales_date_sk\",
    \"sales_web_sales_unified\".\"WS_EXT_SALES_PRICE\" as \"sales_ext_sales_price\",
    \"sales_web_sales_unified\".\"WS_ITEM_SK\" as \"sales_item_sk\",
    \"sales_web_sales_unified\".\"WS_ORDER_NUMBER\" as \"sales_order_id\",
    \"sales_web_sales_unified\".\"WS_QUANTITY\" as \"sales_quantity\"
FROM
    \"memory\".\"web_sales\" as \"sales_web_sales_unified\"),
young as (
SELECT
    \"sales_item_items\".\"I_BRAND_ID\" as \"_curr_i_brand_id\",
    \"sales_item_items\".\"I_CATEGORY_ID\" as \"_curr_i_category_id\",
    \"sales_item_items\".\"I_CLASS_ID\" as \"_curr_i_class_id\",
    \"sales_item_items\".\"I_MANUFACT_ID\" as \"_curr_i_manufact_id\",
    sum(\"abundant\".\"sales_ext_sales_price\" - coalesce(\"cheerful\".\"sales_return_amount\",0.0)) as \"_curr_curr_amt\",
    sum(\"abundant\".\"sales_quantity\" - coalesce(\"cheerful\".\"sales_return_quantity\",0)) as \"_curr_curr_cnt\"
FROM
    \"abundant\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"abundant\".\"sales_date_sk\" = \"sales_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"item\" as \"sales_item_items\" on \"abundant\".\"sales_item_sk\" = \"sales_item_items\".\"I_ITEM_SK\"
    LEFT OUTER JOIN \"cheerful\" on \"abundant\".\"sales_channel\" = \"cheerful\".\"sales_channel\" AND \"abundant\".\"sales_item_sk\" = \"cheerful\".\"sales_item_sk\" AND \"abundant\".\"sales_order_id\" = \"cheerful\".\"sales_order_id\"
WHERE
    \"sales_item_items\".\"I_CATEGORY\" = 'Books' and \"sales_date_date\".\"D_YEAR\" = 2002

GROUP BY
    1,
    2,
    3,
    4),
juicy as (
SELECT
    \"sales_item_items\".\"I_BRAND_ID\" as \"_prev_i_brand_id\",
    \"sales_item_items\".\"I_CATEGORY_ID\" as \"_prev_i_category_id\",
    \"sales_item_items\".\"I_CLASS_ID\" as \"_prev_i_class_id\",
    \"sales_item_items\".\"I_MANUFACT_ID\" as \"_prev_i_manufact_id\",
    sum(\"abundant\".\"sales_ext_sales_price\" - coalesce(\"cheerful\".\"sales_return_amount\",0.0)) as \"_prev_prev_amt\",
    sum(\"abundant\".\"sales_quantity\" - coalesce(\"cheerful\".\"sales_return_quantity\",0)) as \"_prev_prev_cnt\"
FROM
    \"abundant\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"abundant\".\"sales_date_sk\" = \"sales_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"item\" as \"sales_item_items\" on \"abundant\".\"sales_item_sk\" = \"sales_item_items\".\"I_ITEM_SK\"
    LEFT OUTER JOIN \"cheerful\" on \"abundant\".\"sales_channel\" = \"cheerful\".\"sales_channel\" AND \"abundant\".\"sales_item_sk\" = \"cheerful\".\"sales_item_sk\" AND \"abundant\".\"sales_order_id\" = \"cheerful\".\"sales_order_id\"
WHERE
    \"sales_item_items\".\"I_CATEGORY\" = 'Books' and \"sales_date_date\".\"D_YEAR\" = 2001

GROUP BY
    1,
    2,
    3,
    4),
abhorrent as (
SELECT
    \"young\".\"_curr_curr_amt\" as \"curr_curr_amt\",
    \"young\".\"_curr_curr_cnt\" as \"curr_curr_cnt\",
    \"young\".\"_curr_i_brand_id\" as \"curr_i_brand_id\",
    \"young\".\"_curr_i_category_id\" as \"curr_i_category_id\",
    \"young\".\"_curr_i_class_id\" as \"curr_i_class_id\",
    \"young\".\"_curr_i_manufact_id\" as \"curr_i_manufact_id\"
FROM
    \"young\"),
concerned as (
SELECT
    \"juicy\".\"_prev_i_brand_id\" as \"prev_i_brand_id\",
    \"juicy\".\"_prev_i_category_id\" as \"prev_i_category_id\",
    \"juicy\".\"_prev_i_class_id\" as \"prev_i_class_id\",
    \"juicy\".\"_prev_i_manufact_id\" as \"prev_i_manufact_id\",
    \"juicy\".\"_prev_prev_amt\" as \"prev_prev_amt\",
    \"juicy\".\"_prev_prev_cnt\" as \"prev_prev_cnt\"
FROM
    \"juicy\")
SELECT
    2001 as \"prev_year\",
    2002 as \"year_\",
    coalesce(\"abhorrent\".\"curr_i_brand_id\",\"concerned\".\"prev_i_brand_id\") as \"curr_i_brand_id\",
    coalesce(\"abhorrent\".\"curr_i_class_id\",\"concerned\".\"prev_i_class_id\") as \"curr_i_class_id\",
    coalesce(\"abhorrent\".\"curr_i_category_id\",\"concerned\".\"prev_i_category_id\") as \"curr_i_category_id\",
    coalesce(\"abhorrent\".\"curr_i_manufact_id\",\"concerned\".\"prev_i_manufact_id\") as \"curr_i_manufact_id\",
    \"concerned\".\"prev_prev_cnt\" as \"prev_yr_cnt\",
    \"abhorrent\".\"curr_curr_cnt\" as \"curr_yr_cnt\",
    \"abhorrent\".\"curr_curr_cnt\" - \"concerned\".\"prev_prev_cnt\" as \"sales_cnt_diff\",
    \"abhorrent\".\"curr_curr_amt\" - \"concerned\".\"prev_prev_amt\" as \"sales_amt_diff\"
FROM
    \"abhorrent\"
    LEFT OUTER JOIN \"concerned\" on \"abhorrent\".\"curr_i_brand_id\" is not distinct from \"concerned\".\"prev_i_brand_id\" AND \"abhorrent\".\"curr_i_category_id\" is not distinct from \"concerned\".\"prev_i_category_id\" AND \"abhorrent\".\"curr_i_class_id\" is not distinct from \"concerned\".\"prev_i_class_id\" AND \"abhorrent\".\"curr_i_manufact_id\" is not distinct from \"concerned\".\"prev_i_manufact_id\"
WHERE
    cast(\"abhorrent\".\"curr_curr_cnt\" as numeric(17,2)) / cast(\"concerned\".\"prev_prev_cnt\" as numeric(17,2)) < 0.9

ORDER BY 
    \"sales_cnt_diff\" asc nulls first,
    \"sales_amt_diff\" asc nulls first
LIMIT (100)"""
