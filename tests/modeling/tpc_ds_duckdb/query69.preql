import customer as customer;
import all_sales as sales;

# TPC-DS q69 uses ss_customer_sk for the store EXISTS branch,
# ws_bill_customer_sk for web, and cs_ship_customer_sk for catalog, so:
#   - store/web filters use sales.billing_customer.sk (= SS_CUSTOMER_SK / WS_BILL_CUSTOMER_SK)
#   - catalog filter uses sales.ship_customer.sk (= CS_SHIP_CUSTOMER_SK)
rowset store_buyers <- where
    sales.channel = 'STORE'
    and sales.sale_date.year = 2001
    and sales.sale_date.month_of_year between 4 and 6
    and sales.billing_customer.sk is not null
select
    sales.billing_customer.sk as store_cust_id,
;

rowset web_buyers <- where
    sales.channel = 'WEB'
    and sales.sale_date.year = 2001
    and sales.sale_date.month_of_year between 4 and 6
    and sales.billing_customer.sk is not null
select
    sales.billing_customer.sk as web_cust_id,
;

rowset catalog_buyers <- where
    sales.channel = 'CATALOG'
    and sales.sale_date.year = 2001
    and sales.sale_date.month_of_year between 4 and 6
    and sales.ship_customer.sk is not null
select
    sales.ship_customer.sk as cat_cust_id,
;

where
    customer.current_address.state in ('KY', 'GA', 'NM')
    and customer.sk in store_buyers.store_cust_id
    and customer.sk not in web_buyers.web_cust_id
    and customer.sk not in catalog_buyers.cat_cust_id
select
    customer.current_demographics.gender,
    customer.current_demographics.marital_status,
    customer.current_demographics.education_status,
    count(customer.sk) as cnt1,
    customer.current_demographics.purchase_estimate,
    count(customer.sk) as cnt2,
    customer.current_demographics.credit_rating,
    count(customer.sk) as cnt3,
order by
    customer.current_demographics.gender asc,
    customer.current_demographics.marital_status asc,
    customer.current_demographics.education_status asc,
    customer.current_demographics.purchase_estimate asc,
    customer.current_demographics.credit_rating asc
limit 100
;
