generated_sql = """

WITH 
concerned as (
SELECT
    \"sales_web_sales_unified\".\"WS_BILL_CUSTOMER_SK\" as \"_web_buyers_web_cust_id\"
FROM
    \"memory\".\"web_sales\" as \"sales_web_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"sales_web_sales_unified\".\"WS_SOLD_DATE_SK\" = \"sales_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_date_date\".\"D_MOY\" BETWEEN 4 AND 6 and \"sales_web_sales_unified\".\"WS_BILL_CUSTOMER_SK\" is not null

GROUP BY
    1),
uneven as (
SELECT
    \"sales_store_sales_unified\".\"SS_CUSTOMER_SK\" as \"_store_buyers_store_cust_id\"
FROM
    \"memory\".\"store_sales\" as \"sales_store_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"sales_store_sales_unified\".\"SS_SOLD_DATE_SK\" = \"sales_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_date_date\".\"D_MOY\" BETWEEN 4 AND 6 and \"sales_store_sales_unified\".\"SS_CUSTOMER_SK\" is not null

GROUP BY
    1),
cheerful as (
