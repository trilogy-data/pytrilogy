generated_sql = """

WITH 
thoughtful as (
SELECT
    \"ss_store_returns\".\"SR_CUSTOMER_SK\" as \"ss_return_customer_sk\",
    \"ss_store_returns\".\"SR_ITEM_SK\" as \"ss_item_sk\",
    \"ss_store_returns\".\"SR_RETURN_AMT\" as \"ss_return_amount\",
    \"ss_store_returns\".\"SR_STORE_SK\" as \"ss_return_store_sk\",
    \"ss_store_returns\".\"SR_TICKET_NUMBER\" as \"ss_ticket_number\"
FROM
    \"memory\".\"store_returns\" as \"ss_store_returns\"
    INNER JOIN \"memory\".\"date_dim\" as \"ss_return_date_date\" on \"ss_store_returns\".\"SR_RETURNED_DATE_SK\" = \"ss_return_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"store\" as \"ss_return_store_store\" on \"ss_store_returns\".\"SR_STORE_SK\" = \"ss_return_store_store\".\"S_STORE_SK\"
WHERE
    \"ss_return_store_store\".\"S_STATE\" = 'TN' and \"ss_return_date_date\".\"D_YEAR\" = 2000
),
questionable as (
SELECT
    \"thoughtful\".\"ss_return_customer_sk\" as \"ss_return_customer_sk\",
    \"thoughtful\".\"ss_return_store_sk\" as \"ss_return_store_sk\",
    sum(\"thoughtful\".\"ss_return_amount\") as \"total_returns\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
    INNER JOIN \"thoughtful\" on \"ss_store_sales\".\"SS_ITEM_SK\" = \"thoughtful\".\"ss_item_sk\" AND \"ss_store_sales\".\"SS_TICKET_NUMBER\" = \"thoughtful\".\"ss_ticket_number\"
GROUP BY
    1,
    2),
uneven as (
SELECT
    \"questionable\".\"ss_return_store_sk\" as \"ss_return_store_sk\",
    avg(\"questionable\".\"total_returns\") as \"avg_store_returns\"
FROM
    \"questionable\"
GROUP BY
    1),
yummy as (
SELECT
    \"ss_return_customer_customers\".\"C_CUSTOMER_ID\" as \"ss_return_customer_id\"
FROM
    \"questionable\"
    INNER JOIN \"uneven\" on \"questionable\".\"ss_return_store_sk\" is not distinct from \"uneven\".\"ss_return_store_sk\"
    LEFT OUTER JOIN \"memory\".\"customer\" as \"ss_return_customer_customers\" on \"questionable\".\"ss_return_customer_sk\" = \"ss_return_customer_customers\".\"C_CUSTOMER_SK\"
WHERE
    \"questionable\".\"total_returns\" > ( 1.2 * \"uneven\".\"avg_store_returns\" )
)
SELECT
    \"yummy\".\"ss_return_customer_id\" as \"ss_return_customer_id\"
FROM
    \"yummy\"
ORDER BY 
    \"yummy\".\"ss_return_customer_id\" asc
LIMIT (100)"""
