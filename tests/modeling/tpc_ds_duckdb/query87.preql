import store_sales as store_sales;
import catalog_sales as catalog_sales;
import web_sales as web_sales;

from except(
    (
        where
            store_sales.sale_date.month_seq between 1200 and 1211
            and store_sales.customer.sk is not null
        select
            store_sales.customer.last_name,
            store_sales.customer.first_name,
            store_sales.sale_date.date
    ),
    (
        where
            catalog_sales.sale_date.month_seq between 1200 and 1211
            and catalog_sales.billing_customer.sk is not null
        select
            catalog_sales.billing_customer.last_name,
            catalog_sales.billing_customer.first_name,
            catalog_sales.sale_date.date
    ),
    (
        where
            web_sales.sale_date.month_seq between 1200 and 1211
            and web_sales.billing_customer.sk is not null
        select
            web_sales.billing_customer.last_name,
            web_sales.billing_customer.first_name,
            web_sales.sale_date.date
    )
) -> (last_name, first_name, sale_date)
select
    count(sale_date) as cnt
;
