import store_sales as ss;

where
    ss.return_store.state = 'TN' and ss.return_date.year = 2000
select
    ss.return_customer.id,
    --sum(ss.return_amount) by ss.return_customer.sk, ss.return_store.sk as total_returns,
    --ss.return_store.sk,
    --avg(total_returns) by ss.return_store.sk as avg_store_returns,
having
    total_returns > (1.2 * avg_store_returns)

order by
    ss.return_customer.id asc
limit 100
;
