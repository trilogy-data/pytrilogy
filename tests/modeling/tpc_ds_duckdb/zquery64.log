    5,
    \"resonant\".\"ss_customer_first_sales_date_year\",
    \"resonant\".\"ss_customer_first_shipto_date_year\"),
busy as (
SELECT
    \"divergent\".\"ss_date_year\" as \"_agg_00_syear_00\",
    \"divergent\".\"ss_item_sk\" as \"_agg_00_item_sk_00\",
    \"divergent\".\"ss_store_sk\" as \"_agg_00_store_sk_00\",
    count(\"divergent\".\"ss_ticket_number\") as \"_agg_00_cnt_00\",
    sum(\"divergent\".\"ss_coupon_amt\") as \"_agg_00_s3_00\",
    sum(\"divergent\".\"ss_list_price\") as \"_agg_00_s2_00\",
    sum(\"divergent\".\"ss_wholesale_cost\") as \"_agg_00_s1_00\"
FROM
    \"divergent\"
WHERE
    \"divergent\".\"ss_customer_demographic_marital_status\" != \"divergent\".\"ss_customer_demographics_marital_status\"

GROUP BY
    1,
    2,
    3),
vast as (
SELECT
    \"dapper\".\"_agg_99_b_addr_99\" as \"agg_99_b_addr_99\",
    \"dapper\".\"_agg_99_c_addr_99\" as \"agg_99_c_addr_99\",
    \"dapper\".\"_agg_99_cnt_99\" as \"agg_99_cnt_99\",
    \"dapper\".\"_agg_99_item_sk_99\" as \"agg_99_item_sk_99\",
    \"dapper\".\"_agg_99_s1_99\" as \"agg_99_s1_99\",
    \"dapper\".\"_agg_99_s2_99\" as \"agg_99_s2_99\",
    \"dapper\".\"_agg_99_s3_99\" as \"agg_99_s3_99\",
    \"dapper\".\"_agg_99_store_sk_99\" as \"agg_99_store_sk_99\",
    \"dapper\".\"_agg_99_syear_99\" as \"agg_99_syear_99\"
FROM
    \"dapper\"),
protective as (
SELECT
    \"busy\".\"_agg_00_cnt_00\" as \"agg_00_cnt_00\",
    \"busy\".\"_agg_00_item_sk_00\" as \"agg_00_item_sk_00\",
    \"busy\".\"_agg_00_s1_00\" as \"agg_00_s1_00\",
    \"busy\".\"_agg_00_s2_00\" as \"agg_00_s2_00\",
    \"busy\".\"_agg_00_s3_00\" as \"agg_00_s3_00\",
    \"busy\".\"_agg_00_store_sk_00\" as \"agg_00_store_sk_00\",
    \"busy\".\"_agg_00_syear_00\" as \"agg_00_syear_00\"
FROM
    \"busy\"),
cool as (
SELECT
    \"vast\".\"agg_99_b_addr_99\" as \"agg_99_b_addr_99\",
    \"vast\".\"agg_99_c_addr_99\" as \"agg_99_c_addr_99\",
    \"vast\".\"agg_99_item_sk_99\" as \"agg_99_item_sk_99\",
    \"vast\".\"agg_99_store_sk_99\" as \"agg_99_store_sk_99\"
FROM
    \"vast\"
GROUP BY
    1,
    2,
    3,
    4),
premium as (
SELECT
    \"protective\".\"agg_00_item_sk_00\" as \"agg_00_item_sk_00\",
    \"protective\".\"agg_00_store_sk_00\" as \"agg_00_store_sk_00\"
FROM
    \"protective\"
GROUP BY
    1,
    2),
wary as (
SELECT
    \"concerned\".\"ss_item_product_name\" as \"ss_item_product_name\",
    \"elated\".\"ss_sale_address_city\" as \"ss_sale_address_city\",
    \"elated\".\"ss_sale_address_street_name\" as \"ss_sale_address_street_name\",
    \"elated\".\"ss_sale_address_street_number\" as \"ss_sale_address_street_number\",
    \"elated\".\"ss_sale_address_zip\" as \"ss_sale_address_zip\",
    \"friendly\".\"ss_customer_address_city\" as \"ss_customer_address_city\",
    \"friendly\".\"ss_customer_address_street_name\" as \"ss_customer_address_street_name\",
    \"friendly\".\"ss_customer_address_street_number\" as \"ss_customer_address_street_number\",
    \"friendly\".\"ss_customer_address_zip\" as \"ss_customer_address_zip\",
    \"yellow\".\"ss_store_name\" as \"ss_store_name\",
    \"yellow\".\"ss_store_zip\" as \"ss_store_zip\",
    coalesce(\"concerned\".\"ss_item_sk\",\"cool\".\"agg_99_item_sk_99\",\"premium\".\"agg_00_item_sk_00\") as \"agg_00_item_sk_00\",
    coalesce(\"concerned\".\"ss_item_sk\",\"cool\".\"agg_99_item_sk_99\",\"premium\".\"agg_00_item_sk_00\") as \"agg_99_item_sk_99\",
    coalesce(\"concerned\".\"ss_item_sk\",\"cool\".\"agg_99_item_sk_99\",\"premium\".\"agg_00_item_sk_00\") as \"ss_item_sk\",
    coalesce(\"cool\".\"agg_99_b_addr_99\",\"elated\".\"ss_sale_address_sk\") as \"agg_99_b_addr_99\",
    coalesce(\"cool\".\"agg_99_b_addr_99\",\"elated\".\"ss_sale_address_sk\") as \"ss_sale_address_sk\",
    coalesce(\"cool\".\"agg_99_c_addr_99\",\"friendly\".\"ss_customer_address_sk\") as \"agg_99_c_addr_99\",
    coalesce(\"cool\".\"agg_99_c_addr_99\",\"friendly\".\"ss_customer_address_sk\") as \"ss_customer_address_sk\",
    coalesce(\"cool\".\"agg_99_store_sk_99\",\"premium\".\"agg_00_store_sk_00\",\"yellow\".\"ss_store_sk\") as \"agg_00_store_sk_00\",
    coalesce(\"cool\".\"agg_99_store_sk_99\",\"premium\".\"agg_00_store_sk_00\",\"yellow\".\"ss_store_sk\") as \"agg_99_store_sk_99\",
    coalesce(\"cool\".\"agg_99_store_sk_99\",\"premium\".\"agg_00_store_sk_00\",\"yellow\".\"ss_store_sk\") as \"ss_store_sk\"
FROM
    \"cool\"
    RIGHT OUTER JOIN \"elated\" on \"cool\".\"agg_99_b_addr_99\" = \"elated\".\"ss_sale_address_sk\"
    FULL JOIN \"friendly\" on \"cool\".\"agg_99_c_addr_99\" = \"friendly\".\"ss_customer_address_sk\"
    RIGHT OUTER JOIN \"concerned\" on \"cool\".\"agg_99_item_sk_99\" = \"concerned\".\"ss_item_sk\"
    LEFT OUTER JOIN \"premium\" on \"cool\".\"agg_99_store_sk_99\" = \"premium\".\"agg_00_store_sk_00\" AND coalesce(\"concerned\".\"ss_item_sk\", \"cool\".\"agg_99_item_sk_99\") = \"premium\".\"agg_00_item_sk_00\"
    FULL JOIN \"yellow\" on coalesce(\"cool\".\"agg_99_store_sk_99\", \"premium\".\"agg_00_store_sk_00\") = \"yellow\".\"ss_store_sk\"),
bewildered as (
SELECT
    \"vast\".\"agg_99_cnt_99\" as \"agg_99_cnt_99\",
    \"vast\".\"agg_99_s1_99\" as \"agg_99_s1_99\",
    \"vast\".\"agg_99_s2_99\" as \"agg_99_s2_99\",
    \"vast\".\"agg_99_s3_99\" as \"agg_99_s3_99\",
    \"vast\".\"agg_99_syear_99\" as \"agg_99_syear_99\",
    \"wary\".\"agg_00_item_sk_00\" as \"agg_00_item_sk_00\",
    \"wary\".\"agg_00_store_sk_00\" as \"agg_00_store_sk_00\",
    \"wary\".\"agg_99_item_sk_99\" as \"agg_99_item_sk_99\",
    \"wary\".\"agg_99_store_sk_99\" as \"agg_99_store_sk_99\",
    \"wary\".\"ss_customer_address_city\" as \"ss_customer_address_city\",
    \"wary\".\"ss_customer_address_street_name\" as \"ss_customer_address_street_name\",
    \"wary\".\"ss_customer_address_street_number\" as \"ss_customer_address_street_number\",
    \"wary\".\"ss_customer_address_zip\" as \"ss_customer_address_zip\",
    \"wary\".\"ss_item_product_name\" as \"ss_item_product_name\",
    \"wary\".\"ss_item_sk\" as \"ss_item_sk\",
    \"wary\".\"ss_sale_address_city\" as \"ss_sale_address_city\",
    \"wary\".\"ss_sale_address_street_name\" as \"ss_sale_address_street_name\",
    \"wary\".\"ss_sale_address_street_number\" as \"ss_sale_address_street_number\",
    \"wary\".\"ss_sale_address_zip\" as \"ss_sale_address_zip\",
    \"wary\".\"ss_store_name\" as \"ss_store_name\",
    \"wary\".\"ss_store_sk\" as \"ss_store_sk\",
    \"wary\".\"ss_store_zip\" as \"ss_store_zip\"
FROM
    \"wary\"
    INNER JOIN \"vast\" on \"wary\".\"ss_customer_address_sk\" = \"vast\".\"agg_99_c_addr_99\" AND \"wary\".\"ss_item_sk\" = \"vast\".\"agg_99_item_sk_99\" AND \"wary\".\"ss_sale_address_sk\" = \"vast\".\"agg_99_b_addr_99\" AND \"wary\".\"ss_store_sk\" = \"vast\".\"agg_99_store_sk_99\")
SELECT
    \"bewildered\".\"ss_item_product_name\" as \"p_name\",
    \"bewildered\".\"ss_store_name\" as \"s_name\",
    \"bewildered\".\"ss_store_zip\" as \"s_zip\",
    \"bewildered\".\"ss_sale_address_street_number\" as \"b_sn\",
    \"bewildered\".\"ss_sale_address_street_name\" as \"b_str\",
    \"bewildered\".\"ss_sale_address_city\" as \"b_city\",
    \"bewildered\".\"ss_sale_address_zip\" as \"b_zip\",
    \"bewildered\".\"ss_customer_address_street_number\" as \"c_sn\",
    \"bewildered\".\"ss_customer_address_street_name\" as \"c_str\",
    \"bewildered\".\"ss_customer_address_city\" as \"c_city\",
    \"bewildered\".\"ss_customer_address_zip\" as \"c_zip\",
    \"bewildered\".\"agg_99_syear_99\" as \"agg_99_syear_99\",
    \"bewildered\".\"agg_99_cnt_99\" as \"agg_99_cnt_99\",
    \"bewildered\".\"agg_99_s1_99\" as \"agg_99_s1_99\",
    \"bewildered\".\"agg_99_s2_99\" as \"agg_99_s2_99\",
    \"bewildered\".\"agg_99_s3_99\" as \"agg_99_s3_99\",
    \"protective\".\"agg_00_s1_00\" as \"agg_00_s1_00\",
    \"protective\".\"agg_00_s2_00\" as \"agg_00_s2_00\",
    \"protective\".\"agg_00_s3_00\" as \"agg_00_s3_00\",
    \"protective\".\"agg_00_syear_00\" as \"agg_00_syear_00\",
    \"protective\".\"agg_00_cnt_00\" as \"agg_00_cnt_00\"
FROM
    \"bewildered\"
    INNER JOIN \"protective\" on \"bewildered\".\"agg_99_item_sk_99\" = \"protective\".\"agg_00_item_sk_00\" AND \"bewildered\".\"agg_99_store_sk_99\" = \"protective\".\"agg_00_store_sk_00\"
WHERE
    \"protective\".\"agg_00_cnt_00\" <= \"bewildered\".\"agg_99_cnt_99\"

ORDER BY 
    \"p_name\" asc nulls first,
    \"s_name\" asc nulls first,
    \"protective\".\"agg_00_cnt_00\" asc nulls first,
    \"bewildered\".\"agg_99_s1_99\" asc nulls first,
    \"protective\".\"agg_00_s1_00\" asc nulls first"""
