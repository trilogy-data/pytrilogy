    \"rambunctious\"
    LEFT OUTER JOIN \"busy\" on \"rambunctious\".\"ss_customer_address_id\" = \"busy\".\"agg_99_c_addr_99\" AND \"rambunctious\".\"ss_item_id\" = \"busy\".\"agg_99_item_sk_99\" AND \"rambunctious\".\"ss_sale_address_id\" = \"busy\".\"agg_99_b_addr_99\" AND \"rambunctious\".\"ss_store_id\" = \"busy\".\"agg_99_store_sk_99\")
SELECT
    \"puffy\".\"ss_item_product_name\" as \"p_name\",
    \"puffy\".\"ss_store_name\" as \"s_name\",
    \"puffy\".\"ss_store_zip\" as \"s_zip\",
    \"puffy\".\"ss_sale_address_street_number\" as \"b_sn\",
    \"puffy\".\"ss_sale_address_street_name\" as \"b_str\",
    \"puffy\".\"ss_sale_address_city\" as \"b_city\",
    \"puffy\".\"ss_sale_address_zip\" as \"b_zip\",
    \"puffy\".\"ss_customer_address_street_number\" as \"c_sn\",
    \"puffy\".\"ss_customer_address_street_name\" as \"c_str\",
    \"puffy\".\"ss_customer_address_city\" as \"c_city\",
    \"puffy\".\"ss_customer_address_zip\" as \"c_zip\",
    \"puffy\".\"agg_99_syear_99\" as \"agg_99_syear_99\",
    \"puffy\".\"agg_99_cnt_99\" as \"agg_99_cnt_99\",
    \"puffy\".\"agg_99_s1_99\" as \"agg_99_s1_99\",
    \"puffy\".\"agg_99_s2_99\" as \"agg_99_s2_99\",
    \"puffy\".\"agg_99_s3_99\" as \"agg_99_s3_99\",
    \"vast\".\"agg_00_s1_00\" as \"agg_00_s1_00\",
    \"vast\".\"agg_00_s2_00\" as \"agg_00_s2_00\",
    \"vast\".\"agg_00_s3_00\" as \"agg_00_s3_00\",
    \"vast\".\"agg_00_syear_00\" as \"agg_00_syear_00\",
    \"vast\".\"agg_00_cnt_00\" as \"agg_00_cnt_00\"
FROM
    \"puffy\"
    INNER JOIN \"vast\" on \"puffy\".\"agg_99_item_sk_99\" = \"vast\".\"agg_00_item_sk_00\" AND \"puffy\".\"agg_99_store_sk_99\" = \"vast\".\"agg_00_store_sk_00\"
WHERE
    \"vast\".\"agg_00_cnt_00\" <= \"puffy\".\"agg_99_cnt_99\"

ORDER BY 
    \"p_name\" asc nulls first,
    \"s_name\" asc nulls first,
    \"vast\".\"agg_00_cnt_00\" asc nulls first,
    \"puffy\".\"agg_99_s1_99\" asc nulls first,
    \"vast\".\"agg_00_s1_00\" asc nulls first"""
