    \"puzzled\".\"ss_pos_address_zip\" as \"ss_pos_address_zip\",
    \"puzzled\".\"ss_store_name\" as \"ss_store_name\",
    \"puzzled\".\"ss_store_zip\" as \"ss_store_zip\",
    coalesce(\"divergent\".\"agg_99_item_sk_99\",\"puzzled\".\"agg_99_item_sk_99\") as \"agg_99_item_sk_99\",
    coalesce(\"divergent\".\"agg_99_item_sk_99\",\"puzzled\".\"ss_item_sk\") as \"ss_item_sk\",
    coalesce(\"divergent\".\"agg_99_store_sk_99\",\"puzzled\".\"agg_99_store_sk_99\") as \"agg_99_store_sk_99\",
    coalesce(\"divergent\".\"agg_99_store_sk_99\",\"puzzled\".\"ss_store_sk\") as \"ss_store_sk\"
FROM
    \"divergent\"
    INNER JOIN \"puzzled\" on \"divergent\".\"agg_99_b_addr_99\" is not distinct from \"puzzled\".\"ss_pos_address_sk\" AND \"divergent\".\"agg_99_c_addr_99\" is not distinct from \"puzzled\".\"ss_customer_current_address_sk\" AND \"divergent\".\"agg_99_item_sk_99\" is not distinct from \"puzzled\".\"ss_item_sk\" AND \"divergent\".\"agg_99_store_sk_99\" is not distinct from \"puzzled\".\"ss_store_sk\")
SELECT
    \"waggish\".\"ss_item_product_name\" as \"p_name\",
    \"waggish\".\"ss_store_name\" as \"s_name\",
    \"waggish\".\"ss_store_zip\" as \"s_zip\",
    \"waggish\".\"ss_pos_address_street_number\" as \"b_sn\",
    \"waggish\".\"ss_pos_address_street_name\" as \"b_str\",
    \"waggish\".\"ss_pos_address_city\" as \"b_city\",
    \"waggish\".\"ss_pos_address_zip\" as \"b_zip\",
    \"waggish\".\"ss_customer_current_address_street_number\" as \"c_sn\",
    \"waggish\".\"ss_customer_current_address_street_name\" as \"c_str\",
    \"waggish\".\"ss_customer_current_address_city\" as \"c_city\",
    \"waggish\".\"ss_customer_current_address_zip\" as \"c_zip\",
    \"waggish\".\"agg_99_syear_99\" as \"agg_99_syear_99\",
    \"waggish\".\"agg_99_cnt_99\" as \"agg_99_cnt_99\",
    \"waggish\".\"agg_99_s1_99\" as \"agg_99_s1_99\",
    \"waggish\".\"agg_99_s2_99\" as \"agg_99_s2_99\",
    \"waggish\".\"agg_99_s3_99\" as \"agg_99_s3_99\",
    \"courageous\".\"agg_00_s1_00\" as \"agg_00_s1_00\",
    \"courageous\".\"agg_00_s2_00\" as \"agg_00_s2_00\",
    \"courageous\".\"agg_00_s3_00\" as \"agg_00_s3_00\",
    \"courageous\".\"agg_00_syear_00\" as \"agg_00_syear_00\",
    \"courageous\".\"agg_00_cnt_00\" as \"agg_00_cnt_00\"
FROM
    \"waggish\"
    INNER JOIN \"courageous\" on \"waggish\".\"agg_99_item_sk_99\" is not distinct from \"courageous\".\"agg_00_item_sk_00\" AND \"waggish\".\"agg_99_store_sk_99\" is not distinct from \"courageous\".\"agg_00_store_sk_00\"
WHERE
    \"courageous\".\"agg_00_cnt_00\" <= \"waggish\".\"agg_99_cnt_99\"

ORDER BY 
    \"p_name\" asc nulls first,
    \"s_name\" asc nulls first,
    \"courageous\".\"agg_00_cnt_00\" asc nulls first,
    \"waggish\".\"agg_99_s1_99\" asc nulls first,
    \"courageous\".\"agg_00_s1_00\" asc nulls first"""
