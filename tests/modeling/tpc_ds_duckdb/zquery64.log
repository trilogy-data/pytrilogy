FROM
    \"puffy\"
    INNER JOIN \"dapper\" on \"puffy\".\"agg_99_b_addr_99\" is not distinct from \"dapper\".\"ss_pos_address_sk\" AND \"puffy\".\"agg_99_c_addr_99\" is not distinct from \"dapper\".\"ss_customer_address_sk\" AND \"puffy\".\"agg_99_item_sk_99\" is not distinct from \"dapper\".\"ss_item_sk\" AND \"puffy\".\"agg_99_store_sk_99\" is not distinct from \"dapper\".\"ss_store_sk\")
SELECT
    \"courageous\".\"ss_item_product_name\" as \"p_name\",
    \"courageous\".\"ss_store_name\" as \"s_name\",
    \"courageous\".\"ss_store_zip\" as \"s_zip\",
    \"courageous\".\"ss_pos_address_street_number\" as \"b_sn\",
    \"courageous\".\"ss_pos_address_street_name\" as \"b_str\",
    \"courageous\".\"ss_pos_address_city\" as \"b_city\",
    \"courageous\".\"ss_pos_address_zip\" as \"b_zip\",
    \"courageous\".\"ss_customer_address_street_number\" as \"c_sn\",
    \"courageous\".\"ss_customer_address_street_name\" as \"c_str\",
    \"courageous\".\"ss_customer_address_city\" as \"c_city\",
    \"courageous\".\"ss_customer_address_zip\" as \"c_zip\",
    \"courageous\".\"agg_99_syear_99\" as \"agg_99_syear_99\",
    \"courageous\".\"agg_99_cnt_99\" as \"agg_99_cnt_99\",
    \"courageous\".\"agg_99_s1_99\" as \"agg_99_s1_99\",
    \"courageous\".\"agg_99_s2_99\" as \"agg_99_s2_99\",
    \"courageous\".\"agg_99_s3_99\" as \"agg_99_s3_99\",
    \"divergent\".\"agg_00_s1_00\" as \"agg_00_s1_00\",
    \"divergent\".\"agg_00_s2_00\" as \"agg_00_s2_00\",
    \"divergent\".\"agg_00_s3_00\" as \"agg_00_s3_00\",
    \"divergent\".\"agg_00_syear_00\" as \"agg_00_syear_00\",
    \"divergent\".\"agg_00_cnt_00\" as \"agg_00_cnt_00\"
FROM
    \"courageous\"
    INNER JOIN \"divergent\" on \"courageous\".\"agg_99_item_sk_99\" is not distinct from \"divergent\".\"agg_00_item_sk_00\" AND \"courageous\".\"agg_99_store_sk_99\" is not distinct from \"divergent\".\"agg_00_store_sk_00\"
WHERE
    \"divergent\".\"agg_00_cnt_00\" <= \"courageous\".\"agg_99_cnt_99\"

ORDER BY 
    \"p_name\" asc nulls first,
    \"s_name\" asc nulls first,
    \"divergent\".\"agg_00_cnt_00\" asc nulls first,
    \"courageous\".\"agg_99_s1_99\" asc nulls first,
    \"divergent\".\"agg_00_s1_00\" asc nulls first"""
