    \"puzzled\".\"ss_pos_address_street_name\" as \"b_str\",
    \"puzzled\".\"ss_pos_address_city\" as \"b_city\",
    \"puzzled\".\"ss_pos_address_zip\" as \"b_zip\",
    \"puzzled\".\"ss_customer_current_address_street_number\" as \"c_sn\",
    \"puzzled\".\"ss_customer_current_address_street_name\" as \"c_str\",
    \"puzzled\".\"ss_customer_current_address_city\" as \"c_city\",
    \"puzzled\".\"ss_customer_current_address_zip\" as \"c_zip\",
    \"puzzled\".\"agg_99_syear_99\" as \"agg_99_syear_99\",
    \"puzzled\".\"agg_99_cnt_99\" as \"agg_99_cnt_99\",
    \"puzzled\".\"agg_99_s1_99\" as \"agg_99_s1_99\",
    \"puzzled\".\"agg_99_s2_99\" as \"agg_99_s2_99\",
    \"puzzled\".\"agg_99_s3_99\" as \"agg_99_s3_99\",
    \"dapper\".\"agg_00_s1_00\" as \"agg_00_s1_00\",
    \"dapper\".\"agg_00_s2_00\" as \"agg_00_s2_00\",
    \"dapper\".\"agg_00_s3_00\" as \"agg_00_s3_00\",
    \"dapper\".\"agg_00_syear_00\" as \"agg_00_syear_00\",
    \"dapper\".\"agg_00_cnt_00\" as \"agg_00_cnt_00\"
FROM
    \"puzzled\"
    INNER JOIN \"dapper\" on \"puzzled\".\"agg_99_item_sk_99\" is not distinct from \"dapper\".\"agg_00_item_sk_00\" AND \"puzzled\".\"agg_99_store_sk_99\" is not distinct from \"dapper\".\"agg_00_store_sk_00\"
WHERE
    \"dapper\".\"agg_00_cnt_00\" <= \"puzzled\".\"agg_99_cnt_99\"

ORDER BY 
    \"p_name\" asc nulls first,
    \"s_name\" asc nulls first,
    \"dapper\".\"agg_00_cnt_00\" asc nulls first,
    \"puzzled\".\"agg_99_s1_99\" asc nulls first,
    \"dapper\".\"agg_00_s1_00\" asc nulls first"""
