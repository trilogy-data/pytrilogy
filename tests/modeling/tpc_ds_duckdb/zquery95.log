generated_sql = """

WITH 
juicy as (
SELECT
    \"web_sales_web_sales\".\"WS_ORDER_NUMBER\" as \"web_sales_order_number\",
    \"web_sales_web_sales\".\"WS_WAREHOUSE_SK\" as \"web_sales_warehouse_sk\"
FROM
    \"memory\".\"web_sales\" as \"web_sales_web_sales\"
GROUP BY
    1,
    2),
questionable as (
SELECT
    coalesce(\"web_sales_web_returns\".\"WR_ORDER_NUMBER\",\"web_sales_web_sales\".\"WS_ORDER_NUMBER\") as \"returned_orders\"
FROM
    \"memory\".\"web_sales\" as \"web_sales_web_sales\"
    INNER JOIN \"memory\".\"web_returns\" as \"web_sales_web_returns\" on \"web_sales_web_sales\".\"WS_ITEM_SK\" = \"web_sales_web_returns\".\"WR_ITEM_SK\" AND \"web_sales_web_sales\".\"WS_ORDER_NUMBER\" = \"web_sales_web_returns\".\"WR_ORDER_NUMBER\"
WHERE
    (\"web_sales_web_returns\".\"WR_ORDER_NUMBER\" is not null) is True

GROUP BY
    1),
vacuous as (
SELECT
    \"juicy\".\"web_sales_order_number\" as \"web_sales_order_number\"
FROM
    \"juicy\"
GROUP BY
    1
HAVING
    count(\"juicy\".\"web_sales_warehouse_sk\") > 1
),
concerned as (
SELECT
    \"vacuous\".\"web_sales_order_number\" as \"multi_warehouse_order\"
FROM
    \"vacuous\"),
thoughtful as (
SELECT
    \"web_sales_web_sales\".\"WS_EXT_SHIP_COST\" as \"web_sales_ext_ship_cost\",
    \"web_sales_web_sales\".\"WS_NET_PROFIT\" as \"web_sales_net_profit\",
    \"web_sales_web_sales\".\"WS_ORDER_NUMBER\" as \"web_sales_order_number\"
FROM
    \"memory\".\"web_sales\" as \"web_sales_web_sales\"
    INNER JOIN \"memory\".\"web_site\" as \"web_sales_web_site_web_site\" on \"web_sales_web_sales\".\"WS_WEB_SITE_SK\" = \"web_sales_web_site_web_site\".\"web_site_sk\"
    INNER JOIN \"memory\".\"date_dim\" as \"web_sales_ship_date_date\" on \"web_sales_web_sales\".\"WS_SHIP_DATE_SK\" = \"web_sales_ship_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"customer_address\" as \"web_sales_ship_address_customer_address\" on \"web_sales_web_sales\".\"WS_SHIP_ADDR_SK\" = \"web_sales_ship_address_customer_address\".\"CA_ADDRESS_SK\"
WHERE
    cast(\"web_sales_ship_date_date\".\"D_DATE\" as date) BETWEEN date '1999-02-01' AND date '1999-04-02' and \"web_sales_ship_address_customer_address\".\"CA_STATE\" = 'IL' and \"web_sales_web_site_web_site\".\"web_company_name\" = 'pri' and \"web_sales_web_sales\".\"WS_ORDER_NUMBER\" in (select concerned.\"multi_warehouse_order\" from concerned where concerned.\"multi_warehouse_order\" is not null) and \"web_sales_web_sales\".\"WS_ORDER_NUMBER\" in (select questionable.\"returned_orders\" from questionable where questionable.\"returned_orders\" is not null)
),
young as (
SELECT
    \"thoughtful\".\"web_sales_ext_ship_cost\" as \"web_sales_ext_ship_cost\",
    \"thoughtful\".\"web_sales_net_profit\" as \"web_sales_net_profit\",
    \"thoughtful\".\"web_sales_order_number\" as \"web_sales_order_number\"
FROM
    \"thoughtful\"
WHERE
    \"thoughtful\".\"web_sales_order_number\" in (select concerned.\"multi_warehouse_order\" from concerned where concerned.\"multi_warehouse_order\" is not null) and \"thoughtful\".\"web_sales_order_number\" in (select questionable.\"returned_orders\" from questionable where questionable.\"returned_orders\" is not null)
),
abhorrent as (
SELECT
    \"young\".\"web_sales_order_number\" as \"web_sales_order_number\"
FROM
    \"young\"
GROUP BY
    1),
sparkling as (
SELECT
    sum(\"young\".\"web_sales_ext_ship_cost\") as \"total_shipping_cost\",
    sum(\"young\".\"web_sales_net_profit\") as \"total_net_profit\"
FROM
    \"young\"),
sweltering as (
SELECT
    count(\"abhorrent\".\"web_sales_order_number\") as \"order_count\"
FROM
    \"abhorrent\")
SELECT
    coalesce(\"sweltering\".\"order_count\",0) as \"order_count\",
    \"sparkling\".\"total_shipping_cost\" as \"total_shipping_cost\",
    \"sparkling\".\"total_net_profit\" as \"total_net_profit\"
FROM
    \"sparkling\"
    FULL JOIN \"sweltering\" on 1=1
ORDER BY 
    coalesce(\"sweltering\".\"order_count\",0) desc
LIMIT (100)"""
