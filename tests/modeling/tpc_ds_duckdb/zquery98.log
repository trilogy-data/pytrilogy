generated_sql = """

WITH 
cheerful as (
SELECT
    \"store_sales_item_items\".\"I_CATEGORY\" as \"store_sales_item_category\",
    \"store_sales_item_items\".\"I_CLASS\" as \"store_sales_item_class\",
    \"store_sales_item_items\".\"I_ITEM_SK\" as \"store_sales_item_id\",
    \"store_sales_store_sales\".\"SS_EXT_SALES_PRICE\" as \"store_sales_ext_sales_price\"
FROM
    \"memory\".\"store_sales\" as \"store_sales_store_sales\"
    INNER JOIN \"memory\".\"date_dim\" as \"store_sales_date_date\" on \"store_sales_store_sales\".\"SS_SOLD_DATE_SK\" = \"store_sales_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"item\" as \"store_sales_item_items\" on \"store_sales_store_sales\".\"SS_ITEM_SK\" = \"store_sales_item_items\".\"I_ITEM_SK\"
WHERE
    \"store_sales_item_items\".\"I_CATEGORY\" in ('Sports','Books','Home') and cast(\"store_sales_date_date\".\"D_DATE\" as date) BETWEEN date '1999-02-22' AND date '1999-03-24'
),
thoughtful as (
SELECT
    \"cheerful\".\"store_sales_ext_sales_price\" as \"store_sales_ext_sales_price\",
    \"cheerful\".\"store_sales_item_category\" as \"store_sales_item_category\",
    \"cheerful\".\"store_sales_item_class\" as \"store_sales_item_class\",
    \"cheerful\".\"store_sales_item_id\" as \"store_sales_item_id\"
FROM
    \"cheerful\"),
questionable as (
SELECT
    \"thoughtful\".\"store_sales_item_class\" as \"store_sales_item_class\",
    sum(\"thoughtful\".\"store_sales_ext_sales_price\") as \"_virt_agg_sum_7595906549305205\"
FROM
    \"thoughtful\"
GROUP BY
    1),
cooperative as (
SELECT
    \"thoughtful\".\"store_sales_item_category\" as \"store_sales_item_category\",
    \"thoughtful\".\"store_sales_item_class\" as \"store_sales_item_class\",
    \"thoughtful\".\"store_sales_item_id\" as \"store_sales_item_id\",
    sum(\"thoughtful\".\"store_sales_ext_sales_price\") as \"item_revenue\"
FROM
    \"thoughtful\"
GROUP BY
    1,
    2,
    3),
abundant as (
SELECT
    \"cooperative\".\"item_revenue\" as \"item_revenue\",
    \"cooperative\".\"store_sales_item_category\" as \"store_sales_item_category\",
    \"cooperative\".\"store_sales_item_class\" as \"store_sales_item_class\",
    \"cooperative\".\"store_sales_item_id\" as \"store_sales_item_id\",
    ( \"cooperative\".\"item_revenue\" * 100.0 ) / (\"questionable\".\"_virt_agg_sum_7595906549305205\") as \"revenueratio\"
FROM
    \"questionable\"
    RIGHT OUTER JOIN \"cooperative\" on \"questionable\".\"store_sales_item_class\" is not distinct from \"cooperative\".\"store_sales_item_class\")
SELECT
    \"store_sales_item_items\".\"I_ITEM_ID\" as \"store_sales_item_text_id\",
    \"store_sales_item_items\".\"I_ITEM_DESC\" as \"store_sales_item_desc\",
    \"abundant\".\"store_sales_item_category\" as \"store_sales_item_category\",
    \"abundant\".\"store_sales_item_class\" as \"store_sales_item_class\",
    \"store_sales_item_items\".\"I_CURRENT_PRICE\" as \"store_sales_item_current_price\",
    \"abundant\".\"item_revenue\" as \"item_revenue\",
    \"abundant\".\"revenueratio\" as \"revenueratio\"
FROM
    \"memory\".\"item\" as \"store_sales_item_items\"
    INNER JOIN \"abundant\" on \"store_sales_item_items\".\"I_ITEM_SK\" = \"abundant\".\"store_sales_item_id\"
ORDER BY 
    \"abundant\".\"store_sales_item_category\" asc nulls first,
    \"abundant\".\"store_sales_item_class\" asc nulls first,
    \"store_sales_item_items\".\"I_ITEM_ID\" asc nulls first,
    \"store_sales_item_items\".\"I_ITEM_DESC\" asc nulls first,
    \"abundant\".\"revenueratio\" asc nulls first"""
