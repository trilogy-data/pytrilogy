import web_sales as ws;

where
    ws.date.year = 2000
    and (
        (
            ws.return_refund_customer_demographic.marital_status = 'M'
            and ws.return_refund_customer_demographic.marital_status = ws.return_customer_demographic.marital_status
            and ws.return_refund_customer_demographic.education_status = 'Advanced Degree'
            and ws.return_refund_customer_demographic.education_status = ws.return_customer_demographic.education_status
            and ws.sales_price between 100.0 and 150.0
        )
        or (
            ws.return_refund_customer_demographic.marital_status = 'S'
            and ws.return_refund_customer_demographic.marital_status = ws.return_customer_demographic.marital_status
            and ws.return_refund_customer_demographic.education_status = 'College'
            and ws.return_refund_customer_demographic.education_status = ws.return_customer_demographic.education_status
            and ws.sales_price between 50.0 and 100.0
        )
        or (
            ws.return_refund_customer_demographic.marital_status = 'W'
            and ws.return_refund_customer_demographic.marital_status = ws.return_customer_demographic.marital_status
            and ws.return_refund_customer_demographic.education_status = '2 yr Degree'
            and ws.return_refund_customer_demographic.education_status = ws.return_customer_demographic.education_status
            and ws.sales_price between 150.0 and 200.0
        )
    )
    and (
        (
            ws.return_refund_address.country = 'United States'
            and ws.return_refund_address.state in ('IN', 'OH', 'NJ')
            and ws.net_profit between 100 and 200
        )
        or (
            ws.return_refund_address.country = 'United States'
            and ws.return_refund_address.state in ('WI', 'CT', 'KY')
            and ws.net_profit between 150 and 300
        )
        or (
            ws.return_refund_address.country = 'United States'
            and ws.return_refund_address.state in ('LA', 'IA', 'AR')
            and ws.net_profit between 50 and 250
        )
    )
select
    --ws.return_reason.desc,
    substring(ws.return_reason.desc, 1, 20) as reason_desc,
    avg(ws.quantity) as avg1,
    avg(ws.refunded_cash) as avg2,
    avg(ws.return_fee) as avg3,
order by
    reason_desc asc,
    avg1 asc,
    avg2 asc,
    avg3 asc
limit 100
;
