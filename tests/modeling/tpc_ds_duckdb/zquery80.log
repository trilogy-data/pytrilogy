    FULL JOIN \"abhorrent\" on 1=1
    FULL JOIN \"kaput\" on 1=1),
puzzled as (
SELECT
    coalesce(\"divergent\".\"channel\",\"premium\".\"channel\",\"protective\".\"channel\") as \"channel\",
    coalesce(\"divergent\".\"id\",\"premium\".\"id\",\"protective\".\"id\") as \"id\",
    coalesce(\"premium\".\"profit_a\",\"protective\".\"profit_b\",\"divergent\".\"profit_c\") as \"profit_total\",
    coalesce(\"premium\".\"returns_a\",\"protective\".\"returns_b\",\"divergent\".\"returns_c\") as \"returns_total\",
    coalesce(\"premium\".\"sales_a\",\"protective\".\"sales_b\",\"divergent\".\"sales_c\") as \"sales_total\"
FROM
    \"premium\"
    FULL JOIN \"protective\" on \"premium\".\"channel\" is not distinct from \"protective\".\"channel\" AND \"premium\".\"id\" is not distinct from \"protective\".\"id\"
    FULL JOIN \"divergent\" on coalesce(\"premium\".\"channel\", \"protective\".\"channel\") = \"divergent\".\"channel\" AND coalesce(\"premium\".\"id\", \"protective\".\"id\") = \"divergent\".\"id\")
SELECT
    \"puzzled\".\"channel\" as \"q80_results_channel\",
    \"puzzled\".\"id\" as \"q80_results_id\",
    \"puzzled\".\"sales_total\" as \"q80_results_sales_total\",
    \"puzzled\".\"returns_total\" as \"q80_results_returns_total\",
    \"puzzled\".\"profit_total\" as \"q80_results_profit_total\"
FROM
