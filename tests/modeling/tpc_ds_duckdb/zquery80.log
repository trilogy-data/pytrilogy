    \"friendly\"
GROUP BY
    1,
    2),
charming as (
SELECT
    \"friendly\".\"channel_label\" as \"channel_b\",
    sum(\"friendly\".\"profit_minus_loss\") as \"profit_b\",
    sum(\"friendly\".\"sales_ext_sales_price\") as \"sales_b\",
    sum(coalesce(\"friendly\".\"sales_return_amount\",0)) as \"returns_b\"
