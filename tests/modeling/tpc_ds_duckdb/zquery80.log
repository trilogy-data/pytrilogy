FROM
    \"quizzical\"
    RIGHT OUTER JOIN \"young\" on 1=1
WHERE
    \"young\".\"sales_date_date\" >= date '2000-08-23' and \"young\".\"sales_date_date\" <= date '2000-09-22' and \"young\".\"sales_item_current_price\" > 50 and \"young\".\"sales_promotion_channel_tv\" = 'N' and \"young\".\"sales_channel_dim_text_id\" is not null

GROUP BY
    1),
abhorrent as (
SELECT
    \"quizzical\".\"null_id_c\" as \"null_id_c\"
FROM
    \"quizzical\"
    RIGHT OUTER JOIN \"young\" on 1=1
WHERE
    \"young\".\"sales_date_date\" >= date '2000-08-23' and \"young\".\"sales_date_date\" <= date '2000-09-22' and \"young\".\"sales_item_current_price\" > 50 and \"young\".\"sales_promotion_channel_tv\" = 'N' and \"young\".\"sales_channel_dim_text_id\" is not null

GROUP BY
    1),
sparkling as (
SELECT
    \"quizzical\".\"null_channel_c\" as \"null_channel_c\"
FROM
    \"quizzical\"
    RIGHT OUTER JOIN \"young\" on 1=1
WHERE
    \"young\".\"sales_date_date\" >= date '2000-08-23' and \"young\".\"sales_date_date\" <= date '2000-09-22' and \"young\".\"sales_item_current_price\" > 50 and \"young\".\"sales_promotion_channel_tv\" = 'N' and \"young\".\"sales_channel_dim_text_id\" is not null

GROUP BY
    1),
protective as (
SELECT
    \"busy\".\"null_id_b\" as \"id\",
    \"charming\".\"channel_b\" as \"channel\",
    \"charming\".\"profit_b\" as \"profit_b\",
    \"charming\".\"returns_b\" as \"returns_b\",
    \"charming\".\"sales_b\" as \"sales_b\"
FROM
    \"charming\"
    FULL JOIN \"busy\" on 1=1),
divergent as (
SELECT
    \"abhorrent\".\"null_id_c\" as \"id\",
    \"kaput\".\"profit_c\" as \"profit_c\",
