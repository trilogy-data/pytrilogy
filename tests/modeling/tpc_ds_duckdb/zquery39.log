    \"cooperative\".\"inventory_warehouse_id\" as \"inventory_warehouse_id\",
    \"inventory_date_date\".\"D_YEAR\" as \"inventory_date_year\"
FROM
    \"cooperative\"
    INNER JOIN \"memory\".\"date_dim\" as \"inventory_date_date\" on \"cooperative\".\"inventory_date_id\" = \"inventory_date_date\".\"D_DATE_SK\"
WHERE
    \"inventory_date_date\".\"D_YEAR\" = 2001 and \"cooperative\".\"inventory_warehouse_id\" is not null
),
yummy as (
SELECT
    \"abundant\".\"dmoy2\" as \"dmoy2\"
FROM
    \"questionable\"
    LEFT OUTER JOIN \"abundant\" on 1=1
WHERE
    \"questionable\".\"inventory_date_year\" = 2001 and \"questionable\".\"inventory_warehouse_id\" is not null

GROUP BY
