generated_sql = """

WITH 
cooperative as (
SELECT
    \"inventory_warehouse_inventory\".\"inv_date_sk\" as \"inventory_date_id\",
    \"inventory_warehouse_inventory\".\"inv_warehouse_sk\" as \"inventory_warehouse_id\"
FROM
    \"memory\".\"inventory\" as \"inventory_warehouse_inventory\"
