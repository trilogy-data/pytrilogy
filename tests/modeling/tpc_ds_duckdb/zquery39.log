    10
ORDER BY 
    \"wakeful\".\"wsk1\" asc nulls first,
    \"wakeful\".\"isk1\" asc nulls first,
    \"wakeful\".\"mean1\" asc nulls first,
    \"wakeful\".\"cov1\" asc nulls first,
    \"wakeful\".\"mean2\" asc nulls first,
    \"wakeful\".\"cov2\" asc nulls first"""
