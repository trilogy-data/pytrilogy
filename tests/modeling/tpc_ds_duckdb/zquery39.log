ORDER BY 
    \"juicy\".\"wsk1\" asc nulls first,
    \"juicy\".\"isk1\" asc nulls first,
    \"juicy\".\"mean1\" asc nulls first,
    \"juicy\".\"cov1\" asc nulls first,
    \"juicy\".\"mean2\" asc nulls first,
    \"juicy\".\"cov2\" asc nulls first"""
