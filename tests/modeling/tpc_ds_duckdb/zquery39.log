    \"abundant\".\"dmoy1\" as \"dmoy1\"
FROM
    \"questionable\"
    LEFT OUTER JOIN \"abundant\" on 1=1
WHERE
    \"questionable\".\"inventory_date_year\" = 2001 and \"questionable\".\"inventory_warehouse_id\" is not null

GROUP BY
    1)
SELECT
    \"wakeful\".\"wsk1\" as \"wsk1\",
    \"wakeful\".\"isk1\" as \"isk1\",
    \"uneven\".\"dmoy1\" as \"dmoy1\",
    \"wakeful\".\"mean1\" as \"mean1\",
    \"wakeful\".\"cov1\" as \"cov1\",
    \"wakeful\".\"wsk2\" as \"wsk2\",
    \"wakeful\".\"isk2\" as \"isk2\",
    \"yummy\".\"dmoy2\" as \"dmoy2\",
    \"wakeful\".\"mean2\" as \"mean2\",
    \"wakeful\".\"cov2\" as \"cov2\"
FROM
    \"wakeful\"
    LEFT OUTER JOIN \"uneven\" on 1=1
    FULL JOIN \"yummy\" on 1=1
