# Warehouse info: physical storage locations with name, square footage,
# and address (city, county, state, ZIP, country).

import std.geography;

key sk int; # Surrogate key uniquely identifying a warehouse.

properties sk (
    id string, # Stable business identifier for the warehouse (16-char alphanumeric).
    name string?, # Warehouse display name.
    square_feet int?, # Total floor space of the warehouse in square feet.
    state string::us_state_short?, # Two-letter US state code for the warehouse address.
    city string?, # City of the warehouse address.
    county string?, # County of the warehouse address.
    --zip string?, # ZIP/postal code of the warehouse address.
    country string::country?, # Country of the warehouse address.
);

datasource warehouse (
    w_warehouse_sk: sk,
    w_warehouse_id: id,
    w_warehouse_name: ?name,
    w_warehouse_sq_ft: square_feet,
    w_state: state,
    w_city: city,
    w_county: county,
    w_zip: zip,
    w_country: country,
)
grain (sk)
address memory.warehouse;
