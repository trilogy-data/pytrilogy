import store_sales as store_sales;
import catalog_sales as catalog_sales;

merge catalog_sales.bill_customer.id into store_sales.return_customer.id;
merge catalog_sales.item.id into store_sales.item.id;

WHERE
    store_sales.date.quarter_name = '2001Q1'
    and store_sales.return_date.quarter_name in ('2001Q1', '2001Q2', '2001Q3')
    and catalog_sales.date.quarter_name in ('2001Q1', '2001Q2', '2001Q3')
    and store_sales.is_returned
SELECT
    store_sales.item.name,
    store_sales.item.desc,
    store_sales.store.state,
    count(store_sales.quantity) as store_sales_quantitycount,
    avg(store_sales.quantity) as store_sales_quantityave,
    stddev(store_sales.quantity) as store_sales_quantitystdev,
    stddev(store_sales.quantity) / avg(store_sales.quantity) as store_sales_quantitycov,
    count(store_sales.return_quantity) as store_returns_quantitycount,
    avg(store_sales.return_quantity) as store_returns_quantityave,
    stddev(store_sales.return_quantity) as store_returns_quantitystdev,
    stddev(store_sales.return_quantity) / avg(store_sales.return_quantity) as store_returns_quantitycov,
    count(catalog_sales.quantity) as catalog_sales_quantitycount,
    avg(catalog_sales.quantity) as catalog_sales_quantityave,
    stddev(catalog_sales.quantity) as catalog_sales_quantitystdev,
    stddev(catalog_sales.quantity) / avg(catalog_sales.quantity) as catalog_sales_quantitycov
ORDER BY
    store_sales.item.name asc nulls first,
    store_sales.item.desc asc nulls first,
    store_sales.store.state asc nulls first
LIMIT 100;
