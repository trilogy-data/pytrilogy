# Income band lookup (TPC-DS income_band): lower / upper dollar bounds for
# each band. Referenced by household_demographic.income_band to bucket
# customers into income ranges for q08, q13, q48, q85.

key id int;

properties id (
    lower_bound int,
    upper_bound int,
);

datasource income_band (
    IB_INCOME_BAND_SK: id,
    IB_LOWER_BOUND: lower_bound,
    IB_UPPER_BOUND: upper_bound,
)
grain (id)
address memory.income_band;
