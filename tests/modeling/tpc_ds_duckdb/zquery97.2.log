generated_sql = """

WITH 
quizzical as (
SELECT
    \"catalog_sales_catalog_sales\".\"CS_BILL_CUSTOMER_SK\" as \"customer_sk\",
    \"catalog_sales_catalog_sales\".\"CS_ITEM_SK\" as \"item_sk\",
    \"catalog_sales_catalog_sales\".\"CS_SOLD_DATE_SK\" as \"catalog_sales_date_sk\"
FROM
    \"memory\".\"catalog_sales\" as \"catalog_sales_catalog_sales\"
GROUP BY
    1,
    2,
    3),
thoughtful as (
SELECT
    \"store_sales_store_sales\".\"SS_CUSTOMER_SK\" as \"customer_sk\",
    \"store_sales_store_sales\".\"SS_ITEM_SK\" as \"item_sk\",
    \"store_sales_store_sales\".\"SS_SOLD_DATE_SK\" as \"store_sales_date_sk\"
FROM
    \"memory\".\"store_sales\" as \"store_sales_store_sales\"
GROUP BY
    1,
    2,
    3),
questionable as (
SELECT
    CASE WHEN \"catalog_sales_date_date\".\"D_MONTH_SEQ\" BETWEEN 1200 AND 1200 + 11 THEN ((cast(coalesce(\"quizzical\".\"customer_sk\",\"thoughtful\".\"customer_sk\") as string) || '-') || cast(coalesce(\"quizzical\".\"item_sk\",\"thoughtful\".\"item_sk\") as string)) ELSE NULL END as \"catalog_present\",
    CASE WHEN \"store_sales_date_date\".\"D_MONTH_SEQ\" BETWEEN 1200 AND 1200 + 11 THEN ((cast(coalesce(\"quizzical\".\"customer_sk\",\"thoughtful\".\"customer_sk\") as string) || '-') || cast(coalesce(\"quizzical\".\"item_sk\",\"thoughtful\".\"item_sk\") as string)) ELSE NULL END as \"store_present\"
FROM
    \"thoughtful\"
    FULL JOIN \"quizzical\" on \"thoughtful\".\"customer_sk\" is not distinct from \"quizzical\".\"customer_sk\" AND \"thoughtful\".\"item_sk\" = \"quizzical\".\"item_sk\"
    FULL JOIN \"memory\".\"date_dim\" as \"store_sales_date_date\" on \"thoughtful\".\"store_sales_date_sk\" = \"store_sales_date_date\".\"D_DATE_SK\"
    FULL JOIN \"memory\".\"date_dim\" as \"catalog_sales_date_date\" on \"quizzical\".\"catalog_sales_date_sk\" = \"catalog_sales_date_date\".\"D_DATE_SK\"
GROUP BY
    1,
    2,
    coalesce(\"quizzical\".\"customer_sk\",\"thoughtful\".\"customer_sk\"),
    coalesce(\"quizzical\".\"item_sk\",\"thoughtful\".\"item_sk\"))
SELECT
    sum(CASE
	WHEN \"questionable\".\"store_present\" is not null and \"questionable\".\"catalog_present\" is null THEN 1
	ELSE 0
	END) as \"store_sale_count\",
    sum(CASE
	WHEN \"questionable\".\"store_present\" is null and \"questionable\".\"catalog_present\" is not null THEN 1
	ELSE 0
	END) as \"catalog_sale_count\",
    sum(CASE
	WHEN \"questionable\".\"store_present\" is not null and \"questionable\".\"catalog_present\" is not null THEN 1
	ELSE 0
	END) as \"both_sale_count\"
FROM
    \"questionable\""""
