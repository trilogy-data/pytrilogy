generated_sql = """

WITH 
questionable as (
SELECT
    \"catalog_sales_date_date\".\"D_MONTH_SEQ\" as \"catalog_sales_date_month_seq\",
    \"store_sales_date_date\".\"D_MONTH_SEQ\" as \"store_sales_date_month_seq\",
    ((cast(coalesce(\"catalog_sales_catalog_sales\".\"CS_BILL_CUSTOMER_SK\",\"customer_customers\".\"C_CUSTOMER_SK\",\"store_sales_store_sales\".\"SS_CUSTOMER_SK\") as string) || '-') || cast(coalesce(\"catalog_sales_catalog_sales\".\"CS_ITEM_SK\",\"item_items\".\"I_ITEM_SK\",\"store_sales_store_sales\".\"SS_ITEM_SK\") as string)) as \"customer_item\",
    coalesce(\"catalog_sales_catalog_sales\".\"CS_BILL_CUSTOMER_SK\",\"customer_customers\".\"C_CUSTOMER_SK\",\"store_sales_store_sales\".\"SS_CUSTOMER_SK\") as \"customer_sk\",
    coalesce(\"catalog_sales_catalog_sales\".\"CS_ITEM_SK\",\"item_items\".\"I_ITEM_SK\",\"store_sales_store_sales\".\"SS_ITEM_SK\") as \"item_sk\"
FROM
    \"memory\".\"item\" as \"item_items\"
    LEFT OUTER JOIN \"memory\".\"store_sales\" as \"store_sales_store_sales\" on \"item_items\".\"I_ITEM_SK\" = \"store_sales_store_sales\".\"SS_ITEM_SK\"
    FULL JOIN \"memory\".\"catalog_sales\" as \"catalog_sales_catalog_sales\" on \"store_sales_store_sales\".\"SS_CUSTOMER_SK\" is not distinct from \"catalog_sales_catalog_sales\".\"CS_BILL_CUSTOMER_SK\" AND coalesce(\"item_items\".\"I_ITEM_SK\", \"store_sales_store_sales\".\"SS_ITEM_SK\") = \"catalog_sales_catalog_sales\".\"CS_ITEM_SK\"
    FULL JOIN \"memory\".\"customer\" as \"customer_customers\" on coalesce(\"store_sales_store_sales\".\"SS_CUSTOMER_SK\", \"catalog_sales_catalog_sales\".\"CS_BILL_CUSTOMER_SK\") = \"customer_customers\".\"C_CUSTOMER_SK\"
    FULL JOIN \"memory\".\"date_dim\" as \"store_sales_date_date\" on \"store_sales_store_sales\".\"SS_SOLD_DATE_SK\" = \"store_sales_date_date\".\"D_DATE_SK\"
    FULL JOIN \"memory\".\"date_dim\" as \"catalog_sales_date_date\" on \"catalog_sales_catalog_sales\".\"CS_SOLD_DATE_SK\" = \"catalog_sales_date_date\".\"D_DATE_SK\"
GROUP BY
    1,
    2,
    3,
    4,
    5),
abundant as (
SELECT
    CASE WHEN \"questionable\".\"catalog_sales_date_month_seq\" BETWEEN 1200 AND 1200 + 11 THEN \"questionable\".\"customer_item\" ELSE NULL END as \"catalog_sales\",
    CASE WHEN \"questionable\".\"store_sales_date_month_seq\" BETWEEN 1200 AND 1200 + 11 THEN \"questionable\".\"customer_item\" ELSE NULL END as \"store_sales\"
FROM
    \"questionable\"
GROUP BY
    1,
    2,
    \"questionable\".\"customer_sk\",
    \"questionable\".\"item_sk\")
SELECT
    sum(CASE
	WHEN \"abundant\".\"store_sales\" is not null and \"abundant\".\"catalog_sales\" is null THEN 1
	ELSE 0
	END) as \"store_sale_count\",
    sum(CASE
	WHEN \"abundant\".\"store_sales\" is null and \"abundant\".\"catalog_sales\" is not null THEN 1
	ELSE 0
	END) as \"catalog_sale_count\",
    sum(CASE
	WHEN \"abundant\".\"store_sales\" is not null and \"abundant\".\"catalog_sales\" is not null THEN 1
	ELSE 0
	END) as \"both_sale_count\"
FROM
    \"abundant\""""
