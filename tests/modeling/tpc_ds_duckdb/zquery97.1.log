generated_sql = """

WITH 
quizzical as (
SELECT
    \"catalog_sales_catalog_sales\".\"CS_BILL_CUSTOMER_SK\" as \"customer_id\",
    \"catalog_sales_catalog_sales\".\"CS_ITEM_SK\" as \"item_id\",
    \"catalog_sales_catalog_sales\".\"CS_SOLD_DATE_SK\" as \"catalog_sales_date_id\"
FROM
    \"memory\".\"catalog_sales\" as \"catalog_sales_catalog_sales\"
GROUP BY
    1,
    2,
    3),
questionable as (
SELECT
    \"physical_sales_store_sales\".\"SS_CUSTOMER_SK\" as \"customer_id\",
    \"physical_sales_store_sales\".\"SS_ITEM_SK\" as \"item_id\",
    \"physical_sales_store_sales\".\"SS_SOLD_DATE_SK\" as \"physical_sales_date_id\"
FROM
    \"memory\".\"store_sales\" as \"physical_sales_store_sales\"
GROUP BY
    1,
    2,
    3),
uneven as (
SELECT
    \"catalog_sales_date_date\".\"D_MONTH_SEQ\" as \"catalog_sales_date_month_seq\",
    \"physical_sales_date_date\".\"D_MONTH_SEQ\" as \"physical_sales_date_month_seq\",
    ((cast(coalesce(\"customer_customers\".\"C_CUSTOMER_SK\",\"questionable\".\"customer_id\",\"quizzical\".\"customer_id\") as string) || '-') || cast(coalesce(\"item_items\".\"I_ITEM_SK\",\"questionable\".\"item_id\",\"quizzical\".\"item_id\") as string)) as \"customer_item\",
    coalesce(\"customer_customers\".\"C_CUSTOMER_SK\",\"questionable\".\"customer_id\",\"quizzical\".\"customer_id\") as \"customer_id\",
    coalesce(\"item_items\".\"I_ITEM_SK\",\"questionable\".\"item_id\",\"quizzical\".\"item_id\") as \"item_id\"
FROM
    \"quizzical\"
    LEFT OUTER JOIN \"memory\".\"date_dim\" as \"catalog_sales_date_date\" on \"quizzical\".\"catalog_sales_date_id\" = \"catalog_sales_date_date\".\"D_DATE_SK\"
    RIGHT OUTER JOIN \"memory\".\"item\" as \"item_items\" on \"quizzical\".\"item_id\" = \"item_items\".\"I_ITEM_SK\"
    FULL JOIN \"questionable\" on \"quizzical\".\"customer_id\" is not distinct from \"questionable\".\"customer_id\" AND coalesce(\"item_items\".\"I_ITEM_SK\", \"quizzical\".\"item_id\") = \"questionable\".\"item_id\"
    FULL JOIN \"memory\".\"date_dim\" as \"physical_sales_date_date\" on \"questionable\".\"physical_sales_date_id\" = \"physical_sales_date_date\".\"D_DATE_SK\"
    FULL JOIN \"memory\".\"customer\" as \"customer_customers\" on coalesce(\"questionable\".\"customer_id\", \"quizzical\".\"customer_id\") = \"customer_customers\".\"C_CUSTOMER_SK\"
GROUP BY
    1,
    2,
    3,
    4,
    5),
yummy as (
SELECT
    CASE WHEN \"uneven\".\"catalog_sales_date_month_seq\" BETWEEN 1200 AND 1200 + 11 THEN \"uneven\".\"customer_item\" ELSE NULL END as \"catalog_sales\",
    CASE WHEN \"uneven\".\"physical_sales_date_month_seq\" BETWEEN 1200 AND 1200 + 11 THEN \"uneven\".\"customer_item\" ELSE NULL END as \"physical_sales\"
FROM
    \"uneven\"
GROUP BY
    1,
    2,
    \"uneven\".\"customer_id\",
    \"uneven\".\"item_id\")
SELECT
    sum(CASE
	WHEN \"yummy\".\"physical_sales\" is not null and \"yummy\".\"catalog_sales\" is null THEN 1
	ELSE 0
	END) as \"store_sale_count\",
    sum(CASE
	WHEN \"yummy\".\"physical_sales\" is null and \"yummy\".\"catalog_sales\" is not null THEN 1
	ELSE 0
	END) as \"catalog_sale_count\",
    sum(CASE
	WHEN \"yummy\".\"physical_sales\" is not null and \"yummy\".\"catalog_sales\" is not null THEN 1
	ELSE 0
	END) as \"both_sale_count\"
FROM
    \"yummy\""""
