charming as (
SELECT
    \"scrawny\".\"cust_ss_ss_cust_id\" as \"_my_revenue_rev_cust_id\",
    \"scrawny\".\"cust_ss_ss_revenue\" * \"busy\".\"stores_cs_scs_count\" as \"_my_revenue_revenue\"
