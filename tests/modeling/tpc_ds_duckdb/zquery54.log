    cast(round(( \"puzzled\".\"my_revenue_revenue\" ) / 50,0) as int) * 50 as \"segment_base\",
    cast(round(( \"puzzled\".\"my_revenue_revenue\" ) / 50,0) as int) as \"segment\"
