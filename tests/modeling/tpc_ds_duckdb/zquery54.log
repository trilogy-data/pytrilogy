puzzled as (
SELECT
    \"premium\".\"_my_revenue_rev_cust_id\" as \"my_revenue_rev_cust_id\",
    \"premium\".\"_my_revenue_revenue\" as \"my_revenue_revenue\"
FROM
    \"premium\"),
rambunctious as (
SELECT
    \"puzzled\".\"my_revenue_rev_cust_id\" as \"my_revenue_rev_cust_id\"
FROM
    \"puzzled\"
