GROUP BY
    1,
    2,
    3,
    4,
    \"abhorrent\".\"ss_item_id\",
    \"abhorrent\".\"ss_ticket_number\"),
macho as (
SELECT
    \"sweltering\".\"ss_customer_address_county\" as \"ss_customer_address_county\",
    \"sweltering\".\"ss_customer_address_state\" as \"ss_customer_address_state\",
    \"sweltering\".\"ss_customer_id\" as \"ss_customer_id\",
    sum(\"sweltering\".\"ss_ext_sales_price\") as \"_cust_ss_ss_revenue\"
FROM
    \"sweltering\"
GROUP BY
    1,
    2,
    3),
scrawny as (
SELECT
    \"macho\".\"_cust_ss_ss_revenue\" as \"_cust_ss_ss_revenue\",
    \"macho\".\"ss_customer_address_county\" as \"_cust_ss_ss_cust_county\",
    \"macho\".\"ss_customer_address_state\" as \"_cust_ss_ss_cust_state\",
    \"macho\".\"ss_customer_id\" as \"_cust_ss_ss_cust_id\"
FROM
    \"macho\"),
friendly as (
SELECT
    \"scrawny\".\"_cust_ss_ss_cust_county\" as \"cust_ss_ss_cust_county\",
    \"scrawny\".\"_cust_ss_ss_cust_id\" as \"cust_ss_ss_cust_id\",
    \"scrawny\".\"_cust_ss_ss_cust_state\" as \"cust_ss_ss_cust_state\",
    \"scrawny\".\"_cust_ss_ss_revenue\" as \"cust_ss_ss_revenue\"
FROM
    \"scrawny\"),
premium as (
SELECT
    \"friendly\".\"cust_ss_ss_cust_id\" as \"_my_revenue_rev_cust_id\",
    \"friendly\".\"cust_ss_ss_revenue\" * \"protective\".\"stores_cs_scs_count\" as \"_my_revenue_revenue\"
FROM
    \"friendly\"
    INNER JOIN \"protective\" on \"friendly\".\"cust_ss_ss_cust_county\" = \"protective\".\"stores_cs_scs_county\" AND \"friendly\".\"cust_ss_ss_cust_state\" = \"protective\".\"stores_cs_scs_state\"
GROUP BY
    1,
    2),
rambunctious as (
SELECT
    \"premium\".\"_my_revenue_rev_cust_id\" as \"my_revenue_rev_cust_id\",
    \"premium\".\"_my_revenue_revenue\" as \"my_revenue_revenue\"
FROM
    \"premium\"),
hard as (
SELECT
    \"rambunctious\".\"my_revenue_rev_cust_id\" as \"my_revenue_rev_cust_id\"
FROM
    \"rambunctious\"
GROUP BY
    1),
puffy as (
SELECT
    cast(round(( \"rambunctious\".\"my_revenue_revenue\" ) / 50,0) as int) * 50 as \"segment_base\",
    cast(round(( \"rambunctious\".\"my_revenue_revenue\" ) / 50,0) as int) as \"segment\"
FROM
    \"rambunctious\"),
sedate as (
SELECT
    count(\"hard\".\"my_revenue_rev_cust_id\") as \"num_customers\"
FROM
    \"hard\")
SELECT
    \"puffy\".\"segment\" as \"segment\",
    coalesce(\"sedate\".\"num_customers\",0) as \"num_customers\",
    \"puffy\".\"segment_base\" as \"segment_base\"
FROM
    \"sedate\"
    FULL JOIN \"puffy\" on 1=1
ORDER BY 
    \"puffy\".\"segment\" asc nulls first,
    coalesce(\"sedate\".\"num_customers\",0) asc nulls first,
    \"puffy\".\"segment_base\" asc nulls first
LIMIT (100)"""
