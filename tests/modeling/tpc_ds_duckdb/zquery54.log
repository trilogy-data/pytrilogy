    INNER JOIN \"busy\" on \"scrawny\".\"cust_ss_ss_cust_county\" = \"busy\".\"stores_cs_scs_county\" AND \"scrawny\".\"cust_ss_ss_cust_state\" = \"busy\".\"stores_cs_scs_state\"),
premium as (
