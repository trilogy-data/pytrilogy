    lead(\"thoughtful\".\"sum_sales\", 1) over (partition by coalesce(\"sparkling\".\"physical_sales_item_category\",\"thoughtful\".\"physical_sales_item_category\"),coalesce(\"sparkling\".\"physical_sales_item_brand_name\",\"thoughtful\".\"physical_sales_item_brand_name\"),coalesce(\"sparkling\".\"physical_sales_store_name\",\"thoughtful\".\"physical_sales_store_name\"),coalesce(\"sparkling\".\"physical_sales_store_company_name\",\"thoughtful\".\"physical_sales_store_company_name\") order by coalesce(\"sparkling\".\"physical_sales_date_year\",\"thoughtful\".\"physical_sales_date_year\") asc,\"thoughtful\".\"physical_sales_date_month_of_year\" asc ) as \"nsum\"
