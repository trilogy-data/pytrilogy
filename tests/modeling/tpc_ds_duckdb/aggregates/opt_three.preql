const _trilogyt._created_at <- current_datetime();

import ..physical_sales as physical_sales;

# WHERE
#     physical_sales.date.month_of_year = 11 and physical_sales.item.manufacturer_id = 128
# SELECT
#     physical_sales.date.year,
#     physical_sales.item.brand_id,
#     physical_sales.item.brand_name,
#     sum(physical_sales.ext_sales_price) -> sum_agg,
# ORDER BY
#     physical_sales.date.year asc,
#     sum_agg desc,
#     physical_sales.item.brand_id asc
# LIMIT 100
# ;
auto sum_agg <- sum(physical_sales.ext_sales_price)
    by physical_sales.date.year, physical_sales.item.brand_id, physical_sales.item.brand_name;

partial datasource dsstore_sales_date_month_of_year_store_sales_date_year_store_sales_item_id_store_sales_ticket_number_7c04f90c_filtered_on_month_of_year_manufacturer_id (
    store_sales_date_month_of_year: physical_sales.date.month_of_year,
    store_sales_date_year: physical_sales.date.year,
    store_sales_ext_sales_price: physical_sales.ext_sales_price,
    store_sales_item_brand_id: physical_sales.item.brand_id,
    store_sales_item_brand_name: physical_sales.item.brand_name,
    store_sales_item_id: physical_sales.item.id,
    store_sales_item_manufacturer_id: physical_sales.item.manufacturer_id,
    store_sales_ticket_number: physical_sales.ticket_number,
)

complete where physical_sales.date.month_of_year = 11 and physical_sales.item.manufacturer_id = 128
address dsstore_sales_date_month_of_year_store_sales_date_year_store_sales_item_id_store_sales_ticket_number_7c04f90c_filtered_on_month_of_year_manufacturer_id;

