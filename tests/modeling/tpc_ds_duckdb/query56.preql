import all_sales as sales;

auto color_ids <- sales.item.id ? sales.item.color in ('slate', 'blanched', 'burnished');

where
    sales.item.id in color_ids
    and sales.date.year = 2001
    and sales.date.month_of_year = 2
    and sales.bill_address.gmt_offset = -5
select
    sales.item.id,
    sum(sales.ext_sales_price) as total_sales,
order by
    total_sales asc nulls first,
    sales.item.id asc nulls first
limit 100
;
