import unified_sales as sales;

const first_year <- 2001;
const second_year <- 2002;

def channel_year_total(channel, year) -> sum(filter sales.net_paid where sales.sales_channel = channel and sales.date.year = year) by sales.customer.id;

metric store_first_year <- sum(filter sales.net_paid where sales.sales_channel = 'STORE' and sales.date.year = first_year) by sales.customer.id;
metric web_first_year <- sum(filter sales.net_paid where sales.sales_channel = 'WEB' and sales.date.year = first_year) by sales.customer.id;
metric store_second_year <- sum(filter sales.net_paid where sales.sales_channel = 'STORE' and sales.date.year = second_year) by sales.customer.id;
metric web_second_year <- sum(filter sales.net_paid where sales.sales_channel = 'WEB' and sales.date.year = second_year) by sales.customer.id;

WHERE
    sales.sales_channel in ('STORE', 'WEB')
    and sales.customer.id is not null
    and store_first_year > 0
    and web_first_year > 0
    and (CASE
            WHEN web_first_year > 0 THEN web_second_year / web_first_year
            ELSE null
        END) > (CASE
            WHEN store_first_year > 0 THEN store_second_year / store_first_year
            ELSE null
        END)
SELECT
    sales.customer.text_id -> customer_id,
    sales.customer.first_name -> customer_first_name,
    sales.customer.last_name -> customer_last_name,
ORDER BY
    customer_id asc nulls first
LIMIT 100
;
