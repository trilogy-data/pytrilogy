import std.date;
import std.geography;

# Customer dimension (TPC-DS customer): names, contact info, birth/age
# attributes, plus links to demographics, household_demographic, address,
# and first-sales/first-shipto date dimensions.

import customer_demographic as demographics;
import household_demographic as household_demographic;
import address as address;
import date as first_sales_date;
import date as first_shipto_date;

key id int; # Surrogate key uniquely identifying a customer.
unique property id.text_id string; # Stable natural/business customer ID (16-char alphanumeric in TPC-DS).

properties id (
    last_name string, # Customer last (family) name. Not guaranteed unique; weak for identity.
    first_name string, # Customer first (given) name. Display only; low analytical value alone.
    preferred_cust_flag enum<string>['Y', 'N'], # 'Y' if the customer is flagged as a preferred/loyalty customer, else 'N'.
    birth_day int::day, # Day-of-month of birth (1-31; combine with month/year for full DOB).
    birth_month int::month, # Month of birth (1-12).
    birth_year int::year, # Four-digit year of birth (1924-1992 in this dataset).
    birth_country string::country, # Country of birth (free-form name, e.g. 'UNITED STATES').
    salutation enum<string>['Dr.', 'Miss', 'Mr.', 'Mrs.', 'Ms.', 'Sir'], # Title/salutation prefix.
    email_address string, # Customer email address (quasi-unique but not a key; can change over time).
    login string, # Account username/login (more stable than email).
    last_review_date string, # FK to date dimension for customer's last review (stored as string; should be cast to date).
);

auto full_name <- concat(salutation, ' ', first_name, ' ', last_name); # Derived display name: 'Salutation First Last'.
auto birth_date <- concat(birth_year::string, '/', birth_month::string, '/', birth_day::string)::date; # Derived calendar birth date assembled from year/month/day components.

datasource customers (
    C_CUSTOMER_SK: id,
    C_CUSTOMER_ID: text_id,
    C_LAST_NAME: last_name,
    C_FIRST_NAME: first_name,
    C_CURRENT_ADDR_SK: address.id,
    C_CURRENT_CDEMO_SK: ?demographics.id,
    C_CURRENT_HDEMO_SK: ?household_demographic.id,
    C_FIRST_SALES_DATE_SK: ?first_sales_date.id,
    C_FIRST_SHIPTO_DATE_SK: ?first_shipto_date.id,
    C_PREFERRED_CUST_FLAG: preferred_cust_flag,
    C_BIRTH_COUNTRY: birth_country,
    C_SALUTATION: salutation,
    C_EMAIL_ADDRESS: email_address,
    C_BIRTH_DAY: birth_day,
    C_BIRTH_MONTH: birth_month,
    C_BIRTH_YEAR: birth_year,
    C_LOGIN: login,
    C_LAST_REVIEW_DATE_SK: last_review_date,
)
grain (id)
address memory.customer;
