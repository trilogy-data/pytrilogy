# Customer info: names, salutation, login, email, preferred-customer
# flag, country of birth, and decomposed birth date (year / month / day).

import std.date;
import std.geography;

import customer_demographic as current_demographics; # the customer's current customer-demographic record (C_CURRENT_CDEMO_SK)
import household_demographic as current_household_demographics; # the customer's current household-demographic record (C_CURRENT_HDEMO_SK)
import address as current_address; # the customer's current address record (C_CURRENT_ADDR_SK)
import date as first_sales_date;
import date as first_shipto_date;

key sk int; # Surrogate key uniquely identifying a customer.
unique property sk.id string; # Stable natural/business customer ID (16-char alphanumeric) Unique for customers..

properties sk (
    last_name string?, # Customer last (family) name. Not guaranteed unique; weak for identity.
    first_name string?, # Customer first (given) name..
    preferred_cust_flag enum<string>['Y', 'N']?,
    birth_day int::day?, # Day-of-month of birth (1-31; combine with month/year for full DOB).
    birth_month int::month?, # Month of birth (1-12).
    birth_year int::year?, # Four-digit year of birth (1924-1992 in this dataset).
    birth_country string::country?, # Country of birth (free-form name, e.g. 'UNITED STATES').
    salutation enum<string>['Dr.', 'Miss', 'Mr.', 'Mrs.', 'Ms.', 'Sir']?, # Title/salutation prefix.
    email_address string?, # Customer email address.
    login string?, # Account username/login.
    last_review_date string?, # FK to date for customer's last review.
);

auto full_name <- concat(salutation, ' ', first_name, ' ', last_name); # Derived display name: 'Salutation First Last'.
auto birth_date <- (birth_year::string || '/' || birth_month::string || '/' || birth_day::string)::date; # Derived calendar birth date; || so any NULL component yields a NULL date (concat() skips NULLs and would produce an uncastable string).

datasource customers (
    C_CUSTOMER_SK: sk,
    C_CUSTOMER_ID: id,
    C_LAST_NAME: last_name,
    C_FIRST_NAME: first_name,
    C_CURRENT_ADDR_SK: current_address.sk,
    C_CURRENT_CDEMO_SK: ?current_demographics.sk,
    C_CURRENT_HDEMO_SK: ?current_household_demographics.sk,
    C_FIRST_SALES_DATE_SK: ?first_sales_date.sk,
    C_FIRST_SHIPTO_DATE_SK: ?first_shipto_date.sk,
    C_PREFERRED_CUST_FLAG: preferred_cust_flag,
    C_BIRTH_COUNTRY: birth_country,
    C_SALUTATION: salutation,
    C_EMAIL_ADDRESS: email_address,
    C_BIRTH_DAY: birth_day,
    C_BIRTH_MONTH: birth_month,
    C_BIRTH_YEAR: birth_year,
    C_LOGIN: login,
    C_LAST_REVIEW_DATE_SK: last_review_date,
)
grain (sk)
address memory.customer;
