import catalog_sales as catalog_sales;

metric sum_sales <- sum(catalog_sales.sales_price)
    by catalog_sales.item.category, catalog_sales.item.brand_name, catalog_sales.call_center.name, catalog_sales.date.year, catalog_sales.date.month_of_year;
metric avg_monthly_sales <- avg(sum_sales)
    by catalog_sales.item.category, catalog_sales.item.brand_name, catalog_sales.call_center.name, catalog_sales.date.year;
property <catalog_sales.call_center.name, catalog_sales.date.month_of_year, catalog_sales.date.year, catalog_sales.item.brand_name, catalog_sales.item.category>.psum <- lag(sum_sales,1) over (partition by catalog_sales.item.category,catalog_sales.item.brand_name,catalog_sales.call_center.name order by catalog_sales.date.year asc,catalog_sales.date.month_of_year asc);
property <catalog_sales.call_center.name, catalog_sales.date.month_of_year, catalog_sales.date.year, catalog_sales.item.brand_name, catalog_sales.item.category>.nsum <- lead(sum_sales,1) over (partition by catalog_sales.item.category,catalog_sales.item.brand_name,catalog_sales.call_center.name order by catalog_sales.date.year asc,catalog_sales.date.month_of_year asc);
property <catalog_sales.call_center.name, catalog_sales.date.month_of_year, catalog_sales.date.year, catalog_sales.item.brand_name, catalog_sales.item.category>.sum_minus_avg <- sum_sales - avg_monthly_sales;

WHERE
    catalog_sales.call_center.id is not null
    and (
        catalog_sales.date.year = 1999
        or (catalog_sales.date.year = 1998 and catalog_sales.date.month_of_year = 12)
        or (catalog_sales.date.year = 2000 and catalog_sales.date.month_of_year = 1)
    )
SELECT
    catalog_sales.item.category,
    catalog_sales.item.brand_name,
    catalog_sales.call_center.name,
    catalog_sales.date.year,
    catalog_sales.date.month_of_year,
    avg_monthly_sales,
    sum_sales,
    psum,
    nsum,
    --sum_minus_avg,
HAVING
    catalog_sales.date.year = 1999
    and avg_monthly_sales > 0
    and CASE
            WHEN avg_monthly_sales > 0 THEN abs(sum_sales - avg_monthly_sales) / avg_monthly_sales
            ELSE null
        END > 0.1

ORDER BY
    sum_minus_avg asc nulls first,
    catalog_sales.item.category asc,
    catalog_sales.item.brand_name asc,
    catalog_sales.call_center.name asc,
    catalog_sales.date.year asc,
    catalog_sales.date.month_of_year asc,
    avg_monthly_sales asc,
    sum_sales asc,
    psum asc,
    nsum asc
LIMIT 100
;
