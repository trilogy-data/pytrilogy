import store_sales as store_sales;

# Bundle item_revenue + all enrichment dim columns into a single GROUP BY,
# so trilogy emits one filtered store_sales scan instead of three (the
# reference SQL `sa` CTE does the same).
with store_item_revenue as
WHERE
    store_sales.date.month_seq between 1176 and 1187
    and store_sales.store.id is not null
SELECT
    store_sales.store.id,
    store_sales.store.name,
    store_sales.item.id,
    store_sales.item.desc,
    store_sales.item.current_price,
    store_sales.item.wholesale_cost,
    store_sales.item.brand_name,
    sum(store_sales.sales_price) as item_revenue,
;

auto store_avg_revenue <- avg(store_item_revenue.item_revenue) by store_item_revenue.store_sales.store.id;

WHERE
    store_item_revenue.item_revenue <= 0.1 * store_avg_revenue
SELECT
    store_item_revenue.store_sales.store.name,
    store_item_revenue.store_sales.item.desc,
    store_item_revenue.item_revenue as revenue,
    store_item_revenue.store_sales.item.current_price,
    store_item_revenue.store_sales.item.wholesale_cost,
    store_item_revenue.store_sales.item.brand_name,
ORDER BY
    store_item_revenue.store_sales.store.name asc nulls first,
    store_item_revenue.store_sales.item.desc asc nulls first
LIMIT 100;
