
key id int;
properties id (
    date_string string,
    _date_string string,
    date date,
    _year_string string,
    year int,
    day_of_week int,
    week_seq int,
    month_of_year int,
    quarter int,
    d_week_seq1 int,
    month_seq int,
);


datasource date (
    D_DATE_SK: id,
    D_DATE_ID: date_string,
    D_DATE: _date_string,
    cast(_date_string as date): date,
    D_DOW: day_of_week,
    D_WEEK_SEQ: week_seq,
    D_MOY: month_of_year,
    D_MONTH_SEQ: month_seq,
    D_QOY: quarter,
    D_YEAR: _year_string,
    cast(_year_string as int): year
)
grain (id)
address memory.date_dim;
