# Generate counts of promotional sales and total sales, and their ratio from the web channel for a particular item
#category and month to customers in a given time zone
import physical_sales as physical_sales;
import catalog_sales as catalog_sales;
import customer as customer;
import item as item;

auto customer_item <- concat(concat(customer.id::string, '-'), item.id::string);
auto catalog_sales <- customer_item ? catalog_sales.date.month_seq between 1200 and 1200 + 11;
auto physical_sales <- customer_item ? physical_sales.date.month_seq between 1200 and 1200 + 11;

left join physical_sales.customer.id = customer.id
left join physical_sales.item.id = item.id
left join catalog_sales.bill_customer.id = customer.id
left join catalog_sales.item.id = item.id
select
    sum(
            case
                when physical_sales is not null and catalog_sales is null then 1
                else 0
            end
        ) as store_sale_count,
    sum(
            case
                when physical_sales is null and catalog_sales is not null then 1
                else 0
            end
        ) as catalog_sale_count,
    sum(
            case
                when physical_sales is not null and catalog_sales is not null then 1
                else 0
            end
        ) as both_sale_count,
;
