# Generate counts of promotional sales and total sales, and their ratio from the web channel for a particular item
#category and month to customers in a given time zone
import store_sales as store_sales;
import catalog_sales as catalog_sales;
import customer as customer;
import item as item;

MERGE store_sales.customer.id into ~customer.id;
MERGE store_sales.item.id into ~item.id;
MERGE catalog_sales.bill_customer.id into ~customer.id;
MERGE catalog_sales.item.id into ~item.id;

property <customer.id, item.id>.customer_item <- concat(concat(customer.id::string, '-'), item.id::string);
property <customer.id, item.id>.catalog_sales <- customer_item ? catalog_sales.date.month_seq between 1200 and 1200 + 11;
property <customer.id, item.id>.store_sales <- customer_item ? store_sales.date.month_seq between 1200 and 1200 + 11;

SELECT
    sum(
            CASE
            WHEN store_sales is not null and catalog_sales is null THEN 1
            ELSE 0
        END
        ) as store_sale_count,
    sum(
            CASE
            WHEN store_sales is null and catalog_sales is not null THEN 1
            ELSE 0
        END
        ) as catalog_sale_count,
    sum(
            CASE
            WHEN store_sales is not null and catalog_sales is not null THEN 1
            ELSE 0
        END
        ) as both_sale_count,
;
