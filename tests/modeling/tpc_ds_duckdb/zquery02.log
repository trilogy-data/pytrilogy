    sum(CASE WHEN \"sales_date_date\".\"D_DOW\" = 0 THEN \"abundant\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_5898269946212687\",
    sum(CASE WHEN \"sales_date_date\".\"D_DOW\" = 1 THEN \"abundant\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_1215995592885356\",
    sum(CASE WHEN \"sales_date_date\".\"D_DOW\" = 2 THEN \"abundant\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_5503961012463124\",
    sum(CASE WHEN \"sales_date_date\".\"D_DOW\" = 3 THEN \"abundant\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_6232287870778562\",
    sum(CASE WHEN \"sales_date_date\".\"D_DOW\" = 4 THEN \"abundant\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_3226984322777641\",
    sum(CASE WHEN \"sales_date_date\".\"D_DOW\" = 5 THEN \"abundant\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_1755492547499297\",
    sum(CASE WHEN \"sales_date_date\".\"D_DOW\" = 6 THEN \"abundant\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_3160525683686265\"
FROM
    \"abundant\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"abundant\".\"sales_date_id\" = \"sales_date_date\".\"D_DATE_SK\"
    LEFT OUTER JOIN \"cheerful\" on \"abundant\".\"sales_item_id\" = \"cheerful\".\"sales_item_id\" AND \"abundant\".\"sales_order_id\" = \"cheerful\".\"sales_order_id\" AND \"abundant\".\"sales_sales_channel\" = \"cheerful\".\"sales_sales_channel\"
WHERE
    \"abundant\".\"sales_sales_channel\" in ('WEB','CATALOG') and \"sales_date_date\".\"D_WEEK_SEQ\" in (select yummy.\"relevent_week_seq\" from yummy where yummy.\"relevent_week_seq\" is not null)

GROUP BY
    1),
sparkling as (
