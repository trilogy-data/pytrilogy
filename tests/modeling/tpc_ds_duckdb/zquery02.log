    round(\"sparkling\".\"_virt_agg_sum_1755492547499297\" / (\"sparkling\".\"_virt_window_lead_1513977696668684\"),2) as \"friday_increase\",
    round(\"sparkling\".\"_virt_agg_sum_3160525683686265\" / (\"sparkling\".\"_virt_window_lead_6726398054446491\"),2) as \"saturday_increase\"
