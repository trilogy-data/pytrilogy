generated_sql = """

WITH 
cooperative as (
SELECT
    \"sales_sale_date_date\".\"D_WEEK_SEQ\" as \"relevent_week_seq\"
FROM
    \"memory\".\"date_dim\" as \"sales_sale_date_date\"
WHERE
    (\"sales_sale_date_date\".\"D_YEAR\" is not null and \"sales_sale_date_date\".\"D_YEAR\" in (2001,2002))

GROUP BY
    1),
cheerful as (
SELECT
     'CATALOG'  as \"sales_channel\",
    \"sales_catalog_sales_unified\".\"CS_EXT_SALES_PRICE\" as \"sales_ext_sales_price\",
    \"sales_catalog_sales_unified\".\"CS_SOLD_DATE_SK\" as \"sales_sale_date_sk\"
FROM
    \"memory\".\"catalog_sales\" as \"sales_catalog_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_sale_date_date\" on \"sales_catalog_sales_unified\".\"CS_SOLD_DATE_SK\" = \"sales_sale_date_date\".\"D_DATE_SK\"
WHERE
    exists (select 1 from cooperative where cooperative.\"relevent_week_seq\" is not distinct from \"sales_sale_date_date\".\"D_WEEK_SEQ\")

UNION ALL
SELECT
     'WEB'  as \"sales_channel\",
    \"sales_web_sales_unified\".\"WS_EXT_SALES_PRICE\" as \"sales_ext_sales_price\",
    \"sales_web_sales_unified\".\"WS_SOLD_DATE_SK\" as \"sales_sale_date_sk\"
FROM
    \"memory\".\"web_sales\" as \"sales_web_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_sale_date_date\" on \"sales_web_sales_unified\".\"WS_SOLD_DATE_SK\" = \"sales_sale_date_date\".\"D_DATE_SK\"
WHERE
    exists (select 1 from cooperative where cooperative.\"relevent_week_seq\" is not distinct from \"sales_sale_date_date\".\"D_WEEK_SEQ\")
),
abundant as (
SELECT
    \"sales_sale_date_date\".\"D_WEEK_SEQ\" as \"sales_sale_date_week_seq\",
    sum(CASE WHEN \"sales_sale_date_date\".\"D_DOW\" = 0 THEN \"cheerful\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_9819218140412840\",
    sum(CASE WHEN \"sales_sale_date_date\".\"D_DOW\" = 1 THEN \"cheerful\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_6178901442700580\",
    sum(CASE WHEN \"sales_sale_date_date\".\"D_DOW\" = 2 THEN \"cheerful\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_2147862938205875\",
    sum(CASE WHEN \"sales_sale_date_date\".\"D_DOW\" = 3 THEN \"cheerful\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_7660402966670123\",
    sum(CASE WHEN \"sales_sale_date_date\".\"D_DOW\" = 4 THEN \"cheerful\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_4848039152713969\",
    sum(CASE WHEN \"sales_sale_date_date\".\"D_DOW\" = 5 THEN \"cheerful\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_8018526525264939\",
    sum(CASE WHEN \"sales_sale_date_date\".\"D_DOW\" = 6 THEN \"cheerful\".\"sales_ext_sales_price\" ELSE NULL END) as \"_virt_agg_sum_3940035664520405\"
FROM
    \"cheerful\"
    LEFT OUTER JOIN \"memory\".\"date_dim\" as \"sales_sale_date_date\" on \"cheerful\".\"sales_sale_date_sk\" = \"sales_sale_date_date\".\"D_DATE_SK\"
WHERE
    (\"cheerful\".\"sales_channel\" is not null and \"cheerful\".\"sales_channel\" in ('WEB','CATALOG'))

GROUP BY
    1),
juicy as (
SELECT
    \"abundant\".\"sales_sale_date_week_seq\" as \"sales_sale_date_week_seq\",
    round(\"abundant\".\"_virt_agg_sum_2147862938205875\" / (lead(\"abundant\".\"_virt_agg_sum_2147862938205875\", 53) over (order by \"abundant\".\"sales_sale_date_week_seq\" asc )),2) as \"tuesday_increase\",
    round(\"abundant\".\"_virt_agg_sum_3940035664520405\" / (lead(\"abundant\".\"_virt_agg_sum_3940035664520405\", 53) over (order by \"abundant\".\"sales_sale_date_week_seq\" asc )),2) as \"saturday_increase\",
    round(\"abundant\".\"_virt_agg_sum_4848039152713969\" / (lead(\"abundant\".\"_virt_agg_sum_4848039152713969\", 53) over (order by \"abundant\".\"sales_sale_date_week_seq\" asc )),2) as \"thursday_increase\",
    round(\"abundant\".\"_virt_agg_sum_6178901442700580\" / (lead(\"abundant\".\"_virt_agg_sum_6178901442700580\", 53) over (order by \"abundant\".\"sales_sale_date_week_seq\" asc )),2) as \"monday_increase\",
    round(\"abundant\".\"_virt_agg_sum_7660402966670123\" / (lead(\"abundant\".\"_virt_agg_sum_7660402966670123\", 53) over (order by \"abundant\".\"sales_sale_date_week_seq\" asc )),2) as \"wednesday_increase\",
    round(\"abundant\".\"_virt_agg_sum_8018526525264939\" / (lead(\"abundant\".\"_virt_agg_sum_8018526525264939\", 53) over (order by \"abundant\".\"sales_sale_date_week_seq\" asc )),2) as \"friday_increase\",
    round(\"abundant\".\"_virt_agg_sum_9819218140412840\" / (lead(\"abundant\".\"_virt_agg_sum_9819218140412840\", 53) over (order by \"abundant\".\"sales_sale_date_week_seq\" asc )),2) as \"sunday_increase\"
FROM
    \"abundant\")
SELECT
    \"juicy\".\"sales_sale_date_week_seq\" as \"sales_sale_date_week_seq\",
    \"juicy\".\"sunday_increase\" as \"sunday_increase\",
    \"juicy\".\"monday_increase\" as \"monday_increase\",
    \"juicy\".\"tuesday_increase\" as \"tuesday_increase\",
    \"juicy\".\"wednesday_increase\" as \"wednesday_increase\",
    \"juicy\".\"thursday_increase\" as \"thursday_increase\",
    \"juicy\".\"friday_increase\" as \"friday_increase\",
    \"juicy\".\"saturday_increase\" as \"saturday_increase\"
