    round(\"sparkling\".\"_virt_agg_sum_5898269946212687\" / (\"sparkling\".\"_virt_window_lead_3355739386573542\"),2) as \"sunday_increase\",
    round(\"sparkling\".\"_virt_agg_sum_1215995592885356\" / (\"sparkling\".\"_virt_window_lead_8434916643189094\"),2) as \"monday_increase\",
    round(\"sparkling\".\"_virt_agg_sum_5503961012463124\" / (\"sparkling\".\"_virt_window_lead_5402686874923245\"),2) as \"tuesday_increase\",
    round(\"sparkling\".\"_virt_agg_sum_6232287870778562\" / (\"sparkling\".\"_virt_window_lead_8846802885933861\"),2) as \"wednesday_increase\",
