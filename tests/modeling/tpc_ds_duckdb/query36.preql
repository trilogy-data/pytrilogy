import store_sales as ss;

rowset q36_rolled <- WHERE
    ss.date.year = 2001 and ss.store.state = 'TN'
SELECT
    --sum(ss.net_profit) by rollup ss.item.category, ss.item.class -> profit_sum,
    --sum(ss.ext_sales_price) by rollup ss.item.category, ss.item.class -> sales_sum,
    --grouping(ss.item.category) by rollup ss.item.category, ss.item.class -> g_cat,
    --grouping(ss.item.class) by rollup ss.item.category, ss.item.class -> g_class,
    profit_sum::Numeric(15,4) / sales_sum::Numeric(15,4) -> gross_margin,
    g_cat + g_class -> lochierarchy,
    CASE
            WHEN g_class = 0 THEN ss.item.category
            ELSE null
        END -> partition_cat,
    ss.item.category -> r_category,
    ss.item.class -> r_class,
;

SELECT
    q36_rolled.gross_margin,
    q36_rolled.r_category -> i_category,
    q36_rolled.r_class -> i_class,
    q36_rolled.lochierarchy,
    rank(q36_rolled.r_class,q36_rolled.r_category) over (partition by q36_rolled.lochierarchy,q36_rolled.partition_cat order by q36_rolled.gross_margin asc) -> rank_within_parent,
ORDER BY
    q36_rolled.lochierarchy desc nulls first,
    CASE
            WHEN q36_rolled.lochierarchy = 0 THEN i_category
            ELSE null
        END asc nulls first,
    rank_within_parent asc nulls first
LIMIT 100
;
