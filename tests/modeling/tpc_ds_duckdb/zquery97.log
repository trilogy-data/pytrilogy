generated_sql = """

WITH 
cheerful as (
SELECT
    \"sales_catalog_sales_unified\".\"CS_BILL_CUSTOMER_SK\" as \"sales_billing_customer_sk\",
     'CATALOG'  as \"sales_channel\",
    \"sales_catalog_sales_unified\".\"CS_ITEM_SK\" as \"sales_item_sk\",
    \"sales_catalog_sales_unified\".\"CS_ORDER_NUMBER\" as \"sales_order_id\"
FROM
    \"memory\".\"catalog_sales\" as \"sales_catalog_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_sale_date_date\" on \"sales_catalog_sales_unified\".\"CS_SOLD_DATE_SK\" = \"sales_sale_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_catalog_sales_unified\".\"CS_BILL_CUSTOMER_SK\" is not null and \"sales_catalog_sales_unified\".\"CS_ITEM_SK\" is not null and \"sales_sale_date_date\".\"D_MONTH_SEQ\" BETWEEN 1200 AND 1200 + 11

UNION ALL
SELECT
    \"sales_store_sales_unified\".\"SS_CUSTOMER_SK\" as \"sales_billing_customer_sk\",
     'STORE'  as \"sales_channel\",
    \"sales_store_sales_unified\".\"SS_ITEM_SK\" as \"sales_item_sk\",
    \"sales_store_sales_unified\".\"SS_TICKET_NUMBER\" as \"sales_order_id\"
FROM
    \"memory\".\"store_sales\" as \"sales_store_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_sale_date_date\" on \"sales_store_sales_unified\".\"SS_SOLD_DATE_SK\" = \"sales_sale_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_store_sales_unified\".\"SS_CUSTOMER_SK\" is not null and \"sales_store_sales_unified\".\"SS_ITEM_SK\" is not null and \"sales_sale_date_date\".\"D_MONTH_SEQ\" BETWEEN 1200 AND 1200 + 11
),
cooperative as (
SELECT
    max(CASE
	WHEN \"cheerful\".\"sales_channel\" = 'CATALOG' THEN \"cheerful\".\"sales_order_id\"
	ELSE 0
	END) as \"_pair_presence_catalog_present\",
    max(CASE
	WHEN \"cheerful\".\"sales_channel\" = 'STORE' THEN \"cheerful\".\"sales_order_id\"
	ELSE 0
	END) as \"_pair_presence_store_present\"
FROM
    \"cheerful\"
GROUP BY
    \"cheerful\".\"sales_billing_customer_sk\",
    \"cheerful\".\"sales_item_sk\"),
abundant as (
SELECT
    \"cooperative\".\"_pair_presence_catalog_present\" as \"pair_presence_catalog_present\",
    \"cooperative\".\"_pair_presence_store_present\" as \"pair_presence_store_present\"
FROM
    \"cooperative\")
SELECT
    sum(CASE
	WHEN \"abundant\".\"pair_presence_store_present\" >= 1 and \"abundant\".\"pair_presence_catalog_present\" = 0 THEN 1
	ELSE 0
	END) as \"store_sale_count\",
    sum(CASE
	WHEN \"abundant\".\"pair_presence_store_present\" = 0 and \"abundant\".\"pair_presence_catalog_present\" >= 1 THEN 1
	ELSE 0
	END) as \"catalog_sale_count\",
    sum(CASE
	WHEN \"abundant\".\"pair_presence_store_present\" >= 1 and \"abundant\".\"pair_presence_catalog_present\" >= 1 THEN 1
	ELSE 0
	END) as \"both_sale_count\"
FROM
    \"abundant\""""
