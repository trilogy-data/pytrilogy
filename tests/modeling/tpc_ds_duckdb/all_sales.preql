# Use as default for multi-channel analysis (WEB / CATALOG / STORE) or 
# an two channel combination. Carries sales and
# return information in a consolidated format. Channel specific fields 
# and data exist on peer models
# (`store_sales`, `catalog_sales`, `web_sales`) for single-channel-only queries.

import item as item;
import date as date;
import date as return_date;
import time as time;
import customer as billing_customer;
import customer as ship_customer;
import customer as purchasing_customer;
import promotion as promotion;
import address as bill_address;
import warehouse as warehouse;
import ship_mode as ship_mode;

key channel enum<string>['WEB', 'CATALOG', 'STORE']; # the channel for the sale/return: WEB, CATALOG, or STORE
key channel_dim_id int; # the ID of the store/web/site for each order (web_site_id, catalog_id, or store_id as appropriate)
key return_channel_dim_id int; # the ID of the store/web/site used for the return; Unrelated to channel_id

key outlet_id int; # the channel's selling-outlet surrogate id, per channel: store (STORE), call cent for (CATALOG), web_page (WEB). Distinct from channel_dim_id (which is store/web_site/catalog_page).
key order_id int; # the ID of the order (ticket number for store, order number for web/catalog)

# return identifier
properties channel_dim_id (
    channel_dim_text_id string,
);
properties return_channel_dim_id (
    return_channel_dim_text_id string,
);
# Line-grain facts. Sales measures come from the per-channel *sales* datasources;
# the return measures (return_*, is_returned) come from the separate per-channel
# *returns* datasources, unified onto the same (order_id, channel, item.id) grain.
# A row can carry sales facts, return facts, or both.
properties <order_id, channel, item.id> (
    quantity int?, # Units of the item on this sales line.
    sales_price float?, # Per-unit "unit price" charged for ONE unit; the whole-line total is ext_sales_price (the "total price").
    list_price float?, # Per-unit list price before discounts.
    wholesale_cost float?, # Per-unit wholesale acquisition cost.
    ext_sales_price float?, # Whole-line "total price" = sales_price x quantity (the extended line amount); the per-unit price is sales_price.
    ext_wholesale_cost float?, # Line-extended wholesale cost.
    ext_list_price float?, # Line-extended list price.
    ext_discount_amount float?, # Extended (line-level) discount amount applied to the line.
    coupon_amt float?, # Coupon/credit amount applied to the line.
    net_profit float?, # Net profit reported for the line.
    net_paid float?, # Net amount paid for the line, excluding tax/shipping.
    net_paid_inc_tax float?, # Net amount paid including sales tax.
    # --- return measures: sourced from the *returns* datasources below, not the sales ones ---
    return_amount float?, # Amount refunded for the line, if returned.
    return_quantity int?, # Units returned on the line. GOTCHA: NULL even when a return exists (is_returned=true) for some TPC-DS rows. Presence is independent of this measure — don't coalesce to 0 unless asked (the reference keeps the NULL through its derived percentages/averages).
    return_net_loss float?, # Net financial loss on the return for the line.
    is_returned bool?, # Marks a returned line. Sourced only as raw true from the returns datasources, so it is true-or-NULL here (no explicit false): test "not returned" as `is_returned is null`, not `= false`.
    sale_line_item_counter int?, # counter of sales rows (NOT return-only rows). Use is_returned for return presence; `sale_line_item_counter ? is_returned` counts lines with BOTH a sale and a return.
);

partial datasource web_sales_unified (
    raw(''' 'WEB' '''): channel,
    WS_ORDER_NUMBER: order_id,
    WS_ITEM_SK: item.id,
    WS_SOLD_DATE_SK: ?date.id,
    WS_SOLD_TIME_SK: ?time.id,
    WS_BILL_CUSTOMER_SK: ?billing_customer.id,
    WS_BILL_CUSTOMER_SK: ?purchasing_customer.id,
    WS_SHIP_CUSTOMER_SK: ?ship_customer.id,
    WS_BILL_ADDR_SK: ?bill_address.id,
    WS_PROMO_SK: ?promotion.id,
    WS_WEB_SITE_SK: ?channel_dim_id,
    WS_WEB_SITE_SK: ?return_channel_dim_id,
    WS_WEB_PAGE_SK: ?outlet_id,
    WS_WAREHOUSE_SK: ?warehouse.id,
    WS_SHIP_MODE_SK: ?ship_mode.id,
    WS_QUANTITY: quantity,
    WS_SALES_PRICE: sales_price,
    WS_LIST_PRICE: list_price,
    WS_WHOLESALE_COST: wholesale_cost,
    WS_EXT_SALES_PRICE: ext_sales_price,
    WS_EXT_WHOLESALE_COST: ext_wholesale_cost,
    WS_EXT_LIST_PRICE: ext_list_price,
    WS_EXT_DISCOUNT_AMT: ext_discount_amount,
    WS_COUPON_AMT: coupon_amt,
    WS_NET_PROFIT: net_profit,
    WS_NET_PAID: net_paid,
    WS_NET_PAID_INC_TAX: net_paid_inc_tax,
    raw(''' 1 '''): sale_line_item_counter,
)
grain (item.id, order_id, channel)
complete where channel = 'WEB'
address memory.web_sales;

partial datasource catalog_sales_unified (
    raw(''' 'CATALOG' '''): channel,
    CS_ORDER_NUMBER: order_id,
    CS_ITEM_SK: item.id,
    CS_SOLD_DATE_SK: ?date.id,
    CS_SOLD_TIME_SK: ?time.id,
    CS_BILL_CUSTOMER_SK: ?billing_customer.id,
    CS_SHIP_CUSTOMER_SK: ?ship_customer.id,
    CS_SHIP_CUSTOMER_SK: ?purchasing_customer.id,
    CS_BILL_ADDR_SK: ?bill_address.id,
    CS_PROMO_SK: ?promotion.id,
    CS_CATALOG_PAGE_SK: ?channel_dim_id,
    CS_CALL_CENTER_SK: ?outlet_id,
    CS_WAREHOUSE_SK: ?warehouse.id,
    CS_SHIP_MODE_SK: ?ship_mode.id,
    CS_QUANTITY: quantity,
    CS_SALES_PRICE: sales_price,
    CS_LIST_PRICE: list_price,
    CS_WHOLESALE_COST: wholesale_cost,
    CS_EXT_SALES_PRICE: ext_sales_price,
    CS_EXT_WHOLESALE_COST: ext_wholesale_cost,
    CS_EXT_LIST_PRICE: ext_list_price,
    CS_EXT_DISCOUNT_AMT: ext_discount_amount,
    CS_COUPON_AMT: coupon_amt,
    CS_NET_PROFIT: net_profit,
    CS_NET_PAID: net_paid,
    CS_NET_PAID_INC_TAX: net_paid_inc_tax,
    raw(''' 1 '''): sale_line_item_counter,
)
grain (item.id, order_id, channel)
complete where channel = 'CATALOG'
address memory.catalog_sales;

partial datasource store_sales_unified (
    raw(''' 'STORE' '''): channel,
    SS_TICKET_NUMBER: order_id,
    SS_ITEM_SK: item.id,
    SS_SOLD_DATE_SK: ?date.id,
    SS_SOLD_TIME_SK: ?time.id,
    SS_CUSTOMER_SK: ?billing_customer.id,
    SS_CUSTOMER_SK: ?ship_customer.id,
    SS_CUSTOMER_SK: ?purchasing_customer.id,
    SS_ADDR_SK: ?bill_address.id,
    SS_PROMO_SK: ?promotion.id,
    SS_STORE_SK: ?channel_dim_id,
    SS_STORE_SK: ?outlet_id,
    raw(''' NULL '''): warehouse.id,
    raw(''' NULL '''): ship_mode.id,
    SS_QUANTITY: quantity,
    SS_SALES_PRICE: sales_price,
    SS_LIST_PRICE: list_price,
    SS_WHOLESALE_COST: wholesale_cost,
    SS_EXT_SALES_PRICE: ext_sales_price,
    SS_EXT_WHOLESALE_COST: ext_wholesale_cost,
    SS_EXT_LIST_PRICE: ext_list_price,
    SS_EXT_DISCOUNT_AMT: ext_discount_amount,
    SS_COUPON_AMT: coupon_amt,
    SS_NET_PROFIT: net_profit,
    SS_NET_PAID: net_paid,
    SS_NET_PAID_INC_TAX: net_paid_inc_tax,
    raw(''' 1 '''): sale_line_item_counter,
)
grain (item.id, order_id, channel)
complete where channel = 'STORE'
address memory.store_sales;

partial datasource store_dim_unified (
    raw(''' 'STORE' '''): channel,
    S_STORE_SK: channel_dim_id,
    S_STORE_ID: channel_dim_text_id,
)
grain (channel_dim_id, channel)
complete where channel = 'STORE'
address memory.store;

partial datasource catalog_dim_unified (
    raw(''' 'CATALOG' '''): channel,
    CP_CATALOG_PAGE_SK: channel_dim_id,
    CP_CATALOG_PAGE_ID: channel_dim_text_id,
)
grain (channel_dim_id, channel)
complete where channel = 'CATALOG'
address memory.catalog_page;

partial datasource web_dim_unified (
    raw(''' 'WEB' '''): channel,
    web_site_sk: channel_dim_id,
    web_site_id: channel_dim_text_id,
)
grain (channel_dim_id, channel)
complete where channel = 'WEB'
address memory.web_site;

partial datasource store_dim_return_unified (
    raw(''' 'STORE' '''): channel,
    S_STORE_SK: return_channel_dim_id,
    S_STORE_ID: return_channel_dim_text_id,
)
grain (return_channel_dim_id, channel)
complete where channel = 'STORE'
address memory.store;

partial datasource catalog_dim_return_unified (
    raw(''' 'CATALOG' '''): channel,
    CP_CATALOG_PAGE_SK: return_channel_dim_id,
    CP_CATALOG_PAGE_ID: return_channel_dim_text_id,
)
grain (return_channel_dim_id, channel)
complete where channel = 'CATALOG'
address memory.catalog_page;

partial datasource web_dim_return_unified (
    raw(''' 'WEB' '''): channel,
    web_site_sk: return_channel_dim_id,
    web_site_id: return_channel_dim_text_id,
)
grain (return_channel_dim_id, channel)
complete where channel = 'WEB'
address memory.web_site;

partial datasource web_returns_unified (
    raw(''' 'WEB' '''): channel,
    WR_ORDER_NUMBER: ~order_id,
    WR_ITEM_SK: ~item.id,
    WR_RETURNED_DATE_SK: ?~return_date.id,
    WR_RETURN_AMT: return_amount,
    WR_RETURN_QUANTITY: return_quantity,
    WR_NET_LOSS: return_net_loss,
    raw(''' true '''): is_returned,
)
grain (item.id, order_id, channel)
complete where channel = 'WEB'
address memory.web_returns;

partial datasource catalog_returns_unified (
    raw(''' 'CATALOG' '''): channel,
    CR_ORDER_NUMBER: ~order_id,
    CR_ITEM_SK: ~item.id,
    CR_CATALOG_PAGE_SK: ?return_channel_dim_id,
    CR_RETURNED_DATE_SK: ?~return_date.id,
    CR_RETURN_AMOUNT: return_amount,
    CR_RETURN_QUANTITY: return_quantity,
    CR_NET_LOSS: return_net_loss,
    raw(''' true '''): is_returned,
)
grain (item.id, order_id, channel)
complete where channel = 'CATALOG'
address memory.catalog_returns;

partial datasource store_returns_unified (
    raw(''' 'STORE' '''): channel,
    SR_TICKET_NUMBER: ~order_id,
    SR_ITEM_SK: ~item.id,
    SR_STORE_SK: ?return_channel_dim_id,
    SR_RETURNED_DATE_SK: ?~return_date.id,
    SR_RETURN_AMT: return_amount,
    SR_RETURN_QUANTITY: return_quantity,
    SR_NET_LOSS: return_net_loss,
    raw(''' true '''): is_returned,
)
grain (item.id, order_id, channel)
complete where channel = 'STORE'
address memory.store_returns;
