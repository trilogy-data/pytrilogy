# Return reason info: free-form textual description of why an item was
# returned (e.g. 'Did not fit', 'wrong color').

key sk int; # Surrogate key uniquely identifying a return reason.

properties sk (
    id string, # Stable business identifier for the return reason (16-char alphanumeric).
    desc string?, # Free-form description of the reason (e.g. 'Did not fit', 'wrong color').
);

datasource reason (
    R_REASON_SK: sk,
    R_REASON_ID: id,
    R_REASON_DESC: desc,
)
grain (sk)
address memory.reason;
