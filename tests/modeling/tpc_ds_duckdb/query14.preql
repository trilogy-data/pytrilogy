import all_sales as sales;

# count_distinct(channel) per (brand_id, class_id, category_id) tuple - how many
# of the 3 channels each item tuple sold in.
auto cross_channel_count <- count_distinct(sales.channel)
    by sales.item.brand_id, sales.item.class_id, sales.item.category_id;

# cross_tuples: (brand_id, class_id, category_id) tuples sold in all 3 channels
# during 1999-2001. Equivalent to the reference's 3-way INTERSECT on
# (i_brand_id, i_class_id, i_category_id) across store/catalog/web sales. The
# NULL-component exclusions mirror the reference's `item, cross_items where
# i_brand_id = brand_id and ...` inner joins, which can never match a NULL key
# part — trilogy tuple membership is identity matching (NULL = NULL), so the
# set must exclude them explicitly.
rowset cross_tuples <- where
    sales.date.year between 1999 and 2001
    and sales.item.brand_id is not null
    and sales.item.class_id is not null
    and sales.item.category_id is not null
select
    sales.item.brand_id as ci_brand_id,
    sales.item.class_id as ci_class_id,
    sales.item.category_id as ci_category_id,
having
    cross_channel_count = 3
;

# avg_sales: scalar avg(quantity * list_price) over all 3 channels for 1999-2001.
rowset avg_sales <- where
    sales.date.year between 1999 and 2001
select
    avg(sales.quantity * sales.list_price) as average_sales,
;

# One per fact row (all_sales grain is (channel, order_id, item.sk)).
auto channel_label <- lower(sales.channel);


# Per (channel, brand_id, class_id, category_id) aggregates for Nov 2001, items whose
# (brand_id, class_id, category_id) tuple is in cross_tuples, HAVING
# sum(quantity*list_price) > avg_sales. Row-wise tuple membership matches all three
# key parts together (a per-column `in` would match unrelated cross-pairs).
rowset l0_filtered <- where
    sales.date.year = 2001
    and sales.date.month_of_year = 11
    and (sales.item.brand_id, sales.item.class_id, sales.item.category_id)
        in (cross_tuples.ci_brand_id, cross_tuples.ci_class_id, cross_tuples.ci_category_id)
select
    channel_label as channel_l0,
    sales.item.brand_id as brand_l0,
    sales.item.class_id as class_l0,
    sales.item.category_id as category_l0,
    sum(sales.quantity * sales.list_price) as bucket_sum_l0,
    sum(sales.sale_line_item_counter) as bucket_count_l0,
having
    bucket_sum_l0 > avg_sales.average_sales

;

# Final ROLLUP(channel, brand_id, class_id, category_id) over the per-channel L0.
select
    l0_filtered.channel_l0 as channel,
    l0_filtered.brand_l0 as i_brand_id,
    l0_filtered.class_l0 as i_class_id,
    l0_filtered.category_l0 as i_category_id,
    sum(l0_filtered.bucket_sum_l0) as sum_sales,
    sum(l0_filtered.bucket_count_l0) as sum_number_sales,
by rollup ()
order by
    channel asc nulls first,
    i_brand_id asc nulls first,
    i_class_id asc nulls first,
    i_category_id asc nulls first
limit 100
;
