    coalesce(\"young\".\"ws_oct_sales\",0) + coalesce(\"young\".\"cs_oct_sales\",0) as \"oct_sales\",
    coalesce(\"young\".\"ws_sep_net\",0) + coalesce(\"young\".\"cs_sep_net\",0) as \"sep_net\",
    coalesce(\"young\".\"ws_sep_sales\",0) + coalesce(\"young\".\"cs_sep_sales\",0) as \"sep_sales\"
FROM
