    coalesce(\"young\".\"ws_mar_net\",0) + coalesce(\"young\".\"cs_mar_net\",0) as \"mar_net\",
    coalesce(\"young\".\"ws_mar_sales\",0) + coalesce(\"young\".\"cs_mar_sales\",0) as \"mar_sales\",
    coalesce(\"young\".\"ws_may_net\",0) + coalesce(\"young\".\"cs_may_net\",0) as \"may_net\",
    coalesce(\"young\".\"ws_may_sales\",0) + coalesce(\"young\".\"cs_may_sales\",0) as \"may_sales\",
