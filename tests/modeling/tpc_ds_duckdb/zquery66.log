    \"juicy\".\"sales_warehouse_state\" as \"w_state\",
    \"young\".\"sales_date_year\" as \"year_\",
    ( coalesce(\"young\".\"ws_apr_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_apr_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"apr_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_aug_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_aug_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"aug_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_dec_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_dec_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"dec_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_feb_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_feb_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"feb_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_jan_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_jan_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"jan_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_jul_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_jul_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"jul_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_jun_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_jun_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"jun_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_mar_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_mar_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"mar_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_may_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_may_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"may_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_nov_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_nov_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"nov_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_oct_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_oct_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"oct_sales_per_sq_foot\",
    ( coalesce(\"young\".\"ws_sep_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) + ( coalesce(\"young\".\"cs_sep_sales\",0) / \"juicy\".\"sales_warehouse_square_feet\" ) as \"sep_sales_per_sq_foot\",
    coalesce(\"young\".\"ws_apr_net\",0) + coalesce(\"young\".\"cs_apr_net\",0) as \"apr_net\",
    coalesce(\"young\".\"ws_apr_sales\",0) + coalesce(\"young\".\"cs_apr_sales\",0) as \"apr_sales\",
    coalesce(\"young\".\"ws_aug_net\",0) + coalesce(\"young\".\"cs_aug_net\",0) as \"aug_net\",
    coalesce(\"young\".\"ws_aug_sales\",0) + coalesce(\"young\".\"cs_aug_sales\",0) as \"aug_sales\",
    coalesce(\"young\".\"ws_dec_net\",0) + coalesce(\"young\".\"cs_dec_net\",0) as \"dec_net\",
    coalesce(\"young\".\"ws_dec_sales\",0) + coalesce(\"young\".\"cs_dec_sales\",0) as \"dec_sales\",
    coalesce(\"young\".\"ws_feb_net\",0) + coalesce(\"young\".\"cs_feb_net\",0) as \"feb_net\",
    coalesce(\"young\".\"ws_feb_sales\",0) + coalesce(\"young\".\"cs_feb_sales\",0) as \"feb_sales\",
    coalesce(\"young\".\"ws_jan_net\",0) + coalesce(\"young\".\"cs_jan_net\",0) as \"jan_net\",
    coalesce(\"young\".\"ws_jan_sales\",0) + coalesce(\"young\".\"cs_jan_sales\",0) as \"jan_sales\",
    coalesce(\"young\".\"ws_jul_net\",0) + coalesce(\"young\".\"cs_jul_net\",0) as \"jul_net\",
    coalesce(\"young\".\"ws_jul_sales\",0) + coalesce(\"young\".\"cs_jul_sales\",0) as \"jul_sales\",
    coalesce(\"young\".\"ws_jun_net\",0) + coalesce(\"young\".\"cs_jun_net\",0) as \"jun_net\",
