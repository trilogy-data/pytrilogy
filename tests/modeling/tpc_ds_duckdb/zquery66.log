    sum(\"thoughtful\".\"sales_sales_price\" * CASE WHEN \"thoughtful\".\"sales_sales_channel\" = 'CATALOG' and \"sales_date_date\".\"D_MOY\" = 11 and \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_time_time\".\"T_TIME\" >= 30838 and \"sales_time_time\".\"T_TIME\" <= 59638 and \"sales_ship_mode_ship_mode\".\"SM_CARRIER\" in ('DHL','BARIAN') and \"thoughtful\".\"sales_warehouse_id\" is not null THEN \"thoughtful\".\"sales_quantity\" ELSE NULL END) as \"cs_nov_sales\",
    sum(\"thoughtful\".\"sales_sales_price\" * CASE WHEN \"thoughtful\".\"sales_sales_channel\" = 'CATALOG' and \"sales_date_date\".\"D_MOY\" = 12 and \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_time_time\".\"T_TIME\" >= 30838 and \"sales_time_time\".\"T_TIME\" <= 59638 and \"sales_ship_mode_ship_mode\".\"SM_CARRIER\" in ('DHL','BARIAN') and \"thoughtful\".\"sales_warehouse_id\" is not null THEN \"thoughtful\".\"sales_quantity\" ELSE NULL END) as \"cs_dec_sales\",
    sum(\"thoughtful\".\"sales_sales_price\" * CASE WHEN \"thoughtful\".\"sales_sales_channel\" = 'CATALOG' and \"sales_date_date\".\"D_MOY\" = 2 and \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_time_time\".\"T_TIME\" >= 30838 and \"sales_time_time\".\"T_TIME\" <= 59638 and \"sales_ship_mode_ship_mode\".\"SM_CARRIER\" in ('DHL','BARIAN') and \"thoughtful\".\"sales_warehouse_id\" is not null THEN \"thoughtful\".\"sales_quantity\" ELSE NULL END) as \"cs_feb_sales\",
    sum(\"thoughtful\".\"sales_sales_price\" * CASE WHEN \"thoughtful\".\"sales_sales_channel\" = 'CATALOG' and \"sales_date_date\".\"D_MOY\" = 3 and \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_time_time\".\"T_TIME\" >= 30838 and \"sales_time_time\".\"T_TIME\" <= 59638 and \"sales_ship_mode_ship_mode\".\"SM_CARRIER\" in ('DHL','BARIAN') and \"thoughtful\".\"sales_warehouse_id\" is not null THEN \"thoughtful\".\"sales_quantity\" ELSE NULL END) as \"cs_mar_sales\",
    sum(\"thoughtful\".\"sales_sales_price\" * CASE WHEN \"thoughtful\".\"sales_sales_channel\" = 'CATALOG' and \"sales_date_date\".\"D_MOY\" = 4 and \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_time_time\".\"T_TIME\" >= 30838 and \"sales_time_time\".\"T_TIME\" <= 59638 and \"sales_ship_mode_ship_mode\".\"SM_CARRIER\" in ('DHL','BARIAN') and \"thoughtful\".\"sales_warehouse_id\" is not null THEN \"thoughtful\".\"sales_quantity\" ELSE NULL END) as \"cs_apr_sales\",
    sum(\"thoughtful\".\"sales_sales_price\" * CASE WHEN \"thoughtful\".\"sales_sales_channel\" = 'CATALOG' and \"sales_date_date\".\"D_MOY\" = 5 and \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_time_time\".\"T_TIME\" >= 30838 and \"sales_time_time\".\"T_TIME\" <= 59638 and \"sales_ship_mode_ship_mode\".\"SM_CARRIER\" in ('DHL','BARIAN') and \"thoughtful\".\"sales_warehouse_id\" is not null THEN \"thoughtful\".\"sales_quantity\" ELSE NULL END) as \"cs_may_sales\",
    sum(\"thoughtful\".\"sales_sales_price\" * CASE WHEN \"thoughtful\".\"sales_sales_channel\" = 'CATALOG' and \"sales_date_date\".\"D_MOY\" = 6 and \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_time_time\".\"T_TIME\" >= 30838 and \"sales_time_time\".\"T_TIME\" <= 59638 and \"sales_ship_mode_ship_mode\".\"SM_CARRIER\" in ('DHL','BARIAN') and \"thoughtful\".\"sales_warehouse_id\" is not null THEN \"thoughtful\".\"sales_quantity\" ELSE NULL END) as \"cs_jun_sales\",
    sum(\"thoughtful\".\"sales_sales_price\" * CASE WHEN \"thoughtful\".\"sales_sales_channel\" = 'CATALOG' and \"sales_date_date\".\"D_MOY\" = 7 and \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_time_time\".\"T_TIME\" >= 30838 and \"sales_time_time\".\"T_TIME\" <= 59638 and \"sales_ship_mode_ship_mode\".\"SM_CARRIER\" in ('DHL','BARIAN') and \"thoughtful\".\"sales_warehouse_id\" is not null THEN \"thoughtful\".\"sales_quantity\" ELSE NULL END) as \"cs_jul_sales\",
    sum(\"thoughtful\".\"sales_sales_price\" * CASE WHEN \"thoughtful\".\"sales_sales_channel\" = 'CATALOG' and \"sales_date_date\".\"D_MOY\" = 8 and \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_time_time\".\"T_TIME\" >= 30838 and \"sales_time_time\".\"T_TIME\" <= 59638 and \"sales_ship_mode_ship_mode\".\"SM_CARRIER\" in ('DHL','BARIAN') and \"thoughtful\".\"sales_warehouse_id\" is not null THEN \"thoughtful\".\"sales_quantity\" ELSE NULL END) as \"cs_aug_sales\",
    sum(\"thoughtful\".\"sales_sales_price\" * CASE WHEN \"thoughtful\".\"sales_sales_channel\" = 'CATALOG' and \"sales_date_date\".\"D_MOY\" = 9 and \"sales_date_date\".\"D_YEAR\" = 2001 and \"sales_time_time\".\"T_TIME\" >= 30838 and \"sales_time_time\".\"T_TIME\" <= 59638 and \"sales_ship_mode_ship_mode\".\"SM_CARRIER\" in ('DHL','BARIAN') and \"thoughtful\".\"sales_warehouse_id\" is not null THEN \"thoughtful\".\"sales_quantity\" ELSE NULL END) as \"cs_sep_sales\"
FROM
    \"thoughtful\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"thoughtful\".\"sales_date_id\" = \"sales_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"time_dim\" as \"sales_time_time\" on \"thoughtful\".\"sales_time_id\" = \"sales_time_time\".\"T_TIME_SK\"
    INNER JOIN \"memory\".\"ship_mode\" as \"sales_ship_mode_ship_mode\" on \"thoughtful\".\"sales_ship_mode_id\" = \"sales_ship_mode_ship_mode\".\"SM_SHIP_MODE_SK\"
WHERE
    \"sales_date_date\".\"D_YEAR\" = 2001 and \"thoughtful\".\"sales_warehouse_id\" is not null

GROUP BY
    1,
    2),
juicy as (
SELECT
    \"cooperative\".\"sales_warehouse_id\" as \"sales_warehouse_id\",
    \"sales_warehouse_warehouse\".\"w_city\" as \"sales_warehouse_city\",
    \"sales_warehouse_warehouse\".\"w_country\" as \"sales_warehouse_country\",
    \"sales_warehouse_warehouse\".\"w_county\" as \"sales_warehouse_county\",
    \"sales_warehouse_warehouse\".\"w_state\" as \"sales_warehouse_state\",
    \"sales_warehouse_warehouse\".\"w_warehouse_name\" as \"sales_warehouse_name\",
    \"sales_warehouse_warehouse\".\"w_warehouse_sq_ft\" as \"sales_warehouse_square_feet\"
FROM
    \"cooperative\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"cooperative\".\"sales_date_id\" = \"sales_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"warehouse\" as \"sales_warehouse_warehouse\" on \"cooperative\".\"sales_warehouse_id\" = \"sales_warehouse_warehouse\".\"w_warehouse_sk\"
WHERE
    \"sales_date_date\".\"D_YEAR\" = 2001 and \"cooperative\".\"sales_warehouse_id\" is not null

GROUP BY
    1,
    2,
    3,
    4,
    5,
    6,
    7),
abundant as (
SELECT
