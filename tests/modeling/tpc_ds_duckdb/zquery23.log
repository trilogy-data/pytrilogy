generated_sql = """

WITH 
concerned as (
SELECT
     'STORE'  as \"sales_sales_channel\",
    \"sales_store_sales_unified\".\"SS_CUSTOMER_SK\" as \"sales_customer_id\",
    \"sales_store_sales_unified\".\"SS_QUANTITY\" as \"sales_quantity\",
