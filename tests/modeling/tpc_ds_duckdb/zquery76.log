    \"young\"
    INNER JOIN \"juicy\" on \"young\".\"ss_item_id\" = \"juicy\".\"ss_item_id\" AND \"young\".\"ss_ticket_number\" = \"juicy\".\"ss_ticket_number\"
    INNER JOIN \"memory\".\"item\" as \"ss_item_items\" on \"young\".\"ss_item_id\" = \"ss_item_items\".\"I_ITEM_SK\"
