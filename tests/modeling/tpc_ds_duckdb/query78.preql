import unified_sales as sales;

def channel_sum(metric, channel) -> sum(filter metric where sales.sales_channel = channel) by sales.date.year, sales.item.id, sales.customer.id;

metric ss_qty <- sum(filter sales.quantity where sales.sales_channel = 'STORE') by sales.date.year, sales.item.id, sales.customer.id;
metric ss_wc <- sum(filter sales.wholesale_cost where sales.sales_channel = 'STORE') by sales.date.year, sales.item.id, sales.customer.id;
metric ss_sp <- sum(filter sales.sales_price where sales.sales_channel = 'STORE') by sales.date.year, sales.item.id, sales.customer.id;
metric ws_qty <- sum(filter sales.quantity where sales.sales_channel = 'WEB') by sales.date.year, sales.item.id, sales.customer.id;
metric ws_wc <- sum(filter sales.wholesale_cost where sales.sales_channel = 'WEB') by sales.date.year, sales.item.id, sales.customer.id;
metric ws_sp <- sum(filter sales.sales_price where sales.sales_channel = 'WEB') by sales.date.year, sales.item.id, sales.customer.id;
metric cs_qty <- sum(filter sales.quantity where sales.sales_channel = 'CATALOG') by sales.date.year, sales.item.id, sales.customer.id;
metric cs_wc <- sum(filter sales.wholesale_cost where sales.sales_channel = 'CATALOG') by sales.date.year, sales.item.id, sales.customer.id;
metric cs_sp <- sum(filter sales.sales_price where sales.sales_channel = 'CATALOG') by sales.date.year, sales.item.id, sales.customer.id;
property <sales.customer.id, sales.date.year, sales.item.id>.other_chan_qty <- coalesce(ws_qty,0) + coalesce(cs_qty,0);
property <sales.customer.id, sales.date.year, sales.item.id>.other_chan_wc <- coalesce(ws_wc,0) + coalesce(cs_wc,0);
property <sales.customer.id, sales.date.year, sales.item.id>.other_chan_sp <- coalesce(ws_sp,0) + coalesce(cs_sp,0);

WHERE
    sales.is_returned is null and sales.date.year = 2000 and sales.customer.id is not null
SELECT
    sales.date.year -> ss_sold_year,
    sales.item.id -> ss_item_sk,
    sales.customer.id -> ss_customer_sk,
    round(ss_qty::Numeric(7,2) / other_chan_qty::Numeric(7,2),2) -> ratio,
    ss_qty -> store_qty,
    ss_wc -> store_wholesale_cost,
    ss_sp -> store_sales_price,
    other_chan_qty,
    other_chan_wc -> other_chan_wholesale_cost,
    other_chan_sp -> other_chan_sales_price,
    --ws_qty,
    --cs_qty,
HAVING
    store_qty > 0 and (coalesce(ws_qty,0) > 0 or coalesce(cs_qty,0) > 0)

ORDER BY
    ss_sold_year asc nulls first,
    ss_item_sk asc nulls first,
    ss_customer_sk asc nulls first,
    store_qty desc nulls last,
    store_wholesale_cost desc nulls last,
    store_sales_price desc nulls last,
    other_chan_qty asc nulls first,
    other_chan_wholesale_cost asc nulls first,
    other_chan_sales_price asc nulls first,
    ratio asc nulls first
LIMIT 100
;
