    \"late\".\"sr_item_qty\" as \"sr_item_qty\",
    \"late\".\"wr_item_qty\" as \"wr_item_qty\",
    ( ( \"late\".\"sr_item_qty\" + \"late\".\"cr_item_qty\" ) + \"late\".\"wr_item_qty\" ) / 3.0 as \"average\",
    ( ( (\"late\".\"cr_item_qty\" * 1.0) / ( ( \"late\".\"sr_item_qty\" + \"late\".\"cr_item_qty\" ) + \"late\".\"wr_item_qty\" ) ) / 3.0 ) * 100 as \"cr_dev\",
    ( ( (\"late\".\"sr_item_qty\" * 1.0) / ( ( \"late\".\"sr_item_qty\" + \"late\".\"cr_item_qty\" ) + \"late\".\"wr_item_qty\" ) ) / 3.0 ) * 100 as \"sr_dev\",
    ( ( (\"late\".\"wr_item_qty\" * 1.0) / ( ( \"late\".\"sr_item_qty\" + \"late\".\"cr_item_qty\" ) + \"late\".\"wr_item_qty\" ) ) / 3.0 ) * 100 as \"wr_dev\"
