    CASE WHEN \"young\".\"sales_channel\" = 'WEB' THEN \"young\".\"sales_order_id\" ELSE NULL END as \"_virt_filter_order_id_4509973400283298\",
    CASE WHEN \"young\".\"sales_channel\" = 'WEB' THEN \"young\".\"sales_return_quantity\" ELSE NULL END as \"_virt_filter_return_quantity_3080706904930962\"
FROM
    \"young\"),
late as (
SELECT
    \"abhorrent\".\"sales_item_id\" as \"sales_item_id\",
    count(\"abhorrent\".\"_virt_filter_order_id_4509973400283298\") as \"wr_item_present\",
    count(\"abhorrent\".\"_virt_filter_order_id_5221868426357137\") as \"sr_item_present\",
    count(\"abhorrent\".\"_virt_filter_order_id_9747092284480774\") as \"cr_item_present\",
