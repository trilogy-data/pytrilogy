generated_sql = """

WITH 
questionable as (
SELECT
     'CATALOG'  as \"sales_channel\",
    \"sales_catalog_returns_unified\".\"CR_ITEM_SK\" as \"sales_item_sk\",
    \"sales_catalog_returns_unified\".\"CR_ORDER_NUMBER\" as \"sales_order_id\",
    \"sales_catalog_returns_unified\".\"CR_RETURNED_DATE_SK\" as \"sales_return_date_sk\",
    \"sales_catalog_returns_unified\".\"CR_RETURN_QUANTITY\" as \"sales_return_quantity\"
FROM
    \"memory\".\"catalog_returns\" as \"sales_catalog_returns_unified\"
UNION ALL
SELECT
     'STORE'  as \"sales_channel\",
    \"sales_store_returns_unified\".\"SR_ITEM_SK\" as \"sales_item_sk\",
    \"sales_store_returns_unified\".\"SR_TICKET_NUMBER\" as \"sales_order_id\",
    \"sales_store_returns_unified\".\"SR_RETURNED_DATE_SK\" as \"sales_return_date_sk\",
    \"sales_store_returns_unified\".\"SR_RETURN_QUANTITY\" as \"sales_return_quantity\"
FROM
    \"memory\".\"store_returns\" as \"sales_store_returns_unified\"
UNION ALL
SELECT
     'WEB'  as \"sales_channel\",
    \"sales_web_returns_unified\".\"WR_ITEM_SK\" as \"sales_item_sk\",
    \"sales_web_returns_unified\".\"WR_ORDER_NUMBER\" as \"sales_order_id\",
    \"sales_web_returns_unified\".\"WR_RETURNED_DATE_SK\" as \"sales_return_date_sk\",
    \"sales_web_returns_unified\".\"WR_RETURN_QUANTITY\" as \"sales_return_quantity\"
FROM
    \"memory\".\"web_returns\" as \"sales_web_returns_unified\"),
quizzical as (
SELECT
    \"date_date\".\"D_WEEK_SEQ\" as \"target_week_seqs\"
FROM
    \"memory\".\"date_dim\" as \"date_date\"
WHERE
    cast(\"date_date\".\"D_DATE\" as date) in (date '2000-06-30',date '2000-09-27',date '2000-11-17')

GROUP BY
    1),
yummy as (
SELECT
    \"sales_item_items\".\"I_ITEM_ID\" as \"sales_item_id\",
    count(CASE WHEN \"questionable\".\"sales_channel\" = 'CATALOG' THEN \"questionable\".\"sales_order_id\" ELSE NULL END) as \"cr_item_present\",
    count(CASE WHEN \"questionable\".\"sales_channel\" = 'STORE' THEN \"questionable\".\"sales_order_id\" ELSE NULL END) as \"sr_item_present\",
    count(CASE WHEN \"questionable\".\"sales_channel\" = 'WEB' THEN \"questionable\".\"sales_order_id\" ELSE NULL END) as \"wr_item_present\",
    sum(CASE WHEN \"questionable\".\"sales_channel\" = 'CATALOG' THEN \"questionable\".\"sales_return_quantity\" ELSE NULL END) as \"cr_item_qty\",
    sum(CASE WHEN \"questionable\".\"sales_channel\" = 'STORE' THEN \"questionable\".\"sales_return_quantity\" ELSE NULL END) as \"sr_item_qty\",
    sum(CASE WHEN \"questionable\".\"sales_channel\" = 'WEB' THEN \"questionable\".\"sales_return_quantity\" ELSE NULL END) as \"wr_item_qty\"
FROM
    \"memory\".\"item\" as \"sales_item_items\"
    FULL JOIN \"questionable\" on \"sales_item_items\".\"I_ITEM_SK\" = \"questionable\".\"sales_item_sk\"
    RIGHT OUTER JOIN \"memory\".\"date_dim\" as \"sales_return_date_date\" on \"questionable\".\"sales_return_date_sk\" = \"sales_return_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_return_date_date\".\"D_WEEK_SEQ\" in (select quizzical.\"target_week_seqs\" from quizzical where quizzical.\"target_week_seqs\" is not null)

GROUP BY
    1),
young as (
SELECT
    \"yummy\".\"cr_item_qty\" as \"cr_item_qty\",
    \"yummy\".\"sales_item_id\" as \"item_id\",
    \"yummy\".\"sr_item_qty\" as \"sr_item_qty\",
    \"yummy\".\"wr_item_qty\" as \"wr_item_qty\",
    ( ( \"yummy\".\"sr_item_qty\" + \"yummy\".\"cr_item_qty\" ) + \"yummy\".\"wr_item_qty\" ) / 3.0 as \"average\",
    ( ( (\"yummy\".\"cr_item_qty\" * 1.0) / ( ( \"yummy\".\"sr_item_qty\" + \"yummy\".\"cr_item_qty\" ) + \"yummy\".\"wr_item_qty\" ) ) / 3.0 ) * 100 as \"cr_dev\",
    ( ( (\"yummy\".\"sr_item_qty\" * 1.0) / ( ( \"yummy\".\"sr_item_qty\" + \"yummy\".\"cr_item_qty\" ) + \"yummy\".\"wr_item_qty\" ) ) / 3.0 ) * 100 as \"sr_dev\",
    ( ( (\"yummy\".\"wr_item_qty\" * 1.0) / ( ( \"yummy\".\"sr_item_qty\" + \"yummy\".\"cr_item_qty\" ) + \"yummy\".\"wr_item_qty\" ) ) / 3.0 ) * 100 as \"wr_dev\"
FROM
    \"yummy\"),
sparkling as (
SELECT
    \"young\".\"average\" as \"average\",
    \"young\".\"cr_dev\" as \"cr_dev\",
    \"young\".\"cr_item_qty\" as \"cr_item_qty\",
    \"young\".\"item_id\" as \"item_id\",
    \"young\".\"sr_dev\" as \"sr_dev\",
    \"young\".\"sr_item_qty\" as \"sr_item_qty\",
    \"young\".\"wr_dev\" as \"wr_dev\",
    \"young\".\"wr_item_qty\" as \"wr_item_qty\",
    \"yummy\".\"cr_item_present\" as \"cr_item_present\",
    \"yummy\".\"sr_item_present\" as \"sr_item_present\",
    \"yummy\".\"wr_item_present\" as \"wr_item_present\"
FROM
    \"young\"
    INNER JOIN \"yummy\" on \"young\".\"item_id\" = \"yummy\".\"sales_item_id\"
WHERE
    \"yummy\".\"sr_item_present\" > 0
)
SELECT
    \"sparkling\".\"item_id\" as \"item_id\",
    \"sparkling\".\"sr_item_qty\" as \"sr_item_qty\",
    \"sparkling\".\"sr_dev\" as \"sr_dev\",
    \"sparkling\".\"cr_item_qty\" as \"cr_item_qty\",
    \"sparkling\".\"cr_dev\" as \"cr_dev\",
    \"sparkling\".\"wr_item_qty\" as \"wr_item_qty\",
    \"sparkling\".\"wr_dev\" as \"wr_dev\",
    \"sparkling\".\"average\" as \"average\"
FROM
    \"sparkling\"
WHERE
    \"sparkling\".\"cr_item_present\" > 0 and \"sparkling\".\"wr_item_present\" > 0

ORDER BY 
    \"sparkling\".\"item_id\" asc nulls first,
    \"sparkling\".\"sr_item_qty\" asc nulls first
LIMIT (100)"""
