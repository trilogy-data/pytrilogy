    \"late\")
SELECT
    \"sweltering\".\"item_id\" as \"item_id\",
    \"macho\".\"sr_item_qty\" as \"sr_item_qty\",
    \"macho\".\"sr_dev\" as \"sr_dev\",
    \"macho\".\"cr_item_qty\" as \"cr_item_qty\",
    \"macho\".\"cr_dev\" as \"cr_dev\",
