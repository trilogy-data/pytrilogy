generated_sql = """
SELECT
    \"store_sales_item_items\".\"I_ITEM_ID\" as \"store_sales_item_name\",
    \"store_sales_item_items\".\"I_ITEM_DESC\" as \"store_sales_item_desc\",
    \"store_sales_store_store\".\"S_STORE_ID\" as \"store_sales_store_text_id\",
    \"store_sales_store_store\".\"S_STORE_NAME\" as \"store_name\",
    sum(\"store_sales_store_sales\".\"SS_QUANTITY\") as \"store_sales_quantity\",
    sum(\"store_sales_store_returns\".\"SR_RETURN_QUANTITY\") as \"store_returns_quantity\",
    sum(\"catalog_sales_catalog_sales\".\"CS_QUANTITY\") as \"catalog_sales_quantity\"
FROM
    \"memory\".\"store_returns\" as \"store_sales_store_returns\"
    INNER JOIN \"memory\".\"catalog_sales\" as \"catalog_sales_catalog_sales\" on \"store_sales_store_returns\".\"SR_CUSTOMER_SK\" is not distinct from \"catalog_sales_catalog_sales\".\"CS_BILL_CUSTOMER_SK\" AND \"store_sales_store_returns\".\"SR_ITEM_SK\" = \"catalog_sales_catalog_sales\".\"CS_ITEM_SK\"
    INNER JOIN \"memory\".\"store_sales\" as \"store_sales_store_sales\" on \"catalog_sales_catalog_sales\".\"CS_ITEM_SK\" = \"store_sales_store_sales\".\"SS_ITEM_SK\" AND \"store_sales_store_returns\".\"SR_TICKET_NUMBER\" = \"store_sales_store_sales\".\"SS_TICKET_NUMBER\"
    INNER JOIN \"memory\".\"date_dim\" as \"store_sales_sale_date_date\" on \"store_sales_store_sales\".\"SS_SOLD_DATE_SK\" = \"store_sales_sale_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"date_dim\" as \"catalog_sales_sale_date_date\" on \"catalog_sales_catalog_sales\".\"CS_SOLD_DATE_SK\" = \"catalog_sales_sale_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"date_dim\" as \"store_sales_return_date_date\" on \"store_sales_store_returns\".\"SR_RETURNED_DATE_SK\" = \"store_sales_return_date_date\".\"D_DATE_SK\"
    LEFT OUTER JOIN \"memory\".\"item\" as \"store_sales_item_items\" on \"store_sales_store_sales\".\"SS_ITEM_SK\" = \"store_sales_item_items\".\"I_ITEM_SK\"
    LEFT OUTER JOIN \"memory\".\"store\" as \"store_sales_store_store\" on \"store_sales_store_sales\".\"SS_STORE_SK\" = \"store_sales_store_store\".\"S_STORE_SK\"
WHERE
    \"store_sales_sale_date_date\".\"D_MOY\" = 9 and \"store_sales_sale_date_date\".\"D_YEAR\" = 1999 and \"store_sales_return_date_date\".\"D_MOY\" BETWEEN 9 AND 12 and \"store_sales_return_date_date\".\"D_YEAR\" = 1999 and (\"catalog_sales_sale_date_date\".\"D_YEAR\" is not null and \"catalog_sales_sale_date_date\".\"D_YEAR\" in (1999,2000,2001)) and \"catalog_sales_catalog_sales\".\"CS_QUANTITY\" > 0 and (\"store_sales_store_returns\".\"SR_TICKET_NUMBER\" is not null) and \"store_sales_store_sales\".\"SS_CUSTOMER_SK\" = \"store_sales_store_returns\".\"SR_CUSTOMER_SK\"

GROUP BY
    1,
    2,
    3,
    4
HAVING
    \"catalog_sales_quantity\" > 0

ORDER BY 
    \"store_sales_item_name\" asc,
    \"store_sales_item_desc\" asc,
    \"store_sales_store_text_id\" asc,
    \"store_name\" asc
LIMIT (100)"""
