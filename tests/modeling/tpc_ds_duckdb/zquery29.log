generated_sql = """

WITH 
wakeful as (
SELECT
    \"catalog_sales_catalog_sales\".\"CS_BILL_CUSTOMER_SK\" as \"catalog_sales_bill_customer_id\",
    \"catalog_sales_catalog_sales\".\"CS_ITEM_SK\" as \"catalog_sales_item_id\",
    \"catalog_sales_catalog_sales\".\"CS_QUANTITY\" as \"catalog_sales_quantity\"
FROM
    \"memory\".\"catalog_sales\" as \"catalog_sales_catalog_sales\"
    INNER JOIN \"memory\".\"date_dim\" as \"catalog_sales_date_date\" on \"catalog_sales_catalog_sales\".\"CS_SOLD_DATE_SK\" = \"catalog_sales_date_date\".\"D_DATE_SK\"
WHERE
    \"catalog_sales_date_date\".\"D_YEAR\" in (1999,2000,2001) and \"catalog_sales_catalog_sales\".\"CS_QUANTITY\" > 0
),
yummy as (
SELECT
    \"store_sales_date_date\".\"D_MOY\" as \"store_sales_date_month_of_year\",
    \"store_sales_date_date\".\"D_YEAR\" as \"store_sales_date_year\",
    \"store_sales_item_items\".\"I_ITEM_DESC\" as \"store_sales_item_desc\",
    \"store_sales_item_items\".\"I_ITEM_ID\" as \"store_sales_item_text_id\",
    \"store_sales_item_items\".\"I_ITEM_SK\" as \"store_sales_item_id\",
    \"store_sales_return_date_date\".\"D_MOY\" as \"store_sales_return_date_month_of_year\",
    \"store_sales_return_date_date\".\"D_YEAR\" as \"store_sales_return_date_year\",
    \"store_sales_store_returns\".\"SR_RETURN_QUANTITY\" as \"store_sales_return_quantity\",
    \"store_sales_store_sales\".\"SS_CUSTOMER_SK\" as \"store_sales_customer_id\",
    \"store_sales_store_sales\".\"SS_QUANTITY\" as \"store_sales_quantity\",
    \"store_sales_store_store\".\"S_STORE_ID\" as \"store_sales_store_text_id\",
    \"store_sales_store_store\".\"S_STORE_NAME\" as \"store_sales_store_name\",
    SR_RETURN_TIME_SK IS NOT NULL as \"store_sales_is_returned\"
FROM
    \"memory\".\"store_sales\" as \"store_sales_store_sales\"
    INNER JOIN \"memory\".\"date_dim\" as \"store_sales_date_date\" on \"store_sales_store_sales\".\"SS_SOLD_DATE_SK\" = \"store_sales_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"store_returns\" as \"store_sales_store_returns\" on \"store_sales_store_sales\".\"SS_ITEM_SK\" = \"store_sales_store_returns\".\"SR_ITEM_SK\" AND \"store_sales_store_sales\".\"SS_TICKET_NUMBER\" = \"store_sales_store_returns\".\"SR_TICKET_NUMBER\"
    INNER JOIN \"memory\".\"date_dim\" as \"store_sales_return_date_date\" on \"store_sales_store_returns\".\"SR_RETURNED_DATE_SK\" = \"store_sales_return_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"item\" as \"store_sales_item_items\" on \"store_sales_store_sales\".\"SS_ITEM_SK\" = \"store_sales_item_items\".\"I_ITEM_SK\"
    LEFT OUTER JOIN \"memory\".\"store\" as \"store_sales_store_store\" on \"store_sales_store_sales\".\"SS_STORE_SK\" = \"store_sales_store_store\".\"S_STORE_SK\"
WHERE
    \"store_sales_date_date\".\"D_MOY\" = 9 and \"store_sales_date_date\".\"D_YEAR\" = 1999 and \"store_sales_return_date_date\".\"D_MOY\" BETWEEN 9 AND 12 and \"store_sales_return_date_date\".\"D_YEAR\" = 1999 and \"store_sales_store_sales\".\"SS_CUSTOMER_SK\" = \"store_sales_store_returns\".\"SR_CUSTOMER_SK\"
)
SELECT
    \"yummy\".\"store_sales_item_text_id\" as \"store_sales_item_name\",
    \"yummy\".\"store_sales_item_desc\" as \"store_sales_item_desc\",
    \"yummy\".\"store_sales_store_text_id\" as \"store_sales_store_text_id\",
    \"yummy\".\"store_sales_store_name\" as \"store_name\",
    sum(\"yummy\".\"store_sales_quantity\") as \"store_sales_quantity\",
    sum(\"yummy\".\"store_sales_return_quantity\") as \"store_returns_quantity\",
    sum(\"wakeful\".\"catalog_sales_quantity\") as \"catalog_sales_quantity\"
FROM
    \"wakeful\"
    INNER JOIN \"yummy\" on \"wakeful\".\"catalog_sales_item_id\" = \"yummy\".\"store_sales_item_id\"
WHERE
    \"yummy\".\"store_sales_date_month_of_year\" = 9 and \"yummy\".\"store_sales_date_year\" = 1999 and \"yummy\".\"store_sales_return_date_month_of_year\" BETWEEN 9 AND 12 and \"yummy\".\"store_sales_return_date_year\" = 1999 and \"yummy\".\"store_sales_is_returned\" and \"yummy\".\"store_sales_customer_id\" = \"wakeful\".\"catalog_sales_bill_customer_id\" and \"wakeful\".\"catalog_sales_bill_customer_id\" is not distinct from \"wakeful\".\"catalog_sales_bill_customer_id\" and coalesce(\"wakeful\".\"catalog_sales_item_id\",\"yummy\".\"store_sales_item_id\") is not distinct from coalesce(\"wakeful\".\"catalog_sales_item_id\",\"yummy\".\"store_sales_item_id\")

GROUP BY
    1,
    2,
    3,
    4
HAVING
    \"catalog_sales_quantity\" > 0

ORDER BY 
    \"store_sales_item_name\" asc,
    \"store_sales_item_desc\" asc,
    \"store_sales_store_text_id\" asc,
    \"store_name\" asc
LIMIT (100)"""
