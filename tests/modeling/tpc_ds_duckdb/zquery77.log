    \"puffy\"
    FULL JOIN \"cooperative\" on 1=1)
SELECT
    \"hard\".\"l0_union_u_channel\" as \"channel\",
    \"hard\".\"l0_union_u_id\" as \"id\",
    sum(\"hard\".\"l0_union_u_sales\") as \"sales\",
    sum(\"hard\".\"l0_union_u_returns\") as \"returns_\",
    sum(\"hard\".\"l0_union_u_profit\") as \"profit\"
