generated_sql = """

WITH 
highfalutin as (
SELECT
    avg(\"ss_store_sales\".\"SS_NET_PROFIT\") as \"_addr_null_threshold_threshold\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
WHERE
    \"ss_store_sales\".\"SS_STORE_SK\" = 1 and \"ss_store_sales\".\"SS_ADDR_SK\" is null
),
cooperative as (
SELECT
    \"ss_store_sales\".\"SS_ITEM_SK\" as \"ss_item_id\",
    avg(\"ss_store_sales\".\"SS_NET_PROFIT\") as \"item_avg_profit\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
WHERE
    \"ss_store_sales\".\"SS_STORE_SK\" = 1

GROUP BY
    1),
questionable as (
SELECT
    \"ss_store_sales\".\"SS_ITEM_SK\" as \"ss_item_id\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
WHERE
    \"ss_store_sales\".\"SS_STORE_SK\" = 1

GROUP BY
    1,
    \"ss_store_sales\".\"SS_STORE_SK\"),
cheerful as (
SELECT
    \"highfalutin\".\"_addr_null_threshold_threshold\" as \"addr_null_threshold_threshold\"
FROM
    \"highfalutin\"),
abundant as (
SELECT
    \"cooperative\".\"item_avg_profit\" as \"item_avg_profit\",
    \"cooperative\".\"ss_item_id\" as \"ss_item_id\"
FROM
    \"questionable\"
    INNER JOIN \"cooperative\" on \"questionable\".\"ss_item_id\" = \"cooperative\".\"ss_item_id\"),
uneven as (
SELECT
    \"abundant\".\"item_avg_profit\" as \"item_avg_profit\",
    \"abundant\".\"ss_item_id\" as \"ss_item_id\"
FROM
    \"cheerful\"
    INNER JOIN \"abundant\" on 1=1
WHERE
    \"abundant\".\"item_avg_profit\" > 0.9 * \"cheerful\".\"addr_null_threshold_threshold\"

GROUP BY
    1,
    2),
yummy as (
SELECT
    \"uneven\".\"ss_item_id\" as \"ss_item_id\",
    rank() over (order by \"uneven\".\"item_avg_profit\" asc ) as \"_ascending_rnk_a\",
    rank() over (order by \"uneven\".\"item_avg_profit\" desc ) as \"_descending_rnk_d\"
FROM
    \"uneven\"),
concerned as (
SELECT
    \"ss_item_items\".\"I_PRODUCT_NAME\" as \"_descending_worst_performing\",
    \"yummy\".\"_descending_rnk_d\" as \"_descending_rnk_d\"
FROM
    \"yummy\"
    INNER JOIN \"memory\".\"item\" as \"ss_item_items\" on \"yummy\".\"ss_item_id\" = \"ss_item_items\".\"I_ITEM_SK\"
GROUP BY
    1,
    2),
juicy as (
SELECT
    \"ss_item_items\".\"I_PRODUCT_NAME\" as \"_ascending_best_performing\",
    \"yummy\".\"_ascending_rnk_a\" as \"_ascending_rnk_a\"
FROM
    \"yummy\"
    INNER JOIN \"memory\".\"item\" as \"ss_item_items\" on \"yummy\".\"ss_item_id\" = \"ss_item_items\".\"I_ITEM_SK\"
GROUP BY
    1,
    2),
young as (
SELECT
    \"concerned\".\"_descending_rnk_d\" as \"descending_rnk_d\",
    \"concerned\".\"_descending_worst_performing\" as \"descending_worst_performing\"
FROM
    \"concerned\"),
vacuous as (
SELECT
    \"juicy\".\"_ascending_best_performing\" as \"ascending_best_performing\",
    \"juicy\".\"_ascending_rnk_a\" as \"ascending_rnk_a\"
FROM
    \"juicy\")
SELECT
    coalesce(\"vacuous\".\"ascending_rnk_a\",\"young\".\"descending_rnk_d\") as \"rnk\",
    \"vacuous\".\"ascending_best_performing\" as \"ascending_best_performing\",
    \"young\".\"descending_worst_performing\" as \"descending_worst_performing\"
FROM
    \"vacuous\"
    FULL JOIN \"young\" on \"vacuous\".\"ascending_rnk_a\" = \"young\".\"descending_rnk_d\"
WHERE
    coalesce(\"vacuous\".\"ascending_rnk_a\",\"young\".\"descending_rnk_d\") < 11

ORDER BY 
    \"rnk\" asc nulls first,
    \"vacuous\".\"ascending_best_performing\" desc nulls first,
    \"young\".\"descending_worst_performing\" desc nulls first
LIMIT (100)"""
