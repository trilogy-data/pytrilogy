generated_sql = """

WITH 
wakeful as (
SELECT
    \"ss_store_sales\".\"SS_ITEM_SK\" as \"ss_item_id\",
    \"ss_store_sales\".\"SS_STORE_SK\" as \"ss_store_id\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
WHERE
    \"ss_store_sales\".\"SS_STORE_SK\" = 4

GROUP BY
    1,
    2),
thoughtful as (
SELECT
    \"ss_store_sales\".\"SS_ITEM_SK\" as \"ss_item_id\",
    avg(\"ss_store_sales\".\"SS_NET_PROFIT\") as \"item_avg_profit\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
WHERE
    \"ss_store_sales\".\"SS_STORE_SK\" = 4

GROUP BY
    1),
questionable as (
SELECT
    avg(\"ss_store_sales\".\"SS_NET_PROFIT\") as \"addr_null_threshold_threshold\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
WHERE
    \"ss_store_sales\".\"SS_STORE_SK\" = 4 and \"ss_store_sales\".\"SS_ADDR_SK\" is null
),
cheerful as (
SELECT
    \"ss_item_items\".\"I_ITEM_SK\" as \"ss_item_id\",
    \"ss_item_items\".\"I_PRODUCT_NAME\" as \"ss_item_product_name\"
FROM
    \"wakeful\"
    INNER JOIN \"memory\".\"item\" as \"ss_item_items\" on \"wakeful\".\"ss_item_id\" = \"ss_item_items\".\"I_ITEM_SK\"
WHERE
    \"wakeful\".\"ss_store_id\" = 4
),
yummy as (
SELECT
    \"thoughtful\".\"item_avg_profit\" as \"item_avg_profit\",
    \"thoughtful\".\"ss_item_id\" as \"ss_item_id\"
FROM
    \"wakeful\"
    INNER JOIN \"thoughtful\" on \"wakeful\".\"ss_item_id\" = \"thoughtful\".\"ss_item_id\"),
cooperative as (
SELECT
    \"cheerful\".\"ss_item_id\" as \"ss_item_id\",
    \"cheerful\".\"ss_item_product_name\" as \"ss_item_product_name\",
    \"thoughtful\".\"item_avg_profit\" as \"item_avg_profit\"
FROM
    \"cheerful\"
    INNER JOIN \"thoughtful\" on \"cheerful\".\"ss_item_id\" = \"thoughtful\".\"ss_item_id\"),
juicy as (
SELECT
    \"yummy\".\"item_avg_profit\" as \"item_avg_profit\",
    \"yummy\".\"ss_item_id\" as \"ss_item_id\"
FROM
    \"questionable\"
    INNER JOIN \"yummy\" on 1=1
WHERE
    \"yummy\".\"item_avg_profit\" > 0.9 * \"questionable\".\"addr_null_threshold_threshold\"

GROUP BY
    1,
    2),
uneven as (
SELECT
    \"cooperative\".\"ss_item_id\" as \"ss_item_id\",
    \"cooperative\".\"ss_item_product_name\" as \"ss_item_product_name\"
FROM
    \"questionable\"
    INNER JOIN \"cooperative\" on 1=1
WHERE
    \"cooperative\".\"item_avg_profit\" > 0.9 * \"questionable\".\"addr_null_threshold_threshold\"

GROUP BY
    1,
    2),
vacuous as (
SELECT
    \"juicy\".\"ss_item_id\" as \"ss_item_id\",
    rank() over (order by \"juicy\".\"item_avg_profit\" asc ) as \"_ascending_rnk_a\",
    rank() over (order by \"juicy\".\"item_avg_profit\" desc ) as \"_descending_rnk_d\"
FROM
    \"juicy\"),
young as (
SELECT
    \"uneven\".\"ss_item_product_name\" as \"descending_worst_performing\",
    \"vacuous\".\"_descending_rnk_d\" as \"descending_rnk_d\",
    \"vacuous\".\"_descending_rnk_d\" as \"rnk\"
FROM
    \"uneven\"
    INNER JOIN \"vacuous\" on \"uneven\".\"ss_item_id\" = \"vacuous\".\"ss_item_id\"
GROUP BY
    1,
    2,
    3),
concerned as (
SELECT
    \"uneven\".\"ss_item_product_name\" as \"ascending_best_performing\",
    \"vacuous\".\"_ascending_rnk_a\" as \"ascending_rnk_a\"
FROM
    \"uneven\"
    INNER JOIN \"vacuous\" on \"uneven\".\"ss_item_id\" = \"vacuous\".\"ss_item_id\"
GROUP BY
    1,
    2),
sparkling as (
SELECT
    \"concerned\".\"ascending_best_performing\" as \"ascending_best_performing\",
    \"young\".\"descending_worst_performing\" as \"descending_worst_performing\",
    \"young\".\"rnk\" as \"rnk\"
FROM
    \"young\"
    INNER JOIN \"concerned\" on \"young\".\"descending_rnk_d\" = \"concerned\".\"ascending_rnk_a\"
WHERE
    \"young\".\"rnk\" < 11
)
SELECT
    \"sparkling\".\"rnk\" as \"rnk\",
    \"sparkling\".\"ascending_best_performing\" as \"ascending_best_performing\",
    \"sparkling\".\"descending_worst_performing\" as \"descending_worst_performing\"
FROM
    \"sparkling\"
ORDER BY 
    \"sparkling\".\"rnk\" asc nulls first,
    \"sparkling\".\"ascending_best_performing\" desc nulls first,
    \"sparkling\".\"descending_worst_performing\" desc nulls first
LIMIT (100)"""
