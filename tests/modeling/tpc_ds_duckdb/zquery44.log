generated_sql = """

WITH 
questionable as (
SELECT
    avg(\"ss_store_sales\".\"SS_NET_PROFIT\") as \"_addr_null_threshold_threshold\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
WHERE
    \"ss_store_sales\".\"SS_STORE_SK\" = 1 and \"ss_store_sales\".\"SS_ADDR_SK\" is null
),
wakeful as (
SELECT
    \"ss_store_sales\".\"SS_ITEM_SK\" as \"ss_item_sk\",
    avg(CASE WHEN \"ss_store_sales\".\"SS_STORE_SK\" = 1 THEN \"ss_store_sales\".\"SS_NET_PROFIT\" ELSE NULL END) as \"item_avg_profit\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
GROUP BY
    1),
thoughtful as (
SELECT
    \"ss_store_sales\".\"SS_ITEM_SK\" as \"ss_item_sk\",
    \"ss_store_sales\".\"SS_STORE_SK\" as \"ss_store_sk\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
WHERE
    \"ss_store_sales\".\"SS_STORE_SK\" = 1

GROUP BY
    1,
    2),
uneven as (
SELECT
    \"questionable\".\"_addr_null_threshold_threshold\" as \"addr_null_threshold_threshold\"
FROM
    \"questionable\"),
cooperative as (
SELECT
    \"wakeful\".\"item_avg_profit\" as \"item_avg_profit\",
    \"wakeful\".\"ss_item_sk\" as \"ss_item_sk\"
FROM
    \"thoughtful\"
    INNER JOIN \"wakeful\" on \"thoughtful\".\"ss_item_sk\" = \"wakeful\".\"ss_item_sk\"
WHERE
    \"thoughtful\".\"ss_store_sk\" = 1
),
yummy as (
SELECT
    \"cooperative\".\"item_avg_profit\" as \"item_avg_profit\",
    \"cooperative\".\"ss_item_sk\" as \"ss_item_sk\"
FROM
    \"uneven\"
    INNER JOIN \"cooperative\" on 1=1
WHERE
    \"cooperative\".\"item_avg_profit\" > 0.9 * \"uneven\".\"addr_null_threshold_threshold\"

GROUP BY
    1,
    2),
juicy as (
SELECT
    \"yummy\".\"ss_item_sk\" as \"ss_item_sk\",
    rank() over (order by \"yummy\".\"item_avg_profit\" asc ) as \"_ascending_rnk_a\",
    rank() over (order by \"yummy\".\"item_avg_profit\" desc ) as \"_descending_rnk_d\"
FROM
    \"yummy\"),
young as (
SELECT
    \"juicy\".\"_descending_rnk_d\" as \"_descending_rnk_d\",
    \"ss_item_items\".\"I_PRODUCT_NAME\" as \"_descending_worst_performing\"
FROM
    \"juicy\"
    INNER JOIN \"memory\".\"item\" as \"ss_item_items\" on \"juicy\".\"ss_item_sk\" = \"ss_item_items\".\"I_ITEM_SK\"
GROUP BY
    1,
    2),
vacuous as (
SELECT
    \"juicy\".\"_ascending_rnk_a\" as \"_ascending_rnk_a\",
    \"ss_item_items\".\"I_PRODUCT_NAME\" as \"_ascending_best_performing\"
FROM
    \"juicy\"
    INNER JOIN \"memory\".\"item\" as \"ss_item_items\" on \"juicy\".\"ss_item_sk\" = \"ss_item_items\".\"I_ITEM_SK\"
GROUP BY
    1,
    2),
sparkling as (
SELECT
    \"young\".\"_descending_rnk_d\" as \"descending_rnk_d\",
    \"young\".\"_descending_worst_performing\" as \"descending_worst_performing\"
FROM
    \"young\"),
concerned as (
SELECT
    \"vacuous\".\"_ascending_best_performing\" as \"ascending_best_performing\",
    \"vacuous\".\"_ascending_rnk_a\" as \"ascending_rnk_a\"
FROM
    \"vacuous\")
SELECT
    coalesce(\"concerned\".\"ascending_rnk_a\",\"sparkling\".\"descending_rnk_d\") as \"rnk\",
    \"concerned\".\"ascending_best_performing\" as \"ascending_best_performing\",
    \"sparkling\".\"descending_worst_performing\" as \"descending_worst_performing\"
FROM
    \"concerned\"
    LEFT OUTER JOIN \"sparkling\" on \"concerned\".\"ascending_rnk_a\" = \"sparkling\".\"descending_rnk_d\"
WHERE
    coalesce(\"concerned\".\"ascending_rnk_a\",\"sparkling\".\"descending_rnk_d\") < 11

ORDER BY 
    \"rnk\" asc nulls first,
    \"concerned\".\"ascending_best_performing\" desc nulls first,
    \"sparkling\".\"descending_worst_performing\" desc nulls first
LIMIT (100)"""
