	WHEN coalesce(\"abundant\".\"sales_sales_channel\",\"cheerful\".\"sales_sales_channel\",\"sweltering\".\"sales_sales_channel\",\"vacuous\".\"sales_sales_channel\",\"young\".\"sales_sales_channel\") = 'CATALOG' THEN 'catalog channel'
	WHEN coalesce(\"abundant\".\"sales_sales_channel\",\"cheerful\".\"sales_sales_channel\",\"sweltering\".\"sales_sales_channel\",\"vacuous\".\"sales_sales_channel\",\"young\".\"sales_sales_channel\") = 'WEB' THEN 'web channel'
	ELSE null
	END as \"channel_label\",
    CASE
	WHEN coalesce(\"abundant\".\"sales_sales_channel\",\"cheerful\".\"sales_sales_channel\",\"sweltering\".\"sales_sales_channel\",\"vacuous\".\"sales_sales_channel\",\"young\".\"sales_sales_channel\") = 'STORE' THEN ('store' || coalesce(\"abundant\".\"sales_channel_dim_text_id\",\"cheerful\".\"sales_return_channel_dim_text_id\"))
	WHEN coalesce(\"abundant\".\"sales_sales_channel\",\"cheerful\".\"sales_sales_channel\",\"sweltering\".\"sales_sales_channel\",\"vacuous\".\"sales_sales_channel\",\"young\".\"sales_sales_channel\") = 'CATALOG' THEN ('catalog_page' || coalesce(\"abundant\".\"sales_channel_dim_text_id\",\"cheerful\".\"sales_return_channel_dim_text_id\"))
	WHEN coalesce(\"abundant\".\"sales_sales_channel\",\"cheerful\".\"sales_sales_channel\",\"sweltering\".\"sales_sales_channel\",\"vacuous\".\"sales_sales_channel\",\"young\".\"sales_sales_channel\") = 'WEB' THEN ('web_site' || coalesce(\"abundant\".\"sales_channel_dim_text_id\",\"cheerful\".\"sales_return_channel_dim_text_id\"))
	ELSE null
	END as \"entity_id\",
    CASE WHEN cast(\"sales_date_date\".\"D_DATE\" as date) BETWEEN date '2000-08-23' AND date '2000-09-06' and \"abundant\".\"sales_channel_dim_text_id\" is not null THEN \"sweltering\".\"sales_ext_sales_price\" ELSE NULL END as \"_virt_filter_ext_sales_price_3137532262176263\",
    CASE WHEN cast(\"sales_return_date_date\".\"D_DATE\" as date) BETWEEN date '2000-08-23' AND date '2000-09-06' and \"cheerful\".\"sales_return_channel_dim_text_id\" is not null THEN \"vacuous\".\"sales_return_amount\" ELSE NULL END as \"_virt_filter_return_amount_9725734868233209\",
    coalesce(CASE WHEN cast(\"sales_date_date\".\"D_DATE\" as date) BETWEEN date '2000-08-23' AND date '2000-09-06' and \"abundant\".\"sales_channel_dim_text_id\" is not null THEN \"sweltering\".\"sales_net_profit\" ELSE NULL END,0.0) - coalesce(CASE WHEN cast(\"sales_return_date_date\".\"D_DATE\" as date) BETWEEN date '2000-08-23' AND date '2000-09-06' and \"cheerful\".\"sales_return_channel_dim_text_id\" is not null THEN \"vacuous\".\"sales_return_net_loss\" ELSE NULL END,0.0) as \"net_contribution\"
