    \"sweltering\"
    LEFT OUTER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"sweltering\".\"sales_date_id\" = \"sales_date_date\".\"D_DATE_SK\"
    LEFT OUTER JOIN \"abundant\" on \"sweltering\".\"sales_channel_dim_id\" = \"abundant\".\"sales_channel_dim_id\" AND \"sweltering\".\"sales_sales_channel\" = \"abundant\".\"sales_sales_channel\"
    LEFT OUTER JOIN \"young\" on \"sweltering\".\"sales_item_id\" = \"young\".\"sales_item_id\" AND \"sweltering\".\"sales_order_id\" = \"young\".\"sales_order_id\" AND \"sweltering\".\"sales_sales_channel\" = \"young\".\"sales_sales_channel\"
    FULL JOIN \"vacuous\" on \"young\".\"sales_item_id\" = \"vacuous\".\"sales_item_id\" AND \"young\".\"sales_order_id\" = \"vacuous\".\"sales_order_id\" AND coalesce(\"young\".\"sales_sales_channel\", \"abundant\".\"sales_sales_channel\") = \"vacuous\".\"sales_sales_channel\"
    FULL JOIN \"memory\".\"date_dim\" as \"sales_return_date_date\" on \"vacuous\".\"sales_return_date_id\" = \"sales_return_date_date\".\"D_DATE_SK\"
    LEFT OUTER JOIN \"cheerful\" on \"young\".\"sales_return_channel_dim_id\" = \"cheerful\".\"sales_return_channel_dim_id\" AND coalesce(\"young\".\"sales_sales_channel\", \"sweltering\".\"sales_sales_channel\") = \"cheerful\".\"sales_sales_channel\"
