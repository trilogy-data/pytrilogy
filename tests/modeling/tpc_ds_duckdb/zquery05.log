    coalesce(\"abundant\".\"sales_channel_dim_text_id\",\"cheerful\".\"sales_return_channel_dim_text_id\") is not null and ( cast(\"sales_date_date\".\"D_DATE\" as date) BETWEEN date '2000-08-23' AND date '2000-09-06' or cast(\"sales_return_date_date\".\"D_DATE\" as date) BETWEEN date '2000-08-23' AND date '2000-09-06' )

