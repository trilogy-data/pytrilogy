import item as item;
import date as date;
import date as return_date;
import time as time;
import customer as customer;
import promotion as promotion;
import address as bill_address;
import warehouse as warehouse;
import ship_mode as ship_mode;

key sales_channel enum<string>['WEB', 'CATALOG', 'STORE'];
key channel_dim_id int;

properties <sales_channel, channel_dim_id> (
    channel_dim_text_id string,
);

key order_id int;

properties <sales_channel, order_id, item.id> (
    quantity int,
    sales_price float,
    list_price float,
    wholesale_cost float,
    ext_sales_price float,
    ext_wholesale_cost float,
    ext_list_price float,
    ext_discount_amount float,
    coupon_amt float,
    net_profit float,
    net_paid float,
    net_paid_inc_tax float?,
    return_amount float?,
    return_quantity int?,
    return_net_loss float?,
);

partial datasource web_sales_unified (
    raw(''' 'WEB' '''): sales_channel,
    WS_ORDER_NUMBER: order_id,
    WS_ITEM_SK: item.id,
    WS_SOLD_DATE_SK: date.id,
    WS_SOLD_TIME_SK: time.id,
    WS_BILL_CUSTOMER_SK: customer.id,
    WS_BILL_ADDR_SK: bill_address.id,
    WS_PROMO_SK: promotion.id,
    WS_WEB_SITE_SK: channel_dim_id,
    WS_WAREHOUSE_SK: warehouse.id,
    WS_SHIP_MODE_SK: ship_mode.id,
    WS_QUANTITY: quantity,
    WS_SALES_PRICE: sales_price,
    WS_LIST_PRICE: list_price,
    WS_WHOLESALE_COST: wholesale_cost,
    WS_EXT_SALES_PRICE: ext_sales_price,
    WS_EXT_WHOLESALE_COST: ext_wholesale_cost,
    WS_EXT_LIST_PRICE: ext_list_price,
    WS_EXT_DISCOUNT_AMT: ext_discount_amount,
    WS_COUPON_AMT: coupon_amt,
    WS_NET_PROFIT: net_profit,
    WS_NET_PAID: net_paid,
    WS_NET_PAID_INC_TAX: net_paid_inc_tax,
)
grain (sales_channel, order_id, item.id)
complete where sales_channel = 'WEB'
address memory.web_sales;

partial datasource catalog_sales_unified (
    raw(''' 'CATALOG' '''): sales_channel,
    CS_ORDER_NUMBER: order_id,
    CS_ITEM_SK: item.id,
    CS_SOLD_DATE_SK: date.id,
    CS_SOLD_TIME_SK: time.id,
    CS_BILL_CUSTOMER_SK: customer.id,
    CS_BILL_ADDR_SK: bill_address.id,
    CS_PROMO_SK: promotion.id,
    CS_CATALOG_PAGE_SK: channel_dim_id,
    CS_WAREHOUSE_SK: warehouse.id,
    CS_SHIP_MODE_SK: ship_mode.id,
    CS_QUANTITY: quantity,
    CS_SALES_PRICE: sales_price,
    CS_LIST_PRICE: list_price,
    CS_WHOLESALE_COST: wholesale_cost,
    CS_EXT_SALES_PRICE: ext_sales_price,
    CS_EXT_WHOLESALE_COST: ext_wholesale_cost,
    CS_EXT_LIST_PRICE: ext_list_price,
    CS_EXT_DISCOUNT_AMT: ext_discount_amount,
    CS_COUPON_AMT: coupon_amt,
    CS_NET_PROFIT: net_profit,
    CS_NET_PAID: net_paid,
    CS_NET_PAID_INC_TAX: net_paid_inc_tax,
)
grain (sales_channel, order_id, item.id)
complete where sales_channel = 'CATALOG'
address memory.catalog_sales;

partial datasource store_sales_unified (
    raw(''' 'STORE' '''): sales_channel,
    SS_TICKET_NUMBER: order_id,
    SS_ITEM_SK: item.id,
    SS_SOLD_DATE_SK: date.id,
    SS_SOLD_TIME_SK: time.id,
    SS_CUSTOMER_SK: customer.id,
    SS_ADDR_SK: bill_address.id,
    SS_PROMO_SK: promotion.id,
    SS_STORE_SK: channel_dim_id,
    raw(''' NULL '''): warehouse.id,
    raw(''' NULL '''): ship_mode.id,
    SS_QUANTITY: quantity,
    SS_SALES_PRICE: sales_price,
    SS_LIST_PRICE: list_price,
    SS_WHOLESALE_COST: wholesale_cost,
    SS_EXT_SALES_PRICE: ext_sales_price,
    SS_EXT_WHOLESALE_COST: ext_wholesale_cost,
    SS_EXT_LIST_PRICE: ext_list_price,
    SS_EXT_DISCOUNT_AMT: ext_discount_amount,
    SS_COUPON_AMT: coupon_amt,
    SS_NET_PROFIT: net_profit,
    SS_NET_PAID: net_paid,
    SS_NET_PAID_INC_TAX: net_paid_inc_tax,
)
grain (sales_channel, order_id, item.id)
complete where sales_channel = 'STORE'
address memory.store_sales;

partial datasource store_dim_unified (
    raw(''' 'STORE' '''): sales_channel,
    S_STORE_SK: channel_dim_id,
    S_STORE_ID: channel_dim_text_id,
)
grain (sales_channel, channel_dim_id)
complete where sales_channel = 'STORE'
address memory.store;

partial datasource catalog_dim_unified (
    raw(''' 'CATALOG' '''): sales_channel,
    CP_CATALOG_PAGE_SK: channel_dim_id,
    CP_CATALOG_PAGE_ID: channel_dim_text_id,
)
grain (sales_channel, channel_dim_id)
complete where sales_channel = 'CATALOG'
address memory.catalog_page;

partial datasource web_dim_unified (
    raw(''' 'WEB' '''): sales_channel,
    web_site_sk: channel_dim_id,
    web_site_id: channel_dim_text_id,
)
grain (sales_channel, channel_dim_id)
complete where sales_channel = 'WEB'
address memory.web_site;

partial datasource web_returns_unified (
    raw(''' 'WEB' '''): sales_channel,
    WR_ORDER_NUMBER: ~order_id,
    WR_ITEM_SK: ~item.id,
    WR_RETURNED_DATE_SK: return_date.id,
    WR_RETURN_AMT: return_amount,
    WR_RETURN_QUANTITY: return_quantity,
    WR_NET_LOSS: return_net_loss,
)
grain (sales_channel, order_id, item.id)
complete where sales_channel = 'WEB'
address memory.web_returns;

partial datasource catalog_returns_unified (
    raw(''' 'CATALOG' '''): sales_channel,
    CR_ORDER_NUMBER: ~order_id,
    CR_ITEM_SK: ~item.id,
    CR_RETURNED_DATE_SK: return_date.id,
    CR_RETURN_AMOUNT: return_amount,
    CR_RETURN_QUANTITY: return_quantity,
    CR_NET_LOSS: return_net_loss,
)
grain (sales_channel, order_id, item.id)
complete where sales_channel = 'CATALOG'
address memory.catalog_returns;

partial datasource store_returns_unified (
    raw(''' 'STORE' '''): sales_channel,
    SR_TICKET_NUMBER: ~order_id,
    SR_ITEM_SK: ~item.id,
    SR_RETURNED_DATE_SK: return_date.id,
    SR_RETURN_AMT: return_amount,
    SR_RETURN_QUANTITY: return_quantity,
    SR_NET_LOSS: return_net_loss,
)
grain (sales_channel, order_id, item.id)
complete where sales_channel = 'STORE'
address memory.store_returns;
