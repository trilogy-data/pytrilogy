    LEFT OUTER JOIN \"memory\".\"call_center\" as \"cr_call_center_call_center\" on \"cr_catalog_returns\".\"CR_CALL_CENTER_SK\" = \"cr_call_center_call_center\".\"CC_CALL_CENTER_SK\"
