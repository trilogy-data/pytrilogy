    \"store_sales_store_sales\".\"SS_STORE_SK\" as \"store_sales_store_id\",
    \"store_sales_store_sales\".\"SS_TICKET_NUMBER\" as \"store_sales_ticket_number\"
FROM
    \"memory\".\"store_sales\" as \"store_sales_store_sales\"
GROUP BY
    1,
    2,
    3,
    4,
    5,
    6),
yummy as (
SELECT
    \"store_sales_sale_address_customer_address\".\"CA_ADDRESS_SK\" as \"store_sales_sale_address_id\",
    \"store_sales_store_sales\".\"SS_CUSTOMER_SK\" as \"store_sales_customer_id\",
    \"store_sales_store_sales\".\"SS_TICKET_NUMBER\" as \"store_sales_ticket_number\",
    sum(\"store_sales_store_sales\".\"SS_EXT_LIST_PRICE\") as \"list_price\",
    sum(\"store_sales_store_sales\".\"SS_EXT_SALES_PRICE\") as \"extended_price\",
    sum(\"store_sales_store_sales\".\"SS_EXT_TAX\") as \"extended_tax\"
FROM
    \"memory\".\"store_sales\" as \"store_sales_store_sales\"
    INNER JOIN \"memory\".\"date_dim\" as \"store_sales_date_date\" on \"store_sales_store_sales\".\"SS_SOLD_DATE_SK\" = \"store_sales_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"store\" as \"store_sales_store_store\" on \"store_sales_store_sales\".\"SS_STORE_SK\" = \"store_sales_store_store\".\"S_STORE_SK\"
    INNER JOIN \"memory\".\"customer_address\" as \"store_sales_sale_address_customer_address\" on \"store_sales_store_sales\".\"SS_ADDR_SK\" = \"store_sales_sale_address_customer_address\".\"CA_ADDRESS_SK\"
    INNER JOIN \"memory\".\"household_demographics\" as \"store_sales_household_demographic_household_demographics\" on \"store_sales_store_sales\".\"SS_HDEMO_SK\" = \"store_sales_household_demographic_household_demographics\".\"HD_DEMO_SK\"
WHERE
    \"store_sales_date_date\".\"D_DOM\" >= 1 and \"store_sales_date_date\".\"D_DOM\" <= 2 and ( \"store_sales_household_demographic_household_demographics\".\"HD_DEP_COUNT\" = 4 or \"store_sales_household_demographic_household_demographics\".\"HD_VEHICLE_COUNT\" = 3 ) and cast(\"store_sales_date_date\".\"D_YEAR\" as int) in (1999,2000,2001) and \"store_sales_store_store\".\"S_CITY\" in ('Fairview','Midway')

GROUP BY
    1,
    2,
    3,
    \"store_sales_sale_address_customer_address\".\"CA_CITY\"),
uneven as (
SELECT
    \"abundant\".\"store_sales_ticket_number\" as \"store_sales_ticket_number\",
    \"store_sales_customer_address_customer_address\".\"CA_CITY\" as \"store_sales_customer_address_city\",
    \"store_sales_customer_customers\".\"C_CUSTOMER_SK\" as \"store_sales_customer_id\",
    \"store_sales_customer_customers\".\"C_FIRST_NAME\" as \"store_sales_customer_first_name\",
    \"store_sales_customer_customers\".\"C_LAST_NAME\" as \"store_sales_customer_last_name\",
    \"store_sales_sale_address_customer_address\".\"CA_ADDRESS_SK\" as \"store_sales_sale_address_id\",
    \"store_sales_sale_address_customer_address\".\"CA_CITY\" as \"store_sales_sale_address_city\"
FROM
    \"abundant\"
    INNER JOIN \"memory\".\"date_dim\" as \"store_sales_date_date\" on \"abundant\".\"store_sales_date_id\" = \"store_sales_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"store\" as \"store_sales_store_store\" on \"abundant\".\"store_sales_store_id\" = \"store_sales_store_store\".\"S_STORE_SK\"
    INNER JOIN \"memory\".\"customer\" as \"store_sales_customer_customers\" on \"abundant\".\"store_sales_customer_id\" = \"store_sales_customer_customers\".\"C_CUSTOMER_SK\"
    INNER JOIN \"memory\".\"customer_address\" as \"store_sales_sale_address_customer_address\" on \"abundant\".\"store_sales_sale_address_id\" = \"store_sales_sale_address_customer_address\".\"CA_ADDRESS_SK\"
    INNER JOIN \"memory\".\"customer_address\" as \"store_sales_customer_address_customer_address\" on \"store_sales_customer_customers\".\"C_CURRENT_ADDR_SK\" = \"store_sales_customer_address_customer_address\".\"CA_ADDRESS_SK\"
    INNER JOIN \"memory\".\"household_demographics\" as \"store_sales_household_demographic_household_demographics\" on \"abundant\".\"store_sales_household_demographic_id\" = \"store_sales_household_demographic_household_demographics\".\"HD_DEMO_SK\"
WHERE
    \"store_sales_date_date\".\"D_DOM\" >= 1 and \"store_sales_date_date\".\"D_DOM\" <= 2 and ( \"store_sales_household_demographic_household_demographics\".\"HD_DEP_COUNT\" = 4 or \"store_sales_household_demographic_household_demographics\".\"HD_VEHICLE_COUNT\" = 3 ) and cast(\"store_sales_date_date\".\"D_YEAR\" as int) in (1999,2000,2001) and \"store_sales_store_store\".\"S_CITY\" in ('Fairview','Midway')

GROUP BY
    1,
    2,
    3,
    4,
    5,
    6,
    7,
    \"store_sales_customer_address_customer_address\".\"CA_ADDRESS_SK\")
SELECT
    \"uneven\".\"store_sales_customer_last_name\" as \"store_sales_customer_last_name\",
    \"uneven\".\"store_sales_customer_first_name\" as \"store_sales_customer_first_name\",
    \"uneven\".\"store_sales_customer_address_city\" as \"store_sales_customer_address_city\",
    \"uneven\".\"store_sales_sale_address_city\" as \"bought_city\",
    \"uneven\".\"store_sales_ticket_number\" as \"store_sales_ticket_number\",
    \"yummy\".\"extended_price\" as \"extended_price\",
    \"yummy\".\"extended_tax\" as \"extended_tax\",
    \"yummy\".\"list_price\" as \"list_price\"
FROM
