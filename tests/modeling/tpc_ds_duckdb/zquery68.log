generated_sql = """

WITH 
highfalutin as (
SELECT
    \"customer_customers\".\"C_CURRENT_ADDR_SK\" as \"customer_current_address_sk\",
    \"customer_customers\".\"C_CUSTOMER_SK\" as \"customer_sk\",
    \"customer_customers\".\"C_FIRST_NAME\" as \"customer_first_name\",
    \"customer_customers\".\"C_LAST_NAME\" as \"customer_last_name\"
FROM
    \"memory\".\"customer\" as \"customer_customers\"
GROUP BY
    1,
    2,
    3,
    4),
yummy as (
SELECT
    \"store_sales_pos_address_customer_address\".\"CA_CITY\" as \"_bought_bought_city\",
    \"store_sales_store_sales\".\"SS_CUSTOMER_SK\" as \"store_sales_customer_sk\",
    \"store_sales_store_sales\".\"SS_TICKET_NUMBER\" as \"store_sales_ticket_number\",
    sum(\"store_sales_store_sales\".\"SS_EXT_LIST_PRICE\") as \"_bought_list_price\",
    sum(\"store_sales_store_sales\".\"SS_EXT_SALES_PRICE\") as \"_bought_extended_price\",
    sum(\"store_sales_store_sales\".\"SS_EXT_TAX\") as \"_bought_extended_tax\"
FROM
    \"memory\".\"store_sales\" as \"store_sales_store_sales\"
    INNER JOIN \"memory\".\"store\" as \"store_sales_store_store\" on \"store_sales_store_sales\".\"SS_STORE_SK\" = \"store_sales_store_store\".\"S_STORE_SK\"
    INNER JOIN \"memory\".\"date_dim\" as \"store_sales_sale_date_date\" on \"store_sales_store_sales\".\"SS_SOLD_DATE_SK\" = \"store_sales_sale_date_date\".\"D_DATE_SK\"
    INNER JOIN \"memory\".\"household_demographics\" as \"store_sales_pos_household_demographic_household_demographics\" on \"store_sales_store_sales\".\"SS_HDEMO_SK\" = \"store_sales_pos_household_demographic_household_demographics\".\"HD_DEMO_SK\"
    LEFT OUTER JOIN \"memory\".\"customer_address\" as \"store_sales_pos_address_customer_address\" on \"store_sales_store_sales\".\"SS_ADDR_SK\" = \"store_sales_pos_address_customer_address\".\"CA_ADDRESS_SK\"
WHERE
    \"store_sales_sale_date_date\".\"D_DOM\" BETWEEN 1 AND 2 and ( \"store_sales_pos_household_demographic_household_demographics\".\"HD_DEP_COUNT\" = 4 or \"store_sales_pos_household_demographic_household_demographics\".\"HD_VEHICLE_COUNT\" = 3 ) and (\"store_sales_sale_date_date\".\"D_YEAR\" is not null and \"store_sales_sale_date_date\".\"D_YEAR\" in (1999,2000,2001)) and (\"store_sales_store_store\".\"S_CITY\" is not null and \"store_sales_store_store\".\"S_CITY\" in ('Fairview','Midway')) and \"store_sales_store_sales\".\"SS_CUSTOMER_SK\" is not null

GROUP BY
    1,
    2,
    3),
cheerful as (
SELECT
    \"customer_current_address_customer_address\".\"CA_CITY\" as \"customer_current_address_city\",
    \"highfalutin\".\"customer_first_name\" as \"customer_first_name\",
    \"highfalutin\".\"customer_last_name\" as \"customer_last_name\",
    \"highfalutin\".\"customer_sk\" as \"bought_store_sales_customer_sk\",
    \"highfalutin\".\"customer_sk\" as \"customer_sk\"
FROM
    \"highfalutin\"
    INNER JOIN \"memory\".\"customer_address\" as \"customer_current_address_customer_address\" on \"highfalutin\".\"customer_current_address_sk\" = \"customer_current_address_customer_address\".\"CA_ADDRESS_SK\"),
concerned as (
SELECT
    \"yummy\".\"_bought_bought_city\" as \"bought_bought_city\",
    \"yummy\".\"_bought_extended_price\" as \"bought_extended_price\",
    \"yummy\".\"_bought_extended_tax\" as \"bought_extended_tax\",
    \"yummy\".\"_bought_list_price\" as \"bought_list_price\",
    \"yummy\".\"store_sales_customer_sk\" as \"bought_store_sales_customer_sk\",
    \"yummy\".\"store_sales_ticket_number\" as \"bought_store_sales_ticket_number\"
FROM
    \"yummy\")
SELECT
    \"cheerful\".\"customer_last_name\" as \"customer_last_name\",
    \"cheerful\".\"customer_first_name\" as \"customer_first_name\",
    \"cheerful\".\"customer_current_address_city\" as \"customer_current_address_city\",
    \"concerned\".\"bought_bought_city\" as \"bought_bought_city\",
    \"concerned\".\"bought_store_sales_ticket_number\" as \"bought_store_sales_ticket_number\",
    \"concerned\".\"bought_extended_price\" as \"bought_extended_price\",
    \"concerned\".\"bought_extended_tax\" as \"bought_extended_tax\",
    \"concerned\".\"bought_list_price\" as \"bought_list_price\"
FROM
    \"concerned\"
    INNER JOIN \"cheerful\" on \"concerned\".\"bought_store_sales_customer_sk\" = \"cheerful\".\"customer_sk\"
WHERE
    \"cheerful\".\"customer_current_address_city\" != \"concerned\".\"bought_bought_city\"

GROUP BY
    1,
    2,
    3,
    4,
    5,
    6,
    7,
    8
ORDER BY 
    \"cheerful\".\"customer_last_name\" asc nulls first,
    \"concerned\".\"bought_store_sales_ticket_number\" asc nulls first
LIMIT (100)"""
