    INNER JOIN \"yummy\" on \"uneven\".\"store_sales_customer_id\" = \"yummy\".\"store_sales_customer_id\" AND \"uneven\".\"store_sales_sale_address_id\" = \"yummy\".\"store_sales_sale_address_id\" AND \"uneven\".\"store_sales_ticket_number\" = \"yummy\".\"store_sales_ticket_number\"
WHERE
    \"uneven\".\"store_sales_customer_address_city\" != \"uneven\".\"store_sales_sale_address_city\"

ORDER BY 
    \"uneven\".\"store_sales_customer_last_name\" asc nulls first,
    \"uneven\".\"store_sales_ticket_number\" asc nulls first
LIMIT (100)"""
