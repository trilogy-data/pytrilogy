import date as date;

key id int;
unique property id.text_id string;
properties id (
    name string,
    employees int,
    floor_space int,
    hours string,
    store_manager string,
    market_id int,
    geography_class string,
    market_manager string,
    tax_percentage float,
    county string,
    state string,
    city string,
    zip string,
    market int,
);

datasource store (
    S_STORE_SK: id,
    S_STORE_ID: text_id,
    S_CLOSED_DATE: date.id,
    S_STORE_NAME: name,
    S_EMPLOYEES: employees,
    S_FLOOR_SPACE: floor_space,
    S_HOURS: hours,
    S_STORE_MANAGER: store_manager,
    S_MARKET_ID: market_id,
    S_GEOGRAPHY_CLASS: geography_class,
    S_MARKET_MANAGER: market_manager,
    S_TAX_PERCENTAGE: tax_percentage,
    S_CITY: city,
    S_STATE: state,
    S_COUNTY: county,
    S_ZIP: zip,
    S_MARKET_ID: market,
)
grain (id)
address memory.store;
