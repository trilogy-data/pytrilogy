import all_sales as sales;
import store_sales as ss;

# my_customers: customers who bought i_category='Women' & i_class='maternity'
# from catalog or web in Dec 1998
rowset my_customers <- where
    sales.channel in ('CATALOG', 'WEB')
    and sales.item.category = 'Women'
    and sales.item.class = 'maternity'
    and sales.date.year = 1998
    and sales.date.month_of_year = 12
    and sales.billing_customer.sk is not null
select
    sales.billing_customer.sk as my_cust_id,
;

# Per-customer store-sale revenue in the 3-month window after Dec 1998,
# restricted to store sales made at the SALE's own store located in the
# customer's current-address county AND state (ss.store, linked to the sale,
# not a cross-join over every store in that county/state).
rowset my_revenue <- where
    ss.customer.sk in my_customers.my_cust_id
    and ss.date.month_seq >= 1188
    and ss.date.month_seq <= 1190
    and ss.store.county = ss.customer.address.county
    and ss.store.state = ss.customer.address.state
    and ss.customer.sk is not null
select
    ss.customer.sk as rev_cust_id,
    sum(ss.ext_sales_price) as revenue,
;

auto segment <- round(my_revenue.revenue / 50, 0)::int;

select
    segment,
    count(my_revenue.rev_cust_id) as num_customers,
    segment * 50 as segment_base,
order by
    segment asc nulls first,
    num_customers asc nulls first,
    segment_base asc nulls first
limit 100
;
