# Time-of-day dimension (TPC-DS time_dim): hour / minute / second
# decomposition plus a meal_time bucket (breakfast/lunch/dinner). Imported
# by sales and returns models under aliases like time / return_time to
# answer time-of-day questions (q08, q70, q90).

key id int;

properties id (
    time_string string,
    time int,
    hour int,
    minute int,
    second int,
    meal_time string?,
);

datasource time (
    T_TIME_SK: id,
    T_TIME_ID: time_string,
    T_TIME: time,
    T_HOUR: hour,
    T_MINUTE: minute,
    T_SECOND: second,
    T_MEAL_TIME: meal_time,
)
grain (id)
address memory.time_dim;
