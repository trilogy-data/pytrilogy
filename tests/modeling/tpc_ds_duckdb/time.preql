# Time-of-day dimension (TPC-DS time_dim): hour / minute / second
# decomposition plus a meal_time bucket (breakfast/lunch/dinner). Imported
# by sales and returns models under aliases like time / return_time to
# answer time-of-day questions (q08, q70, q90).

key id int; # Surrogate key uniquely identifying a time-of-day row (seconds since midnight).

properties id (
    time_string string, # Stable textual time-of-day identifier (16-char alphanumeric in TPC-DS).
    time int, # Seconds elapsed since midnight (0-86399).
    hour int, # Hour of day (0-23).
    minute int, # Minute within the hour (0-59).
    second int, # Second within the minute (0-59).
    meal_time enum<string>['', 'breakfast', 'lunch', 'dinner']?, # Meal-time bucket; empty string for off-meal hours.
);

datasource time (
    T_TIME_SK: id,
    T_TIME_ID: time_string,
    T_TIME: time,
    T_HOUR: hour,
    T_MINUTE: minute,
    T_SECOND: second,
    T_MEAL_TIME: meal_time,
)
grain (id)
address memory.time_dim;
