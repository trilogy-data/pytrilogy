
key id int;
properties id (
    time_string string,
    time int,
    hour int,
    minute int,
    second int,
    meal_time string?,
);


datasource time (
    T_TIME_SK: id,
    T_TIME_ID: time_string,
    T_TIME: time,
    T_HOUR: hour,
    T_MINUTE: minute,
    T_SECOND: second,
    T_MEAL_TIME: meal_time,
)
grain (id)
address memory.time_dim;
