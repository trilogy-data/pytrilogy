    coalesce(\"analysis_catalog_sales\".\"CS_ITEM_SK\",\"analysis_item_items\".\"I_ITEM_SK\",\"analysis_store_returns\".\"SR_ITEM_SK\",\"analysis_store_sales\".\"SS_ITEM_SK\")),
