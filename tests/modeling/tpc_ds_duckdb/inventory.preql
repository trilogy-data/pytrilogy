# Inventory snapshots: quantity_on_hand for each item in each warehouse on
# each (typically weekly) snapshot date.

import warehouse as warehouse;
import item as item;
import date as date;

property <date.sk, item.sk, warehouse.sk>.quantity_on_hand int?; # Number of units of the item physically on hand in the warehouse at the snapshot date.

datasource warehouse_inventory (
    inv_warehouse_sk: ?warehouse.sk, # FK to warehouse the snapshot was taken for.
    inv_date_sk: date.sk, # FK to the date (snapshot date, typically weekly).
    inv_quantity_on_hand: quantity_on_hand,
    inv_item_sk: item.sk, # FK to the item being counted.
)
grain (date.sk, item.sk, warehouse.sk)
address memory.inventory;
