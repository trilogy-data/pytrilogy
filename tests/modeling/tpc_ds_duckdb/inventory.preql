# Inventory snapshots (TPC-DS inventory): quantity_on_hand at the
# (date, item, warehouse) grain. Used by q21, q22, q37 to assess stock
# levels and coverage across the warehouse network.

import warehouse as warehouse;
import item as item;
import date as date;

property <date.id, item.id, warehouse.id>.quantity_on_hand int;

datasource warehouse_inventory (
    inv_warehouse_sk: ?warehouse.id,
    inv_date_sk: date.id,
    inv_quantity_on_hand: quantity_on_hand,
    inv_item_sk: item.id,
)
grain (date.id, item.id, warehouse.id)
address memory.inventory;
