import catalog_sales as catalog_sales;
import web_sales as web_sales;
import date as date;

auto relevent_week_seq <- date.week_seq ? date.year in (2001, 2002);

def weekday_sales(weekday) -> sum(
    case
        when date.day_of_week = weekday then web_sales.ext_sales_price
        else 0.0::numeric(15,2)
    end
) by date.week_seq + sum(
    case
        when date.day_of_week = weekday then catalog_sales.ext_sales_price
        else 0.0::numeric(15,2)
    end
) by date.week_seq;

auto sunday_sales <- @weekday_sales(0);
auto monday_sales <- @weekday_sales(1);
auto tuesday_sales <- @weekday_sales(2);
auto wednesday_sales <- @weekday_sales(3);
auto thursday_sales <- @weekday_sales(4);
auto friday_sales <- @weekday_sales(5);
auto saturday_sales <- @weekday_sales(6);

def round_lag(sales) -> round(sales / (lead(sales, 53) over (order by date.week_seq asc)), 2);

where
    date.week_seq in relevent_week_seq
subset join date.sk = catalog_sales.date.sk
subset join date.sk = web_sales.date.sk
select
    date.week_seq,
    @round_lag(sunday_sales) as sunday_increase,
    @round_lag(monday_sales) as monday_increase,
    @round_lag(tuesday_sales) as tuesday_increase,
    @round_lag(wednesday_sales) as wednesday_increase,
    @round_lag(thursday_sales) as thursday_increase,
    @round_lag(friday_sales) as friday_increase,
    @round_lag(saturday_sales) as saturday_increase,
having
    sunday_increase is not null

order by
    date.week_seq asc nulls first
limit 100
;
