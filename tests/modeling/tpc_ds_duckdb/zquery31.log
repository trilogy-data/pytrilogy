     'WEB'  as \"sales_channel\",
    \"sales_web_sales_unified\".\"WS_EXT_SALES_PRICE\" as \"sales_ext_sales_price\",
    \"sales_date_date\".\"D_QOY\" as \"sales_date_quarter\",
    \"sales_date_date\".\"D_YEAR\" as \"sales_date_year\"
