# Promotion info: per-channel Y/N flags (email, catalog, event,
# direct-mail, TV, radio, press) and total cost (USD) per promotion.

import std.money;

key id int; # Surrogate key uniquely identifying a promotion.

properties id (
    text_id string, # Stable business identifier for the promotion (16-char alphanumeric).
    channel_email enum<string>['Y', 'N']?, # 'Y' if the promotion ran in the email channel, else 'N'.
    channel_catalog enum<string>['Y', 'N']?, # 'Y' if the promotion ran in the printed-catalog channel, else 'N'.
    channel_event enum<string>['Y', 'N']?, # 'Y' if the promotion ran via in-person events, else 'N'.
    channel_dmail enum<string>['Y', 'N']?, # 'Y' if the promotion ran in the direct-mail channel, else 'N'.
    channel_tv enum<string>['Y', 'N']?, # 'Y' if the promotion ran on TV, else 'N'.
    channel_radio enum<string>['Y', 'N']?, # 'Y' if the promotion ran on radio, else 'N'.
    channel_press enum<string>['Y', 'N']?, # 'Y' if the promotion ran in the press channel, else 'N'.
    cost numeric::usd, # Total cost of running the promotion in USD.
);

datasource promotion (
    P_PROMO_SK: id,
    P_PROMO_ID: text_id,
    P_COST: cost,
    P_CHANNEL_EMAIL: channel_email,
    P_CHANNEL_EVENT: channel_event,
    P_CHANNEL_CATALOG: channel_catalog,
    P_CHANNEL_DMAIL: channel_dmail,
    P_CHANNEL_TV: channel_tv,
    P_CHANNEL_RADIO: channel_radio,
    P_CHANNEL_PRESS: channel_press,
)
grain (id)
address memory.promotion;
