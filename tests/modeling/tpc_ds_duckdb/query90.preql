import web_sales as ws;


auto amc <- sum(count(ws.item.id ?
    ws.time.hour between 8 and 9) by ws.order_number);

auto pmc <- sum(count(ws.item.id ?
    ws.time.hour between 19 and 20) by ws.order_number);

WHERE ws.ship_household_demographic.dependent_count = 6
    and ws.web_page.char_count between 5000 and 5200
    and ws.time.hour in (8, 9, 19, 20)
SELECT
    case when pmc = 0 then null else cast(amc as numeric(15, 4)) / cast(pmc as numeric(15, 4)) end -> am_pm_ratio,
ORDER BY
    am_pm_ratio asc nulls first
LIMIT 100;
