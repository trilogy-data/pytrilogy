    \"store_sales_date_date\".\"D_DOM\" >= 1 and \"store_sales_date_date\".\"D_DOM\" <= 2 and cast(\"store_sales_date_date\".\"D_YEAR\" as int) in (1999,2000,2001) and \"store_sales_store_store\".\"S_COUNTY\" in ('Orange County','Bronx County','Franklin Parish','Williamson County') and ( \"store_sales_household_demographic_household_demographics\".\"HD_BUY_POTENTIAL\" = '>10000' or \"store_sales_household_demographic_household_demographics\".\"HD_BUY_POTENTIAL\" = 'Unknown' ) and \"store_sales_household_demographic_household_demographics\".\"HD_VEHICLE_COUNT\" > 0 and ( CASE
