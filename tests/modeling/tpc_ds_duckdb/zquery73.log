WHERE
    \"vacuous\".\"cnt\" >= 1 and \"vacuous\".\"cnt\" <= 5

ORDER BY 
    \"vacuous\".\"cnt\" desc,
    \"questionable\".\"store_sales_customer_last_name\" asc,
    \"questionable\".\"store_sales_ticket_number\" asc"""
