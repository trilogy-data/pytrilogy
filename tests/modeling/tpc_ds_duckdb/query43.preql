import store_sales as store_sales;

WHERE
    store_sales.store.gmt_offset = -5 and store_sales.date.year = 2000
SELECT
    store_sales.store.name,
    store_sales.store.text_id,
    sum(filter store_sales.sales_price where store_sales.date.day_name = 'Sunday') -> sun_sales,
    sum(filter store_sales.sales_price where store_sales.date.day_name = 'Monday') -> mon_sales,
    sum(filter store_sales.sales_price where store_sales.date.day_name = 'Tuesday') -> tue_sales,
    sum(filter store_sales.sales_price where store_sales.date.day_name = 'Wednesday') -> wed_sales,
    sum(filter store_sales.sales_price where store_sales.date.day_name = 'Thursday') -> thu_sales,
    sum(filter store_sales.sales_price where store_sales.date.day_name = 'Friday') -> fri_sales,
    sum(filter store_sales.sales_price where store_sales.date.day_name = 'Saturday') -> sat_sales,
ORDER BY
    store_sales.store.name asc,
    store_sales.store.text_id asc,
    sun_sales asc,
    mon_sales asc,
    tue_sales asc,
    wed_sales asc,
    thu_sales asc,
    fri_sales asc,
    sat_sales asc
LIMIT 100
;
