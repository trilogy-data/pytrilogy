# For cross-channel questions, prefer `all_sales` (combines this with catalog_sales and web_sales).
# Store channel sales AND returns at (item, ticket_number) grain — the single
# model for all store-channel analysis, including returns-only questions.
# Sales: quantity, sales / list / wholesale / extended prices, discount and
# coupon amounts, net paid, extended tax, net profit. Returns (NULL on lines
# never returned): is_returned flag, refund amount / quantity / tax / fee /
# ship cost / refunded cash / reversed charge / store credit / net loss, plus
# return date/time/store/customer/reason/demographics/address.
#

import std.money;

import item as item;
import date as sale_date;
import date as return_date;
import time as sale_time;
import time as return_time;
import customer as customer; # the customer account tied to the order
import customer as return_customer; # the customer account tied to the return
import promotion as promotion;
import customer_demographic as pos_customer_demographic; # the customer demographics recorded on this sale (the buyer's demographic profile at the time of purchase)
import customer_demographic as return_customer_demographic; # the customer demographics recorded on the return (the returner's demographic profile at return time)
import household_demographic as pos_household_demographic; # the household demographics recorded on this sale (the buyer's household at the time of purchase)
import household_demographic as return_household_demographic; # the household demographics recorded on the return (the returner's household at return time)
import store as store;
import store as return_store;
import address as pos_address; # the customer's address as recorded on the sale (the purchase-time address)
import address as return_address; # the returning customer's address as recorded on the return
import reason as return_reason;

key ticket_number int; # Store-sale ticket (receipt) number identifying a single in-store transaction.

properties <ticket_number, item.sk> (
    quantity int, # Number of units of the item sold on this ticket line.
    sales_price numeric::usd, # Per-unit "unit price" actually charged for ONE unit. The whole-line total is ext_sales_price (the "total price").
    list_price numeric::usd, # Per-unit list price before discounts.
    ext_sales_price numeric(15,2)::usd, # Whole-line "total price" = sales_price x quantity, the extended line amount. The per-unit price is sales_price (the "unit price").
    ext_wholesale_cost numeric::usd, # Line-extended wholesale cost.
    ext_list_price numeric::usd, # Line-extended list price.
    ext_discount_amount numeric::usd, # Extended discount applied to the line.
    coupon_amt numeric::usd, # Coupon/credit amount applied to the line.
    net_profit numeric::usd, # Reported net profit for the line. Distinct from the derived `profit` (extended gross value); use net_profit for "net profit" questions.
    _returned_ticket int?, # The store_returns ticket number matched to this line.
    net_paid numeric::usd, # Net amount paid by the customer for the line, excluding tax.
    ext_tax numeric::usd?, # Extended sales tax on the line.
    wholesale_cost numeric::usd, # Per-unit wholesale acquisition cost.
    return_amount numeric::usd?, # Refund amount if the item on this line was returned.
    return_quantity int?, # Number of units returned for this line.
    return_net_loss numeric::usd?, # Net financial loss on the return for this line.
    return_tax numeric::usd?, # Sales tax refunded on the return.
    return_amount_inc_tax numeric::usd?, # Refund amount including tax.
    return_fee numeric::usd?, # Fee charged on the return.
    return_ship_cost numeric::usd?, # Shipping cost associated with the return.
    refunded_cash numeric::usd?, # Cash portion of the refund.
    reversed_charge numeric::usd?, # Refund portion credited back to the payment card.
    store_credit numeric::usd?, # Refund portion issued as store credit.
    row_counter int, # Constant 1, used for unconditional row counts.
);

auto profit <- ext_list_price - ext_wholesale_cost - ext_discount_amount + ext_sales_price; # Derived line "gross value" (extended list - extended wholesale - extended discount + extended sales). NOT the reported net_profit column.

auto line_item <- concat(ticket_number::string, '-', item.sk::string); # Unique line-item identifier (one ticket + item). Count line items with count(line_item); do NOT use count(ticket_number), a receipt key that dedups and undercounts multi-item tickets.
auto line_item_count<- sum(row_counter); # Number of line items (= count(line_item)); kept for queries that reference it.
auto is_returned <- _returned_ticket is not null; # True if this ticket line was later returned, else False.

datasource store_sales (
    raw('''1'''): row_counter,
    SS_SOLD_DATE_SK: ?sale_date.sk, # FK to date the sale occurred (optional in source data).
    SS_SOLD_TIME_SK: ?sale_time.sk, # FK to time-of-day the sale occurred.
    SS_CUSTOMER_SK: ?customer.sk, # FK to the purchasing customer (optional — anonymous sales allowed).
    SS_CDEMO_SK: ?pos_customer_demographic.sk, # FK to the customer's demographic profile at time of sale.
    SS_HDEMO_SK: ?pos_household_demographic.sk, # FK to the customer's household profile at time of sale.
    SS_TICKET_NUMBER: ticket_number,
    SS_ITEM_SK: item.sk, # FK to the item sold.
    SS_SALES_PRICE: sales_price,
    SS_LIST_PRICE: list_price,
    SS_EXT_SALES_PRICE: ext_sales_price,
    SS_EXT_LIST_PRICE: ext_list_price,
    SS_EXT_WHOLESALE_COST: ext_wholesale_cost,
    SS_EXT_DISCOUNT_AMT: ext_discount_amount,
    SS_NET_PROFIT: net_profit,
    SS_PROMO_SK: ?promotion.sk, # FK to the promotion applied to the line, if any.
    SS_QUANTITY: quantity,
    SS_COUPON_AMT: coupon_amt,
    SS_STORE_SK: ?store.sk, # FK to the store the sale occurred at.
    SS_NET_PAID: net_paid,
    SS_EXT_TAX: ext_tax,
    SS_WHOLESALE_COST: wholesale_cost,
    SS_ADDR_SK: ?pos_address.sk, # FK to the customer's address at time of sale.
)
grain (item.sk, ticket_number)
address memory.store_sales;

datasource store_returns (
    SR_RETURNED_DATE_SK: return_date.sk, # FK to date the return occurred.
    SR_RETURN_TIME_SK: return_time.sk, # FK to time-of-day the return was processed.
    SR_ITEM_SK: ~item.sk,
    SR_CUSTOMER_SK: ?return_customer.sk, # FK to the customer returning the item (may differ from purchaser); nullable — some returns record no customer.
    SR_CDEMO_SK: ?return_customer_demographic.sk, # FK to the returning customer's demographic profile at return time.
    SR_HDEMO_SK: ?return_household_demographic.sk, # FK to the returning customer's household profile at return time.
    SR_ADDR_SK: ?return_address.sk, # FK to the returning customer's address at return time.
    SR_RETURN_AMT: return_amount,
    SR_RETURN_QUANTITY: return_quantity,
    SR_RETURN_TAX: return_tax,
    SR_RETURN_AMT_INC_TAX: return_amount_inc_tax,
    SR_FEE: return_fee,
    SR_RETURN_SHIP_COST: return_ship_cost,
    SR_REFUNDED_CASH: refunded_cash,
    SR_REVERSED_CHARGE: reversed_charge,
    SR_STORE_CREDIT: store_credit,
    SR_TICKET_NUMBER: ~ticket_number,
    SR_STORE_SK: ?return_store.sk, # FK to the store the return was processed at; nullable — some returns record no store.
    SR_REASON_SK: return_reason.sk, # FK to the return-reason code.
    SR_NET_LOSS: return_net_loss,
    SR_TICKET_NUMBER: _returned_ticket,
)
grain (item.sk, ticket_number)
address memory.store_returns;
