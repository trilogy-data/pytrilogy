import income_band as income_band;

key id int;
properties id (
    income_band_id int,
    buy_potential string,
    dependent_count int,
    vehicle_count int,
);


datasource household_demographics (
    HD_DEMO_SK: id,
    HD_INCOME_BAND_SK: income_band_id,
    HD_INCOME_BAND_SK: income_band.id,
    HD_BUY_POTENTIAL: buy_potential,
    HD_DEP_COUNT: dependent_count,
    HD_VEHICLE_COUNT: vehicle_count,
)
grain (id)
address memory.household_demographics;
