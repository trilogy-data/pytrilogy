# Household demographic info: buy_potential bucket, dependent count,
# vehicle count, and a household income band identifier.

import income_band as income_band;

key sk int; # Surrogate key uniquely identifying a household demographic profile.

properties sk (
    income_band_id int, # FK to the income_band defining the household's income range.
    buy_potential enum<string>['0-500', '501-1000', '1001-5000', '5001-10000', '>10000', 'Unknown'], # Estimated annual spend bucket (USD).
    dependent_count int, # Total dependents in the household (0-9).
    vehicle_count int, # Number of vehicles in the household (-1 = unknown, 0-4 otherwise).
);

datasource household_demographics (
    HD_DEMO_SK: sk,
    HD_INCOME_BAND_SK: income_band_id,
    HD_INCOME_BAND_SK: income_band.sk,
    HD_BUY_POTENTIAL: buy_potential,
    HD_DEP_COUNT: dependent_count,
    HD_VEHICLE_COUNT: vehicle_count,
)
grain (sk)
address memory.household_demographics;
