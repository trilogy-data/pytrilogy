    INNER JOIN \"memory\".\"customer\" as \"catalog_sales_billing_customer_customers\" on \"catalog_sales_catalog_sales\".\"CS_BILL_CUSTOMER_SK\" = \"catalog_sales_billing_customer_customers\".\"C_CUSTOMER_SK\"
WHERE
    \"catalog_sales_sale_date_date\".\"D_MONTH_SEQ\" BETWEEN 1200 AND 1211 and \"catalog_sales_catalog_sales\".\"CS_BILL_CUSTOMER_SK\" is not null

