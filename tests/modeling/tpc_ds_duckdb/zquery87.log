    INNER JOIN \"memory\".\"customer\" as \"web_sales_billing_customer_customers\" on \"web_sales_web_sales\".\"WS_BILL_CUSTOMER_SK\" = \"web_sales_billing_customer_customers\".\"C_CUSTOMER_SK\"
WHERE
    \"web_sales_sale_date_date\".\"D_MONTH_SEQ\" BETWEEN 1200 AND 1211 and \"web_sales_web_sales\".\"WS_BILL_CUSTOMER_SK\" is not null

GROUP BY
    1,
    2),
abhorrent as (
SELECT
    \"cheerful\".\"store_sales_customer_last_name\" as \"_tvf_union_last_name\",
    \"cheerful\".\"store_sales_customer_first_name\" as \"_tvf_union_first_name\",
    \"cheerful\".\"store_sales_sale_date_date\" as \"_tvf_union_sale_date\"
FROM
    \"wakeful\"
    LEFT OUTER JOIN \"memory\".\"date_dim\" as \"store_sales_date_date\" on \"wakeful\".\"store_sales_date_sk\" = \"store_sales_date_date\".\"D_DATE_SK\"
    LEFT OUTER JOIN \"memory\".\"customer\" as \"store_sales_customer_customers\" on \"wakeful\".\"store_sales_customer_sk\" = \"store_sales_customer_customers\".\"C_CUSTOMER_SK\"
