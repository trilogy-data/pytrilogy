    INNER JOIN \"memory\".\"customer\" as \"store_sales_customer_customers\" on \"store_sales_store_sales\".\"SS_CUSTOMER_SK\" = \"store_sales_customer_customers\".\"C_CUSTOMER_SK\"
    INNER JOIN \"memory\".\"date_dim\" as \"store_sales_sale_date_date\" on \"store_sales_store_sales\".\"SS_SOLD_DATE_SK\" = \"store_sales_sale_date_date\".\"D_DATE_SK\"
WHERE
    \"store_sales_sale_date_date\".\"D_MONTH_SEQ\" BETWEEN 1200 AND 1211 and \"store_sales_store_sales\".\"SS_CUSTOMER_SK\" is not null

GROUP BY
    1,
    2),
