generated_sql = """

WITH 
highfalutin as (
SELECT
    \"customer_customers\".\"C_CURRENT_ADDR_SK\" as \"customer_address_sk\",
    \"customer_customers\".\"C_CURRENT_CDEMO_SK\" as \"customer_demographics_sk\",
    \"customer_customers\".\"C_CURRENT_HDEMO_SK\" as \"customer_household_demographic_sk\",
    \"customer_customers\".\"C_CUSTOMER_ID\" as \"customer_id\",
    \"customer_customers\".\"C_FIRST_NAME\" as \"customer_first_name\",
    \"customer_customers\".\"C_LAST_NAME\" as \"customer_last_name\"
FROM
    \"memory\".\"customer\" as \"customer_customers\"
WHERE
    \"customer_customers\".\"C_CURRENT_CDEMO_SK\" is not null and \"customer_customers\".\"C_CURRENT_HDEMO_SK\" is not null

GROUP BY
    1,
    2,
    3,
    4,
    5,
    6)
SELECT
    \"highfalutin\".\"customer_id\" as \"customer_id\",
    CONCAT(coalesce(\"highfalutin\".\"customer_last_name\",''), ', ', coalesce(\"highfalutin\".\"customer_first_name\",'')) as \"customername\"
FROM
    \"highfalutin\"
    INNER JOIN \"memory\".\"customer_address\" as \"customer_address_customer_address\" on \"highfalutin\".\"customer_address_sk\" = \"customer_address_customer_address\".\"CA_ADDRESS_SK\"
    INNER JOIN \"memory\".\"store_returns\" as \"returns_store_returns\" on \"highfalutin\".\"customer_demographics_sk\" = \"returns_store_returns\".\"SR_CDEMO_SK\"
    INNER JOIN \"memory\".\"household_demographics\" as \"customer_household_demographic_household_demographics\" on \"highfalutin\".\"customer_household_demographic_sk\" = \"customer_household_demographic_household_demographics\".\"HD_DEMO_SK\"
    INNER JOIN \"memory\".\"income_band\" as \"customer_household_demographic_income_band_income_band\" on \"customer_household_demographic_household_demographics\".\"HD_INCOME_BAND_SK\" = \"customer_household_demographic_income_band_income_band\".\"IB_INCOME_BAND_SK\"
WHERE
    \"customer_address_customer_address\".\"CA_CITY\" = 'Edgewood' and coalesce(\"highfalutin\".\"customer_demographics_sk\",\"returns_store_returns\".\"SR_CDEMO_SK\") is not null and coalesce(\"customer_household_demographic_household_demographics\".\"HD_DEMO_SK\",\"highfalutin\".\"customer_household_demographic_sk\") is not null and \"customer_household_demographic_income_band_income_band\".\"IB_LOWER_BOUND\" >= 38128 and \"customer_household_demographic_income_band_income_band\".\"IB_UPPER_BOUND\" <= 38128 + 50000 and \"returns_store_returns\".\"SR_TICKET_NUMBER\" is not null

GROUP BY
    1,
    2,
    \"returns_store_returns\".\"SR_ITEM_SK\",
    \"returns_store_returns\".\"SR_TICKET_NUMBER\"
ORDER BY 
    \"highfalutin\".\"customer_id\" asc nulls first
LIMIT (100)"""
