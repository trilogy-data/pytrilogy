    \"customer_household_demographic_income_band_income_band\".\"IB_LOWER_BOUND\" as \"customer_household_demographic_income_band_lower_bound\",
    \"customer_household_demographic_income_band_income_band\".\"IB_UPPER_BOUND\" as \"customer_household_demographic_income_band_upper_bound\",
    \"thoughtful\".\"_virt_presence_5269535758143238\" as \"_virt_presence_5269535758143238\",
    \"thoughtful\".\"ss__returned_ticket\" as \"ss__returned_ticket\",
    \"thoughtful\".\"ss_is_returned\" as \"ss_is_returned\",
    \"thoughtful\".\"ss_item_sk\" as \"ss_item_sk\",
    \"thoughtful\".\"ss_ticket_number\" as \"ss_ticket_number\",
    coalesce(\"customer_customers\".\"C_CURRENT_CDEMO_SK\",\"thoughtful\".\"customer_demographics_sk\") as \"customer_demographics_sk\",
    coalesce(\"customer_customers\".\"C_CURRENT_HDEMO_SK\",\"customer_household_demographic_household_demographics\".\"HD_DEMO_SK\") as \"customer_household_demographic_sk\"
FROM
    \"memory\".\"customer\" as \"customer_customers\"
    INNER JOIN \"thoughtful\" on \"customer_customers\".\"C_CURRENT_CDEMO_SK\" is not distinct from \"thoughtful\".\"customer_demographics_sk\"
    INNER JOIN \"memory\".\"customer_address\" as \"customer_address_customer_address\" on \"customer_customers\".\"C_CURRENT_ADDR_SK\" = \"customer_address_customer_address\".\"CA_ADDRESS_SK\"
    INNER JOIN \"memory\".\"household_demographics\" as \"customer_household_demographic_household_demographics\" on \"customer_customers\".\"C_CURRENT_HDEMO_SK\" = \"customer_household_demographic_household_demographics\".\"HD_DEMO_SK\"
    INNER JOIN \"memory\".\"income_band\" as \"customer_household_demographic_income_band_income_band\" on \"customer_household_demographic_household_demographics\".\"HD_INCOME_BAND_SK\" = \"customer_household_demographic_income_band_income_band\".\"IB_INCOME_BAND_SK\"
WHERE
    \"customer_address_customer_address\".\"CA_CITY\" = 'Edgewood' and \"thoughtful\".\"_virt_presence_5269535758143238\" is not null and \"customer_household_demographic_income_band_income_band\".\"IB_LOWER_BOUND\" >= 38128 and \"customer_household_demographic_income_band_income_band\".\"IB_UPPER_BOUND\" <= 38128 + 50000 and \"thoughtful\".\"ss_is_returned\"
)
SELECT
    \"cooperative\".\"customer_id\" as \"customer_id\",
    CONCAT(coalesce(\"cooperative\".\"customer_last_name\",''), ', ', coalesce(\"cooperative\".\"customer_first_name\",'')) as \"customername\"
FROM
    \"cooperative\"
    LEFT OUTER JOIN \"memory\".\"store_sales\" as \"ss_store_sales\" on \"cooperative\".\"ss_item_sk\" = \"ss_store_sales\".\"SS_ITEM_SK\" AND \"cooperative\".\"ss_ticket_number\" = \"ss_store_sales\".\"SS_TICKET_NUMBER\"
ORDER BY 
    \"cooperative\".\"customer_id\" asc nulls first
LIMIT (100)"""
