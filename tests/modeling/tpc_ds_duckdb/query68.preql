import physical_sales as physical_sales;
import customer as customer;

rowset bought <- where
    physical_sales.date.day_of_month between 1 and 2
    and (
        physical_sales.household_demographic.dependent_count = 4
        or physical_sales.household_demographic.vehicle_count = 3
    )
    and physical_sales.date.year in (1999, 2000, 2001)
    and physical_sales.store.city in ('Fairview', 'Midway')
    and physical_sales.customer.id is not null
select
    physical_sales.customer.id,
    physical_sales.ticket_number,
    physical_sales.sale_address.city as bought_city,
    sum(physical_sales.ext_sales_price) as extended_price,
    sum(physical_sales.ext_tax) as extended_tax,
    sum(physical_sales.ext_list_price) as list_price,
;

rowset cust <- select
    customer.id,
    customer.last_name,
    customer.first_name,
    customer.address.city as current_city,
;

inner join bought.physical_sales.customer.id = cust.customer.id
select
    cust.customer.last_name,
    cust.customer.first_name,
    cust.current_city,
    bought.bought_city,
    bought.physical_sales.ticket_number,
    bought.extended_price,
    bought.extended_tax,
    bought.list_price,
having
    cust.current_city != bought.bought_city
order by
    cust.customer.last_name asc nulls first,
    bought.physical_sales.ticket_number asc nulls first
limit 100
;
