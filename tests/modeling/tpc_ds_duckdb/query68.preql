import store_sales as store_sales;

WHERE
    store_sales.date.day_of_month between 1 and 2
    and (store_sales.household_demographic.dependent_count = 4 or store_sales.household_demographic.vehicle_count = 3)
    and store_sales.date.year in (1999, 2000, 2001)
    and store_sales.store.city in ('Fairview', 'Midway')
    and store_sales.customer.address.city != store_sales.sale_address.city
SELECT
    --store_sales.customer.id,
    store_sales.customer.last_name,
    store_sales.customer.first_name,
    store_sales.customer.address.city,
    store_sales.sale_address.city -> bought_city,
    store_sales.ticket_number,
    sum(store_sales.ext_sales_price) by store_sales.customer.id, store_sales.ticket_number -> extended_price,
    sum(store_sales.ext_tax) by store_sales.customer.id, store_sales.ticket_number -> extended_tax,
    sum(store_sales.ext_list_price) by store_sales.customer.id, store_sales.ticket_number -> list_price
ORDER BY
    store_sales.customer.last_name asc nulls first,
    store_sales.ticket_number asc nulls first
LIMIT 100;
