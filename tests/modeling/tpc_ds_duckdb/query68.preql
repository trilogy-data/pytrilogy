import store_sales as store_sales;
import customer as customer;

rowset bought <- where
    store_sales.sale_date.day_of_month between 1 and 2
    and (
        store_sales.pos_household_demographic.dependent_count = 4
        or store_sales.pos_household_demographic.vehicle_count = 3
    )
    and store_sales.sale_date.year in (1999, 2000, 2001)
    and store_sales.store.city in ('Fairview', 'Midway')
    and store_sales.customer.sk is not null
select
    store_sales.customer.sk,
    store_sales.ticket_number,
    store_sales.pos_address.city as bought_city,
    sum(store_sales.ext_sales_price) as extended_price,
    sum(store_sales.ext_tax) as extended_tax,
    sum(store_sales.ext_list_price) as list_price,
;

subset join customer.sk = bought.store_sales.customer.sk
select
    customer.last_name,
    customer.first_name,
    customer.current_address.city,
    bought.bought_city,
    bought.store_sales.ticket_number,
    bought.extended_price,
    bought.extended_tax,
    bought.list_price,
having
    customer.current_address.city != bought.bought_city
order by
    customer.last_name asc nulls first,
    bought.store_sales.ticket_number asc nulls first
limit 100
;
