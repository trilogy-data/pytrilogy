generated_sql = """

WITH 
thoughtful as (
SELECT
    \"sales_catalog_sales_unified\".\"CS_BILL_CUSTOMER_SK\" as \"sales_billing_customer_sk\",
     'CATALOG'  as \"sales_channel\",
    \"sales_catalog_sales_unified\".\"CS_SOLD_DATE_SK\" as \"sales_sale_date_sk\"
FROM
    \"memory\".\"catalog_sales\" as \"sales_catalog_sales_unified\"
UNION ALL
SELECT
    \"sales_store_sales_unified\".\"SS_CUSTOMER_SK\" as \"sales_billing_customer_sk\",
     'STORE'  as \"sales_channel\",
    \"sales_store_sales_unified\".\"SS_SOLD_DATE_SK\" as \"sales_sale_date_sk\"
FROM
    \"memory\".\"store_sales\" as \"sales_store_sales_unified\"
UNION ALL
SELECT
    \"sales_web_sales_unified\".\"WS_BILL_CUSTOMER_SK\" as \"sales_billing_customer_sk\",
     'WEB'  as \"sales_channel\",
    \"sales_web_sales_unified\".\"WS_SOLD_DATE_SK\" as \"sales_sale_date_sk\"
FROM
    \"memory\".\"web_sales\" as \"sales_web_sales_unified\"),
questionable as (
SELECT
    \"sales_billing_customer_customers\".\"C_FIRST_NAME\" as \"sales_billing_customer_first_name\",
    \"sales_billing_customer_customers\".\"C_LAST_NAME\" as \"sales_billing_customer_last_name\",
    \"sales_sale_date_date\".\"D_MONTH_SEQ\" as \"sales_sale_date_month_seq\",
    \"thoughtful\".\"sales_billing_customer_sk\" as \"sales_billing_customer_sk\",
    \"thoughtful\".\"sales_channel\" as \"sales_channel\",
    cast(\"sales_sale_date_date\".\"D_DATE\" as date) as \"sales_sale_date_date\"
FROM
    \"thoughtful\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_sale_date_date\" on \"thoughtful\".\"sales_sale_date_sk\" = \"sales_sale_date_date\".\"D_DATE_SK\"
    LEFT OUTER JOIN \"memory\".\"customer\" as \"sales_billing_customer_customers\" on \"thoughtful\".\"sales_billing_customer_sk\" = \"sales_billing_customer_customers\".\"C_CUSTOMER_SK\"
WHERE
    \"sales_sale_date_date\".\"D_MONTH_SEQ\" BETWEEN 1200 AND 1200 + 11

GROUP BY
    1,
    2,
    3,
    4,
    5,
    6,
    \"thoughtful\".\"sales_sale_date_sk\"),
uneven as (
SELECT
    sum(CASE
	WHEN \"questionable\".\"sales_channel\" = 'CATALOG' and \"questionable\".\"sales_sale_date_month_seq\" BETWEEN 1200 AND 1200 + 11 and \"questionable\".\"sales_billing_customer_sk\" is not null THEN 1
	ELSE 0
	END) as \"catalog_in_window\",
    sum(CASE
	WHEN \"questionable\".\"sales_channel\" = 'STORE' and \"questionable\".\"sales_sale_date_month_seq\" BETWEEN 1200 AND 1200 + 11 and \"questionable\".\"sales_billing_customer_sk\" is not null THEN 1
	ELSE 0
	END) as \"store_in_window\",
    sum(CASE
	WHEN \"questionable\".\"sales_channel\" = 'WEB' and \"questionable\".\"sales_sale_date_month_seq\" BETWEEN 1200 AND 1200 + 11 and \"questionable\".\"sales_billing_customer_sk\" is not null THEN 1
	ELSE 0
	END) as \"web_in_window\"
FROM
    \"questionable\"
GROUP BY
    \"questionable\".\"sales_billing_customer_first_name\",
    \"questionable\".\"sales_billing_customer_last_name\",
    \"questionable\".\"sales_sale_date_date\")
SELECT
    sum(CASE
	WHEN \"uneven\".\"store_in_window\" > 0 and \"uneven\".\"catalog_in_window\" > 0 and \"uneven\".\"web_in_window\" > 0 THEN 1
	ELSE 0
	END) as \"cnt\"
FROM
    \"uneven\"
LIMIT (100)"""
