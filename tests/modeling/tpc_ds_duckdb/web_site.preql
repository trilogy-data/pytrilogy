# Web site info: operator/company associated with each web storefront.

key sk int; # Surrogate key uniquely identifying a web site.

properties sk (
    id string, # Stable business identifier for the web site (16-char alphanumeric).
    company_name string, # Operating company name for the web site.
    name string?, # Display name of the web site.
);

datasource web_site (
    web_site_sk: sk,
    web_site_id: id,
    web_company_name: company_name,
    web_name: name,
)
grain (sk)
address memory.web_site;
