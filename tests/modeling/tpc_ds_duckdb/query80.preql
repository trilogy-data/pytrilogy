import all_sales as sales;

auto channel_label <- case
    when sales.channel = 'STORE' then 'store channel'
    when sales.channel = 'CATALOG' then 'catalog channel'
    when sales.channel = 'WEB' then 'web channel'
    else null
end;
auto id_label <- case
    when sales.channel = 'STORE' then 'store' || sales.channel_dim_text_id
    when sales.channel = 'CATALOG' then 'catalog_page' || sales.channel_dim_text_id
    when sales.channel = 'WEB' then 'web_site' || sales.channel_dim_text_id
    else null
end;
auto profit_minus_loss <- sales.net_profit - coalesce(sales.return_net_loss, 0);

where
    sales.date.date >= '2000-08-23'::date
    and sales.date.date <= '2000-09-22'::date
    and sales.item.current_price > 50
    and sales.promotion.channel_tv = 'N'
    and sales.channel_dim_text_id is not null
select
    channel_label as channel,
    id_label as sk,
    sum(sales.ext_sales_price) as sales_total,
    sum(coalesce(sales.return_amount, 0)) as returns_total,
    sum(profit_minus_loss) as profit_total,
by rollup (channel_label, id_label)
order by
    channel asc nulls first,
    sk asc nulls first
limit 100
;
