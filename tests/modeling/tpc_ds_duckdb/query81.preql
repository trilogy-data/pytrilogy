import catalog_sales as cs;

# Non-rowset equivalent of the rowset form: the key-join shape achieved by
# grouping the aggregate to (return_address.state, customer.sk). The year/state
# filter is bound *inside* the conditional sum because a plain sum + a row-grain
# WHERE year=2000 loses the filter from the customer-grain aggregate.
auto customer_state <- sum(cs.return_amount_inc_tax ? cs.return_date.year = 2000 and cs.return_address.state is not null)
    by cs.return_address.state, cs.return_customer.sk;
auto scaled_state <- 1.2 * avg(customer_state) by cs.return_address.state;

where
    customer_state > scaled_state
    and cs.return_customer.current_address.state = 'GA'
    and cs.return_address.state is not null
select
    --cs.return_customer.sk,
    cs.return_customer.id,
    cs.return_customer.salutation,
    cs.return_customer.first_name,
    cs.return_customer.last_name,
    cs.return_customer.current_address.street_number,
    cs.return_customer.current_address.street_name,
    cs.return_customer.current_address.street_type,
    cs.return_customer.current_address.suite_number,
    cs.return_customer.current_address.city,
    cs.return_customer.current_address.county,
    cs.return_customer.current_address.state,
    cs.return_customer.current_address.zip,
    cs.return_customer.current_address.country,
    cs.return_customer.current_address.gmt_offset,
    cs.return_customer.current_address.location_type,
    customer_state,
order by
    cs.return_customer.id asc nulls first,
    cs.return_customer.salutation asc nulls first,
    cs.return_customer.first_name asc nulls first,
    cs.return_customer.last_name asc nulls first,
    cs.return_customer.current_address.street_number asc nulls first,
    cs.return_customer.current_address.street_name asc nulls first,
    cs.return_customer.current_address.street_type asc nulls first,
    cs.return_customer.current_address.suite_number asc nulls first,
    cs.return_customer.current_address.city asc nulls first,
    cs.return_customer.current_address.county asc nulls first,
    cs.return_customer.current_address.state asc nulls first,
    cs.return_customer.current_address.zip asc nulls first,
    cs.return_customer.current_address.country asc nulls first,
    cs.return_customer.current_address.gmt_offset asc nulls first,
    cs.return_customer.current_address.location_type asc nulls first,
    customer_state asc nulls first
limit 100
;
