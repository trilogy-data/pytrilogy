SELECT
    \"abhorrent\".\"store_sales_store_name\" as \"store_sales_store_name\",
    sum(\"abhorrent\".\"store_sales_net_profit\") as \"store_net_profit\"
FROM
    \"abhorrent\"
GROUP BY
    1
ORDER BY 
