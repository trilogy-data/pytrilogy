import all_sales as sales;

auto relevent_week_seq <- sales.sale_date.week_seq ? sales.sale_date.year in (2001, 2002);

def weekday_sum(weekday) -> sum(sales.ext_sales_price ? sales.sale_date.day_of_week = weekday) by sales.sale_date.week_seq;
def round_lag(amt) -> round(amt / (lead(amt, 53) over (order by sales.sale_date.week_seq asc)), 2);

where
    sales.channel in ('WEB', 'CATALOG') and sales.sale_date.week_seq in relevent_week_seq
select
    sales.sale_date.week_seq,
    @round_lag(@weekday_sum(0)) as sunday_increase,
    @round_lag(@weekday_sum(1)) as monday_increase,
    @round_lag(@weekday_sum(2)) as tuesday_increase,
    @round_lag(@weekday_sum(3)) as wednesday_increase,
    @round_lag(@weekday_sum(4)) as thursday_increase,
    @round_lag(@weekday_sum(5)) as friday_increase,
    @round_lag(@weekday_sum(6)) as saturday_increase,
having
    sunday_increase is not null

order by
    sales.sale_date.week_seq asc nulls first
limit 100
;
