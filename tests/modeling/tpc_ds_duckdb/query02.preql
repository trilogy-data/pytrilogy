import unified_sales as sales;

property relevent_week_seq <- filter sales.date.week_seq where sales.date.year in (2001, 2002);

def weekday_sum(weekday) -> sum(filter sales.ext_sales_price where sales.date.day_of_week = weekday) by sales.date.week_seq;
def round_lag(amt) -> round(amt / (lead(amt,53) over (order by sales.date.week_seq asc)),2);

WHERE
    sales.sales_channel in ('WEB', 'CATALOG') and sales.date.week_seq in relevent_week_seq
SELECT
    sales.date.week_seq,
    @round_lag(@weekday_sum(0)) -> sunday_increase,
    @round_lag(@weekday_sum(1)) -> monday_increase,
    @round_lag(@weekday_sum(2)) -> tuesday_increase,
    @round_lag(@weekday_sum(3)) -> wednesday_increase,
    @round_lag(@weekday_sum(4)) -> thursday_increase,
    @round_lag(@weekday_sum(5)) -> friday_increase,
    @round_lag(@weekday_sum(6)) -> saturday_increase,
HAVING
    sunday_increase is not null

ORDER BY
    sales.date.week_seq asc nulls first
LIMIT 100
;
