import store_sales as ss;
import catalog_returns as cr;

property cr.sales.item.id.cs_ui_refund_amt <- coalesce(cr.refunded_cash,0) + coalesce(cr.reversed_charge,0) + coalesce(cr.store_credit,0);
metric cs_ui_sale <- sum(cr.sales.ext_list_price) by cr.sales.item.id;
metric cs_ui_refund <- sum(cr.sales.item.cs_ui_refund_amt) by cr.sales.item.id;

auto cs_ui_sale <- sum(cr.sales.ext_list_price) by cr.sales.item.id;
auto cs_ui_refund <- sum(cs_ui_refund_amt) by cr.sales.item.id;

with cs_ui as
WHERE cs_ui_sale > 2 * cs_ui_refund
SELECT cr.sales.item.id as cs_ui_item_id
;

def year_row_filter(yr) -> ss.item.id in cs_ui.cs_ui_item_id
and ss.date.year = yr
and ss.is_returned
and ss.item.color in ('purple', 'burlywood', 'indian', 'spring', 'floral', 'medium')
and ss.item.current_price between 65 and 74
and ss.customer.id is not null
and ss.store.id is not null
and ss.sale_address.id is not null
and ss.customer.address.id is not null;

rowset ss_rows_99 <- WHERE
    @year_row_filter(1999) = True
SELECT
    ss.ticket_number,
    ss.item.id,
    ss.item.product_name,
    ss.store.name,
    ss.store.zip,
    ss.sale_address.street_number,
    ss.sale_address.street_name,
    ss.sale_address.city,
    ss.sale_address.zip,
    ss.customer.address.street_number,
    ss.customer.address.street_name,
    ss.customer.address.city,
    ss.customer.address.zip,
    ss.date.year,
    ss.customer.first_sales_date.year,
    ss.customer.first_shipto_date.year,
    ss.wholesale_cost,
    ss.list_price,
    ss.coupon_amt,
    ss.customer_demographic.marital_status,
    ss.customer.demographics.marital_status,
;

rowset ss_rows_00 <- WHERE
    @year_row_filter(2000) = True
SELECT
    ss.ticket_number,
    ss.item.id,
    ss.store.name,
    ss.store.zip,
    ss.date.year,
    ss.wholesale_cost,
    ss.list_price,
    ss.coupon_amt,
    ss.customer_demographic.marital_status,
    ss.customer.demographics.marital_status,
;

rowset q64_results <- WHERE
    ss_rows_99.ss.customer_demographic.marital_status != ss_rows_99.ss.customer.demographics.marital_status
SELECT
    ss_rows_99.ss.item.id -> item_sk_99,
    ss_rows_99.ss.store.name -> s_name_99,
    ss_rows_99.ss.store.zip -> s_zip_99,
    ss_rows_99.ss.item.product_name -> p_name_99,
    ss_rows_99.ss.sale_address.street_number -> b_sn_99,
    ss_rows_99.ss.sale_address.street_name -> b_str_99,
    ss_rows_99.ss.sale_address.city -> b_city_99,
    ss_rows_99.ss.sale_address.zip -> b_zip_99,
    ss_rows_99.ss.customer.address.street_number -> c_sn_99,
    ss_rows_99.ss.customer.address.street_name -> c_str_99,
    ss_rows_99.ss.customer.address.city -> c_city_99,
    ss_rows_99.ss.customer.address.zip -> c_zip_99,
    ss_rows_99.ss.date.year -> syear_99,
    ss_rows_99.ss.customer.first_sales_date.year -> fsyear_99,
    ss_rows_99.ss.customer.first_shipto_date.year -> s2year_99,
    count(ss_rows_99.ss.ticket_number) -> cnt_99,
    sum(ss_rows_99.ss.wholesale_cost) -> s1_99,
    sum(ss_rows_99.ss.list_price) -> s2_99,
    sum(ss_rows_99.ss.coupon_amt) -> s3_99,
MERGE
WHERE
    ss_rows_00.ss.customer_demographic.marital_status != ss_rows_00.ss.customer.demographics.marital_status
SELECT
    ss_rows_00.ss.item.id -> item_sk_00,
    ss_rows_00.ss.store.name -> s_name_00,
    ss_rows_00.ss.store.zip -> s_zip_00,
    ss_rows_00.ss.date.year -> syear_00,
    count(ss_rows_00.ss.ticket_number) -> cnt_00,
    sum(ss_rows_00.ss.wholesale_cost) -> s1_00,
    sum(ss_rows_00.ss.list_price) -> s2_00,
    sum(ss_rows_00.ss.coupon_amt) -> s3_00,
ALIGN
    item_sk: item_sk_99, item_sk_00
    and s_name: s_name_99, s_name_00
    and s_zip: s_zip_99, s_zip_00
;

WHERE
    q64_results.cnt_00 <= q64_results.cnt_99
SELECT
    q64_results.p_name_99,
    q64_results.s_name,
    q64_results.s_zip,
    q64_results.b_sn_99,
    q64_results.b_str_99,
    q64_results.b_city_99,
    q64_results.b_zip_99,
    q64_results.c_sn_99,
    q64_results.c_str_99,
    q64_results.c_city_99,
    q64_results.c_zip_99,
    q64_results.syear_99,
    q64_results.cnt_99,
    q64_results.s1_99,
    q64_results.s2_99,
    q64_results.s3_99,
    q64_results.s1_00,
    q64_results.s2_00,
    q64_results.s3_00,
    q64_results.syear_00,
    q64_results.cnt_00,
ORDER BY
    q64_results.p_name_99 asc nulls first,
    q64_results.s_name asc nulls first,
    q64_results.cnt_00 asc nulls first,
    q64_results.s1_99 asc nulls first,
    q64_results.s1_00 asc nulls first
;
