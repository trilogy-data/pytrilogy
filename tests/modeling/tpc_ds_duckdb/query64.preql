# Matches PRAGMA tpcds(64) at sf=1 (2 rows).
import store_sales as ss;
import catalog_sales as cs;

# cs_ui: items where catalog sale (sum of cs_ext_list_price) exceeds twice the
# catalog refund (refunded_cash + reversed_charge + store_credit) for items with
# a matching catalog_return. The `? cs.is_returned` filters restrict both sums
# to returned lines, matching the reference's INNER cs<->cr join.
auto cs_ui_refund_amt <- coalesce(cs.refunded_cash, 0) + coalesce(cs.reversed_charge, 0) + coalesce(cs.store_credit, 0);
auto cs_ui_sale <- sum(cs.ext_list_price ? cs.is_returned) by cs.item.sk;
auto cs_ui_refund <- sum(cs_ui_refund_amt ? cs.is_returned) by cs.item.sk;

rowset cs_ui <- where
    cs_ui_sale > 2 * cs_ui_refund
select
    cs.item.sk as cs_ui_item_id,
;

# Row-level filter common to both year slices. Excludes the cross-CDEMO
# marital_status inequality — deferring that to the outer aggregate keeps it out
# of the customer_demographics join planning, which otherwise triggers a
# LEFT->INNER upgrade that DuckDB plans catastrophically (q64 went 0.05s -> 18s
# in PR #549's null-safe promotion). Empirically re-confirmed 2026-06-10: pushing
# the inequality into this row filter (and collapsing ss_rows_* away) blows the
# sf=1 plan past 3GB / 5+ min, so the extra row-grain rowset stays on purpose.
def year_row_filter(yr) -> ss.item.sk in cs_ui.cs_ui_item_id
and ss.sale_date.year = yr
and ss.is_returned
and ss.item.color in ('purple', 'burlywood', 'indian', 'spring', 'floral', 'medium')
and ss.item.current_price between 65 and 74
and ss.customer.sk is not null
and ss.store.sk is not null
and ss.pos_address.sk is not null
and ss.customer.current_address.sk is not null;

# Row-grain projection for each year — sk keys only, no descriptive text. Both
# marital_status columns are selected so the outer aggregate can apply the
# inequality without dragging the customer_demographics joins into the main
# aggregate's join planning.
rowset ss_rows_99 <- where
    @year_row_filter(1999) = True
select
    ss.ticket_number,
    ss.item.sk,
    ss.store.sk,
    ss.pos_address.sk,
    ss.customer.current_address.sk,
    ss.sale_date.year,
    ss.customer.first_sales_date.year,
    ss.customer.first_shipto_date.year,
    ss.wholesale_cost,
    ss.list_price,
    ss.coupon_amt,
    ss.pos_customer_demographic.marital_status,
    ss.customer.current_demographics.marital_status,
;

rowset ss_rows_00 <- where
    @year_row_filter(2000) = True
select
    ss.ticket_number,
    ss.item.sk,
    ss.store.sk,
    ss.sale_date.year,
    ss.wholesale_cost,
    ss.list_price,
    ss.coupon_amt,
    ss.pos_customer_demographic.marital_status,
    ss.customer.current_demographics.marital_status,
;

# Per-year aggregates on sk keys. The marital-status inequality is applied here
# (not in year_row_filter) per the perf note above.
rowset agg_99 <- where
    ss_rows_99.ss.pos_customer_demographic.marital_status != ss_rows_99.ss.customer.current_demographics.marital_status
select
    ss_rows_99.ss.item.sk as item_sk_99,
    ss_rows_99.ss.store.sk as store_sk_99,
    ss_rows_99.ss.pos_address.sk as b_addr_99,
    ss_rows_99.ss.customer.current_address.sk as c_addr_99,
    ss_rows_99.ss.sale_date.year as syear_99,
    ss_rows_99.ss.customer.first_sales_date.year as fsyear_99,
    ss_rows_99.ss.customer.first_shipto_date.year as s2year_99,
    count(ss_rows_99.ss.ticket_number) as cnt_99,
    sum(ss_rows_99.ss.wholesale_cost) as s1_99,
    sum(ss_rows_99.ss.list_price) as s2_99,
    sum(ss_rows_99.ss.coupon_amt) as s3_99,
;

rowset agg_00 <- where
    ss_rows_00.ss.pos_customer_demographic.marital_status != ss_rows_00.ss.customer.current_demographics.marital_status
select
    ss_rows_00.ss.item.sk as item_sk_00,
    ss_rows_00.ss.store.sk as store_sk_00,
    ss_rows_00.ss.sale_date.year as syear_00,
    count(ss_rows_00.ss.ticket_number) as cnt_00,
    sum(ss_rows_00.ss.wholesale_cost) as s1_00,
    sum(ss_rows_00.ss.list_price) as s2_00,
    sum(ss_rows_00.ss.coupon_amt) as s3_00,
;

# Join the two year slices on item + store. Chaining each join key to its base
# (`= ss.item.sk`, `= ss.store.sk`) puts the base key in the join group so the
# store/item properties can be enriched off it; the arm-only address ids are
# chained to their base so the address text enriches from them.
where
    agg_00.cnt_00 <= agg_99.cnt_99
union join agg_99.item_sk_99 = agg_00.item_sk_00 = ss.item.sk
union join agg_99.store_sk_99 = agg_00.store_sk_00 = ss.store.sk
union join agg_99.b_addr_99 = ss.pos_address.sk
union join agg_99.c_addr_99 = ss.customer.current_address.sk
select
    --ss.item.sk,
    --ss.store.sk,
    --ss.pos_address.sk,
    --ss.customer.current_address.sk,
    ss.item.product_name as p_name,
    ss.store.name as s_name,
    ss.store.zip as s_zip,
    ss.pos_address.street_number as b_sn,
    ss.pos_address.street_name as b_str,
    ss.pos_address.city as b_city,
    ss.pos_address.zip as b_zip,
    ss.customer.current_address.street_number as c_sn,
    ss.customer.current_address.street_name as c_str,
    ss.customer.current_address.city as c_city,
    ss.customer.current_address.zip as c_zip,
    agg_99.syear_99,
    agg_99.cnt_99,
    agg_99.s1_99,
    agg_99.s2_99,
    agg_99.s3_99,
    agg_00.s1_00,
    agg_00.s2_00,
    agg_00.s3_00,
    agg_00.syear_00,
    agg_00.cnt_00,
order by
    p_name asc nulls first,
    s_name asc nulls first,
    agg_00.cnt_00 asc nulls first,
    agg_99.s1_99 asc nulls first,
    agg_00.s1_00 asc nulls first
;
