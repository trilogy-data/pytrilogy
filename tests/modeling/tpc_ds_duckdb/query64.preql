# q64 as a query-scoped INNER `join`, "aggregate on keys, join text later" form:
# the per-year aggregates group on id keys only (item, store, sale/customer
# address, the date years); the descriptive text (product name, store name/zip,
# address fields) is enriched in the outer select. Enriching a property off a
# renamed scoped-join key requires chaining the base key into the join group
# (`agg_99.item_sk_99 = agg_00.item_sk_00 = ss.item.id`); the arm-only address
# ids are chained to their base directly. Matches PRAGMA tpcds(64) at sf=1 (2 rows).
import physical_sales as ss;
import catalog_returns as cr;

# cs_ui: items where catalog sale (sum of cs_ext_list_price) exceeds twice the
# catalog refund (refunded_cash + reversed_charge + store_credit) for items with
# a matching catalog_return. catalog_sales is reached through cr.sales (cr
# already imports catalog_sales as sales) so we avoid the cross-import merge.
auto cs_ui_refund_amt <- coalesce(cr.refunded_cash, 0) + coalesce(cr.reversed_charge, 0) + coalesce(cr.store_credit, 0);
auto cs_ui_sale <- sum(cr.sales.ext_list_price) by cr.sales.item.id;
auto cs_ui_refund <- sum(cs_ui_refund_amt) by cr.sales.item.id;

rowset cs_ui <- where
    cs_ui_sale > 2 * cs_ui_refund
select
    cr.sales.item.id as cs_ui_item_id,
;

# Row-level filter common to both year slices. Excludes the cross-CDEMO
# marital_status inequality — deferring that to the outer aggregate keeps it out
# of the customer_demographics join planning, which otherwise triggers a
# LEFT->INNER upgrade that DuckDB plans catastrophically (q64 went 0.05s -> 18s
# in PR #549's null-safe promotion). Empirically re-confirmed 2026-06-10: pushing
# the inequality into this row filter (and collapsing ss_rows_* away) blows the
# sf=1 plan past 3GB / 5+ min, so the extra row-grain rowset stays on purpose.
def year_row_filter(yr) -> ss.item.id in cs_ui.cs_ui_item_id
and ss.date.year = yr
and ss.is_returned
and ss.item.color in ('purple', 'burlywood', 'indian', 'spring', 'floral', 'medium')
and ss.item.current_price between 65 and 74
and ss.customer.id is not null
and ss.store.id is not null
and ss.sale_address.id is not null
and ss.customer.address.id is not null;

# Row-grain projection for each year — id keys only, no descriptive text. Both
# marital_status columns are selected so the outer aggregate can apply the
# inequality without dragging the customer_demographics joins into the main
# aggregate's join planning.
rowset ss_rows_99 <- where
    @year_row_filter(1999) = True
select
    ss.ticket_number,
    ss.item.id,
    ss.store.id,
    ss.sale_address.id,
    ss.customer.address.id,
    ss.date.year,
    ss.customer.first_sales_date.year,
    ss.customer.first_shipto_date.year,
    ss.wholesale_cost,
    ss.list_price,
    ss.coupon_amt,
    ss.customer_demographic.marital_status,
    ss.customer.demographics.marital_status,
;

rowset ss_rows_00 <- where
    @year_row_filter(2000) = True
select
    ss.ticket_number,
    ss.item.id,
    ss.store.id,
    ss.date.year,
    ss.wholesale_cost,
    ss.list_price,
    ss.coupon_amt,
    ss.customer_demographic.marital_status,
    ss.customer.demographics.marital_status,
;

# Per-year aggregates on id keys. The marital-status inequality is applied here
# (not in year_row_filter) per the perf note above.
rowset agg_99 <- where
    ss_rows_99.ss.customer_demographic.marital_status != ss_rows_99.ss.customer.demographics.marital_status
select
    ss_rows_99.ss.item.id as item_sk_99,
    ss_rows_99.ss.store.id as store_sk_99,
    ss_rows_99.ss.sale_address.id as b_addr_99,
    ss_rows_99.ss.customer.address.id as c_addr_99,
    ss_rows_99.ss.date.year as syear_99,
    ss_rows_99.ss.customer.first_sales_date.year as fsyear_99,
    ss_rows_99.ss.customer.first_shipto_date.year as s2year_99,
    count(ss_rows_99.ss.ticket_number) as cnt_99,
    sum(ss_rows_99.ss.wholesale_cost) as s1_99,
    sum(ss_rows_99.ss.list_price) as s2_99,
    sum(ss_rows_99.ss.coupon_amt) as s3_99,
;

rowset agg_00 <- where
    ss_rows_00.ss.customer_demographic.marital_status != ss_rows_00.ss.customer.demographics.marital_status
select
    ss_rows_00.ss.item.id as item_sk_00,
    ss_rows_00.ss.store.id as store_sk_00,
    ss_rows_00.ss.date.year as syear_00,
    count(ss_rows_00.ss.ticket_number) as cnt_00,
    sum(ss_rows_00.ss.wholesale_cost) as s1_00,
    sum(ss_rows_00.ss.list_price) as s2_00,
    sum(ss_rows_00.ss.coupon_amt) as s3_00,
;

# Join the two year slices on item + store. Chaining each join key to its base
# (`= ss.item.id`, `= ss.store.id`) puts the base key in the join group so the
# store/item properties can be enriched off it; the arm-only address ids are
# chained to their base so the address text enriches from them.
where
    agg_00.cnt_00 <= agg_99.cnt_99
inner join agg_99.item_sk_99 = agg_00.item_sk_00 = ss.item.id
inner join agg_99.store_sk_99 = agg_00.store_sk_00 = ss.store.id
inner join agg_99.b_addr_99 = ss.sale_address.id
inner join agg_99.c_addr_99 = ss.customer.address.id
select
    ss.item.product_name as p_name,
    ss.store.name as s_name,
    ss.store.zip as s_zip,
    ss.sale_address.street_number as b_sn,
    ss.sale_address.street_name as b_str,
    ss.sale_address.city as b_city,
    ss.sale_address.zip as b_zip,
    ss.customer.address.street_number as c_sn,
    ss.customer.address.street_name as c_str,
    ss.customer.address.city as c_city,
    ss.customer.address.zip as c_zip,
    agg_99.syear_99,
    agg_99.cnt_99,
    agg_99.s1_99,
    agg_99.s2_99,
    agg_99.s3_99,
    agg_00.s1_00,
    agg_00.s2_00,
    agg_00.s3_00,
    agg_00.syear_00,
    agg_00.cnt_00,
order by
    p_name asc nulls first,
    s_name asc nulls first,
    agg_00.cnt_00 asc nulls first,
    agg_99.s1_99 asc nulls first,
    agg_00.s1_00 asc nulls first
;
