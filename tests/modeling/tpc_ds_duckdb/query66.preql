import unified_sales as sales;

def web_month_sum(metric, month) -> sum(metric * filter sales.quantity where sales.sales_channel = 'WEB' and sales.date.month_of_year = month) by sales.warehouse.id, sales.date.year;
def cat_month_sum(metric, month) -> sum(metric * filter sales.quantity where sales.sales_channel = 'CATALOG' and sales.date.month_of_year = month) by sales.warehouse.id, sales.date.year;
def channel_total(ws, cs) -> coalesce(ws,0) + coalesce(cs,0);
def per_sqft(ws, cs) -> coalesce(ws,0) / sales.warehouse.square_feet + coalesce(cs,0) / sales.warehouse.square_feet;

metric ws_jan_sales <- sum(sales.ext_sales_price * filter sales.quantity where sales.sales_channel = 'WEB' and sales.date.month_of_year = 1) by sales.warehouse.id, sales.date.year;
metric ws_feb_sales <- sum(sales.ext_sales_price * filter sales.quantity where sales.sales_channel = 'WEB' and sales.date.month_of_year = 2) by sales.warehouse.id, sales.date.year;
