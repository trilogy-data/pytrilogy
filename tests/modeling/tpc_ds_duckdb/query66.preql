metric cs_jan_net <- sum(
    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 1
)
    by sales.warehouse.id, sales.date.year;
metric cs_feb_net <- sum(
    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 2
)
    by sales.warehouse.id, sales.date.year;
metric cs_mar_net <- sum(
    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 3
)
    by sales.warehouse.id, sales.date.year;
metric cs_apr_net <- sum(
    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 4
)
    by sales.warehouse.id, sales.date.year;
metric cs_may_net <- sum(
    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 5
)
    by sales.warehouse.id, sales.date.year;
metric cs_jun_net <- sum(
    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 6
)
    by sales.warehouse.id, sales.date.year;
metric cs_jul_net <- sum(
    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 7
)
    by sales.warehouse.id, sales.date.year;
metric cs_aug_net <- sum(
    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 8
)
    by sales.warehouse.id, sales.date.year;
metric cs_sep_net <- sum(
    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 9
)
    by sales.warehouse.id, sales.date.year;
metric cs_oct_net <- sum(
    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 10
)
    by sales.warehouse.id, sales.date.year;
