import unified_sales as sales;

# Per-channel monthly aggregate. Web uses ext_sales_price + net_paid;
# catalog uses sales_price + net_paid_inc_tax (matches the reference query).
# Store has no warehouse/ship_mode mappings, so the planner uses the
# 2-channel (web+catalog) union for any aggregate that touches them.

def web_month_sum(metric, month) -> sum(metric * sales.quantity ?
    sales.sales_channel = 'WEB' and sales.date.month_of_year = month
) by sales.warehouse.id, sales.date.year;

def cat_month_sum(metric, month) -> sum(metric * sales.quantity ?
    sales.sales_channel = 'CATALOG' and sales.date.month_of_year = month
) by sales.warehouse.id, sales.date.year;

def channel_total(ws, cs) -> coalesce(ws, 0) + coalesce(cs, 0);
def per_sqft(ws, cs) -> coalesce(ws, 0) / sales.warehouse.square_feet + coalesce(cs, 0) / sales.warehouse.square_feet;

auto ws_jan_sales <- @web_month_sum(sales.ext_sales_price, 1);
auto ws_feb_sales <- @web_month_sum(sales.ext_sales_price, 2);
auto ws_mar_sales <- @web_month_sum(sales.ext_sales_price, 3);
auto ws_apr_sales <- @web_month_sum(sales.ext_sales_price, 4);
auto ws_may_sales <- @web_month_sum(sales.ext_sales_price, 5);
auto ws_jun_sales <- @web_month_sum(sales.ext_sales_price, 6);
auto ws_jul_sales <- @web_month_sum(sales.ext_sales_price, 7);
auto ws_aug_sales <- @web_month_sum(sales.ext_sales_price, 8);
auto ws_sep_sales <- @web_month_sum(sales.ext_sales_price, 9);
auto ws_oct_sales <- @web_month_sum(sales.ext_sales_price, 10);
auto ws_nov_sales <- @web_month_sum(sales.ext_sales_price, 11);
auto ws_dec_sales <- @web_month_sum(sales.ext_sales_price, 12);

auto ws_jan_net <- @web_month_sum(sales.net_paid, 1);
auto ws_feb_net <- @web_month_sum(sales.net_paid, 2);
auto ws_mar_net <- @web_month_sum(sales.net_paid, 3);
auto ws_apr_net <- @web_month_sum(sales.net_paid, 4);
auto ws_may_net <- @web_month_sum(sales.net_paid, 5);
auto ws_jun_net <- @web_month_sum(sales.net_paid, 6);
auto ws_jul_net <- @web_month_sum(sales.net_paid, 7);
auto ws_aug_net <- @web_month_sum(sales.net_paid, 8);
auto ws_sep_net <- @web_month_sum(sales.net_paid, 9);
auto ws_oct_net <- @web_month_sum(sales.net_paid, 10);
auto ws_nov_net <- @web_month_sum(sales.net_paid, 11);
auto ws_dec_net <- @web_month_sum(sales.net_paid, 12);

auto cs_jan_sales <- @cat_month_sum(sales.sales_price, 1);
auto cs_feb_sales <- @cat_month_sum(sales.sales_price, 2);
auto cs_mar_sales <- @cat_month_sum(sales.sales_price, 3);
auto cs_apr_sales <- @cat_month_sum(sales.sales_price, 4);
auto cs_may_sales <- @cat_month_sum(sales.sales_price, 5);
auto cs_jun_sales <- @cat_month_sum(sales.sales_price, 6);
auto cs_jul_sales <- @cat_month_sum(sales.sales_price, 7);
auto cs_aug_sales <- @cat_month_sum(sales.sales_price, 8);
auto cs_sep_sales <- @cat_month_sum(sales.sales_price, 9);
auto cs_oct_sales <- @cat_month_sum(sales.sales_price, 10);
auto cs_nov_sales <- @cat_month_sum(sales.sales_price, 11);
auto cs_dec_sales <- @cat_month_sum(sales.sales_price, 12);

auto cs_jan_net <- @cat_month_sum(sales.net_paid_inc_tax, 1);
auto cs_feb_net <- @cat_month_sum(sales.net_paid_inc_tax, 2);
auto cs_mar_net <- @cat_month_sum(sales.net_paid_inc_tax, 3);
auto cs_apr_net <- @cat_month_sum(sales.net_paid_inc_tax, 4);
auto cs_may_net <- @cat_month_sum(sales.net_paid_inc_tax, 5);
auto cs_jun_net <- @cat_month_sum(sales.net_paid_inc_tax, 6);
auto cs_jul_net <- @cat_month_sum(sales.net_paid_inc_tax, 7);
auto cs_aug_net <- @cat_month_sum(sales.net_paid_inc_tax, 8);
auto cs_sep_net <- @cat_month_sum(sales.net_paid_inc_tax, 9);
auto cs_oct_net <- @cat_month_sum(sales.net_paid_inc_tax, 10);
auto cs_nov_net <- @cat_month_sum(sales.net_paid_inc_tax, 11);
auto cs_dec_net <- @cat_month_sum(sales.net_paid_inc_tax, 12);

auto jan_sales <- @channel_total(ws_jan_sales, cs_jan_sales);
auto feb_sales <- @channel_total(ws_feb_sales, cs_feb_sales);
auto mar_sales <- @channel_total(ws_mar_sales, cs_mar_sales);
auto apr_sales <- @channel_total(ws_apr_sales, cs_apr_sales);
auto may_sales <- @channel_total(ws_may_sales, cs_may_sales);
auto jun_sales <- @channel_total(ws_jun_sales, cs_jun_sales);
auto jul_sales <- @channel_total(ws_jul_sales, cs_jul_sales);
auto aug_sales <- @channel_total(ws_aug_sales, cs_aug_sales);
auto sep_sales <- @channel_total(ws_sep_sales, cs_sep_sales);
auto oct_sales <- @channel_total(ws_oct_sales, cs_oct_sales);
auto nov_sales <- @channel_total(ws_nov_sales, cs_nov_sales);
auto dec_sales <- @channel_total(ws_dec_sales, cs_dec_sales);

auto jan_net <- @channel_total(ws_jan_net, cs_jan_net);
auto feb_net <- @channel_total(ws_feb_net, cs_feb_net);
auto mar_net <- @channel_total(ws_mar_net, cs_mar_net);
auto apr_net <- @channel_total(ws_apr_net, cs_apr_net);
auto may_net <- @channel_total(ws_may_net, cs_may_net);
auto jun_net <- @channel_total(ws_jun_net, cs_jun_net);
auto jul_net <- @channel_total(ws_jul_net, cs_jul_net);
auto aug_net <- @channel_total(ws_aug_net, cs_aug_net);
auto sep_net <- @channel_total(ws_sep_net, cs_sep_net);
auto oct_net <- @channel_total(ws_oct_net, cs_oct_net);
auto nov_net <- @channel_total(ws_nov_net, cs_nov_net);
auto dec_net <- @channel_total(ws_dec_net, cs_dec_net);

WHERE
    sales.sales_channel in ('WEB', 'CATALOG')
    and sales.date.year = 2001
    and sales.time.time between 30838 and 59638
    and sales.ship_mode.carrier in ('DHL', 'BARIAN')
    and sales.warehouse.id is not null
SELECT
    --sales.warehouse.id,
    sales.warehouse.name as w_warehouse_name,
    sales.warehouse.square_feet as w_warehouse_sq_ft,
    sales.warehouse.city as w_city,
    sales.warehouse.county as w_county,
    sales.warehouse.state as w_state,
    sales.warehouse.country as w_country,
    'DHL,BARIAN' as ship_carriers,
    sales.date.year as year_,
    jan_sales,
    feb_sales,
    mar_sales,
    apr_sales,
    may_sales,
    jun_sales,
    jul_sales,
    aug_sales,
    sep_sales,
    oct_sales,
    nov_sales,
    dec_sales,
    @per_sqft(ws_jan_sales, cs_jan_sales) as jan_sales_per_sq_foot,
    @per_sqft(ws_feb_sales, cs_feb_sales) as feb_sales_per_sq_foot,
    @per_sqft(ws_mar_sales, cs_mar_sales) as mar_sales_per_sq_foot,
    @per_sqft(ws_apr_sales, cs_apr_sales) as apr_sales_per_sq_foot,
    @per_sqft(ws_may_sales, cs_may_sales) as may_sales_per_sq_foot,
    @per_sqft(ws_jun_sales, cs_jun_sales) as jun_sales_per_sq_foot,
    @per_sqft(ws_jul_sales, cs_jul_sales) as jul_sales_per_sq_foot,
    @per_sqft(ws_aug_sales, cs_aug_sales) as aug_sales_per_sq_foot,
    @per_sqft(ws_sep_sales, cs_sep_sales) as sep_sales_per_sq_foot,
    @per_sqft(ws_oct_sales, cs_oct_sales) as oct_sales_per_sq_foot,
    @per_sqft(ws_nov_sales, cs_nov_sales) as nov_sales_per_sq_foot,
    @per_sqft(ws_dec_sales, cs_dec_sales) as dec_sales_per_sq_foot,
    jan_net,
    feb_net,
    mar_net,
    apr_net,
    may_net,
    jun_net,
    jul_net,
    aug_net,
    sep_net,
    oct_net,
    nov_net,
    dec_net,

ORDER BY
    w_warehouse_name asc nulls first,
    year_ asc nulls first
LIMIT 100;
