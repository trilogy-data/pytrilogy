    by sales.warehouse.id, sales.date.year;
metric ws_may_net <- sum(sales.net_paid * sales.quantity ? sales.sales_channel = 'WEB' and sales.date.month_of_year = 5)
    by sales.warehouse.id, sales.date.year;
metric ws_jun_net <- sum(sales.net_paid * sales.quantity ? sales.sales_channel = 'WEB' and sales.date.month_of_year = 6)
    by sales.warehouse.id, sales.date.year;
metric ws_jul_net <- sum(sales.net_paid * sales.quantity ? sales.sales_channel = 'WEB' and sales.date.month_of_year = 7)
    by sales.warehouse.id, sales.date.year;
metric ws_aug_net <- sum(sales.net_paid * sales.quantity ? sales.sales_channel = 'WEB' and sales.date.month_of_year = 8)
