    sales.net_paid_inc_tax * sales.quantity ? sales.sales_channel = 'CATALOG' and sales.date.month_of_year = 12
)
    by sales.warehouse.id, sales.date.year;
auto jan_sales <- coalesce(ws_jan_sales, 0) + coalesce(cs_jan_sales, 0);
auto feb_sales <- coalesce(ws_feb_sales, 0) + coalesce(cs_feb_sales, 0);
auto mar_sales <- coalesce(ws_mar_sales, 0) + coalesce(cs_mar_sales, 0);
auto apr_sales <- coalesce(ws_apr_sales, 0) + coalesce(cs_apr_sales, 0);
auto may_sales <- coalesce(ws_may_sales, 0) + coalesce(cs_may_sales, 0);
auto jun_sales <- coalesce(ws_jun_sales, 0) + coalesce(cs_jun_sales, 0);
auto jul_sales <- coalesce(ws_jul_sales, 0) + coalesce(cs_jul_sales, 0);
auto aug_sales <- coalesce(ws_aug_sales, 0) + coalesce(cs_aug_sales, 0);
auto sep_sales <- coalesce(ws_sep_sales, 0) + coalesce(cs_sep_sales, 0);
auto oct_sales <- coalesce(ws_oct_sales, 0) + coalesce(cs_oct_sales, 0);
auto nov_sales <- coalesce(ws_nov_sales, 0) + coalesce(cs_nov_sales, 0);
auto dec_sales <- coalesce(ws_dec_sales, 0) + coalesce(cs_dec_sales, 0);
auto jan_net <- coalesce(ws_jan_net, 0) + coalesce(cs_jan_net, 0);
auto feb_net <- coalesce(ws_feb_net, 0) + coalesce(cs_feb_net, 0);
auto mar_net <- coalesce(ws_mar_net, 0) + coalesce(cs_mar_net, 0);
auto apr_net <- coalesce(ws_apr_net, 0) + coalesce(cs_apr_net, 0);
auto may_net <- coalesce(ws_may_net, 0) + coalesce(cs_may_net, 0);
auto jun_net <- coalesce(ws_jun_net, 0) + coalesce(cs_jun_net, 0);
auto jul_net <- coalesce(ws_jul_net, 0) + coalesce(cs_jul_net, 0);
auto aug_net <- coalesce(ws_aug_net, 0) + coalesce(cs_aug_net, 0);
auto sep_net <- coalesce(ws_sep_net, 0) + coalesce(cs_sep_net, 0);
auto oct_net <- coalesce(ws_oct_net, 0) + coalesce(cs_oct_net, 0);
auto nov_net <- coalesce(ws_nov_net, 0) + coalesce(cs_nov_net, 0);
auto dec_net <- coalesce(ws_dec_net, 0) + coalesce(cs_dec_net, 0);

WHERE
    sales.sales_channel in ('WEB', 'CATALOG')
    and sales.date.year = 2001
    and sales.time.time between 30838 and 59638
    and sales.ship_mode.carrier in ('DHL', 'BARIAN')
    and sales.warehouse.id is not null
SELECT
    --sales.warehouse.id,
    sales.warehouse.name as w_warehouse_name,
    sales.warehouse.square_feet as w_warehouse_sq_ft,
    sales.warehouse.city as w_city,
    sales.warehouse.county as w_county,
    sales.warehouse.state as w_state,
    sales.warehouse.country as w_country,
    'DHL,BARIAN' as ship_carriers,
    sales.date.year as year_,
    jan_sales,
    feb_sales,
    mar_sales,
    apr_sales,
    may_sales,
    jun_sales,
    jul_sales,
    aug_sales,
    sep_sales,
    oct_sales,
    nov_sales,
    dec_sales,
    @per_sqft(ws_jan_sales, cs_jan_sales) as jan_sales_per_sq_foot,
    @per_sqft(ws_feb_sales, cs_feb_sales) as feb_sales_per_sq_foot,
    @per_sqft(ws_mar_sales, cs_mar_sales) as mar_sales_per_sq_foot,
    @per_sqft(ws_apr_sales, cs_apr_sales) as apr_sales_per_sq_foot,
    @per_sqft(ws_may_sales, cs_may_sales) as may_sales_per_sq_foot,
    @per_sqft(ws_jun_sales, cs_jun_sales) as jun_sales_per_sq_foot,
    @per_sqft(ws_jul_sales, cs_jul_sales) as jul_sales_per_sq_foot,
    @per_sqft(ws_aug_sales, cs_aug_sales) as aug_sales_per_sq_foot,
    @per_sqft(ws_sep_sales, cs_sep_sales) as sep_sales_per_sq_foot,
    @per_sqft(ws_oct_sales, cs_oct_sales) as oct_sales_per_sq_foot,
    @per_sqft(ws_nov_sales, cs_nov_sales) as nov_sales_per_sq_foot,
    @per_sqft(ws_dec_sales, cs_dec_sales) as dec_sales_per_sq_foot,
    jan_net,
    feb_net,
    mar_net,
    apr_net,
    may_net,
    jun_net,
    jul_net,
    aug_net,
    sep_net,
    oct_net,
    nov_net,
    dec_net,
ORDER BY
    w_warehouse_name asc nulls first,
    year_ asc nulls first
LIMIT 100
;
