import store_sales as ss;
import catalog_sales as cs;
import web_sales as ws;

# Row-grain 0/1 flag that sums to the row count without count()'s COALESCE-to-0 wrapping.
auto ss_row_flag <- sum(
    case
        when ss.store.id is null then 1
        else 0
    end
)
    by ss.ticket_number, ss.item.id;
auto ws_row_flag <- sum(
    case
        when ws.ship_customer.id is null then 1
        else 0
    end
)
    by ws.order_number, ws.item.id;
auto cs_row_flag <- sum(
    case
        when cs.customer_address.id is null then 1
        else 0
    end
)
    by cs.order_number, cs.item.id;

# UNION the 3 channels via the relational union(...) TVF. A row-stack means cnt
# and amt are just additional positional outputs (no coalesce/derive needed, as
# the old FULL-JOIN multiselect required to fold per-arm columns together).
with q76_results as union(
    (where ss.store.id is null and ss.ticket_number is not null and ss.date.id is not null
     select
        'store' as channel,
        'ss_store_sk' as col_name,
        ss.date.year as d_year,
        ss.date.quarter as d_qoy,
        ss.item.category as i_category,
        sum(ss_row_flag) as sales_cnt,
        sum(ss.ext_sales_price) as sales_amt,
    ),
    (where ws.ship_customer.id is null and ws.order_number is not null and ws.date.id is not null
     select
        'web' as channel,
        'ws_ship_customer_sk' as col_name,
        ws.date.year as d_year,
        ws.date.quarter as d_qoy,
        ws.item.category as i_category,
        sum(ws_row_flag) as sales_cnt,
        sum(ws.ext_sales_price) as sales_amt,
    ),
    (where cs.customer_address.id is null and cs.order_number is not null and cs.date.id is not null
     select
        'catalog' as channel,
        'cs_ship_addr_sk' as col_name,
        cs.date.year as d_year,
        cs.date.quarter as d_qoy,
        cs.item.category as i_category,
        sum(cs_row_flag) as sales_cnt,
        sum(cs.ext_sales_price) as sales_amt,
    )
) -> (channel, col_name, d_year, d_qoy, i_category, sales_cnt, sales_amt);

select
    q76_results.channel,
    q76_results.col_name,
    q76_results.d_year,
    q76_results.d_qoy,
    q76_results.i_category,
    q76_results.sales_cnt,
    q76_results.sales_amt,
order by
    q76_results.channel asc nulls first,
    q76_results.col_name asc nulls first,
    q76_results.d_year asc nulls first,
    q76_results.d_qoy asc nulls first,
    q76_results.i_category asc nulls first
limit 100
;
