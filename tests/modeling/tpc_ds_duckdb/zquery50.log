    count(CASE WHEN \"cooperative\".\"days_to_return\" > 120 and \"cooperative\".\"days_to_return\" <= 99999 THEN \"cooperative\".\"store_sales_item_id\" ELSE NULL END) as \"_virt_agg_count_7969998780980378\",
    count(CASE WHEN \"cooperative\".\"days_to_return\" > 30 and \"cooperative\".\"days_to_return\" <= 60 THEN \"cooperative\".\"store_sales_item_id\" ELSE NULL END) as \"_virt_agg_count_3393740962845140\",
    count(CASE WHEN \"cooperative\".\"days_to_return\" > 60 and \"cooperative\".\"days_to_return\" <= 90 THEN \"cooperative\".\"store_sales_item_id\" ELSE NULL END) as \"_virt_agg_count_4020156712075239\",
