    \"sweltering\".\"avg3\" as \"avg3\"
FROM
    \"sweltering\"
    FULL JOIN \"young\" on \"sweltering\".\"customer_address_state\" is not distinct from \"young\".\"customer_address_state\" AND \"sweltering\".\"customer_demographics_college_dependent_count\" = \"young\".\"customer_demographics_college_dependent_count\" AND \"sweltering\".\"customer_demographics_dependent_count\" = \"young\".\"customer_demographics_dependent_count\" AND \"sweltering\".\"customer_demographics_employed_dependent_count\" = \"young\".\"customer_demographics_employed_dependent_count\" AND \"sweltering\".\"customer_demographics_gender\" = \"young\".\"customer_demographics_gender\" AND \"sweltering\".\"customer_demographics_marital_status\" = \"young\".\"customer_demographics_marital_status\"
ORDER BY 
    coalesce(\"sweltering\".\"customer_address_state\",\"young\".\"customer_address_state\") asc nulls first,
    coalesce(\"sweltering\".\"customer_demographics_gender\",\"young\".\"customer_demographics_gender\") asc nulls first,
    coalesce(\"sweltering\".\"customer_demographics_marital_status\",\"young\".\"customer_demographics_marital_status\") asc nulls first,
    coalesce(\"sweltering\".\"customer_demographics_dependent_count\",\"young\".\"customer_demographics_dependent_count\") asc nulls first,
