    FULL JOIN \"cooperative\" on coalesce(\"quizzical\".\"customer_id\", \"uneven\".\"customer_id\") = \"cooperative\".\"customer_id\"
    FULL JOIN \"memory\".\"customer\" as \"customer_customers\" on coalesce(\"quizzical\".\"customer_id\", \"cooperative\".\"customer_id\", \"uneven\".\"customer_id\") = \"customer_customers\".\"C_CUSTOMER_SK\"
    RIGHT OUTER JOIN \"memory\".\"date_dim\" as \"store_sales_date_date\" on \"cooperative\".\"store_sales_date_id\" = \"store_sales_date_date\".\"D_DATE_SK\"
    LEFT OUTER JOIN \"memory\".\"date_dim\" as \"catalog_sales_date_date\" on \"quizzical\".\"catalog_sales_date_id\" = \"catalog_sales_date_date\".\"D_DATE_SK\"
