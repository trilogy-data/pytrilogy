    \"sales_store_sales_unified\".\"SS_CUSTOMER_SK\" as \"sales_customer_id\",
    \"sales_store_sales_unified\".\"SS_SOLD_DATE_SK\" as \"sales_date_id\"
FROM
    \"memory\".\"store_sales\" as \"sales_store_sales_unified\"
WHERE
     'STORE'  = 'STORE' and \"sales_store_sales_unified\".\"SS_CUSTOMER_SK\" is not null

GROUP BY
    1,
    2,
     'STORE' ),
cheerful as (
SELECT
    \"sales_catalog_sales_unified\".\"CS_SHIP_CUSTOMER_SK\" as \"sales_ship_customer_id\",
    \"sales_catalog_sales_unified\".\"CS_SOLD_DATE_SK\" as \"sales_date_id\"
FROM
    \"memory\".\"catalog_sales\" as \"sales_catalog_sales_unified\"
WHERE
     'CATALOG'  = 'CATALOG' and \"sales_catalog_sales_unified\".\"CS_SHIP_CUSTOMER_SK\" is not null

GROUP BY
    1,
    2,
     'CATALOG' ),
concerned as (
SELECT
    \"juicy\".\"sales_customer_id\" as \"web_buyers_web_cust_id\"
FROM
    \"juicy\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"juicy\".\"sales_date_id\" = \"sales_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_date_date\".\"D_YEAR\" = 2002 and \"sales_date_date\".\"D_QOY\" < 4

GROUP BY
    1),
yummy as (
SELECT
    \"abundant\".\"sales_customer_id\" as \"store_buyers_store_cust_id\"
FROM
    \"abundant\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"abundant\".\"sales_date_id\" = \"sales_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_date_date\".\"D_YEAR\" = 2002 and \"sales_date_date\".\"D_QOY\" < 4

GROUP BY
    1),
questionable as (
