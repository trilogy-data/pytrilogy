    coalesce(\"sweltering\".\"customer_demographics_college_dependent_count\",\"young\".\"customer_demographics_college_dependent_count\") as \"customer_demographics_college_dependent_count\",
    coalesce(\"young\".\"cnt3\",0) as \"cnt3\",
