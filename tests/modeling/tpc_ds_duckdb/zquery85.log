fund_address_customer_address\".\"CA_STATE\" is not null and \"ws_return_refund_address_customer_address\".\"CA_STATE\" in ('IN','OH','NJ')) and \"ws_web_sales\".\"WS_NET_PROFIT\" BETWEEN 100 AND 200 ) or ( \"ws_return_refund_address_customer_address\".\"CA_COUNTRY\" = 'United States' and (\"ws_return_refund_address_customer_address\".\"CA_STATE\" is not null and \"ws_return_refund_address_customer_address\".\"CA_STATE\" in ('WI','CT','KY')) and \"ws_web_sales\".\"WS_NET_PROFIT\" BETWEEN 150 AND 300 ) or ( \"ws_return_refund_address_customer_address\".\"CA_COUNTRY\" = 'United States' and (\"ws_return_refund_address_customer_address\".\"CA_STATE\" is not null and \"ws_return_refund_address_customer_address\".\"CA_STATE\" in ('LA','IA','AR')) and \"ws_web_sales\".\"WS_NET_PROFIT\" BETWEEN 50 AND 250 ) )

