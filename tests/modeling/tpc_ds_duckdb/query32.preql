import catalog_sales;

const start_date <- '2000-01-27'::date;
const end_date <- '2000-04-26'::date;

# Pure aggregate; the 1.3 multiplier moves into the staged comparison so the
# staged search can bound the per-item avg scan (a `1.3 * avg(...)` concept is
# BASIC-wrapped and is not yet staged-reducible).
auto avg_item_disc <- avg(discount_amount ?
    sold_date.date between start_date and end_date) by item.id;

where
    item.manufacturer_id = 977
    and sold_date.date between start_date and end_date
then where
    discount_amount > 1.3 * avg_item_disc
select
    sum(discount_amount) as total_discount,
limit 100;
