import all_sales as sales;

# q75: year-over-year book sales count comparison, as a query-scoped `join`.
# UNION DISTINCT semantics in the reference's `sales_detail` subquery dedups rows
# with identical (year, brand, class, cat, manufact, cnt_per_row, amt_per_row)
# tuples — including across cs/ss/ws — before the outer SUM. The `deduped` rowset
# materializes that 7-tuple via implicit GROUP BY at SELECT grain; the per-year
# `curr`/`prev` rowsets each roll the deduped rows up to item-attribute grain, and
# the inner join on the 4 item-attribute keys reproduces the reference's
# `from all_sales curr_yr, all_sales prev_yr where curr_yr.<key> = prev_yr.<key>`.
auto cnt_per_row <- sales.quantity - coalesce(sales.return_quantity, 0);
auto amt_per_row <- sales.ext_sales_price - coalesce(sales.return_amount, 0.0);

rowset deduped <- where
    sales.item.category = 'Books' and sales.date.year in (2001, 2002)
select
    sales.date.year,
    sales.item.brand_id,
    sales.item.class_id,
    sales.item.category_id,
    sales.item.manufacturer_id,
    cnt_per_row,
    amt_per_row,
;

rowset curr <- where deduped.sales.date.year = 2002
select
    deduped.sales.item.brand_id as i_brand_id,
    deduped.sales.item.class_id as i_class_id,
    deduped.sales.item.category_id as i_category_id,
    deduped.sales.item.manufacturer_id as i_manufact_id,
    sum(deduped.cnt_per_row) as curr_cnt,
    sum(deduped.amt_per_row) as curr_amt,
;

rowset prev <- where deduped.sales.date.year = 2001
select
    deduped.sales.item.brand_id as i_brand_id,
    deduped.sales.item.class_id as i_class_id,
    deduped.sales.item.category_id as i_category_id,
    deduped.sales.item.manufacturer_id as i_manufact_id,
    sum(deduped.cnt_per_row) as prev_cnt,
    sum(deduped.amt_per_row) as prev_amt,
;

inner join curr.i_brand_id = prev.i_brand_id
inner join curr.i_class_id = prev.i_class_id
inner join curr.i_category_id = prev.i_category_id
inner join curr.i_manufact_id = prev.i_manufact_id
select
    2001 as prev_year,
    2002 as year_,
    curr.i_brand_id,
    curr.i_class_id,
    curr.i_category_id,
    curr.i_manufact_id,
    prev.prev_cnt as prev_yr_cnt,
    curr.curr_cnt as curr_yr_cnt,
    curr.curr_cnt - prev.prev_cnt as sales_cnt_diff,
    curr.curr_amt - prev.prev_amt as sales_amt_diff,
having
    curr_yr_cnt::numeric(17,2) / prev_yr_cnt::numeric(17,2) < 0.9

order by
    sales_cnt_diff asc nulls first,
    sales_amt_diff asc nulls first
limit 100
;
