import all_sales as sales;

# q75: year-over-year Books sales-count comparison across store, catalog and web.
# Per-line net = sale minus its matched return (returns are unified onto the same
# (item, order, channel) line grain, so a missing return is simply absent - no
# join or dedup step needed). Aggregate each year to the item-attribute grain,
# then join 2002 vs 2001 on the 4 keys. (This uses UNION ALL semantics - every
# line contributes; see query75.sql, which deviates from the official q75's
# artificial UNION-DISTINCT on purpose.)
auto cnt_per_row <- sales.quantity - coalesce(sales.return_quantity, 0);
auto amt_per_row <- sales.ext_sales_price - coalesce(sales.return_amount, 0.0);

rowset curr <- where sales.item.category = 'Books' and sales.date.year = 2002
select
    sales.item.brand_id as i_brand_id,
    sales.item.class_id as i_class_id,
    sales.item.category_id as i_category_id,
    sales.item.manufacturer_id as i_manufact_id,
    sum(cnt_per_row) as curr_cnt,
    sum(amt_per_row) as curr_amt,
;

rowset prev <- where sales.item.category = 'Books' and sales.date.year = 2001
select
    sales.item.brand_id as i_brand_id,
    sales.item.class_id as i_class_id,
    sales.item.category_id as i_category_id,
    sales.item.manufacturer_id as i_manufact_id,
    sum(cnt_per_row) as prev_cnt,
    sum(amt_per_row) as prev_amt,
;

subset join prev.i_brand_id = curr.i_brand_id
subset join prev.i_class_id = curr.i_class_id
subset join prev.i_category_id = curr.i_category_id
subset join prev.i_manufact_id = curr.i_manufact_id
select
    2001 as prev_year,
    2002 as year_,
    curr.i_brand_id,
    curr.i_class_id,
    curr.i_category_id,
    curr.i_manufact_id,
    prev.prev_cnt as prev_yr_cnt,
    curr.curr_cnt as curr_yr_cnt,
    curr.curr_cnt - prev.prev_cnt as sales_cnt_diff,
    curr.curr_amt - prev.prev_amt as sales_amt_diff,
having
    curr_yr_cnt::numeric(17,2) / prev_yr_cnt::numeric(17,2) < 0.9

order by
    sales_cnt_diff asc nulls first,
    sales_amt_diff asc nulls first
limit 100
;
