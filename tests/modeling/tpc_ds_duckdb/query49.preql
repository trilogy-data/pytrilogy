import unified_sales as sales;

def in_window(metric) -> sum(metric) by sales.sales_channel, sales.item.id;

metric return_qty <- sum(sales.return_quantity) by sales.sales_channel, sales.item.id;
metric sale_qty <- sum(sales.quantity) by sales.sales_channel, sales.item.id;
metric return_amt <- sum(sales.return_amount) by sales.sales_channel, sales.item.id;
metric sale_paid <- sum(sales.net_paid) by sales.sales_channel, sales.item.id;
property <sales.item.id, sales.sales_channel>.return_rank <- rank(sales.item.id) over (partition by sales.sales_channel order by return_ratio asc);
property <sales.item.id, sales.sales_channel>.currency_rank <- rank(sales.item.id) over (partition by sales.sales_channel order by currency_ratio asc);
property channel_label <- CASE
    WHEN sales.sales_channel = 'WEB' THEN 'web'
    WHEN sales.sales_channel = 'CATALOG' THEN 'catalog'
    WHEN sales.sales_channel = 'STORE' THEN 'store'
    ELSE null
END;
property <sales.item.id, sales.sales_channel>.return_ratio <- return_qty::numeric(15,4) / sale_qty::numeric(15,4);
property <sales.item.id, sales.sales_channel>.currency_ratio <- return_amt::numeric(15,4) / sale_paid::numeric(15,4);

WHERE
    sales.return_amount > 10000
    and sales.net_profit > 1
    and sales.net_paid > 0
    and sales.quantity > 0
    and sales.date.year = 2001
    and sales.date.month_of_year = 12
SELECT
    channel_label as channel,
    sales.item.id as item,
    return_ratio,
    return_rank,
    currency_rank,
HAVING
    return_rank <= 10 or currency_rank <= 10

ORDER BY
    channel asc nulls first,
    return_rank asc nulls first,
    currency_rank asc nulls first,
    item asc nulls first
LIMIT 100
;
