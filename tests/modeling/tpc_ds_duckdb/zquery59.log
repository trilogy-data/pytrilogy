    INNER JOIN \"memory\".\"date_dim\" as \"ss_date_date\" on \"cheerful\".\"ss_date_id\" = \"ss_date_date\".\"D_DATE_SK\"
    LEFT OUTER JOIN \"memory\".\"store\" as \"ss_store_store\" on \"cheerful\".\"ss_store_id\" = \"ss_store_store\".\"S_STORE_SK\"
WHERE
    \"ss_date_date\".\"D_WEEK_SEQ\" is not null

GROUP BY
    1,
    2,
    3),
uneven as (
SELECT
    \"cheerful\".\"ss_store_id\" as \"ss_store_id\",
    \"ss_date_date\".\"D_WEEK_SEQ\" as \"ss_date_week_seq\",
    \"ss_store_store\".\"S_STORE_ID\" as \"ss_store_text_id\",
    \"ss_store_store\".\"S_STORE_NAME\" as \"ss_store_name\"
FROM
    \"cheerful\"
    INNER JOIN \"memory\".\"date_dim\" as \"ss_date_date\" on \"cheerful\".\"ss_date_id\" = \"ss_date_date\".\"D_DATE_SK\"
    LEFT OUTER JOIN \"memory\".\"store\" as \"ss_store_store\" on \"cheerful\".\"ss_store_id\" = \"ss_store_store\".\"S_STORE_SK\"
WHERE
    \"ss_date_date\".\"D_WEEK_SEQ\" is not null

GROUP BY
    1,
    2,
    3,
    4),
scrawny as (
SELECT
    \"thoughtful\".\"ss_date_week_seq\" as \"ss_date_week_seq\",
    \"thoughtful\".\"ss_store_id\" as \"ss_store_id\",
    sum(CASE WHEN \"juicy\".\"ss_date_day_name\" = 'Friday' THEN \"juicy\".\"ss_sales_price\" ELSE NULL END) as \"fri_sales\",
    sum(CASE WHEN \"juicy\".\"ss_date_day_name\" = 'Monday' THEN \"juicy\".\"ss_sales_price\" ELSE NULL END) as \"mon_sales\",
    sum(CASE WHEN \"juicy\".\"ss_date_day_name\" = 'Saturday' THEN \"juicy\".\"ss_sales_price\" ELSE NULL END) as \"sat_sales\",
    sum(CASE WHEN \"juicy\".\"ss_date_day_name\" = 'Sunday' THEN \"juicy\".\"ss_sales_price\" ELSE NULL END) as \"sun_sales\",
    sum(CASE WHEN \"juicy\".\"ss_date_day_name\" = 'Thursday' THEN \"juicy\".\"ss_sales_price\" ELSE NULL END) as \"thu_sales\",
    sum(CASE WHEN \"juicy\".\"ss_date_day_name\" = 'Tuesday' THEN \"juicy\".\"ss_sales_price\" ELSE NULL END) as \"tue_sales\",
    sum(CASE WHEN \"juicy\".\"ss_date_day_name\" = 'Wednesday' THEN \"juicy\".\"ss_sales_price\" ELSE NULL END) as \"wed_sales\"
FROM
    \"thoughtful\"
    LEFT OUTER JOIN \"juicy\" on \"thoughtful\".\"ss_date_week_seq\" is not distinct from \"juicy\".\"ss_date_week_seq\" AND \"thoughtful\".\"ss_store_id\" is not distinct from \"juicy\".\"ss_store_id\"
WHERE
    \"thoughtful\".\"in_year2\" = 1

GROUP BY
    1,
    2),
sweltering as (
SELECT
    \"quizzical\".\"year2_present\" as \"year2_present\"
FROM
    \"thoughtful\"
    LEFT OUTER JOIN \"quizzical\" on 1=1
WHERE
    \"thoughtful\".\"in_year2\" = 1
),
