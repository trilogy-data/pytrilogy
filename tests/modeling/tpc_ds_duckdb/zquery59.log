    \"vacuous\".\"wss_week_seq\" as \"wss_week_seq\",
    lead(\"vacuous\".\"wss_fri_sales\", 1) over (partition by \"vacuous\".\"wss_store_id\",\"vacuous\".\"normalized_week\" order by \"vacuous\".\"wss_in_year2\" asc ) as \"_virt_window_lead_6145286498170393\",
    lead(\"vacuous\".\"wss_mon_sales\", 1) over (partition by \"vacuous\".\"wss_store_id\",\"vacuous\".\"normalized_week\" order by \"vacuous\".\"wss_in_year2\" asc ) as \"_virt_window_lead_4810407976310175\",
    lead(\"vacuous\".\"wss_sat_sales\", 1) over (partition by \"vacuous\".\"wss_store_id\",\"vacuous\".\"normalized_week\" order by \"vacuous\".\"wss_in_year2\" asc ) as \"_virt_window_lead_5231294923035285\",
    lead(\"vacuous\".\"wss_sun_sales\", 1) over (partition by \"vacuous\".\"wss_store_id\",\"vacuous\".\"normalized_week\" order by \"vacuous\".\"wss_in_year2\" asc ) as \"_virt_window_lead_5413357402804969\",
    lead(\"vacuous\".\"wss_thu_sales\", 1) over (partition by \"vacuous\".\"wss_store_id\",\"vacuous\".\"normalized_week\" order by \"vacuous\".\"wss_in_year2\" asc ) as \"_virt_window_lead_4156631954188575\",
    lead(\"vacuous\".\"wss_tue_sales\", 1) over (partition by \"vacuous\".\"wss_store_id\",\"vacuous\".\"normalized_week\" order by \"vacuous\".\"wss_in_year2\" asc ) as \"_virt_window_lead_6115154150547261\",
    lead(\"vacuous\".\"wss_wed_sales\", 1) over (partition by \"vacuous\".\"wss_store_id\",\"vacuous\".\"normalized_week\" order by \"vacuous\".\"wss_in_year2\" asc ) as \"_virt_window_lead_6511286120906247\"
FROM
    \"vacuous\")
SELECT
    \"vacuous\".\"wss_store_name\" as \"s_store_name1\",
    \"vacuous\".\"wss_store_text_id\" as \"s_store_id1\",
    \"vacuous\".\"wss_week_seq\" as \"d_week_seq1\",
    \"concerned\".\"wss_sun_sales\" / \"concerned\".\"_virt_window_lead_5413357402804969\" as \"sun_sales_ratio\",
    \"concerned\".\"wss_mon_sales\" / \"concerned\".\"_virt_window_lead_4810407976310175\" as \"mon_sales_ratio\",
    \"concerned\".\"wss_tue_sales\" / \"concerned\".\"_virt_window_lead_6115154150547261\" as \"tue_sales_ratio\",
    \"concerned\".\"wss_wed_sales\" / \"concerned\".\"_virt_window_lead_6511286120906247\" as \"wed_sales_ratio\",
    \"concerned\".\"wss_thu_sales\" / \"concerned\".\"_virt_window_lead_4156631954188575\" as \"thu_sales_ratio\",
    \"concerned\".\"wss_fri_sales\" / \"concerned\".\"_virt_window_lead_6145286498170393\" as \"fri_sales_ratio\",
    \"concerned\".\"wss_sat_sales\" / \"concerned\".\"_virt_window_lead_5231294923035285\" as \"sat_sales_ratio\"
FROM
    \"vacuous\"
    LEFT OUTER JOIN \"concerned\" on \"vacuous\".\"normalized_week\" = \"concerned\".\"normalized_week\" AND \"vacuous\".\"wss_in_year2\" = \"concerned\".\"wss_in_year2\" AND \"vacuous\".\"wss_store_id\" = \"concerned\".\"wss_store_id\" AND \"vacuous\".\"wss_week_seq\" = \"concerned\".\"wss_week_seq\"
WHERE
    \"vacuous\".\"wss_in_year1\" = 1 and \"concerned\".\"wss_sun_sales\" / \"concerned\".\"_virt_window_lead_5413357402804969\" is not null

