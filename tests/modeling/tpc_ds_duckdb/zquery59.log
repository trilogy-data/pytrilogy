    \"abundant\".\"ss_date_week_seq\" as \"d_week_seq1\",
    \"abundant\".\"ss_store_sk\" as \"ss_store_sk\",
    \"abundant\".\"sun_sales\" / \"abundant\".\"_virt_window_lead_6256435185087398\" as \"sun_sales_ratio\",
