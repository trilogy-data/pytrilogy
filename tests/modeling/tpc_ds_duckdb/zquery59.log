    \"vacuous\".\"sun_sales\" as \"sun1\",
    \"vacuous\".\"thu_sales\" as \"thu1\",
    \"vacuous\".\"tue_sales\" as \"tue1\",
    \"vacuous\".\"wed_sales\" as \"wed1\",
    \"yummy\".\"ss_store_name\" as \"store_name_1\",
    \"yummy\".\"ss_store_text_id\" as \"store_text_id_1\",
    coalesce(\"vacuous\".\"ss_date_week_seq\",\"yummy\".\"ss_date_week_seq\") + 52 as \"join_week\",
    coalesce(\"vacuous\".\"ss_date_week_seq\",\"yummy\".\"ss_date_week_seq\") as \"week_seq_1\"
FROM
    \"yummy\"
    FULL JOIN \"vacuous\" on \"yummy\".\"ss_date_week_seq\" = \"vacuous\".\"ss_date_week_seq\" AND \"yummy\".\"ss_store_id\" is not distinct from \"vacuous\".\"ss_store_id\"
GROUP BY
    1,
    2,
    3,
    4,
    5,
    6,
    7,
    8,
    9,
