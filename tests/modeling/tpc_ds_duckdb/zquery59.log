SELECT
    \"concerned\".\"s_store_name1\" as \"s_store_name1\",
    \"concerned\".\"s_store_id1\" as \"s_store_id1\",
    \"concerned\".\"d_week_seq1\" as \"d_week_seq1\",
    \"concerned\".\"sun_sales_ratio\" as \"sun_sales_ratio\",
