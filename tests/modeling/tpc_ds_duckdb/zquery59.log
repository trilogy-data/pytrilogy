    \"ss_date_date\".\"D_MONTH_SEQ\" BETWEEN 1212 AND 1235 and \"ss_store_sales\".\"SS_STORE_SK\" is not null and \"ss_date_date\".\"D_WEEK_SEQ\" is not null
),
juicy as (
SELECT
    \"ss_store_store\".\"S_STORE_ID\" as \"s_store_id1\",
