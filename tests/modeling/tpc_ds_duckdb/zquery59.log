    \"divergent\".\"sat2\" as \"year2_sat2\",
    \"divergent\".\"store_text_id_2\" as \"year2_store_text_id_2\",
    \"divergent\".\"sun2\" as \"year2_sun2\",
    \"divergent\".\"thu2\" as \"year2_thu2\",
    \"divergent\".\"tue2\" as \"year2_tue2\",
