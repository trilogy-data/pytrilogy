generated_sql = """

WITH 
cheerful as (
SELECT
    \"ss_store_sales\".\"SS_SOLD_DATE_SK\" as \"ss_date_id\",
    \"ss_store_sales\".\"SS_STORE_SK\" as \"ss_store_id\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
WHERE
    \"ss_store_sales\".\"SS_STORE_SK\" is not null

GROUP BY
    1,
    2),
juicy as (
SELECT
    \"ss_date_date\".\"D_DAY_NAME\" as \"ss_date_day_name\",
    \"ss_date_date\".\"D_WEEK_SEQ\" as \"ss_date_week_seq\",
    \"ss_store_sales\".\"SS_SALES_PRICE\" as \"ss_sales_price\",
    \"ss_store_sales\".\"SS_STORE_SK\" as \"ss_store_id\"
FROM
    \"memory\".\"store_sales\" as \"ss_store_sales\"
    INNER JOIN \"memory\".\"date_dim\" as \"ss_date_date\" on \"ss_store_sales\".\"SS_SOLD_DATE_SK\" = \"ss_date_date\".\"D_DATE_SK\"
WHERE
    \"ss_store_sales\".\"SS_STORE_SK\" is not null and \"ss_date_date\".\"D_WEEK_SEQ\" is not null
),
quizzical as (
SELECT
    1 as \"year1_present\",
    1 as \"year2_present\"
),
thoughtful as (
SELECT
    \"cheerful\".\"ss_store_id\" as \"ss_store_id\",
    \"ss_date_date\".\"D_WEEK_SEQ\" as \"ss_date_week_seq\",
    max(CASE
	WHEN \"ss_date_date\".\"D_MONTH_SEQ\" >= 1212 and \"ss_date_date\".\"D_MONTH_SEQ\" <= 1223 THEN 1
	ELSE 0
	END) as \"in_year1\",
    max(CASE
	WHEN \"ss_date_date\".\"D_MONTH_SEQ\" >= 1224 and \"ss_date_date\".\"D_MONTH_SEQ\" <= 1235 THEN 1
	ELSE 0
	END) as \"in_year2\"
FROM
    \"cheerful\"
    INNER JOIN \"memory\".\"date_dim\" as \"ss_date_date\" on \"cheerful\".\"ss_date_id\" = \"ss_date_date\".\"D_DATE_SK\"
WHERE
    \"ss_date_date\".\"D_WEEK_SEQ\" is not null

GROUP BY
    1,
    2),
late as (
SELECT
    \"cheerful\".\"ss_store_id\" as \"ss_store_id\",
