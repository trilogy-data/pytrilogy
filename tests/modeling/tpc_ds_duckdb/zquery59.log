    \"late\".\"ss_store_id\" as \"ss_store_id\",
    \"late\".\"ss_store_text_id\" as \"ss_store_text_id\"
FROM
    \"late\"
    INNER JOIN \"thoughtful\" on \"late\".\"ss_date_week_seq\" is not distinct from \"thoughtful\".\"ss_date_week_seq\" AND \"late\".\"ss_store_id\" is not distinct from \"thoughtful\".\"ss_store_id\"
WHERE
    \"thoughtful\".\"in_year2\" = 1 and \"late\".\"ss_store_id\" is not null and \"late\".\"ss_date_week_seq\" is not null
),
yummy as (
SELECT
    \"uneven\".\"ss_date_week_seq\" as \"ss_date_week_seq\",
    \"uneven\".\"ss_store_id\" as \"ss_store_id\",
    \"uneven\".\"ss_store_name\" as \"ss_store_name\",
    \"uneven\".\"ss_store_text_id\" as \"ss_store_text_id\"
FROM
    \"uneven\"
    INNER JOIN \"thoughtful\" on \"uneven\".\"ss_date_week_seq\" is not distinct from \"thoughtful\".\"ss_date_week_seq\" AND \"uneven\".\"ss_store_id\" is not distinct from \"thoughtful\".\"ss_store_id\"
WHERE
    \"thoughtful\".\"in_year1\" = 1 and \"uneven\".\"ss_store_id\" is not null and \"uneven\".\"ss_date_week_seq\" is not null
),
divergent as (
SELECT
    \"macho\".\"ss_store_text_id\" as \"store_text_id_2\",
    \"scrawny\".\"fri_sales\" as \"fri2\",
    \"scrawny\".\"mon_sales\" as \"mon2\",
    \"scrawny\".\"sat_sales\" as \"sat2\",
    \"scrawny\".\"sun_sales\" as \"sun2\",
    \"scrawny\".\"thu_sales\" as \"thu2\",
    \"scrawny\".\"tue_sales\" as \"tue2\",
    \"scrawny\".\"wed_sales\" as \"wed2\",
    coalesce(\"macho\".\"ss_date_week_seq\",\"scrawny\".\"ss_date_week_seq\") as \"week_seq_2\"
FROM
    \"macho\"
    FULL JOIN \"scrawny\" on \"macho\".\"ss_date_week_seq\" = \"scrawny\".\"ss_date_week_seq\" AND \"macho\".\"ss_store_id\" is not distinct from \"scrawny\".\"ss_store_id\"
GROUP BY
    1,
    2,
    3,
    4,
    5,
    6,
    7,
    8,
    9),
sparkling as (
SELECT
    \"vacuous\".\"fri_sales\" as \"fri1\",
