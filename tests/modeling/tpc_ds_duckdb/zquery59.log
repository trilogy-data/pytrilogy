    \"juicy\".\"s_store_name1\" as \"s_store_name1\",
    \"yummy\".\"d_week_seq1\" as \"d_week_seq1\",
    \"yummy\".\"fri_sales_ratio\" as \"fri_sales_ratio\",
    \"yummy\".\"mon_sales_ratio\" as \"mon_sales_ratio\",
    \"yummy\".\"sat_sales_ratio\" as \"sat_sales_ratio\",
    \"yummy\".\"sun_sales_ratio\" as \"sun_sales_ratio\",
    \"yummy\".\"thu_sales_ratio\" as \"thu_sales_ratio\",
    \"yummy\".\"tue_sales_ratio\" as \"tue_sales_ratio\",
