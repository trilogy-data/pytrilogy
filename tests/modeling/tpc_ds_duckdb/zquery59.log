    \"wakeful\"
GROUP BY
    1,
    2,
    3,
    \"wakeful\".\"ss_date_sk\"),
thoughtful as (
SELECT
    \"cheerful\".\"ss_date_week_seq\" - (CASE
	WHEN max(CASE
	WHEN \"cheerful\".\"ss_date_month_seq\" BETWEEN 1212 AND 1223 THEN 1
	WHEN \"cheerful\".\"ss_date_month_seq\" BETWEEN 1224 AND 1235 THEN 2
	ELSE 0
	END) = 2 THEN 52
	ELSE 0
	END) as \"normalized_week\",
    \"cheerful\".\"ss_date_week_seq\" as \"ss_date_week_seq\",
    \"cheerful\".\"ss_store_sk\" as \"ss_store_sk\",
    max(CASE
	WHEN \"cheerful\".\"ss_date_month_seq\" BETWEEN 1212 AND 1223 THEN 1
	WHEN \"cheerful\".\"ss_date_month_seq\" BETWEEN 1224 AND 1235 THEN 2
	ELSE 0
	END) as \"year_flag\"
FROM
    \"cheerful\"
GROUP BY
