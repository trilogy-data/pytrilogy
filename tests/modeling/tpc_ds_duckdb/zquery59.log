    \"concerned\".\"tue_sales_ratio\" as \"tue_sales_ratio\",
    \"concerned\".\"wed_sales_ratio\" as \"wed_sales_ratio\",
    \"concerned\".\"thu_sales_ratio\" as \"thu_sales_ratio\",
