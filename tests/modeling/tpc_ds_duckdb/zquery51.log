generated_sql = """

WITH 
cheerful as (
SELECT
    \"sales_store_sales_unified\".\"SS_SOLD_DATE_SK\" as \"sales_date_id\",
    \"sales_store_sales_unified\".\"SS_ITEM_SK\" as \"sales_item_id\",
     'STORE'  as \"sales_sales_channel\",
    \"sales_store_sales_unified\".\"SS_SALES_PRICE\" as \"sales_sales_price\"
FROM
    \"memory\".\"store_sales\" as \"sales_store_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"sales_store_sales_unified\".\"SS_SOLD_DATE_SK\" = \"sales_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_store_sales_unified\".\"SS_ITEM_SK\" is not null and \"sales_date_date\".\"D_MONTH_SEQ\" >= 1200 and \"sales_date_date\".\"D_MONTH_SEQ\" <= 1211

UNION ALL
SELECT
    \"sales_web_sales_unified\".\"WS_SOLD_DATE_SK\" as \"sales_date_id\",
    \"sales_web_sales_unified\".\"WS_ITEM_SK\" as \"sales_item_id\",
     'WEB'  as \"sales_sales_channel\",
    \"sales_web_sales_unified\".\"WS_SALES_PRICE\" as \"sales_sales_price\"
FROM
    \"memory\".\"web_sales\" as \"sales_web_sales_unified\"
    INNER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"sales_web_sales_unified\".\"WS_SOLD_DATE_SK\" = \"sales_date_date\".\"D_DATE_SK\"
WHERE
    \"sales_web_sales_unified\".\"WS_ITEM_SK\" is not null and \"sales_date_date\".\"D_MONTH_SEQ\" >= 1200 and \"sales_date_date\".\"D_MONTH_SEQ\" <= 1211
),
vacuous as (
SELECT
    \"cheerful\".\"sales_item_id\" as \"sales_item_id\",
    \"cheerful\".\"sales_sales_channel\" as \"sales_sales_channel\",
    cast(\"sales_date_date\".\"D_DATE\" as date) as \"sales_date_date\"
FROM
    \"cheerful\"
    LEFT OUTER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"cheerful\".\"sales_date_id\" = \"sales_date_date\".\"D_DATE_SK\"
GROUP BY
    1,
    2,
    3),
yummy as (
SELECT
    \"cheerful\".\"sales_item_id\" as \"sales_item_id\",
    cast(\"sales_date_date\".\"D_DATE\" as date) as \"sales_date_date\"
FROM
    \"cheerful\"
    LEFT OUTER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"cheerful\".\"sales_date_id\" = \"sales_date_date\".\"D_DATE_SK\"
GROUP BY
    1,
    2,
    \"cheerful\".\"sales_sales_channel\",
    \"sales_date_date\".\"D_MONTH_SEQ\"),
cooperative as (
SELECT
    \"cheerful\".\"sales_item_id\" as \"sales_item_id\",
    cast(\"sales_date_date\".\"D_DATE\" as date) as \"sales_date_date\",
    sum(CASE WHEN \"cheerful\".\"sales_sales_channel\" = 'STORE' THEN \"cheerful\".\"sales_sales_price\" ELSE NULL END) as \"store_daily\",
    sum(CASE WHEN \"cheerful\".\"sales_sales_channel\" = 'WEB' THEN \"cheerful\".\"sales_sales_price\" ELSE NULL END) as \"web_daily\"
FROM
    \"cheerful\"
    LEFT OUTER JOIN \"memory\".\"date_dim\" as \"sales_date_date\" on \"cheerful\".\"sales_date_id\" = \"sales_date_date\".\"D_DATE_SK\"
GROUP BY
    1,
    2),
concerned as (
SELECT
    \"vacuous\".\"sales_date_date\" as \"sales_date_date\",
    \"vacuous\".\"sales_item_id\" as \"sales_item_id\",
    max(CASE
	WHEN \"vacuous\".\"sales_sales_channel\" = 'STORE' THEN 1
	ELSE 0
	END) as \"store_has_row\",
    max(CASE
	WHEN \"vacuous\".\"sales_sales_channel\" = 'WEB' THEN 1
	ELSE 0
	END) as \"web_has_row\"
FROM
    \"vacuous\"
GROUP BY
    1,
    2),
uneven as (
SELECT
    \"cooperative\".\"sales_date_date\" as \"sales_date_date\",
    \"cooperative\".\"sales_item_id\" as \"sales_item_id\",
    sum(\"cooperative\".\"store_daily\") over (partition by \"cooperative\".\"sales_item_id\" order by \"cooperative\".\"sales_date_date\" asc ) as \"store_cume\",
    sum(\"cooperative\".\"web_daily\") over (partition by \"cooperative\".\"sales_item_id\" order by \"cooperative\".\"sales_date_date\" asc ) as \"web_cume\"
FROM
    \"cooperative\"),
juicy as (
SELECT
    \"uneven\".\"store_cume\" as \"store_cume\",
    \"uneven\".\"web_cume\" as \"web_cume\",
    coalesce(\"uneven\".\"sales_date_date\",\"yummy\".\"sales_date_date\") as \"sales_date_date\",
    coalesce(\"uneven\".\"sales_item_id\",\"yummy\".\"sales_item_id\") as \"sales_item_id\"
FROM
    \"uneven\"
    FULL JOIN \"yummy\" on \"uneven\".\"sales_date_date\" is not distinct from \"yummy\".\"sales_date_date\" AND \"uneven\".\"sales_item_id\" = \"yummy\".\"sales_item_id\")
SELECT
    coalesce(\"concerned\".\"sales_item_id\",\"juicy\".\"sales_item_id\") as \"item_sk\",
    coalesce(\"concerned\".\"sales_date_date\",\"juicy\".\"sales_date_date\") as \"d_date\",
    CASE
	WHEN \"concerned\".\"web_has_row\" = 1 THEN \"juicy\".\"web_cume\"
	ELSE null
	END as \"web_sales\",
    CASE
	WHEN \"concerned\".\"store_has_row\" = 1 THEN \"juicy\".\"store_cume\"
	ELSE null
	END as \"store_sales\",
    \"juicy\".\"web_cume\" as \"web_cumulative\",
    \"juicy\".\"store_cume\" as \"store_cumulative\"
FROM
    \"juicy\"
    FULL JOIN \"concerned\" on \"juicy\".\"sales_date_date\" is not distinct from \"concerned\".\"sales_date_date\" AND \"juicy\".\"sales_item_id\" = \"concerned\".\"sales_item_id\"
WHERE
    \"juicy\".\"web_cume\" > \"juicy\".\"store_cume\"

GROUP BY
    1,
    2,
    3,
    4,
    5,
    6
ORDER BY 
    \"item_sk\" asc nulls first,
    \"d_date\" asc nulls first
LIMIT (100)"""
