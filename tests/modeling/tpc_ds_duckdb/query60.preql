import unified_sales as sales;

property music_item_ids <- filter sales.item.name where sales.item.category = 'Music';

WHERE
    sales.item.name in music_item_ids
    and sales.date.year = 1998
    and sales.date.month_of_year = 9
    and sales.bill_address.gmt_offset = -5
SELECT
    sales.item.name,
    sum(sales.ext_sales_price) -> total_sales,
ORDER BY
    sales.item.name asc,
    total_sales asc
LIMIT 100
;
