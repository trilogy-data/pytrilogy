import all_sales as sales;

auto music_item_ids <- sales.item.id ? sales.item.category = 'Music';

where
    sales.item.id in music_item_ids
    and sales.sale_date.year = 1998
    and sales.sale_date.month_of_year = 9
    and sales.pos_bill_address.gmt_offset = -5
select
    sales.item.id,
    sum(sales.ext_sales_price) as total_sales,
order by
    sales.item.id asc,
    total_sales asc
limit 100
;
