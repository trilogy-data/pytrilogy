import catalog_sales as catalog_sales;
import web_sales as web_sales;
import date as date;

auto relevent_week_seq <- date.week_seq ? date.year in (2001, 2002);

def weekday_sales(weekday) -> sum(
    case
        when date.day_of_week = weekday then web_sales.ext_sales_price
        else 0.0::numeric(15,2)
    end
)
    by date.week_seq + sum(
    case
        when date.day_of_week = weekday then catalog_sales.ext_sales_price
        else 0.0::numeric(15,2)
    end
)
    by date.week_seq;
def round_lag(sales) -> round(sales / (lead(sales, 53) over (order by date.week_seq asc)), 2);

where
    date.week_seq in relevent_week_seq
subset join date.sk = catalog_sales.date.sk
subset join date.sk = web_sales.date.sk
select
    date.week_seq,
    @round_lag(@weekday_sales(0)) as sunday_increase,
    @round_lag(@weekday_sales(1)) as monday_increase,
    @round_lag(@weekday_sales(2)) as tuesday_increase,
    @round_lag(@weekday_sales(3)) as wednesday_increase,
    @round_lag(@weekday_sales(4)) as thursday_increase,
    @round_lag(@weekday_sales(5)) as friday_increase,
    @round_lag(@weekday_sales(6)) as saturday_increase,
having
    sunday_increase is not null

order by
    date.week_seq asc nulls first
limit 100
;
