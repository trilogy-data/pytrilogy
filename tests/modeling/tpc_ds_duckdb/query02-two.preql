import catalog_sales as catalog_sales;
import web_sales as web_sales;
import date as date;

MERGE catalog_sales.date.* into ~date.*;
MERGE web_sales.date.* into ~date.*;

property relevent_week_seq <- filter date.week_seq where date.year in (2001, 2002);

def weekday_sales(weekday) -> sum(CASE
    WHEN date.day_of_week = weekday THEN web_sales.ext_sales_price
    ELSE 0.0::Numeric(15,2)
END) by date.week_seq + sum(CASE
    WHEN date.day_of_week = weekday THEN catalog_sales.ext_sales_price
    ELSE 0.0::Numeric(15,2)
END) by date.week_seq;
def round_lag(sales) -> round(sales / (lead(sales,53) over (order by date.week_seq asc)),2);

WHERE
    date.week_seq in relevent_week_seq
SELECT
    date.week_seq,
    @round_lag(@weekday_sales(0)) -> sunday_increase,
    @round_lag(@weekday_sales(1)) -> monday_increase,
    @round_lag(@weekday_sales(2)) -> tuesday_increase,
    @round_lag(@weekday_sales(3)) -> wednesday_increase,
    @round_lag(@weekday_sales(4)) -> thursday_increase,
    @round_lag(@weekday_sales(5)) -> friday_increase,
    @round_lag(@weekday_sales(6)) -> saturday_increase,
HAVING
    sunday_increase is not null

ORDER BY
    date.week_seq asc nulls first
LIMIT 100
;
