import catalog_sales as cs;
import catalog_returns as cr;
import store_sales as ss;
import web_sales as ws;
import web_returns as wr;

const period_start <- '2000-08-23'::date;
const period_end <- '2000-09-22'::date;

# Catalog returns aggregated per call_center, folded to a 1-row scalar so the
# catalog branch can broadcast (replicates the reference's `FROM cs , cr`).
rowset cr_grouped <- where
    cr.date.date between period_start and period_end
select
    coalesce(cr.call_center.id, -1) as cr_cc_key,
    sum(cr.return_amount) as cr_returns_per_cc,
    sum(cr.net_loss) as cr_loss_per_cc,
;

rowset cr_totals <- select
    count(cr_grouped.cr_cc_key) as cr_n_groups,
    sum(cr_grouped.cr_returns_per_cc) as cr_total_returns,
    sum(cr_grouped.cr_loss_per_cc) as cr_total_loss,
;

rowset ss_grouped <- where
    ss.date.date between period_start and period_end
    and ss.store.id is not null
select
    ss.store.id as ss_store_id,
    sum(ss.ext_sales_price) as ss_sales,
    sum(ss.net_profit) as ss_profit,
;

rowset sr_grouped <- where
    ss.return_date.date between period_start and period_end
select
    ss.return_store.id as sr_store_id,
    sum(ss.return_amount) as sr_returns,
    sum(ss.return_net_loss) as sr_loss,
;

rowset ws_grouped <- where
    ws.date.date between period_start and period_end
    and ws.web_page.id is not null
select
    ws.web_page.id as ws_wp_id,
    sum(ws.ext_sales_price) as ws_sales,
    sum(ws.net_profit) as ws_profit,
;

rowset wr_grouped <- where
    wr.return_date.date between period_start and period_end
select
    wr.web_page.id as wr_wp_id,
    sum(wr.return_amount) as wr_returns,
    sum(wr.net_loss) as wr_loss,
;

# UNION the 3 channel branches via the relational union(...) TVF. Each arm is a
# self-contained select; the store/web sales<-returns join is localized to the
# arm that needs it (vs the old multiselect where the joins lived in the outer
# select).
with l0_union as union(
    (where cs.date.date between period_start and period_end
     select
        'catalog channel' as u_channel,
        cs.call_center.id as u_id,
        sum(cs.ext_sales_price) * cr_totals.cr_n_groups::numeric(15,2) as u_sales,
        cr_totals.cr_total_returns::numeric(15,2) as u_returns,
        sum(cs.net_profit) * cr_totals.cr_n_groups - cr_totals.cr_total_loss::numeric(15,2) as u_profit,
    ),
    (left join ss_grouped.ss_store_id = sr_grouped.sr_store_id
     select
        'store channel' as u_channel,
        ss_grouped.ss_store_id as u_id,
        ss_grouped.ss_sales::numeric(15,2) as u_sales,
        coalesce(sr_grouped.sr_returns, 0)::numeric(15,2) as u_returns,
        ss_grouped.ss_profit - coalesce(sr_grouped.sr_loss, 0)::numeric(15,2) as u_profit,
    ),
    (left join ws_grouped.ws_wp_id = wr_grouped.wr_wp_id
     select
        'web channel' as u_channel,
        ws_grouped.ws_wp_id as u_id,
        ws_grouped.ws_sales::numeric(15,2) as u_sales,
        coalesce(wr_grouped.wr_returns, 0)::numeric(15,2) as u_returns,
        ws_grouped.ws_profit - coalesce(wr_grouped.wr_loss, 0)::numeric(15,2) as u_profit,
    )
) -> (u_channel, u_id, u_sales, u_returns, u_profit);

# Final ROLLUP(channel, id) over the unioned L0. The sales<-returns joins are
# now declared inside each arm (arm-local query-scoped joins).
select
    l0_union.u_channel as channel,
    l0_union.u_id as id,
    sum(l0_union.u_sales) by rollup l0_union.u_channel, l0_union.u_id as sales,
    sum(l0_union.u_returns) by rollup l0_union.u_channel, l0_union.u_id as returns_,
    sum(l0_union.u_profit) by rollup l0_union.u_channel, l0_union.u_id as profit,
order by
    channel asc nulls first,
    id asc nulls first,
    returns_ desc
limit 100
;
