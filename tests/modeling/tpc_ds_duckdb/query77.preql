import catalog_sales as cs;
import catalog_returns as cr;
import store_sales as ss;
import web_sales as ws;
import web_returns as wr;

const period_start <- '2000-08-23'::date;
const period_end <- '2000-09-22'::date;

rowset cr_grouped <- WHERE
    cr.date.date between period_start and period_end
SELECT
    coalesce(cr.call_center.id,-1) -> cr_cc_key,
    sum(cr.return_amount) -> cr_returns_per_cc,
    sum(cr.net_loss) -> cr_loss_per_cc,
;

rowset cr_totals <- SELECT
    count(cr_grouped.cr_cc_key) -> cr_n_groups,
    sum(cr_grouped.cr_returns_per_cc) -> cr_total_returns,
    sum(cr_grouped.cr_loss_per_cc) -> cr_total_loss,
;

rowset ss_grouped <- WHERE
    ss.date.date between period_start and period_end
SELECT
    ss.store.id -> ss_store_id,
    sum(ss.ext_sales_price) -> ss_sales,
    sum(ss.net_profit) -> ss_profit,
;

rowset sr_grouped <- WHERE
    ss.return_date.date between period_start and period_end
SELECT
    ss.return_store.id -> sr_store_id,
    sum(ss.return_amount) -> sr_returns,
    sum(ss.return_net_loss) -> sr_loss,
;

MERGE sr_grouped.sr_store_id into ss_grouped.ss_store_id;

rowset ws_grouped <- WHERE
    ws.date.date between period_start and period_end
SELECT
    ws.web_page.id -> ws_wp_id,
    sum(ws.ext_sales_price) -> ws_sales,
    sum(ws.net_profit) -> ws_profit,
;

rowset wr_grouped <- WHERE
    wr.return_date.date between period_start and period_end
SELECT
    wr.web_page.id -> wr_wp_id,
    sum(wr.return_amount) -> wr_returns,
    sum(wr.net_loss) -> wr_loss,
;

MERGE wr_grouped.wr_wp_id into ws_grouped.ws_wp_id;

rowset l0_union <- WHERE
    cs.date.date between period_start and period_end
SELECT
    'catalog channel' -> u_channel_c,
    cs.call_center.id -> u_id_c,
    sum(cs.ext_sales_price) * cr_totals.cr_n_groups::Numeric(15,2) -> u_sales_c,
    cr_totals.cr_total_returns::Numeric(15,2) -> u_returns_c,
    sum(cs.net_profit) * cr_totals.cr_n_groups - cr_totals.cr_total_loss::Numeric(15,2) -> u_profit_c,
MERGE
SELECT
    'store channel' -> u_channel_s,
    ss_grouped.ss_store_id -> u_id_s,
    ss_grouped.ss_sales::Numeric(15,2) -> u_sales_s,
    coalesce(sr_grouped.sr_returns,0)::Numeric(15,2) -> u_returns_s,
    ss_grouped.ss_profit - coalesce(sr_grouped.sr_loss,0)::Numeric(15,2) -> u_profit_s,
MERGE
SELECT
    'web channel' -> u_channel_w,
    ws_grouped.ws_wp_id -> u_id_w,
    ws_grouped.ws_sales::Numeric(15,2) -> u_sales_w,
    coalesce(wr_grouped.wr_returns,0)::Numeric(15,2) -> u_returns_w,
    ws_grouped.ws_profit - coalesce(wr_grouped.wr_loss,0)::Numeric(15,2) -> u_profit_w,
ALIGN
    u_channel: u_channel_c, u_channel_s, u_channel_w
    and u_id: u_id_c, u_id_s, u_id_w
    and u_sales: u_sales_c, u_sales_s, u_sales_w
    and u_returns: u_returns_c, u_returns_s, u_returns_w
    and u_profit: u_profit_c, u_profit_s, u_profit_w
;

SELECT
    l0_union.u_channel -> channel,
    l0_union.u_id -> id,
    sum(l0_union.u_sales) by rollup l0_union.u_channel, l0_union.u_id -> sales,
    sum(l0_union.u_returns) by rollup l0_union.u_channel, l0_union.u_id -> returns_,
    sum(l0_union.u_profit) by rollup l0_union.u_channel, l0_union.u_id -> profit,
ORDER BY
    channel asc nulls first,
    id asc nulls first,
    returns_ desc
LIMIT 100
;
