import web_sales as ws;

auto multi_warehouse_orders <- ws.order_number ? count(ws.warehouse.sk) by ws.order_number > 1;
auto returned_orders <- ws.order_number ? ws.is_returned;

where
    ws.ship_date.date between '1999-02-01'::date and '1999-04-02'::date
    and ws.pos_ship_address.state = 'IL'
    and ws.web_site.company_name = 'pri'
    and ws.order_number in multi_warehouse_orders
    and ws.order_number not in returned_orders
select
    count_distinct(ws.order_number) as order_count,
    sum(ws.ext_ship_cost) as total_shipping_cost,
    sum(ws.net_profit) as total_net_profit,
order by
    order_count asc
limit 100
;
