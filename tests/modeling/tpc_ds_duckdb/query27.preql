import store_sales as store_sales;

where
    store_sales.customer_demographic.gender = 'M'
    and store_sales.customer_demographic.marital_status = 'S'
    and store_sales.customer_demographic.education_status = 'College'
    and store_sales.date.year = 2002
    and store_sales.store.state = 'TN'
select
    store_sales.item.id,
    store_sales.store.state,
    grouping(store_sales.store.state) as g_state,
    avg(store_sales.quantity::numeric(12,2)) as agg1,
    avg(store_sales.list_price::numeric(12,2)) as agg2,
    avg(store_sales.coupon_amt::numeric(12,2)) as agg3,
    avg(store_sales.sales_price::numeric(12,2)) as agg4,
by rollup (store_sales.item.id, store_sales.store.state)
order by
    store_sales.item.id asc nulls first,
    store_sales.store.state asc nulls first
limit 100
;
