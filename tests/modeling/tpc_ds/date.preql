


key id int;
properties id (
    date_string string,
    date date,
    year int, # 
    day_of_week int, #DOW, 0 indexed
);

datasource date (
    D_DATE_SK: id,
    D_DATE_ID: date_string,
     D_DOW: day_of_week,
    raw('''cast("D_YEAR" as int)'''): year
)
grain (id)
address SNOWFLAKE_SAMPLE_DATA.TPCDS_SF10TCL.date_dim;
