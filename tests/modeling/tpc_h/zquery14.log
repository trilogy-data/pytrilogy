generated_sql = """

WITH 
wakeful as (
SELECT
    sum(\"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\")) as \"_virt_agg_sum_1789203937951976\",
    sum(CASE WHEN \"part_part\".\"p_type\" like 'PROMO%' THEN \"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\") ELSE NULL END) as \"_virt_agg_sum_923544407546593\"
FROM
    \"memory\".\"part\" as \"part_part\"
    INNER JOIN \"memory\".\"lineitem\" as \"lineitem\" on \"part_part\".\"p_partkey\" = \"lineitem\".\"l_partkey\"
WHERE
    \"lineitem\".\"l_shipdate\" >= date '1995-09-01' and \"lineitem\".\"l_shipdate\" < date '1995-10-01'
)
SELECT
    ( 100.0 * \"wakeful\".\"_virt_agg_sum_923544407546593\" ) / \"wakeful\".\"_virt_agg_sum_1789203937951976\" as \"promo_revenue\"
FROM
    \"wakeful\""""
