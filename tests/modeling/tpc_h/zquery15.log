generated_sql = """

WITH 
highfalutin as (
SELECT
    \"lineitem\".\"l_suppkey\" as \"part_supplier_id\",
    sum(CASE WHEN \"lineitem\".\"l_shipdate\" >= date '1996-01-01' and \"lineitem\".\"l_shipdate\" < date '1996-04-01' THEN \"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\") ELSE NULL END) as \"supplier_rev\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
GROUP BY
    1),
cooperative as (
SELECT
    \"lineitem\".\"l_suppkey\" as \"part_supplier_id\",
    \"part_supplier_supplier\".\"s_address\" as \"part_supplier_address\",
    \"part_supplier_supplier\".\"s_name\" as \"part_supplier_name\",
    \"part_supplier_supplier\".\"s_phone\" as \"part_supplier_phone\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"supplier\" as \"part_supplier_supplier\" on \"lineitem\".\"l_suppkey\" = \"part_supplier_supplier\".\"s_suppkey\"),
wakeful as (
SELECT
    max(\"highfalutin\".\"supplier_rev\") as \"max_supplier_rev\"
FROM
    \"highfalutin\"),
questionable as (
SELECT
    \"cooperative\".\"part_supplier_address\" as \"part_supplier_address\",
    \"cooperative\".\"part_supplier_id\" as \"part_supplier_id\",
    \"cooperative\".\"part_supplier_name\" as \"part_supplier_name\",
    \"cooperative\".\"part_supplier_phone\" as \"part_supplier_phone\",
    \"highfalutin\".\"supplier_rev\" as \"supplier_rev\",
    \"highfalutin\".\"supplier_rev\" as \"total_revenue\"
FROM
    \"cooperative\"
    INNER JOIN \"highfalutin\" on \"cooperative\".\"part_supplier_id\" = \"highfalutin\".\"part_supplier_id\"
    INNER JOIN \"wakeful\" on 1=1
WHERE
    \"highfalutin\".\"supplier_rev\" = \"wakeful\".\"max_supplier_rev\"

GROUP BY
    1,
    2,
    3,
    4,
    5)
SELECT
    \"questionable\".\"part_supplier_id\" as \"part_supplier_id\",
    \"questionable\".\"part_supplier_name\" as \"part_supplier_name\",
    \"questionable\".\"part_supplier_address\" as \"part_supplier_address\",
    \"questionable\".\"part_supplier_phone\" as \"part_supplier_phone\",
    \"questionable\".\"total_revenue\" as \"total_revenue\"
FROM
    \"wakeful\"
    INNER JOIN \"questionable\" on 1=1
WHERE
    \"questionable\".\"supplier_rev\" = \"wakeful\".\"max_supplier_rev\"

ORDER BY 
    \"questionable\".\"part_supplier_id\" asc"""
