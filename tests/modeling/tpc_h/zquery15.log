generated_sql = """

WITH 
quizzical as (
SELECT
    \"lineitem\".\"l_suppkey\" as \"part_supplier_id\",
    sum(\"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\")) as \"supplier_rev\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
WHERE
    \"lineitem\".\"l_shipdate\" >= date '1996-01-01' and \"lineitem\".\"l_shipdate\" < date '1996-04-01'

GROUP BY
    1),
cheerful as (
SELECT
    max(\"quizzical\".\"supplier_rev\") as \"max_supplier_rev\"
FROM
    \"quizzical\"),
cooperative as (
SELECT
    \"part_supplier_supplier\".\"s_address\" as \"part_supplier_address\",
    \"part_supplier_supplier\".\"s_name\" as \"part_supplier_name\",
    \"part_supplier_supplier\".\"s_phone\" as \"part_supplier_phone\",
    \"quizzical\".\"part_supplier_id\" as \"part_supplier_id\",
    \"quizzical\".\"supplier_rev\" as \"supplier_rev\"
FROM
    \"quizzical\"
    INNER JOIN \"memory\".\"supplier\" as \"part_supplier_supplier\" on \"quizzical\".\"part_supplier_id\" = \"part_supplier_supplier\".\"s_suppkey\")
SELECT
    \"cooperative\".\"part_supplier_id\" as \"part_supplier_id\",
    \"cooperative\".\"part_supplier_name\" as \"part_supplier_name\",
    \"cooperative\".\"part_supplier_address\" as \"part_supplier_address\",
    \"cooperative\".\"part_supplier_phone\" as \"part_supplier_phone\",
    \"cooperative\".\"supplier_rev\" as \"total_revenue\"
FROM
    \"cheerful\"
    INNER JOIN \"cooperative\" on 1=1
WHERE
    \"cooperative\".\"supplier_rev\" = \"cheerful\".\"max_supplier_rev\"

ORDER BY 
    \"cooperative\".\"part_supplier_id\" asc"""
