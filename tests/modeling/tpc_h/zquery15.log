    CASE WHEN \"lineitem\".\"l_shipdate\" >= date '1996-01-01' and \"lineitem\".\"l_shipdate\" < date '1996-04-01' THEN \"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\") ELSE NULL END as \"_virt_filter_revenue_6893837512415319\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"),
abundant as (
