generated_sql = """

WITH 
highfalutin as (
SELECT
    \"lineitem\".\"l_suppkey\" as \"part_supplier_id\",
    sum(CASE WHEN \"lineitem\".\"l_shipdate\" >= date '1996-01-01' and \"lineitem\".\"l_shipdate\" < date '1996-04-01' THEN \"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\") ELSE NULL END) as \"supplier_rev\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
GROUP BY
    1),
uneven as (
SELECT
    \"lineitem\".\"l_linenumber\" as \"line_no\",
    \"lineitem\".\"l_orderkey\" as \"order_id\",
    \"lineitem\".\"l_suppkey\" as \"part_supplier_id\",
    \"part_supplier_supplier\".\"s_address\" as \"part_supplier_address\",
    \"part_supplier_supplier\".\"s_name\" as \"part_supplier_name\",
    \"part_supplier_supplier\".\"s_phone\" as \"part_supplier_phone\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"supplier\" as \"part_supplier_supplier\" on \"lineitem\".\"l_suppkey\" = \"part_supplier_supplier\".\"s_suppkey\"),
cooperative as (
SELECT
    max(\"highfalutin\".\"supplier_rev\") as \"max_supplier_rev\"
FROM
    \"highfalutin\"),
yummy as (
SELECT
    \"uneven\".\"line_no\" as \"line_no\",
    \"uneven\".\"order_id\" as \"order_id\",
    \"uneven\".\"part_supplier_id\" as \"part_supplier_id\"
FROM
    \"uneven\"),
vacuous as (
SELECT
    \"highfalutin\".\"supplier_rev\" as \"supplier_rev\",
    \"uneven\".\"part_supplier_address\" as \"part_supplier_address\",
    \"uneven\".\"part_supplier_id\" as \"part_supplier_id\",
    \"uneven\".\"part_supplier_name\" as \"part_supplier_name\",
    \"uneven\".\"part_supplier_phone\" as \"part_supplier_phone\"
FROM
    \"yummy\"
    INNER JOIN \"uneven\" on \"yummy\".\"line_no\" = \"uneven\".\"line_no\" AND \"yummy\".\"order_id\" = \"uneven\".\"order_id\"
    INNER JOIN \"highfalutin\" on \"yummy\".\"part_supplier_id\" = \"highfalutin\".\"part_supplier_id\"
    FULL JOIN \"cooperative\" on 1=1
GROUP BY
    1,
    2,
    3,
    4,
    5),
sparkling as (
SELECT
    \"vacuous\".\"part_supplier_address\" as \"part_supplier_address\",
    \"vacuous\".\"part_supplier_id\" as \"part_supplier_id\",
    \"vacuous\".\"part_supplier_name\" as \"part_supplier_name\",
    \"vacuous\".\"part_supplier_phone\" as \"part_supplier_phone\",
    \"vacuous\".\"supplier_rev\" as \"supplier_rev\",
    \"vacuous\".\"supplier_rev\" as \"total_revenue\"
FROM
    \"vacuous\")
SELECT
    \"sparkling\".\"part_supplier_id\" as \"part_supplier_id\",
    \"sparkling\".\"part_supplier_name\" as \"part_supplier_name\",
    \"sparkling\".\"part_supplier_address\" as \"part_supplier_address\",
    \"sparkling\".\"part_supplier_phone\" as \"part_supplier_phone\",
    \"sparkling\".\"total_revenue\" as \"total_revenue\"
FROM
    \"cooperative\"
    INNER JOIN \"sparkling\" on 1=1
WHERE
    \"sparkling\".\"supplier_rev\" = \"cooperative\".\"max_supplier_rev\"

ORDER BY 
    \"sparkling\".\"part_supplier_id\" asc"""
