import lineitem;

auto distinct_suppliers_per_order <- count(part.supplier.id ) by order.id;
auto late_suppliers_per_order <- count(part.supplier.id ?  receipt_date > commit_date) by order.id;

where
    part.supplier.nation.name = 'SAUDI ARABIA'
    and order.status = 'F'
    and receipt_date > commit_date
    and distinct_suppliers_per_order > 1
    and late_suppliers_per_order = 1
SELECT
    part.supplier.name,
    sum(row_counter) -> numwait,
ORDER BY
    numwait desc,
    part.supplier.name asc
LIMIT 100
;