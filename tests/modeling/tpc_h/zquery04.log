generated_sql = """

WITH 
wakeful as (
SELECT
    \"lineitem\".\"l_orderkey\" as \"order_id\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"lineitem\".\"l_orderkey\" = \"order_orders\".\"o_orderkey\"
WHERE
    \"order_orders\".\"o_orderdate\" >= date '1993-07-01' and \"order_orders\".\"o_orderdate\" < date '1993-10-01' and \"lineitem\".\"l_commitdate\" < \"lineitem\".\"l_receiptdate\"

GROUP BY
    1
HAVING
    count(\"lineitem\".\"l_linenumber\") > 0
),
thoughtful as (
SELECT
    \"order_orders\".\"o_orderkey\" as \"order_id\",
    \"order_orders\".\"o_orderpriority\" as \"order_priority\"
FROM
    \"memory\".\"orders\" as \"order_orders\"
WHERE
    \"order_orders\".\"o_orderdate\" >= date '1993-07-01' and \"order_orders\".\"o_orderdate\" < date '1993-10-01'
)
SELECT
    \"thoughtful\".\"order_priority\" as \"order_priority\",
    count(\"wakeful\".\"order_id\") as \"order_count\"
FROM
    \"wakeful\"
    INNER JOIN \"thoughtful\" on \"wakeful\".\"order_id\" = \"thoughtful\".\"order_id\"
GROUP BY
    1
ORDER BY 
    \"thoughtful\".\"order_priority\" asc"""
