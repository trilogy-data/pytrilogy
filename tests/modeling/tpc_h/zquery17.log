generated_sql = """

WITH 
cheerful as (
SELECT
    \"lineitem\".\"l_extendedprice\" as \"extended_price\",
    \"lineitem\".\"l_quantity\" as \"quantity\",
    \"part_part\".\"p_partkey\" as \"part_id\"
FROM
    \"memory\".\"partsupp\" as \"part_partsupp\"
    LEFT OUTER JOIN \"memory\".\"lineitem\" as \"lineitem\" on \"part_partsupp\".\"ps_partkey\" = \"lineitem\".\"l_partkey\" AND \"part_partsupp\".\"ps_suppkey\" = \"lineitem\".\"l_suppkey\"
    INNER JOIN \"memory\".\"part\" as \"part_part\" on \"part_partsupp\".\"ps_partkey\" = \"part_part\".\"p_partkey\"
WHERE
    \"part_part\".\"p_brand\" = 'Brand#23' and \"part_part\".\"p_container\" = 'MED BOX'
),
cooperative as (
SELECT
    \"part_partsupp\".\"ps_partkey\" as \"part_id\",
    avg(\"lineitem\".\"l_quantity\") as \"avg_qty_per_part\"
FROM
    \"memory\".\"partsupp\" as \"part_partsupp\"
    LEFT OUTER JOIN \"memory\".\"lineitem\" as \"lineitem\" on \"part_partsupp\".\"ps_partkey\" = \"lineitem\".\"l_partkey\" AND \"part_partsupp\".\"ps_suppkey\" = \"lineitem\".\"l_suppkey\"
GROUP BY
    1),
thoughtful as (
SELECT
    \"cheerful\".\"extended_price\" as \"extended_price\",
    \"cheerful\".\"part_id\" as \"part_id\",
    \"cheerful\".\"quantity\" as \"quantity\"
FROM
    \"cheerful\")
SELECT
    sum(\"thoughtful\".\"extended_price\") / 7.0 as \"avg_yearly\"
FROM
    \"thoughtful\"
    INNER JOIN \"cooperative\" on \"thoughtful\".\"part_id\" = \"cooperative\".\"part_id\"
WHERE
    \"thoughtful\".\"quantity\" < 0.2 * \"cooperative\".\"avg_qty_per_part\"
"""
