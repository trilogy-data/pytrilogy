generated_sql = """

WITH 
cheerful as (
SELECT
    \"lineitem\".\"l_extendedprice\" as \"extended_price\",
    \"lineitem\".\"l_quantity\" as \"quantity\",
    \"part_part\".\"p_partkey\" as \"part_id\"
FROM
    \"memory\".\"part\" as \"part_part\"
    LEFT OUTER JOIN \"memory\".\"lineitem\" as \"lineitem\" on \"part_part\".\"p_partkey\" = \"lineitem\".\"l_partkey\"),
cheerful as (
SELECT
    \"part_partsupp\".\"ps_partkey\" as \"part_id\",
    avg(\"lineitem\".\"l_quantity\") as \"avg_qty_per_part\"
FROM
    \"memory\".\"partsupp\" as \"part_partsupp\"
    LEFT OUTER JOIN \"memory\".\"lineitem\" as \"lineitem\" on \"part_partsupp\".\"ps_partkey\" = \"lineitem\".\"l_partkey\" AND \"part_partsupp\".\"ps_suppkey\" = \"lineitem\".\"l_suppkey\"
GROUP BY
    1)
SELECT
    sum(\"wakeful\".\"extended_price\") / 7.0 as \"avg_yearly\"
FROM
    \"wakeful\"
    INNER JOIN \"cheerful\" on \"wakeful\".\"part_id\" = \"cheerful\".\"part_id\"
WHERE
    \"wakeful\".\"part_brand\" = 'Brand#23' and \"wakeful\".\"part_container\" = 'MED BOX' and \"wakeful\".\"quantity\" < 0.2 * \"cheerful\".\"avg_qty_per_part\"
"""
