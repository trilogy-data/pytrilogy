generated_sql = """

WITH 
wakeful as (
SELECT
    \"lineitem\".\"l_extendedprice\" as \"extended_price\",
    \"lineitem\".\"l_quantity\" as \"quantity\",
    \"part_part\".\"p_brand\" as \"part_brand\",
    \"part_part\".\"p_container\" as \"part_container\",
    \"part_part\".\"p_partkey\" as \"part_id\"
FROM
    \"memory\".\"part\" as \"part_part\"
    LEFT OUTER JOIN \"memory\".\"lineitem\" as \"lineitem\" on \"part_part\".\"p_partkey\" = \"lineitem\".\"l_partkey\"),
thoughtful as (
SELECT
    \"wakeful\".\"part_id\" as \"part_id\",
    avg(\"wakeful\".\"quantity\") as \"avg_qty_per_part\"
FROM
    \"wakeful\"
GROUP BY
    1),
cheerful as (
SELECT
    \"wakeful\".\"extended_price\" as \"extended_price\",
    \"wakeful\".\"part_id\" as \"part_id\",
    \"wakeful\".\"quantity\" as \"quantity\"
FROM
    \"wakeful\"
WHERE
    \"wakeful\".\"part_brand\" = 'Brand#23' and \"wakeful\".\"part_container\" = 'MED BOX'
),
questionable as (
SELECT
    sum(\"cheerful\".\"extended_price\") as \"_virt_agg_sum_5592368918008795\"
FROM
    \"cheerful\"
    INNER JOIN \"thoughtful\" on \"cheerful\".\"part_id\" = \"thoughtful\".\"part_id\"
WHERE
    \"cheerful\".\"quantity\" < 0.2 * \"thoughtful\".\"avg_qty_per_part\"
)
SELECT
    \"questionable\".\"_virt_agg_sum_5592368918008795\" / 7.0 as \"avg_yearly\"
FROM
    \"questionable\""""
