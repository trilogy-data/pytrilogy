generated_sql = """

WITH 
cooperative as (
SELECT
    \"lineitem\".\"l_quantity\" as \"quantity\",
    \"lineitem\".\"l_shipdate\" as \"ship_date\",
    \"part_part\".\"p_name\" as \"part_name\",
    \"part_part\".\"p_partkey\" as \"part_id\",
    \"part_partsupp\".\"ps_availqty\" as \"part_available_quantity\",
    \"part_partsupp\".\"ps_suppkey\" as \"part_supplier_id\",
    \"part_supplier_nation_nation\".\"n_nationkey\" as \"part_supplier_nation_id\",
    UPPER(\"part_supplier_nation_nation\".\"n_name\")  as \"part_supplier_nation_name\"
FROM
    \"memory\".\"supplier\" as \"part_supplier_supplier\"
    INNER JOIN \"memory\".\"nation\" as \"part_supplier_nation_nation\" on \"part_supplier_supplier\".\"s_nationkey\" = \"part_supplier_nation_nation\".\"n_nationkey\"
    INNER JOIN \"memory\".\"partsupp\" as \"part_partsupp\" on \"part_supplier_supplier\".\"s_suppkey\" = \"part_partsupp\".\"ps_suppkey\"
    LEFT OUTER JOIN \"memory\".\"lineitem\" as \"lineitem\" on \"part_partsupp\".\"ps_partkey\" = \"lineitem\".\"l_partkey\" AND \"part_partsupp\".\"ps_suppkey\" = \"lineitem\".\"l_suppkey\"
    INNER JOIN \"memory\".\"part\" as \"part_part\" on \"part_partsupp\".\"ps_partkey\" = \"part_part\".\"p_partkey\"
WHERE
    \"part_part\".\"p_name\" like 'forest%'
),
questionable as (
SELECT
    \"cooperative\".\"part_available_quantity\" as \"part_available_quantity\",
    \"cooperative\".\"part_id\" as \"part_id\",
    \"cooperative\".\"part_name\" as \"part_name\",
    \"cooperative\".\"part_supplier_id\" as \"part_supplier_id\",
    \"cooperative\".\"part_supplier_nation_id\" as \"part_supplier_nation_id\",
    \"cooperative\".\"part_supplier_nation_name\" as \"part_supplier_nation_name\",
    CASE WHEN \"cooperative\".\"ship_date\" >= date '1994-01-01' and \"cooperative\".\"ship_date\" < date '1995-01-01' THEN \"cooperative\".\"quantity\" ELSE NULL END as \"_virt_filter_quantity_5687548333108690\"
FROM
    \"cooperative\"
WHERE
    \"cooperative\".\"part_name\" like 'forest%'
),
abundant as (
SELECT
    \"questionable\".\"part_id\" as \"part_id\",
    \"questionable\".\"part_supplier_id\" as \"part_supplier_id\",
    sum(\"questionable\".\"_virt_filter_quantity_5687548333108690\") as \"qty_per_partsupp_1994\"
FROM
    \"questionable\"
WHERE
    \"questionable\".\"part_name\" like 'forest%'

GROUP BY
    1,
    2),
yummy as (
SELECT
    \"questionable\".\"part_supplier_nation_name\" as \"part_supplier_nation_name\",
    coalesce(\"abundant\".\"part_supplier_id\",\"questionable\".\"part_supplier_id\") as \"part_supplier_id\"
FROM
    \"abundant\"
    INNER JOIN \"questionable\" on \"abundant\".\"part_id\" = \"questionable\".\"part_id\" AND \"abundant\".\"part_supplier_id\" = \"questionable\".\"part_supplier_id\"
WHERE
    \"questionable\".\"part_name\" like 'forest%' and \"questionable\".\"part_available_quantity\" > 0.5 * \"abundant\".\"qty_per_partsupp_1994\"

GROUP BY
    1,
    2,
    \"abundant\".\"qty_per_partsupp_1994\",
    \"questionable\".\"part_available_quantity\",
    \"questionable\".\"part_name\",
    \"questionable\".\"part_supplier_nation_id\",
    coalesce(\"abundant\".\"part_id\",\"questionable\".\"part_id\"))
SELECT
    \"part_supplier_supplier\".\"s_name\" as \"part_supplier_name\",
    \"part_supplier_supplier\".\"s_address\" as \"part_supplier_address\"
FROM
    \"yummy\"
    INNER JOIN \"memory\".\"supplier\" as \"part_supplier_supplier\" on \"yummy\".\"part_supplier_id\" = \"part_supplier_supplier\".\"s_suppkey\"
WHERE
    \"yummy\".\"part_supplier_nation_name\" = 'CANADA'

GROUP BY
    1,
    2
ORDER BY 
    \"part_supplier_supplier\".\"s_name\" asc"""
