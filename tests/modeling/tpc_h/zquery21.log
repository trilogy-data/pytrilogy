generated_sql = """

WITH 
highfalutin as (
SELECT
    \"lineitem\".\"l_commitdate\" as \"commit_date\",
    \"lineitem\".\"l_orderkey\" as \"order_id\",
    \"lineitem\".\"l_receiptdate\" as \"receipt_date\",
    \"lineitem\".\"l_suppkey\" as \"part_supplier_id\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
GROUP BY
    1,
    2,
    3,
    4),
abundant as (
SELECT
    \"lineitem\".\"l_orderkey\" as \"order_id\",
    \"part_supplier_supplier\".\"s_name\" as \"part_supplier_name\",
    1 as \"line_item\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"lineitem\".\"l_orderkey\" = \"order_orders\".\"o_orderkey\"
    INNER JOIN \"memory\".\"supplier\" as \"part_supplier_supplier\" on \"lineitem\".\"l_suppkey\" = \"part_supplier_supplier\".\"s_suppkey\"
    INNER JOIN \"memory\".\"nation\" as \"part_supplier_nation_nation\" on \"part_supplier_supplier\".\"s_nationkey\" = \"part_supplier_nation_nation\".\"n_nationkey\"
WHERE
    UPPER(\"part_supplier_nation_nation\".\"n_name\")  = 'SAUDI ARABIA' and \"order_orders\".\"o_orderstatus\" = 'F' and \"lineitem\".\"l_receiptdate\" > \"lineitem\".\"l_commitdate\"
),
wakeful as (
SELECT
    \"highfalutin\".\"order_id\" as \"order_id\"
FROM
    \"highfalutin\"
GROUP BY
    1
HAVING
    count(\"highfalutin\".\"part_supplier_id\") > 1 and count(CASE WHEN \"highfalutin\".\"receipt_date\" > \"highfalutin\".\"commit_date\" THEN \"highfalutin\".\"part_supplier_id\" ELSE NULL END) = 1
)
SELECT
    \"abundant\".\"part_supplier_name\" as \"part_supplier_name\",
    sum(\"abundant\".\"line_item\") as \"numwait\"
FROM
    \"abundant\"
    INNER JOIN \"wakeful\" on \"abundant\".\"order_id\" = \"wakeful\".\"order_id\"
GROUP BY
    1
ORDER BY 
    \"numwait\" desc,
    \"abundant\".\"part_supplier_name\" asc
LIMIT (100)"""
