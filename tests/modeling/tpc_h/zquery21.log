generated_sql = """

WITH 
highfalutin as (
SELECT
    \"order_orders\".\"o_orderkey\" as \"order_id\"
FROM
    \"memory\".\"orders\" as \"order_orders\"
WHERE
    \"order_orders\".\"o_orderstatus\" = 'F'
),
yummy as (
SELECT
    \"lineitem\".\"l_orderkey\" as \"order_id\",
    \"part_supplier_supplier\".\"s_name\" as \"part_supplier_name\",
    1 as \"row_counter\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"lineitem\".\"l_orderkey\" = \"order_orders\".\"o_orderkey\"
    INNER JOIN \"memory\".\"supplier\" as \"part_supplier_supplier\" on \"lineitem\".\"l_suppkey\" = \"part_supplier_supplier\".\"s_suppkey\"
    INNER JOIN \"memory\".\"nation\" as \"part_supplier_nation_nation\" on \"part_supplier_supplier\".\"s_nationkey\" = \"part_supplier_nation_nation\".\"n_nationkey\"
WHERE
    \"order_orders\".\"o_orderstatus\" = 'F' and UPPER(\"part_supplier_nation_nation\".\"n_name\")  = 'SAUDI ARABIA' and \"lineitem\".\"l_receiptdate\" > \"lineitem\".\"l_commitdate\"
),
wakeful as (
SELECT
    \"lineitem\".\"l_orderkey\" as \"order_id\",
    \"lineitem\".\"l_suppkey\" as \"part_supplier_id\",
    CASE WHEN \"lineitem\".\"l_receiptdate\" > \"lineitem\".\"l_commitdate\" THEN \"lineitem\".\"l_suppkey\" ELSE NULL END as \"_virt_filter_id_1852383943558009\"
FROM
    \"highfalutin\"
    INNER JOIN \"memory\".\"lineitem\" as \"lineitem\" on \"highfalutin\".\"order_id\" = \"lineitem\".\"l_orderkey\"
GROUP BY
    1,
    2,
    3),
cooperative as (
SELECT
    \"wakeful\".\"order_id\" as \"order_id\"
FROM
    \"wakeful\"
GROUP BY
    1
HAVING
    count(\"highfalutin\".\"part_supplier_id\") > 1 and count(\"highfalutin\".\"_virt_filter_id_1852383943558009\") = 1
)
SELECT
    \"yummy\".\"part_supplier_name\" as \"part_supplier_name\",
    sum(\"yummy\".\"row_counter\") as \"numwait\"
FROM
    \"cooperative\"
    INNER JOIN \"yummy\" on \"cooperative\".\"order_id\" = \"yummy\".\"order_id\"
GROUP BY
    1
ORDER BY 
    \"numwait\" desc,
    \"yummy\".\"part_supplier_name\" asc
LIMIT (100)"""
