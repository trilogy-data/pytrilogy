generated_sql = """

WITH 
questionable as (
SELECT
    \"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\") as \"revenue\",
    UPPER(\"part_supplier_nation_nation\".\"n_name\")  as \"part_supplier_nation_name\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"lineitem\".\"l_orderkey\" = \"order_orders\".\"o_orderkey\"
    INNER JOIN \"memory\".\"supplier\" as \"part_supplier_supplier\" on \"lineitem\".\"l_suppkey\" = \"part_supplier_supplier\".\"s_suppkey\"
    INNER JOIN \"memory\".\"customer\" as \"order_customer_customers\" on \"order_orders\".\"o_custkey\" = \"order_customer_customers\".\"c_custkey\"
    INNER JOIN \"memory\".\"nation\" as \"part_supplier_nation_nation\" on \"part_supplier_supplier\".\"s_nationkey\" = \"part_supplier_nation_nation\".\"n_nationkey\"
    INNER JOIN \"memory\".\"region\" as \"part_supplier_nation_region_region\" on \"part_supplier_nation_nation\".\"n_regionkey\" = \"part_supplier_nation_region_region\".\"r_regionkey\"
WHERE
    \"part_supplier_nation_region_region\".\"r_name\" = 'ASIA' and \"order_customer_customers\".\"c_nationkey\" = \"part_supplier_nation_nation\".\"n_nationkey\" and \"order_orders\".\"o_orderdate\" >= date '1994-01-01' and \"order_orders\".\"o_orderdate\" < date '1995-01-01'

GROUP BY
    1,
    2,
    \"lineitem\".\"l_linenumber\",
    \"lineitem\".\"l_orderkey\")
SELECT
    \"questionable\".\"part_supplier_nation_name\" as \"part_supplier_nation_name\",
    sum(\"questionable\".\"revenue\") as \"q_revenue\"
FROM
    \"questionable\"
GROUP BY
    1
ORDER BY 
    \"q_revenue\" desc"""
