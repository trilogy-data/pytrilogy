import part;

auto germany_total_value <- sum(supply_cost * available_quantity);
auto part_total_value <- sum(supply_cost * available_quantity) by id;

where supplier.nation.name = 'GERMANY'
then where part_total_value > germany_total_value * 0.0001
select
    id,
    part_total_value -> total_value
order by
    total_value desc;
