import order as orders;
metric orders_per_customer <- count(filter orders.id where coalesce(like(orders.comment,'%special%requests%'), False) = False) by orders.customer.id;
SELECT
    coalesce(orders_per_customer,0) -> c_count,
    count(orders.customer.id) -> custdist,
ORDER BY
    custdist desc,
    c_count desc
;