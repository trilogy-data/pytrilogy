generated_sql = """

WITH 
thoughtful as (
SELECT
    \"customers\".\"c_custkey\" as \"id\",
    count(\"orders_orders\".\"o_orderkey\") as \"order_count_per_customer\"
FROM
    \"memory\".\"customer\" as \"customers\"
    LEFT OUTER JOIN \"memory\".\"orders\" as \"orders_orders\" on \"customers\".\"c_custkey\" = \"orders_orders\".\"o_custkey\"
WHERE
    SUBSTRING(\"customers\".\"c_phone\",1,2) in ('13','31','23','29','30','18','17')

GROUP BY
    1),
highfalutin as (
SELECT
    avg(CASE WHEN \"customers\".\"c_acctbal\" > 0 and SUBSTRING(\"customers\".\"c_phone\",1,2) in ('13','31','23','29','30','18','17') THEN \"customers\".\"c_acctbal\" ELSE NULL END) as \"avg_bal_in_target\"
FROM
    \"memory\".\"customer\" as \"customers\"
WHERE
    SUBSTRING(\"customers\".\"c_phone\",1,2) in ('13','31','23','29','30','18','17')
),
questionable as (
SELECT
    \"customers\".\"c_acctbal\" as \"account_balance\",
    \"customers\".\"c_custkey\" as \"id\",
    \"customers\".\"c_phone\" as \"phone\"
FROM
    \"memory\".\"customer\" as \"customers\"
    LEFT OUTER JOIN \"thoughtful\" on \"customers\".\"c_custkey\" = \"thoughtful\".\"id\"
WHERE
    SUBSTRING(\"customers\".\"c_phone\",1,2) in ('13','31','23','29','30','18','17') and coalesce(coalesce(\"thoughtful\".\"order_count_per_customer\",0),0) = 0
)
SELECT
    SUBSTRING(\"questionable\".\"phone\",1,2) as \"cntrycode\",
    count(\"questionable\".\"id\") as \"numcust\",
    sum(\"questionable\".\"account_balance\") as \"totacctbal\"
FROM
    \"questionable\"
    INNER JOIN \"highfalutin\" on 1=1
WHERE
    \"questionable\".\"account_balance\" > \"highfalutin\".\"avg_bal_in_target\"

GROUP BY
    1
ORDER BY 
    \"cntrycode\" asc"""
