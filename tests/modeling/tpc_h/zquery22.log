generated_sql = """

WITH 
highfalutin as (
SELECT
    \"orders_customer_customers\".\"c_custkey\" as \"target_customers\"
FROM
    \"memory\".\"customer\" as \"orders_customer_customers\"
WHERE
    SUBSTRING(\"orders_customer_customers\".\"c_phone\",1,2) in ('13','31','23','29','30','18','17')
),
cooperative as (
SELECT
    \"orders_customer_customers\".\"c_custkey\" as \"orders_customer_id\",
    count(\"orders_orders\".\"o_orderkey\") as \"order_count_per_customer\"
FROM
    \"memory\".\"customer\" as \"orders_customer_customers\"
    LEFT OUTER JOIN \"memory\".\"orders\" as \"orders_orders\" on \"orders_customer_customers\".\"c_custkey\" = \"orders_orders\".\"o_custkey\"
WHERE
    SUBSTRING(\"orders_customer_customers\".\"c_phone\",1,2) in ('13','31','23','29','30','18','17')

GROUP BY
    1),
wakeful as (
SELECT
    avg(CASE WHEN \"orders_customer_customers\".\"c_acctbal\" > 0 and \"orders_customer_customers\".\"c_custkey\" in (select highfalutin.\"target_customers\" from highfalutin where highfalutin.\"target_customers\" is not null) THEN \"orders_customer_customers\".\"c_acctbal\" ELSE NULL END) as \"avg_bal_in_target\"
FROM
    \"memory\".\"customer\" as \"orders_customer_customers\"
WHERE
    SUBSTRING(\"orders_customer_customers\".\"c_phone\",1,2) in ('13','31','23','29','30','18','17')
),
abundant as (
SELECT
    \"orders_customer_customers\".\"c_acctbal\" as \"orders_customer_account_balance\",
    \"orders_customer_customers\".\"c_custkey\" as \"orders_customer_id\",
    \"orders_customer_customers\".\"c_phone\" as \"orders_customer_phone\"
FROM
    \"memory\".\"customer\" as \"orders_customer_customers\"
    LEFT OUTER JOIN \"cooperative\" on \"orders_customer_customers\".\"c_custkey\" = \"cooperative\".\"orders_customer_id\"
WHERE
    SUBSTRING(\"orders_customer_customers\".\"c_phone\",1,2) in ('13','31','23','29','30','18','17') and coalesce(coalesce(\"cooperative\".\"order_count_per_customer\",0),0) = 0
)
SELECT
    SUBSTRING(\"abundant\".\"orders_customer_phone\",1,2) as \"cntrycode\",
    count(\"abundant\".\"orders_customer_id\") as \"numcust\",
    sum(\"abundant\".\"orders_customer_account_balance\") as \"totacctbal\"
FROM
    \"wakeful\"
    INNER JOIN \"abundant\" on 1=1
WHERE
    \"abundant\".\"orders_customer_account_balance\" > \"wakeful\".\"avg_bal_in_target\"

GROUP BY
    1
ORDER BY 
    \"cntrycode\" asc"""
