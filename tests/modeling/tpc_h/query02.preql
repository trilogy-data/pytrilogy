import part;

auto min_supply_cost <- min(supply_cost) by id;

where
    supplier.nation.region.name = 'EUROPE'
then where
    size = 15
    and type like '%BRASS'
    and supply_cost = min_supply_cost
select
    --supplier.id,
    supplier.account_balance,
    supplier.name,
    supplier.nation.name,
    id,
    manufacturer,
    supplier.address,
    supplier.phone,
    supplier.comment
order by
    supplier.account_balance desc,
    supplier.nation.name asc,
    supplier.name asc,
    id asc
limit 100;
