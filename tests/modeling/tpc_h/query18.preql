import lineitem;

auto qty_per_order <- sum(quantity) by order.id;

where  order.id is not null
select
    order.customer.name,
    order.customer.id,
    order.id,
    order.date,
    order.total_price,
    qty_per_order
having
    qty_per_order > 300
order by
    order.total_price desc,
    order.date asc
limit 100;
