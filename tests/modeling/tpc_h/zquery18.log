generated_sql = """

WITH 
highfalutin as (
SELECT
    \"lineitem\".\"l_orderkey\" as \"order_id\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
GROUP BY
    1
HAVING
    sum(\"lineitem\".\"l_quantity\") > 300
),
thoughtful as (
SELECT
    \"order_customer_customers\".\"c_custkey\" as \"order_customer_id\",
    \"order_customer_customers\".\"c_name\" as \"order_customer_name\",
    \"order_orders\".\"o_orderdate\" as \"order_date\",
    \"order_orders\".\"o_orderkey\" as \"order_id\",
    \"order_orders\".\"o_totalprice\" as \"order_total_price\"
FROM
    \"memory\".\"customer\" as \"order_customer_customers\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"order_customer_customers\".\"c_custkey\" = \"order_orders\".\"o_custkey\"),
questionable as (
SELECT
    \"lineitem\".\"l_orderkey\" as \"order_id\",
    sum(\"lineitem\".\"l_quantity\") as \"sum_quantity\"
FROM
    \"highfalutin\"
    INNER JOIN \"memory\".\"lineitem\" as \"lineitem\" on \"highfalutin\".\"order_id\" = \"lineitem\".\"l_orderkey\"
GROUP BY
    1),
cooperative as (
SELECT
    \"highfalutin\".\"order_id\" as \"order_id\",
    \"thoughtful\".\"order_customer_id\" as \"order_customer_id\",
    \"thoughtful\".\"order_customer_name\" as \"order_customer_name\",
    \"thoughtful\".\"order_date\" as \"order_date\",
    \"thoughtful\".\"order_total_price\" as \"order_total_price\"
FROM
    \"thoughtful\"
    INNER JOIN \"highfalutin\" on \"thoughtful\".\"order_id\" = \"highfalutin\".\"order_id\")
SELECT
    \"cooperative\".\"order_customer_name\" as \"order_customer_name\",
    \"cooperative\".\"order_customer_id\" as \"order_customer_id\",
    \"cooperative\".\"order_id\" as \"order_id\",
    \"cooperative\".\"order_date\" as \"order_date\",
    \"cooperative\".\"order_total_price\" as \"order_total_price\",
    \"questionable\".\"sum_quantity\" as \"sum_quantity\"
FROM
    \"cooperative\"
    INNER JOIN \"questionable\" on \"cooperative\".\"order_id\" = \"questionable\".\"order_id\"
ORDER BY 
    \"cooperative\".\"order_total_price\" desc,
    \"cooperative\".\"order_date\" asc
LIMIT (100)"""
