generated_sql = """

WITH 
cheerful as (
SELECT
    \"lineitem\".\"l_orderkey\" as \"order_id\",
    \"lineitem\".\"l_quantity\" as \"quantity\",
    \"order_customer_customers\".\"c_custkey\" as \"order_customer_id\",
    \"order_customer_customers\".\"c_name\" as \"order_customer_name\",
    \"order_orders\".\"o_orderdate\" as \"order_date\",
    \"order_orders\".\"o_totalprice\" as \"order_total_price\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"lineitem\".\"l_orderkey\" = \"order_orders\".\"o_orderkey\"
    INNER JOIN \"memory\".\"customer\" as \"order_customer_customers\" on \"order_orders\".\"o_custkey\" = \"order_customer_customers\".\"c_custkey\"
WHERE
    \"lineitem\".\"l_orderkey\" is not null
),
abundant as (
SELECT
    \"cheerful\".\"order_customer_id\" as \"order_customer_id\",
    \"cheerful\".\"order_id\" as \"order_id\"
FROM
    \"cheerful\"
GROUP BY
    1,
    2,
    \"cheerful\".\"order_date\",
    \"cheerful\".\"order_total_price\"),
questionable as (
SELECT
    \"cheerful\".\"order_customer_id\" as \"order_customer_id\",
    \"cheerful\".\"order_customer_name\" as \"order_customer_name\"
FROM
    \"cheerful\"
GROUP BY
    1,
    2),
thoughtful as (
SELECT
    \"cheerful\".\"order_date\" as \"order_date\",
    \"cheerful\".\"order_id\" as \"order_id\",
    \"cheerful\".\"order_total_price\" as \"order_total_price\",
    sum(\"cheerful\".\"quantity\") as \"qty_per_order\"
FROM
    \"cheerful\"
GROUP BY
    1,
    2,
    3
HAVING
    \"qty_per_order\" > 300
)
SELECT
    \"questionable\".\"order_customer_name\" as \"order_customer_name\",
    coalesce(\"abundant\".\"order_customer_id\",\"questionable\".\"order_customer_id\") as \"order_customer_id\",
    \"thoughtful\".\"order_id\" as \"order_id\",
    \"thoughtful\".\"order_date\" as \"order_date\",
    \"thoughtful\".\"order_total_price\" as \"order_total_price\",
    \"thoughtful\".\"qty_per_order\" as \"qty_per_order\"
FROM
    \"abundant\"
    INNER JOIN \"thoughtful\" on \"abundant\".\"order_id\" = \"thoughtful\".\"order_id\"
    LEFT OUTER JOIN \"questionable\" on \"abundant\".\"order_customer_id\" = \"questionable\".\"order_customer_id\"
WHERE
    \"thoughtful\".\"qty_per_order\" > 300

ORDER BY 
    \"thoughtful\".\"order_total_price\" desc,
    \"thoughtful\".\"order_date\" asc
LIMIT (100)"""
