
import order as orders;


auto avg_bal_in_target <- avg(orders.customer.account_balance ? orders.customer.account_balance > 0 and substring(orders.customer.phone, 1, 2) in ('13', '31', '23', '29', '30', '18', '17')) by *;

where
    substring(orders.customer.phone, 1, 2) in ('13', '31', '23', '29', '30', '18', '17')
    and orders.customer.account_balance > avg_bal_in_target
    and orders.id is null
select
    substring(orders.customer.phone, 1, 2) -> cntrycode,
    count(orders.customer.id) -> numcust,
    sum(orders.customer.account_balance) -> totacctbal
order by
    cntrycode asc;
