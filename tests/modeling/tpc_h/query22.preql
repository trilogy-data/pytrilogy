import customer;
import order as orders;

merge orders.customer.id into ~id;

auto avg_bal_in_target <- avg(account_balance);
auto order_count_per_customer <- count(orders.id) by id;

where
    account_balance > 0
    and substring(phone, 1, 2) in ('13', '31', '23', '29', '30', '18', '17')
then where
    account_balance > avg_bal_in_target
    and coalesce(order_count_per_customer, 0) = 0
select
    substring(phone, 1, 2) -> cntrycode,
    count(id) -> numcust,
    sum(account_balance) -> totacctbal
order by
    cntrycode asc;
