generated_sql = """

WITH 
cheerful as (
SELECT
    \"partsupp\".\"ps_availqty\" as \"available_quantity\",
    \"partsupp\".\"ps_partkey\" as \"id\",
    \"partsupp\".\"ps_supplycost\" as \"supply_cost\",
    UPPER(\"supplier_nation_nation\".\"n_name\")  as \"supplier_nation_name\"
FROM
    \"memory\".\"partsupp\" as \"partsupp\"
    INNER JOIN \"memory\".\"supplier\" as \"supplier_supplier\" on \"partsupp\".\"ps_suppkey\" = \"supplier_supplier\".\"s_suppkey\"
    INNER JOIN \"memory\".\"nation\" as \"supplier_nation_nation\" on \"supplier_supplier\".\"s_nationkey\" = \"supplier_nation_nation\".\"n_nationkey\"),
thoughtful as (
SELECT
    \"cheerful\".\"id\" as \"id\",
    \"cheerful\".\"supply_cost\" as \"supply_cost\",
    CASE WHEN \"cheerful\".\"supplier_nation_name\" = 'GERMANY' THEN \"cheerful\".\"available_quantity\" ELSE NULL END as \"_virt_filter_available_quantity_5442867613516720\"
FROM
    \"cheerful\"),
cooperative as (
SELECT
    \"thoughtful\".\"_virt_filter_available_quantity_5442867613516720\" as \"_virt_filter_available_quantity_5442867613516720\",
    \"thoughtful\".\"id\" as \"id\",
    \"thoughtful\".\"supply_cost\" as \"supply_cost\"
FROM
    \"thoughtful\"),
abundant as (
SELECT
    \"cooperative\".\"id\" as \"id\",
    sum(\"cooperative\".\"supply_cost\" * \"cooperative\".\"_virt_filter_available_quantity_5442867613516720\") as \"part_total_value\"
FROM
    \"cooperative\"
GROUP BY
    1),
questionable as (
SELECT
    sum(\"cooperative\".\"supply_cost\" * \"cooperative\".\"_virt_filter_available_quantity_5442867613516720\") as \"germany_total_value\"
FROM
    \"cooperative\"),
uneven as (
SELECT
    \"abundant\".\"id\" as \"id\",
    \"abundant\".\"part_total_value\" as \"part_total_value\",
    \"abundant\".\"part_total_value\" as \"total_value\"
FROM
    \"questionable\"
    INNER JOIN \"abundant\" on 1=1
WHERE
    \"abundant\".\"part_total_value\" > \"questionable\".\"germany_total_value\" * 0.0001
)
SELECT
    \"uneven\".\"id\" as \"id\",
    \"uneven\".\"total_value\" as \"total_value\"
FROM
    \"questionable\"
    INNER JOIN \"uneven\" on 1=1
WHERE
    \"uneven\".\"part_total_value\" > \"questionable\".\"germany_total_value\" * 0.0001

ORDER BY 
    \"uneven\".\"total_value\" desc"""
