generated_sql = """

WITH 
cheerful as (
SELECT
    \"partsupp\".\"ps_availqty\" as \"available_quantity\",
    \"partsupp\".\"ps_partkey\" as \"id\",
    \"partsupp\".\"ps_supplycost\" as \"supply_cost\"
FROM
    \"memory\".\"supplier\" as \"supplier_supplier\"
    INNER JOIN \"memory\".\"partsupp\" as \"partsupp\" on \"supplier_supplier\".\"s_suppkey\" = \"partsupp\".\"ps_suppkey\"
    INNER JOIN \"memory\".\"nation\" as \"supplier_nation_nation\" on \"supplier_supplier\".\"s_nationkey\" = \"supplier_nation_nation\".\"n_nationkey\"
WHERE
    UPPER(\"supplier_nation_nation\".\"n_name\")  = 'GERMANY'
),
questionable as (
SELECT
    \"partsupp\".\"ps_partkey\" as \"id\",
    UPPER(\"supplier_nation_nation\".\"n_name\")  as \"supplier_nation_name\"
FROM
    \"memory\".\"supplier\" as \"supplier_supplier\"
    INNER JOIN \"memory\".\"partsupp\" as \"partsupp\" on \"supplier_supplier\".\"s_suppkey\" = \"partsupp\".\"ps_suppkey\"
    INNER JOIN \"memory\".\"nation\" as \"supplier_nation_nation\" on \"supplier_supplier\".\"s_nationkey\" = \"supplier_nation_nation\".\"n_nationkey\"
WHERE
    UPPER(\"supplier_nation_nation\".\"n_name\")  = 'GERMANY'

GROUP BY
    1,
    2),
cooperative as (
SELECT
    \"cheerful\".\"id\" as \"id\",
    sum(\"cheerful\".\"supply_cost\" * \"cheerful\".\"available_quantity\") as \"part_total_value\"
FROM
    \"cheerful\"
GROUP BY
    1),
thoughtful as (
SELECT
    sum(\"cheerful\".\"supply_cost\" * \"cheerful\".\"available_quantity\") as \"germany_total_value\"
FROM
    \"cheerful\"),
abundant as (
SELECT
    \"cooperative\".\"id\" as \"id\",
    \"cooperative\".\"part_total_value\" as \"part_total_value\"
FROM
    \"questionable\"
    INNER JOIN \"cooperative\" on \"questionable\".\"id\" = \"cooperative\".\"id\"
WHERE
    \"questionable\".\"supplier_nation_name\" = 'GERMANY'
)
SELECT
    \"abundant\".\"id\" as \"id\",
    \"abundant\".\"part_total_value\" as \"total_value\"
FROM
    \"thoughtful\"
    INNER JOIN \"abundant\" on 1=1
WHERE
    \"abundant\".\"part_total_value\" > \"thoughtful\".\"germany_total_value\" * 0.0001

GROUP BY
    1,
    2
ORDER BY 
    \"total_value\" desc"""
