generated_sql = """

WITH 
uneven as (
SELECT
    sum(\"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\")) as \"_virt_agg_sum_1789203937951976\",
    sum(CASE WHEN UPPER(\"part_supplier_nation_nation\".\"n_name\")  = 'BRAZIL' THEN \"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\") ELSE NULL END) as \"_virt_agg_sum_4311411778856528\",
    year(\"order_orders\".\"o_orderdate\") as \"o_year\"
FROM
    \"memory\".\"part\" as \"part_part\"
    INNER JOIN \"memory\".\"lineitem\" as \"lineitem\" on \"part_part\".\"p_partkey\" = \"lineitem\".\"l_partkey\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"lineitem\".\"l_orderkey\" = \"order_orders\".\"o_orderkey\"
    LEFT OUTER JOIN \"memory\".\"supplier\" as \"part_supplier_supplier\" on \"lineitem\".\"l_suppkey\" = \"part_supplier_supplier\".\"s_suppkey\"
    INNER JOIN \"memory\".\"customer\" as \"order_customer_customers\" on \"order_orders\".\"o_custkey\" = \"order_customer_customers\".\"c_custkey\"
    LEFT OUTER JOIN \"memory\".\"nation\" as \"part_supplier_nation_nation\" on \"part_supplier_supplier\".\"s_nationkey\" = \"part_supplier_nation_nation\".\"n_nationkey\"
    INNER JOIN \"memory\".\"nation\" as \"order_customer_nation_nation\" on \"order_customer_customers\".\"c_nationkey\" = \"order_customer_nation_nation\".\"n_nationkey\"
    INNER JOIN \"memory\".\"region\" as \"order_customer_nation_region_region\" on \"order_customer_nation_nation\".\"n_regionkey\" = \"order_customer_nation_region_region\".\"r_regionkey\"
WHERE
    \"order_customer_nation_region_region\".\"r_name\" = 'AMERICA' and year(\"order_orders\".\"o_orderdate\") BETWEEN 1995 AND 1996 and \"part_part\".\"p_type\" = 'ECONOMY ANODIZED STEEL'

GROUP BY
    3)
SELECT
    \"uneven\".\"o_year\" as \"o_year\",
    \"uneven\".\"_virt_agg_sum_4311411778856528\" / \"uneven\".\"_virt_agg_sum_1789203937951976\" as \"mkt_share\"
FROM
    \"uneven\"
ORDER BY 
    \"uneven\".\"o_year\" asc"""
