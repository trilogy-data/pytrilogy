generated_sql = """

WITH 
thoughtful as (
SELECT
    \"order_customer_customers\".\"c_custkey\" as \"order_customer_id\",
    UPPER(\"order_customer_nation_nation\".\"n_name\")  as \"order_customer_nation_name\",
    sum(\"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\")) as \"q_revenue\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"lineitem\".\"l_orderkey\" = \"order_orders\".\"o_orderkey\"
    INNER JOIN \"memory\".\"customer\" as \"order_customer_customers\" on \"order_orders\".\"o_custkey\" = \"order_customer_customers\".\"c_custkey\"
    INNER JOIN \"memory\".\"nation\" as \"order_customer_nation_nation\" on \"order_customer_customers\".\"c_nationkey\" = \"order_customer_nation_nation\".\"n_nationkey\"
WHERE
    \"order_orders\".\"o_orderdate\" >= date '1993-10-01' and \"order_orders\".\"o_orderdate\" < date '1994-01-01' and \"lineitem\".\"l_returnflag\" = 'R' and \"order_customer_customers\".\"c_custkey\" is not null

GROUP BY
    1,
    2),
questionable as (
SELECT
    \"order_customer_customers\".\"c_acctbal\" as \"order_customer_account_balance\",
    \"order_customer_customers\".\"c_address\" as \"order_customer_address\",
    \"order_customer_customers\".\"c_comment\" as \"order_customer_comment\",
    \"order_customer_customers\".\"c_custkey\" as \"order_customer_id\",
    \"order_customer_customers\".\"c_name\" as \"order_customer_name\",
    \"order_customer_customers\".\"c_phone\" as \"order_customer_phone\"
FROM
    \"memory\".\"customer\" as \"order_customer_customers\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"order_customer_customers\".\"c_custkey\" = \"order_orders\".\"o_custkey\"
WHERE
    \"order_orders\".\"o_orderdate\" >= date '1993-10-01' and \"order_orders\".\"o_orderdate\" < date '1994-01-01' and \"order_customer_customers\".\"c_custkey\" is not null
)
SELECT
    coalesce(\"questionable\".\"order_customer_id\",\"thoughtful\".\"order_customer_id\") as \"order_customer_id\",
    \"questionable\".\"order_customer_name\" as \"order_customer_name\",
    \"thoughtful\".\"q_revenue\" as \"q_revenue\",
    \"questionable\".\"order_customer_account_balance\" as \"order_customer_account_balance\",
    \"thoughtful\".\"order_customer_nation_name\" as \"order_customer_nation_name\",
    \"questionable\".\"order_customer_address\" as \"order_customer_address\",
    \"questionable\".\"order_customer_phone\" as \"order_customer_phone\",
    \"questionable\".\"order_customer_comment\" as \"order_customer_comment\"
FROM
    \"thoughtful\"
    FULL JOIN \"questionable\" on \"thoughtful\".\"order_customer_id\" = \"questionable\".\"order_customer_id\"
GROUP BY
    1,
    2,
    3,
    4,
    5,
    6,
    7,
    8
ORDER BY 
    \"thoughtful\".\"q_revenue\" desc
LIMIT (20)"""
