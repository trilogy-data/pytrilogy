generated_sql = """

WITH 
wakeful as (
SELECT
    \"lineitem\".\"l_discount\" as \"discount\",
    \"lineitem\".\"l_extendedprice\" as \"extended_price\",
    \"order_orders\".\"o_custkey\" as \"order_customer_id\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"lineitem\".\"l_orderkey\" = \"order_orders\".\"o_orderkey\"
WHERE
    \"order_orders\".\"o_orderdate\" >= date '1993-10-01' and \"order_orders\".\"o_orderdate\" < date '1994-01-01' and \"lineitem\".\"l_returnflag\" = 'R'
),
abundant as (
SELECT
    \"order_customer_customers\".\"c_acctbal\" as \"order_customer_account_balance\",
    \"order_customer_customers\".\"c_address\" as \"order_customer_address\",
    \"order_customer_customers\".\"c_comment\" as \"order_customer_comment\",
    \"order_customer_customers\".\"c_custkey\" as \"order_customer_id\",
    \"order_customer_customers\".\"c_name\" as \"order_customer_name\",
    \"order_customer_customers\".\"c_phone\" as \"order_customer_phone\",
    UPPER(\"order_customer_nation_nation\".\"n_name\")  as \"order_customer_nation_name\"
FROM
    \"memory\".\"nation\" as \"order_customer_nation_nation\"
    INNER JOIN \"memory\".\"customer\" as \"order_customer_customers\" on \"order_customer_nation_nation\".\"n_nationkey\" = \"order_customer_customers\".\"c_nationkey\"),
thoughtful as (
SELECT
    \"order_customer_customers\".\"c_custkey\" as \"order_customer_id\",
    sum(\"wakeful\".\"extended_price\" * (1 - \"wakeful\".\"discount\")) as \"q_revenue\"
FROM
    \"memory\".\"customer\" as \"order_customer_customers\"
    INNER JOIN \"wakeful\" on \"order_customer_customers\".\"c_custkey\" = \"wakeful\".\"order_customer_id\"
GROUP BY
    1)
SELECT
    coalesce(\"abundant\".\"order_customer_id\",\"thoughtful\".\"order_customer_id\") as \"order_customer_id\",
    \"abundant\".\"order_customer_name\" as \"order_customer_name\",
    \"thoughtful\".\"q_revenue\" as \"q_revenue\",
    \"abundant\".\"order_customer_account_balance\" as \"order_customer_account_balance\",
    \"abundant\".\"order_customer_nation_name\" as \"order_customer_nation_name\",
    \"abundant\".\"order_customer_address\" as \"order_customer_address\",
    \"abundant\".\"order_customer_phone\" as \"order_customer_phone\",
    \"abundant\".\"order_customer_comment\" as \"order_customer_comment\"
FROM
    \"abundant\"
    FULL JOIN \"thoughtful\" on \"abundant\".\"order_customer_id\" = \"thoughtful\".\"order_customer_id\"
ORDER BY 
    \"thoughtful\".\"q_revenue\" desc
LIMIT (20)"""
