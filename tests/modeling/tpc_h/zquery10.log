generated_sql = """

WITH 
highfalutin as (
SELECT
    \"lineitem\".\"l_orderkey\" as \"order_id\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
GROUP BY
    1),
questionable as (
SELECT
    \"order_customer_customers\".\"c_custkey\" as \"order_customer_id\",
    sum(\"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\")) as \"q_revenue\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"lineitem\".\"l_orderkey\" = \"order_orders\".\"o_orderkey\"
    INNER JOIN \"memory\".\"customer\" as \"order_customer_customers\" on \"order_orders\".\"o_custkey\" = \"order_customer_customers\".\"c_custkey\"
    INNER JOIN \"memory\".\"nation\" as \"order_customer_nation_nation\" on \"order_customer_customers\".\"c_nationkey\" = \"order_customer_nation_nation\".\"n_nationkey\"
WHERE
    \"order_orders\".\"o_orderdate\" >= date '1993-10-01' and \"order_orders\".\"o_orderdate\" < date '1994-01-01' and \"lineitem\".\"l_returnflag\" = 'R'

GROUP BY
    1),
cooperative as (
SELECT
    \"order_customer_customers\".\"c_acctbal\" as \"order_customer_account_balance\",
    \"order_customer_customers\".\"c_address\" as \"order_customer_address\",
    \"order_customer_customers\".\"c_comment\" as \"order_customer_comment\",
    \"order_customer_customers\".\"c_custkey\" as \"order_customer_id\",
    \"order_customer_customers\".\"c_name\" as \"order_customer_name\",
    \"order_customer_customers\".\"c_phone\" as \"order_customer_phone\",
    UPPER(\"order_customer_nation_nation\".\"n_name\")  as \"order_customer_nation_name\"
FROM
    \"memory\".\"orders\" as \"order_orders\"
    INNER JOIN \"highfalutin\" on \"order_orders\".\"o_orderkey\" = \"highfalutin\".\"order_id\"
    RIGHT OUTER JOIN \"memory\".\"customer\" as \"order_customer_customers\" on \"order_orders\".\"o_custkey\" = \"order_customer_customers\".\"c_custkey\"
    INNER JOIN \"memory\".\"nation\" as \"order_customer_nation_nation\" on \"order_customer_customers\".\"c_nationkey\" = \"order_customer_nation_nation\".\"n_nationkey\")
SELECT
    coalesce(\"cooperative\".\"order_customer_id\",\"questionable\".\"order_customer_id\") as \"order_customer_id\",
    \"cooperative\".\"order_customer_name\" as \"order_customer_name\",
    \"questionable\".\"q_revenue\" as \"q_revenue\",
    \"cooperative\".\"order_customer_account_balance\" as \"order_customer_account_balance\",
    \"cooperative\".\"order_customer_nation_name\" as \"order_customer_nation_name\",
    \"cooperative\".\"order_customer_address\" as \"order_customer_address\",
    \"cooperative\".\"order_customer_phone\" as \"order_customer_phone\",
    \"cooperative\".\"order_customer_comment\" as \"order_customer_comment\"
FROM
    \"questionable\"
    FULL JOIN \"cooperative\" on \"questionable\".\"order_customer_id\" = \"cooperative\".\"order_customer_id\"
GROUP BY
    1,
    2,
    3,
    4,
    5,
    6,
    7,
    8
ORDER BY 
    \"questionable\".\"q_revenue\" desc
LIMIT (20)"""
