generated_sql = """
SELECT
    UPPER(\"part_supplier_nation_nation\".\"n_name\")  as \"nation\",
    year(\"order_orders\".\"o_orderdate\") as \"o_year\",
    sum(( \"lineitem\".\"l_extendedprice\" * (1 - \"lineitem\".\"l_discount\") ) - ( \"part_partsupp\".\"ps_supplycost\" * \"lineitem\".\"l_quantity\" )) as \"sum_profit\"
FROM
    \"memory\".\"lineitem\" as \"lineitem\"
    INNER JOIN \"memory\".\"orders\" as \"order_orders\" on \"lineitem\".\"l_orderkey\" = \"order_orders\".\"o_orderkey\"
    INNER JOIN \"memory\".\"partsupp\" as \"part_partsupp\" on \"lineitem\".\"l_partkey\" = \"part_partsupp\".\"ps_partkey\" AND \"lineitem\".\"l_suppkey\" = \"part_partsupp\".\"ps_suppkey\"
    INNER JOIN \"memory\".\"part\" as \"part_part\" on \"part_partsupp\".\"ps_partkey\" = \"part_part\".\"p_partkey\"
    INNER JOIN \"memory\".\"supplier\" as \"part_supplier_supplier\" on \"part_partsupp\".\"ps_suppkey\" = \"part_supplier_supplier\".\"s_suppkey\"
    INNER JOIN \"memory\".\"nation\" as \"part_supplier_nation_nation\" on \"part_supplier_supplier\".\"s_nationkey\" = \"part_supplier_nation_nation\".\"n_nationkey\"
WHERE
    \"part_part\".\"p_name\" like '%green%'

GROUP BY
    1,
    2
ORDER BY 
    \"nation\" asc,
    \"o_year\" desc"""
