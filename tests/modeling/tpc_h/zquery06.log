    \"memory\".\"lineitem\" as \"lineitem\"
WHERE
    \"lineitem\".\"l_shipdate\" >= date '1994-01-01' and \"lineitem\".\"l_shipdate\" < date '1995-01-01' and \"lineitem\".\"l_discount\" >= 0.05 and \"lineitem\".\"l_discount\" <= 0.07 and \"lineitem\".\"l_quantity\" < 24
"""
