
property <*>.version int;

key id int;
property id.value string;
property id.label string;

root datasource raw_source (
    id,
    value,
    label,
    version
)
grain (id)
query '''
select 1 as id, 'hello' as value, 'greeting' as label, 1 as version
union all
select 2 as id, 'world' as value, 'noun' as label, 1 as version
''';

datasource processed (
    id,
    value,
    label,
    version
)
grain (id)
address schema_refresh_test
incremental by version;
