import raw.store_sales as ss;
import raw.catalog_sales as cs;
import raw.web_sales as ws;

# Merge item dimensions across the three channels
merge cs.item.item_sk into ~ss.item.item_sk;
merge ws.item.item_sk into ~ss.item.item_sk;

# --- Identify combos present in all three channels during 1999-2001 ---
rowset all_channel_combos <- select
    ss.item.brand_id as brand_id,
    ss.item.class_id as class_id,
    ss.item.category_id as category_id,
    --bool_or(ss.date_dim.year between 1999 and 2001) as in_store,
    --bool_or(cs.sold_date.year between 1999 and 2001) as in_catalog,
    --bool_or(ws.sold_date.year between 1999 and 2001) as in_web,
having
    in_store = true
    and in_catalog = true
    and in_web = true
;

# --- Overall average sale value 1999-2001 ---
auto overall_sales_all <- 
    sum(ss.quantity * ss.list_price ? ss.date_dim.year between 1999 and 2001)
    + sum(cs.quantity * cs.list_price ? cs.sold_date.year between 1999 and 2001)
    + sum(ws.quantity * ws.list_price ? ws.sold_date.year between 1999 and 2001);

auto overall_count_all <- 
    count(ss.ticket_number ? ss.date_dim.year between 1999 and 2001)
    + count(cs.order_number ? cs.sold_date.year between 1999 and 2001)
    + count(ws.order_number ? ws.sold_date.year between 1999 and 2001);

# Define rollup aggregate pattern
def rollup_sales(metric) -> sum(metric) by rollup ss.item.brand_id, ss.item.class_id, ss.item.category_id;
def rollup_count(metric) -> count(metric) by rollup ss.item.brand_id, ss.item.class_id, ss.item.category_id;

# Store sales (Nov 2001, qualifying combos only)
where
    ss.date_dim.moy = 11
    and ss.date_dim.year = 2001
    and ss.item.brand_id in all_channel_combos.brand_id
    and ss.item.class_id in all_channel_combos.class_id
    and ss.item.category_id in all_channel_combos.category_id
select
    'store' as channel,
    ss.item.brand_id,
    ss.item.class_id,
    ss.item.category_id,
    @rollup_sales(ss.quantity * ss.list_price) as total_sales,
    @rollup_count(ss.ticket_number) as num_sales,
    --overall_sales_all,
    --overall_count_all
having total_sales > overall_sales_all / nullif(overall_count_all, 0)
order by
    grouping(ss.item.brand_id) desc,
    grouping(ss.item.class_id) desc,
    grouping(ss.item.category_id) desc,
    channel nulls first,
    ss.item.brand_id nulls first,
    ss.item.class_id nulls first,
    ss.item.category_id nulls first
limit 100;