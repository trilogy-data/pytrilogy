WITH 
highfalutin as (
SELECT
    "sr_store_returns"."c" as "cs_customer_customer_sk",
    "sr_store_returns"."i" as "cs_item_item_sk",
    "sr_store_returns"."l" as "sr_loss",
    "sr_store_returns"."t" as "sr_ticket"
FROM
    (
select 1 t, 10 i, 1 c, 5 l
union all select 4 t, 20 i, cast(null as int) c, 9 l
) as "sr_store_returns"),
wakeful as (
SELECT
    "ss_store_sales"."c" as "cs_customer_customer_sk",
    "ss_store_sales"."i" as "cs_item_item_sk",
    "ss_store_sales"."p" as "ss_profit",
    "ss_store_sales"."s" as "ss_store",
    "ss_store_sales"."t" as "sr_ticket"
FROM
    (
select 1 t, 10 i, 1 c, 's1' s, 100 p
union all select 2 t, 10 i, 2 c, 's1' s, 200 p
union all select 3 t, 20 i, 3 c, 's1' s, 300 p
union all select 4 t, 20 i, cast(null as int) c, 's1' s, 400 p
) as "ss_store_sales"),
quizzical as (
SELECT
    "cs_catalog_sales"."c" as "cs_customer_customer_sk",
    "cs_catalog_sales"."i" as "cs_item_item_sk",
    "cs_catalog_sales"."o" as "cs_order_id",
    "cs_catalog_sales"."p" as "cs_cprofit"
FROM
    (
select 9 o, 10 i, 2 c, 50 p
union all select 8 o, 20 i, 3 c, 70 p
union all select 7 o, 20 i, cast(null as int) c, 90 p
) as "cs_catalog_sales"),
questionable as (
SELECT
    "highfalutin"."sr_loss" as "sr_loss",
    "wakeful"."ss_profit" as "ss_profit",
    "wakeful"."ss_store" as "ss_store",
    coalesce("highfalutin"."cs_item_item_sk","wakeful"."cs_item_item_sk") as "cs_item_item_sk",
    coalesce("highfalutin"."sr_ticket","wakeful"."sr_ticket") as "sr_ticket"
FROM
    "wakeful"
    FULL JOIN "highfalutin" on "wakeful"."cs_customer_customer_sk" is not distinct from "highfalutin"."cs_customer_customer_sk" AND "wakeful"."cs_item_item_sk" = "highfalutin"."cs_item_item_sk" AND "wakeful"."sr_ticket" = "highfalutin"."sr_ticket"
GROUP BY
    1,
    2,
    3,
    4,
    5,
    coalesce("highfalutin"."cs_customer_customer_sk","wakeful"."cs_customer_customer_sk")),
cheerful as (
SELECT
    "quizzical"."cs_cprofit" as "cs_cprofit",
    "wakeful"."ss_store" as "ss_store",
    coalesce("highfalutin"."cs_item_item_sk","quizzical"."cs_item_item_sk","wakeful"."cs_item_item_sk") as "cs_item_item_sk"
FROM
    "wakeful"
    FULL JOIN "highfalutin" on "wakeful"."cs_customer_customer_sk" is not distinct from "highfalutin"."cs_customer_customer_sk" AND "wakeful"."cs_item_item_sk" = "highfalutin"."cs_item_item_sk" AND "wakeful"."sr_ticket" = "highfalutin"."sr_ticket"
    FULL JOIN "quizzical" on coalesce("wakeful"."cs_customer_customer_sk", "highfalutin"."cs_customer_customer_sk") is not distinct from "quizzical"."cs_customer_customer_sk" AND coalesce("wakeful"."cs_item_item_sk", "highfalutin"."cs_item_item_sk") = "quizzical"."cs_item_item_sk"
GROUP BY
    1,
    2,
    3,
    "quizzical"."cs_order_id"),
abundant as (
SELECT
    "questionable"."cs_item_item_sk" as "cs_item_item_sk",
    "questionable"."ss_store" as "ss_store",
    sum("questionable"."sr_loss") as "sr_loss",
    sum("questionable"."ss_profit") as "ss_profit"
FROM
    "questionable"
GROUP BY
    1,
    2,
    "questionable"."sr_ticket"
HAVING
    "sr_loss" is not null
),
cooperative as (
SELECT
    "cheerful"."cs_item_item_sk" as "cs_item_item_sk",
    "cheerful"."ss_store" as "ss_store",
    sum("cheerful"."cs_cprofit") as "cs_profit"
FROM
    "cheerful"
GROUP BY
    1,
    2
HAVING
    "cs_profit" is not null
)
SELECT
    coalesce("abundant"."cs_item_item_sk","cooperative"."cs_item_item_sk") as "ss_item_item_sk",
    coalesce("abundant"."ss_store","cooperative"."ss_store") as "ss_store",
    "abundant"."ss_profit" as "ss_profit",
    "abundant"."sr_loss" as "sr_loss",
    "cooperative"."cs_profit" as "cs_profit"
FROM
    "abundant"
    INNER JOIN "cooperative" on "abundant"."cs_item_item_sk" is not distinct from "cooperative"."cs_item_item_sk" AND "abundant"."ss_store" is not distinct from "cooperative"."ss_store"
GROUP BY
    1,
    2,
    3,
    4,
    5
