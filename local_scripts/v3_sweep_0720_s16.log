    coalesce("highfalutin"."cs_item_item_sk","quizzical"."cs_item_item_sk","wakeful"."cs_item_item_sk") as "cs_item_item_sk"
FROM
    "wakeful"
    LEFT OUTER JOIN "highfalutin" on "wakeful"."cs_customer_customer_sk" is not distinct from "highfalutin"."cs_customer_customer_sk" AND "wakeful"."cs_item_item_sk" = "highfalutin"."cs_item_item_sk" AND "wakeful"."sr_ticket" = "highfalutin"."sr_ticket"
    LEFT OUTER JOIN "quizzical" on coalesce("wakeful"."cs_customer_customer_sk", "highfalutin"."cs_customer_customer_sk") is not distinct from "quizzical"."cs_customer_customer_sk" AND coalesce("wakeful"."cs_item_item_sk", "highfalutin"."cs_item_item_sk") = "quizzical"."cs_item_item_sk"
WHERE
