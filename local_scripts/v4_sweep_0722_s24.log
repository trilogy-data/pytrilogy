WITH 
quizzical as (
SELECT
    "sales"."amt" as "amount",
    "sales"."cat" as "category",
    "sales"."cl" as "cls"
FROM
    (select * from (values
    (1,'A','x',10),(2,'A','y',20),(3,'B','x',5),(4,null,null,3)
) as t(id,cat,cl,amt)) as "sales"),
wakeful as (
SELECT
    "quizzical"."category" as "category",
    "quizzical"."cls" as "cls",
    CASE
	WHEN grouping("quizzical"."cls") = 0 THEN "quizzical"."category"
	ELSE null
	END as "parent",
    grouping("quizzical"."category") + grouping("quizzical"."cls") as "lvl",
    sum("quizzical"."amount") as "total"
FROM
    "quizzical"
GROUP BY
    CUBE (1, 2)),
cooperative as (
SELECT
    "wakeful"."category" as "category",
    "wakeful"."cls" as "cls",
    rank() over (partition by "wakeful"."lvl" order by "wakeful"."total" desc ) as "rank_b"
FROM
    "wakeful"),
thoughtful as (
SELECT
    "wakeful"."category" as "category",
    "wakeful"."cls" as "cls",
    "wakeful"."lvl" as "lvl",
    "wakeful"."total" as "total",
    rank() over (partition by "wakeful"."lvl","wakeful"."parent" order by "wakeful"."total" desc ) as "rank_a"
FROM
    "wakeful")
SELECT
    "cooperative"."category" as "category",
    "cooperative"."cls" as "cls",
    "thoughtful"."total" as "total",
    "thoughtful"."lvl" as "lvl",
    "thoughtful"."rank_a" as "rank_a",
    "cooperative"."rank_b" as "rank_b"
FROM
    "cooperative"
    LEFT OUTER JOIN "thoughtful" on "cooperative"."category" = "thoughtful"."category" AND "cooperative"."cls" = "thoughtful"."cls"
ORDER BY 
    "thoughtful"."lvl" asc,
    "cooperative"."category" asc,
    "cooperative"."cls" asc
