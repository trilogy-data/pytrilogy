[RENDERING] Compiled query: 
WITH 
cobra as (
SELECT
    "s_catalog_sales_unified"."CS_BILL_CUSTOMER_SK" as "s_billing_customer_sk",
     'CATALOG'  as "s_channel",
    "s_catalog_sales_unified"."CS_SOLD_DATE_SK" as "s_sale_date_sk",
    "s_catalog_sales_unified"."CS_EXT_SALES_PRICE" as "s_ext_sales_price"
FROM
    "memory"."catalog_sales" as "s_catalog_sales_unified"
UNION ALL
SELECT
    "s_store_sales_unified"."SS_CUSTOMER_SK" as "s_billing_customer_sk",
     'STORE'  as "s_channel",
    "s_store_sales_unified"."SS_SOLD_DATE_SK" as "s_sale_date_sk",
    "s_store_sales_unified"."SS_EXT_SALES_PRICE" as "s_ext_sales_price"
FROM
    "memory"."store_sales" as "s_store_sales_unified"
UNION ALL
SELECT
    "s_web_sales_unified"."WS_BILL_CUSTOMER_SK" as "s_billing_customer_sk",
     'WEB'  as "s_channel",
    "s_web_sales_unified"."WS_SOLD_DATE_SK" as "s_sale_date_sk",
    "s_web_sales_unified"."WS_EXT_SALES_PRICE" as "s_ext_sales_price"
FROM
    "memory"."web_sales" as "s_web_sales_unified"),
cougar as (
SELECT
    "cobra"."s_channel" as "s_channel",
    "cobra"."s_ext_sales_price" as "s_ext_sales_price",
    "s_billing_customer_customers"."C_CUSTOMER_ID" as "s_billing_customer_id"
FROM
    "cobra"
    INNER JOIN "memory"."customer" as "s_billing_customer_customers" on "cobra"."s_billing_customer_sk" = "s_billing_customer_customers"."C_CUSTOMER_SK"),
crocodile as (
SELECT
    "cobra"."s_channel" as "s_channel",
    "s_billing_customer_customers"."C_CUSTOMER_ID" as "s_billing_customer_id",
    "s_sale_date_date"."D_YEAR" as "s_sale_date_year"
FROM
    "cobra"
    LEFT OUTER JOIN "memory"."date_dim" as "s_sale_date_date" on "cobra"."s_sale_date_sk" = "s_sale_date_date"."D_DATE_SK"
    LEFT OUTER JOIN "memory"."customer" as "s_billing_customer_customers" on "cobra"."s_billing_customer_sk" = "s_billing_customer_customers"."C_CUSTOMER_SK"),
eagle as (
SELECT
    CASE WHEN "crocodile"."s_channel" = 'WEB' and "crocodile"."s_sale_date_year" = 1998 THEN "crocodile"."s_billing_customer_id" ELSE NULL END as "web_qual"
FROM
    "crocodile"),
dingo as (
SELECT
    CASE WHEN "crocodile"."s_channel" = 'CATALOG' and "crocodile"."s_sale_date_year" = 1998 THEN "crocodile"."s_billing_customer_id" ELSE NULL END as "cat_qual"
FROM
    "crocodile"),
eel as (
SELECT
    "cougar"."s_billing_customer_id" as "s_billing_customer_id",
    round(sum(CASE WHEN "cougar"."s_channel" = 'STORE' THEN "cougar"."s_ext_sales_price" ELSE NULL END) / 50,0) as "segment"
FROM
    "cougar"
GROUP BY
    1
HAVING
    exists (select 1 from dingo where dingo."cat_qual" is not distinct from "s_billing_customer_id") or exists (select 1 from eagle where eagle."web_qual" is not distinct from "s_billing_customer_id") and sum(CASE WHEN "cougar"."s_channel" = 'STORE' THEN "cougar"."s_ext_sales_price" ELSE NULL END) is not null
)
SELECT
    "eel"."segment" as "segment",
    count("s_billing_customer_customers"."C_CUSTOMER_ID") as "customer_count"
FROM
    "eel"
    INNER JOIN "memory"."customer" as "s_billing_customer_customers" on "eel"."s_billing_customer_id" = "s_billing_customer_customers"."C_CUSTOMER_ID"
GROUP BY
    1
LIMIT (100)
