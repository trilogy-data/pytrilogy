WITH 
quizzical as (
SELECT
    "returns"."x" as "all_k",
    "returns"."y" as "all_amt"
FROM
    (
select 3 as x, cast(5.0 as numeric(15,2)) as y
) as "returns"),
wakeful as (
SELECT
    "sales"."x" as "all_k",
    "sales"."y" as "all_amt"
FROM
    (
select 3 as x, cast(5.0 as numeric(15,2)) as y
union all
select 4, cast(5.0 as numeric(15,2))
) as "sales")
SELECT
    "quizzical"."all_amt" as "all_amt",
    "quizzical"."all_k" as "all_k"
FROM
    "quizzical"
UNION ALL
SELECT
    "wakeful"."all_amt" as "all_amt",
    "wakeful"."all_k" as "all_k"
FROM
    "wakeful"
