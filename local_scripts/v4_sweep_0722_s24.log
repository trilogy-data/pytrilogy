WITH 
questionable as (
SELECT
    "store_sales_store_returns"."SR_CUSTOMER_SK" as "store_sales_return_customer_sk",
    "store_sales_store_returns"."SR_ITEM_SK" as "store_sales_item_sk",
    "store_sales_store_returns"."SR_RETURNED_DATE_SK" as "store_sales_return_date_sk",
    "store_sales_store_returns"."SR_RETURN_QUANTITY" as "store_sales_return_quantity",
    "store_sales_store_returns"."SR_TICKET_NUMBER" as "store_sales_ticket_number",
    ("store_sales_store_returns"."SR_TICKET_NUMBER" is not null) as "store_sales_is_returned"
FROM
    "memory"."store_returns" as "store_sales_store_returns"
WHERE
    ("store_sales_store_returns"."SR_TICKET_NUMBER" is not null)
),
uneven as (
SELECT
    "catalog_sales_catalog_sales"."CS_QUANTITY" as "catalog_sales_quantity",
    "questionable"."store_sales_return_quantity" as "store_sales_return_quantity",
    "store_sales_item_items"."I_ITEM_DESC" as "store_sales_item_desc",
    "store_sales_item_items"."I_ITEM_ID" as "store_sales_item_id",
    "store_sales_store_sales"."SS_QUANTITY" as "store_sales_quantity",
    "store_sales_store_sales"."SS_TICKET_NUMBER" as "store_sales_ticket_number",
    "store_sales_store_store"."S_STORE_ID" as "store_sales_store_id",
    "store_sales_store_store"."S_STORE_NAME" as "store_sales_store_name",
    coalesce("catalog_sales_catalog_sales"."CS_ITEM_SK","questionable"."store_sales_item_sk","store_sales_item_items"."I_ITEM_SK","store_sales_store_sales"."SS_ITEM_SK") as "store_sales_item_sk"
FROM
    "questionable"
    INNER JOIN "memory"."catalog_sales" as "catalog_sales_catalog_sales" on "questionable"."store_sales_item_sk" = "catalog_sales_catalog_sales"."CS_ITEM_SK" AND "questionable"."store_sales_return_customer_sk" = "catalog_sales_catalog_sales"."CS_BILL_CUSTOMER_SK"
    INNER JOIN "memory"."store_sales" as "store_sales_store_sales" on "catalog_sales_catalog_sales"."CS_ITEM_SK" = "store_sales_store_sales"."SS_ITEM_SK" AND "questionable"."store_sales_ticket_number" = "store_sales_store_sales"."SS_TICKET_NUMBER"
    INNER JOIN "memory"."date_dim" as "store_sales_sale_date_date" on "store_sales_store_sales"."SS_SOLD_DATE_SK" = "store_sales_sale_date_date"."D_DATE_SK"
    INNER JOIN "memory"."date_dim" as "catalog_sales_sale_date_date" on "catalog_sales_catalog_sales"."CS_SOLD_DATE_SK" = "catalog_sales_sale_date_date"."D_DATE_SK"
    INNER JOIN "memory"."date_dim" as "store_sales_return_date_date" on "questionable"."store_sales_return_date_sk" = "store_sales_return_date_date"."D_DATE_SK"
    LEFT OUTER JOIN "memory"."item" as "store_sales_item_items" on "store_sales_store_sales"."SS_ITEM_SK" = "store_sales_item_items"."I_ITEM_SK"
    LEFT OUTER JOIN "memory"."store" as "store_sales_store_store" on "store_sales_store_sales"."SS_STORE_SK" = "store_sales_store_store"."S_STORE_SK"
WHERE
    "store_sales_sale_date_date"."D_MOY" = 9 and "store_sales_sale_date_date"."D_YEAR" = 1999 and "store_sales_return_date_date"."D_MOY" BETWEEN 9 AND 12 and "store_sales_return_date_date"."D_YEAR" = 1999 and ("catalog_sales_sale_date_date"."D_YEAR" is not null and "catalog_sales_sale_date_date"."D_YEAR" in (1999,2000,2001)) and "catalog_sales_catalog_sales"."CS_QUANTITY" > 0 and "questionable"."store_sales_is_returned" and "store_sales_store_sales"."SS_CUSTOMER_SK" = "questionable"."store_sales_return_customer_sk"
),
yummy as (
SELECT
    "uneven"."catalog_sales_quantity" as "correlated_catalog_sales_quantity",
    "uneven"."store_sales_item_desc" as "correlated_store_sales_item_desc",
    "uneven"."store_sales_item_id" as "correlated_store_sales_item_id",
    "uneven"."store_sales_item_sk" as "correlated_store_sales_item_sk",
    "uneven"."store_sales_quantity" as "correlated_store_sales_quantity",
    "uneven"."store_sales_return_quantity" as "correlated_store_sales_return_quantity",
    "uneven"."store_sales_store_id" as "correlated_store_sales_store_id",
    "uneven"."store_sales_store_name" as "correlated_store_sales_store_name",
    "uneven"."store_sales_ticket_number" as "correlated_store_sales_ticket_number"
FROM
    "uneven"),
young as (
SELECT
    "yummy"."correlated_store_sales_item_desc" as "correlated_store_sales_item_desc",
    "yummy"."correlated_store_sales_item_id" as "correlated_store_sales_item_id",
    "yummy"."correlated_store_sales_store_id" as "correlated_store_sales_store_id",
    "yummy"."correlated_store_sales_store_name" as "correlated_store_sales_store_name",
    sum("yummy"."correlated_catalog_sales_quantity") as "catalog_sales_quantity"
FROM
    "yummy"
GROUP BY
    1,
    2,
    3,
    4
HAVING
    "catalog_sales_quantity" > 0
),
vacuous as (
SELECT
    "yummy"."correlated_store_sales_item_desc" as "correlated_store_sales_item_desc",
    "yummy"."correlated_store_sales_item_id" as "correlated_store_sales_item_id",
    "yummy"."correlated_store_sales_quantity" as "correlated_store_sales_quantity",
    "yummy"."correlated_store_sales_return_quantity" as "correlated_store_sales_return_quantity",
    "yummy"."correlated_store_sales_store_id" as "correlated_store_sales_store_id",
    "yummy"."correlated_store_sales_store_name" as "correlated_store_sales_store_name"
FROM
    "yummy"
GROUP BY
    1,
    2,
    3,
    4,
    5,
    6,
    "yummy"."correlated_store_sales_item_sk",
    "yummy"."correlated_store_sales_ticket_number"),
juicy as (
SELECT
    "yummy"."correlated_store_sales_item_desc" as "store_sales_item_desc",
    "yummy"."correlated_store_sales_item_id" as "store_sales_item_name",
    "yummy"."correlated_store_sales_store_id" as "store_sales_store_text_id",
    "yummy"."correlated_store_sales_store_name" as "store_name"
FROM
    "yummy"),
concerned as (
SELECT
    "vacuous"."correlated_store_sales_item_desc" as "correlated_store_sales_item_desc",
    "vacuous"."correlated_store_sales_item_id" as "correlated_store_sales_item_id",
    "vacuous"."correlated_store_sales_store_id" as "correlated_store_sales_store_id",
    "vacuous"."correlated_store_sales_store_name" as "correlated_store_sales_store_name",
    sum("vacuous"."correlated_store_sales_quantity") as "store_sales_quantity",
    sum("vacuous"."correlated_store_sales_return_quantity") as "store_returns_quantity"
FROM
    "vacuous"
GROUP BY
    1,
    2,
    3,
    4)
SELECT
    "juicy"."store_sales_item_name" as "store_sales_item_name",
    "juicy"."store_sales_item_desc" as "store_sales_item_desc",
    "juicy"."store_sales_store_text_id" as "store_sales_store_text_id",
    "juicy"."store_name" as "store_name",
    "concerned"."store_sales_quantity" as "store_sales_quantity",
    "concerned"."store_returns_quantity" as "store_returns_quantity",
    "young"."catalog_sales_quantity" as "catalog_sales_quantity"
FROM
    "young"
    INNER JOIN "concerned" on "young"."correlated_store_sales_item_desc" = "concerned"."correlated_store_sales_item_desc" AND "young"."correlated_store_sales_item_id" = "concerned"."correlated_store_sales_item_id" AND "young"."correlated_store_sales_store_id" is not distinct from "concerned"."correlated_store_sales_store_id" AND "young"."correlated_store_sales_store_name" is not distinct from "concerned"."correlated_store_sales_store_name"
    INNER JOIN "juicy" on "young"."correlated_store_sales_item_desc" = "juicy"."store_sales_item_desc" AND "young"."correlated_store_sales_item_id" = "juicy"."store_sales_item_name" AND "young"."correlated_store_sales_store_id" is not distinct from "juicy"."store_sales_store_text_id" AND "young"."correlated_store_sales_store_name" is not distinct from "juicy"."store_name"
GROUP BY
    1,
    2,
    3,
    4,
    5,
    6,
