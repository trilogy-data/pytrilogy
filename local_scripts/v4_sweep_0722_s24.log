WITH 
cheerful as (
SELECT
    "cs_catalog_returns"."CR_ITEM_SK" as "cs_item_sk",
    "cs_catalog_returns"."CR_ORDER_NUMBER" as "cs_order_number",
    "cs_catalog_returns"."CR_RETURNING_CUSTOMER_SK" as "cs_return_customer_sk",
    "cs_catalog_returns"."CR_RETURN_AMT_INC_TAX" as "cs_return_amount_inc_tax",
    "cs_return_address_customer_address"."CA_STATE" as "cs_return_address_state",
    "cs_return_date_date"."D_YEAR" as "cs_return_date_year"
FROM
    "memory"."catalog_returns" as "cs_catalog_returns"
    INNER JOIN "memory"."date_dim" as "cs_return_date_date" on "cs_catalog_returns"."CR_RETURNED_DATE_SK" = "cs_return_date_date"."D_DATE_SK"
    INNER JOIN "memory"."customer_address" as "cs_return_address_customer_address" on "cs_catalog_returns"."CR_RETURNING_ADDR_SK" = "cs_return_address_customer_address"."CA_ADDRESS_SK"
WHERE
    "cs_return_address_customer_address"."CA_STATE" is not null
),
abhorrent as (
SELECT
    "cs_return_customer_current_address_customer_address"."CA_CITY" as "cs_return_customer_current_address_city",
    "cs_return_customer_current_address_customer_address"."CA_COUNTRY" as "cs_return_customer_current_address_country",
    "cs_return_customer_current_address_customer_address"."CA_COUNTY" as "cs_return_customer_current_address_county",
    "cs_return_customer_current_address_customer_address"."CA_GMT_OFFSET" as "cs_return_customer_current_address_gmt_offset",
    "cs_return_customer_current_address_customer_address"."CA_LOCATION_TYPE" as "cs_return_customer_current_address_location_type",
    "cs_return_customer_current_address_customer_address"."CA_STATE" as "cs_return_customer_current_address_state",
    "cs_return_customer_current_address_customer_address"."CA_STREET_NAME" as "cs_return_customer_current_address_street_name",
    "cs_return_customer_current_address_customer_address"."CA_STREET_NUMBER" as "cs_return_customer_current_address_street_number",
    "cs_return_customer_current_address_customer_address"."CA_STREET_TYPE" as "cs_return_customer_current_address_street_type",
    "cs_return_customer_current_address_customer_address"."CA_SUITE_NUMBER" as "cs_return_customer_current_address_suite_number",
    "cs_return_customer_current_address_customer_address"."CA_ZIP" as "cs_return_customer_current_address_zip",
    "cs_return_customer_customers"."C_CUSTOMER_ID" as "cs_return_customer_id",
    "cs_return_customer_customers"."C_CUSTOMER_SK" as "cs_return_customer_sk",
    "cs_return_customer_customers"."C_FIRST_NAME" as "cs_return_customer_first_name",
    "cs_return_customer_customers"."C_LAST_NAME" as "cs_return_customer_last_name",
    "cs_return_customer_customers"."C_SALUTATION" as "cs_return_customer_salutation"
FROM
    "memory"."customer" as "cs_return_customer_customers"
    INNER JOIN "memory"."customer_address" as "cs_return_customer_current_address_customer_address" on "cs_return_customer_customers"."C_CURRENT_ADDR_SK" = "cs_return_customer_current_address_customer_address"."CA_ADDRESS_SK"
WHERE
    "cs_return_customer_current_address_customer_address"."CA_STATE" = 'GA'
),
cooperative as (
SELECT
    "cheerful"."cs_return_address_state" as "cs_return_address_state",
    "cheerful"."cs_return_customer_sk" as "cs_return_customer_sk",
    sum(CASE WHEN "cheerful"."cs_return_date_year" = 2000 and "cheerful"."cs_return_address_state" is not null THEN "cheerful"."cs_return_amount_inc_tax" ELSE NULL END) as "_virt_agg_sum_2893965424206230_wscope",
    sum(CASE WHEN "cheerful"."cs_return_date_year" = 2000 and "cheerful"."cs_return_address_state" is not null THEN "cheerful"."cs_return_amount_inc_tax" ELSE NULL END) as "customer_state"
FROM
    "memory"."catalog_sales" as "cs_catalog_sales"
    INNER JOIN "cheerful" on "cs_catalog_sales"."CS_ITEM_SK" = "cheerful"."cs_item_sk" AND "cs_catalog_sales"."CS_ORDER_NUMBER" = "cheerful"."cs_order_number"
WHERE
    "cheerful"."cs_return_address_state" is not null

GROUP BY
    1,
    2),
uneven as (
SELECT
    "cooperative"."cs_return_address_state" as "cs_return_address_state",
    1.2 * avg("cooperative"."_virt_agg_sum_2893965424206230_wscope") as "_virt_func_multiply_1237551001127604_wscope"
FROM
    "cooperative"
GROUP BY
    1),
juicy as (
SELECT
    "cooperative"."cs_return_customer_sk" as "cs_return_customer_sk",
    "cooperative"."customer_state" as "customer_state"
FROM
    "cooperative"
    INNER JOIN "uneven" on "cooperative"."cs_return_address_state" is not distinct from "uneven"."cs_return_address_state"
WHERE
    "cooperative"."customer_state" > "uneven"."_virt_func_multiply_1237551001127604_wscope"
),
concerned as (
SELECT
    "juicy"."cs_return_customer_sk" as "cs_return_customer_sk",
    "juicy"."customer_state" as "customer_state"
FROM
    "juicy")
SELECT
    "abhorrent"."cs_return_customer_id" as "cs_return_customer_id",
    "abhorrent"."cs_return_customer_salutation" as "cs_return_customer_salutation",
    "abhorrent"."cs_return_customer_first_name" as "cs_return_customer_first_name",
    "abhorrent"."cs_return_customer_last_name" as "cs_return_customer_last_name",
    "abhorrent"."cs_return_customer_current_address_street_number" as "cs_return_customer_current_address_street_number",
    "abhorrent"."cs_return_customer_current_address_street_name" as "cs_return_customer_current_address_street_name",
    "abhorrent"."cs_return_customer_current_address_street_type" as "cs_return_customer_current_address_street_type",
    "abhorrent"."cs_return_customer_current_address_suite_number" as "cs_return_customer_current_address_suite_number",
    "abhorrent"."cs_return_customer_current_address_city" as "cs_return_customer_current_address_city",
    "abhorrent"."cs_return_customer_current_address_county" as "cs_return_customer_current_address_county",
    "abhorrent"."cs_return_customer_current_address_state" as "cs_return_customer_current_address_state",
    "abhorrent"."cs_return_customer_current_address_zip" as "cs_return_customer_current_address_zip",
    "abhorrent"."cs_return_customer_current_address_country" as "cs_return_customer_current_address_country",
    "abhorrent"."cs_return_customer_current_address_gmt_offset" as "cs_return_customer_current_address_gmt_offset",
    "abhorrent"."cs_return_customer_current_address_location_type" as "cs_return_customer_current_address_location_type",
    "concerned"."customer_state" as "customer_state"
FROM
    "concerned"
    LEFT OUTER JOIN "abhorrent" on "concerned"."cs_return_customer_sk" = "abhorrent"."cs_return_customer_sk"
GROUP BY
