WITH 
quizzical as (
SELECT
    "d"."x" as "x",
    "d"."z" as "z"
FROM
    (select 1 as id, 1 as x, 2 as z, 1 as f
union all select 2, 1, 10, 0
union all select 3, 2, 100, 1) as "d"),
uneven as (
SELECT
    "d"."x" as "x",
    "d"."z" * 2 as "w"
FROM
    (select 1 as id, 1 as x, 2 as z, 1 as f
union all select 2, 1, 10, 0
union all select 3, 2, 100, 1) as "d"
WHERE
    "d"."f" = 1
),
cheerful as (
SELECT
    "quizzical"."x" as "x",
    sum("quizzical"."z") as "_virt_agg_sum_1730646535677350_wscope"
FROM
    "quizzical"
GROUP BY
    1),
highfalutin as (
SELECT
    "quizzical"."x" as "x",
    "quizzical"."z" as "z"
FROM
    "quizzical"),
thoughtful as (
SELECT
    "cheerful"."_virt_agg_sum_1730646535677350_wscope" + ( "highfalutin"."z" * 2 ) as "_virt_func_add_8275166132883705_wscope",
    "highfalutin"."x" as "x",
    "highfalutin"."z" as "z"
FROM
    "cheerful"
    INNER JOIN "highfalutin" on "cheerful"."x" = "highfalutin"."x"),
questionable as (
SELECT
    "thoughtful"."x" as "x",
    sum("thoughtful"."z") as "sx"
FROM
    "thoughtful"
WHERE
    "thoughtful"."_virt_func_add_8275166132883705_wscope" > 20

GROUP BY
    1),
juicy as (
SELECT
    "questionable"."sx" + ( "uneven"."w" ) as "v",
    "questionable"."x" as "x"
FROM
    "uneven"
    INNER JOIN "questionable" on "uneven"."x" = "questionable"."x")
SELECT
    "juicy"."x" as "x",
    "juicy"."v" as "v"
FROM
    "juicy"
GROUP BY
    1,
    2
