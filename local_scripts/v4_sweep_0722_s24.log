[RENDERING] Compiled query: 
WITH 
quizzical as (
SELECT
    "events"."id" as "event_id",
    CASE
	WHEN "events"."ename" = 'a' THEN 1
	ELSE 2
	END as "_stages_stage"
FROM
    (select 1 id, 'a' as ename union all select 2 id, 'a' as ename
         union all select 3 id, 'b' as ename) as "events"),
wakeful as (
SELECT
    "quizzical"."_stages_stage" as "stages_stage",
    "quizzical"."event_id" as "stages_event_id"
FROM
    "quizzical"),
thoughtful as (
SELECT
    count("wakeful"."stages_event_id") as "event_count"
FROM
    "wakeful"),
cheerful as (
SELECT
    "wakeful"."stages_stage" as "stages_stage",
    "wakeful"."stages_stage" as "step",
    CASE
	WHEN "wakeful"."stages_stage" = 1 THEN 'one'
	WHEN "wakeful"."stages_stage" = 2 THEN 'two'
	END as "name"
FROM
    "wakeful")
SELECT
    "cheerful"."name" as "name",
    coalesce("thoughtful"."event_count",0) as "event_count"
FROM
    "thoughtful"
    FULL JOIN "cheerful" on 1=1
ORDER BY 
    "cheerful"."step" asc
