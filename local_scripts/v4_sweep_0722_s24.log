[RENDERING] Compiled query: 
WITH 
quizzical as (
SELECT
    "dim_class"."class_id" as "class_id",
    "dim_class"."passenger_class" as "passenger_class"
FROM
    (
select * from (
    values
        (10, 1),
        (30, 3)
) as t(class_id, passenger_class)
) as "dim_class"),
highfalutin as (
SELECT
    "fact_passengers"."cabin" as "cabin",
    "fact_passengers"."class_id" as "class_id"
FROM
    (
select * from (
    values
        (1, 'B96 B98', 10),
        (2, null,      30)
) as t(passenger_id, cabin, class_id)
) as "fact_passengers"),
wakeful as (
SELECT
    "highfalutin"."cabin" as "cabin",
    "quizzical"."passenger_class" as "passenger_class"
FROM
    "highfalutin"
    INNER JOIN "quizzical" on "highfalutin"."class_id" = "quizzical"."class_id"),
thoughtful as (
SELECT
    "wakeful"."passenger_class" as "passenger_class",
    CASE
	WHEN coalesce("wakeful"."cabin",:unknown_cabin) = :unknown_cabin THEN :unknown_cabin
	ELSE SUBSTRING(coalesce("wakeful"."cabin",:unknown_cabin),1,1)
	END as "cabin_type"
FROM
    "wakeful"),
cheerful as (
SELECT
    unnest(STRING_SPLIT( coalesce("wakeful"."cabin",:unknown_cabin) , ' ' )) as "cabin_value"
FROM
    "wakeful"),
cooperative as (
SELECT
    "cheerful"."cabin_value" as "cabin_value",
    "thoughtful"."cabin_type" as "cabin_type",
    "thoughtful"."passenger_class" as "passenger_class"
FROM
    "thoughtful"
    FULL JOIN "cheerful" on 1=1)
SELECT
    "cooperative"."passenger_class" as "passenger_class",
    "cooperative"."cabin_type" as "cabin_type",
    count("cooperative"."cabin_value") as "cabin_assignments"
FROM
    "cooperative"
GROUP BY
    1,
    2
ORDER BY 
    "cooperative"."passenger_class" asc
