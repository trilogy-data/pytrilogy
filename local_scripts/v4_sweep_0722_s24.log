[RENDERING] Compiled query: 
WITH 
highfalutin as (
SELECT
    "sales"."it" as "_rs_k",
    sum("sales"."q") as "_rs_sq"
FROM
    (
select 1 id, 1 it, 10 q, 1999 y union all
select 2 id, 1 it, 5 q, 2000 y union all
select 3 id, 2 it, 7 q, 1999 y union all
select 4 id, 2 it, 3 q, 2000 y union all
select 5 id, 3 it, 9 q, 2000 y
) as "sales"
GROUP BY
    1),
quizzical as (
SELECT
    "items"."id" as "rs_k",
    "items"."nm" as "item_name"
FROM
    (select 1 id, 'apple' nm union all select 2 id, 'banana' nm union all select 3 id, 'cherry' nm) as "items"),
thoughtful as (
SELECT
    "highfalutin"."_rs_k" as "rs_k",
    "highfalutin"."_rs_sq" as "rs_sq"
FROM
    "highfalutin")
SELECT
    "quizzical"."item_name" as "item_name",
    "thoughtful"."rs_sq" as "rs_sq"
FROM
    "thoughtful"
    INNER JOIN "quizzical" on "thoughtful"."rs_k" = "quizzical"."rs_k"
ORDER BY 
    "quizzical"."item_name" asc
