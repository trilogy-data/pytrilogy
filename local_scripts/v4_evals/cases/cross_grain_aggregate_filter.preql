# Root cause: a WHERE comparing a per-key aggregate to a GLOBAL aggregate of a
# different grain. v3 computes the two in separate CTEs, cross-joins them, and
# filters with a post-aggregate WHERE. v4 instead cross-joined the global
# aggregate INTO the per-key GROUP BY and emitted a HAVING referencing it — an
# ungrouped column → "must appear in the GROUP BY clause" binder error.
# Source: tests/modeling/tpc_h/query11.preql (germany_total_value).
key id int;
key line int;
property <id, line>.qty int;
property <id, line>.flag bool;

datasource raw (
    id: id,
    line: line,
    qty: qty,
    flag: flag
)
grain (id, line)
query '''
select 1 as id, 1 as line, 100 as qty, true as flag
union all
select 1, 2, 50, true
union all
select 2, 1, 10, false
union all
select 3, 1, 5, true
''';

auto total_flagged <- sum(qty ? flag = true);
auto per_id_flagged <- sum(qty ? flag = true) by id;

WHERE per_id_flagged > total_flagged * 0.3
SELECT
    id,
    per_id_flagged -> value
ORDER BY
    value desc;
