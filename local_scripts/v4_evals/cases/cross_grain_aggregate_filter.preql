# A WHERE comparing a per-key aggregate to a GLOBAL aggregate of a different
# grain. The global side uses an explicit `by *`: a bare aggregate in WHERE now
# auto-grains to the SELECT grain (like HAVING), so `by *` is required to keep
# the comparison against the whole-table total. Both planners compute the two in
# separate CTEs, cross-join them, and filter with a post-aggregate WHERE.
# Source: tests/modeling/tpc_h/query11.preql (germany_total_value).
key id int;
key line int;
property <id, line>.qty int;
property <id, line>.flag bool;

datasource raw (
    id: id,
    line: line,
    qty: qty,
    flag: flag
)
grain (id, line)
query '''
select 1 as id, 1 as line, 100 as qty, true as flag
union all
select 1, 2, 50, true
union all
select 2, 1, 10, false
union all
select 3, 1, 5, true
''';

auto total_flagged <- sum(qty ? flag = true) by *;
auto per_id_flagged <- sum(qty ? flag = true) by id;

WHERE per_id_flagged > total_flagged * 0.3
SELECT
    id,
    per_id_flagged -> value
ORDER BY
    value desc;
