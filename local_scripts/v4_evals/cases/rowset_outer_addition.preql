key order_id int;
key store_id int;

datasource orders (
    order_id:order_id,
    store_id:~store_id,
)
grain (order_id)
query '''
select 1 order_id, 1 store_id
union all select 2, 1
union all select 3, 2
union all select 4, 2
''';

datasource stores (
    store_id:store_id,
)
grain (store_id)
query '''
select 1 store_id
union all select 2
''';

# a rowset filtered to even orders, projected back alongside the unfiltered
# order_id. Odd orders must survive with NULL-extended rowset columns
# (LEFT/OUTER), not be dropped or mis-joined. Expected rows:
#   (1, None, None), (2, 2, 1), (3, None, None), (4, 4, 2)
rowset even_orders <- select order_id, store_id where (order_id % 2) = 0;

SELECT
    order_id,
    even_orders.order_id,
    even_orders.store_id
order by
    order_id asc
;
