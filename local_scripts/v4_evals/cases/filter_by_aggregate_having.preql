key order_id int;
key warehouse_id int;

datasource sales (
    order_id,
    warehouse_id,
)
grain (order_id, warehouse_id)
query '''
select 1 as order_id, 10 as warehouse_id
union all select 1, 20
union all select 2, 10
''';

# filter a key by a per-key aggregate predicate (orders shipped from >1
# warehouse). Should compile to a HAVING (not a CASE WHEN) and return only
# order 1. Expected: [(1,)].
auto multi_warehouse_orders <- filter order_id
    where count(warehouse_id) by order_id > 1;

select
    multi_warehouse_orders
order by
    multi_warehouse_orders asc
;
